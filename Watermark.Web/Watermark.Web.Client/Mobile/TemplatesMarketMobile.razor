@using System.Diagnostics
@inject IPopupService PopupService
<MCard Flat Style="width:100%;height:100%;overflow-y:hidden">
        <WmGrid Spacing="2" Justify="Justify.FlexStart" Style="height:calc(100vh - 30px);overflow-y:auto;padding:5px;">
            @if (ZipedTemplates != null)
            {
                @foreach (var t in ZipedTemplates)
                {
                    <WmItem xs="12">
                        <WmCard>
                            @if (!string.IsNullOrEmpty(t.Src))
                            {
                                <WmImage Style="width:100%" Height="200" Src="@t.Src" ObjectFit="ObjectFit.Contain" />
                            }
                            else
                            {
                                <WmOverlay Visible="@loading" DarkBackground="true" Absolute="true">
                                    <WmProgressCircular Color="Color.Secondary" Indeterminate="true" />
                                </WmOverlay>
                            }
                            <WmCardContent Style="height:80px;overflow-y:auto;">
                                <WmText Typo="Typo.body2">@t.Desc</WmText>
                                </WmCardContent>
                                <WmCardActions Style="position:relative;">
                                    @t.DownloadTimes<WmIcon Icon="@WmIcons.Phosphor.Regular.Favorite" Color="Color.Error" Style="cursor:pointer;" />
                                <WmButton Size="Size.Small" Variant="Variant.Text" EndIcon="@WmIcons.Phosphor.Regular.Download" Color="Color.Primary" Style="position:absolute;right:70px" OnClick="()=>Download(t.WatermarkId)">下载</WmButton>
                                <WmIconButton Variant="Variant.Text" Color="Color.Secondary" Icon="@WmIcons.Phosphor.Regular.Share" Style="position:absolute;right:10px" OnClick="()=>Share(t.WatermarkId)"></WmIconButton>
                            </WmCardActions>
                        </WmCard>

                    </WmItem>
                }
                <WmButton FullWidth Variant="Variant.Text" Class="mt-5" Style="height:30px" OnClick="LoadMore">加载更多...</WmButton>
            }
        </WmGrid>
        <WmOverlay Visible="@loading" DarkBackground="false" Style="background:#e6e6e6" Absolute="false" ZIndex="9999">
            <WmStack Justify="Justify.Center">
                <WmProgressCircular Color="Color.Secondary" Indeterminate="true" Style="margin:auto" />
                <WmText Typo="Typo.subtitle1" Color="Color.Dark">
                    <b>正在加载模板...</b>
                </WmText>
            </WmStack>
        </WmOverlay>
</MCard>


@code {

    [Parameter] public EventCallback<WMZipedTemplate> Downloaded { get; set; }
    bool loading = false;
    List<WMZipedTemplate> ZipedTemplates;
    int start = 1;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        var helper = new APIHelper();
        ZipedTemplates = await helper.GetWatermarks("", start, 10);
        List<Task> tasks1 = new List<Task>();
        foreach (var t in ZipedTemplates)
        {
            var task = helper.ExtractZip(t.WatermarkId).ContinueWith(item =>
            {
                t.WMCanvas = item.Result.WMCanvas;
                t.Images = item.Result.Images;
                t.Fonts = item.Result.Fonts;
                t.Bitmap = item.Result.Bitmap;
            });
            tasks1.Add(task);
        }
        await Task.WhenAll(tasks1);
        var whelper = new WatermarkHelper();
        List<Task> tasks = new List<Task>();
        foreach (var t in ZipedTemplates)
        {
            var c = Task.Run(() =>
            {
                t.Src = whelper.Generation(t.WMCanvas, t, true);
                return t.Src;
            });

            tasks.Add(c);
        }
        await Task.WhenAll(tasks);
        loading = false;
        StateHasChanged();
    }

    void Share(string id)
    {
        //System.Windows.Clipboard.SetText(id);

        string message = "已复制ID到剪贴板";
        Common.ShowMsg(PopupService, message, AlertTypes.Success);
    }

    async void LoadMore()
    {
        loading = true;
        var helper = new APIHelper();
        var more = await helper.GetWatermarks("", ++start, 10);
        List<Task> tasks1 = new List<Task>();
        foreach (var t in more)
        {
            var task = helper.ExtractZip(t.WatermarkId).ContinueWith(item =>
            {
                t.WMCanvas = item.Result.WMCanvas;
                t.Images = item.Result.Images;
                t.Fonts = item.Result.Fonts;
                t.Bitmap = item.Result.Bitmap;
            });
            tasks1.Add(task);
        }
        await Task.WhenAll(tasks1);
        var whelper = new WatermarkHelper();
        List<Task> tasks = new List<Task>();
        foreach (var t in more)
        {
            var c = Task.Run(() =>
            {
                t.Src = whelper.Generation(t.WMCanvas, t, true);
                return t.Src;
            });

            tasks.Add(c);
        }
        await Task.WhenAll(tasks);
        ZipedTemplates.AddRange(more);
        loading = false;
    }

    async void Download(string watermarkId)
    {
        var helper = new APIHelper();
        var result = await helper.ExtractZip(watermarkId);
        string message = "";
        if (result != null)
        {
            message = "下载成功";
            await Downloaded.InvokeAsync(result);
            Common.ShowMsg(PopupService, message, AlertTypes.Success);
        }
        else
        {
            message = "下载失败";
            Common.ShowMsg(PopupService, message, AlertTypes.Error);
        }
    }
}
