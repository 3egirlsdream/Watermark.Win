@page "/deploy"
@rendermode InteractiveWebAssembly
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>轻影发布台 · Litograph Deploy</PageTitle>

<div class="deploy-page">
    <header class="deploy-header">
        <a class="deploy-brand" href="/" aria-label="返回轻影官网">
            <span class="deploy-brand-mark"><span class="mdi mdi-camera-iris" aria-hidden="true"></span></span>
            <span><b>轻影</b><small>LITOGRAPH / RELEASE DESK</small></span>
        </a>
        <div class="deploy-runtime">
            <span class="runtime-light"></span>
            浏览器本地处理 · 七牛直传
        </div>
    </header>

    <main class="deploy-workspace">
            <section class="workspace-intro">
                <div>
                    <p class="deploy-eyebrow">RELEASE CONTROL / @_clockText</p>
                    <h1>发布一个新版本</h1>
                    <p>选择安装包后自动识别平台与版本；确认更新日志，一次完成版本化命名、七牛上传和版本入库。</p>
                </div>
            </section>

            <section class="release-strip" aria-label="各平台线上版本">
                @foreach (var platform in Platforms)
                {
                    var release = CurrentReleaseFor(platform.Id);
                    <article class="release-chip @(_analysis?.Platform == platform.Id ? "is-active" : "")">
                        <span class="platform-icon"><span class="mdi @platform.Icon" aria-hidden="true"></span></span>
                        <span><small>@platform.Name.ToUpperInvariant()</small><b>@(release?.Version is null ? "—" : $"v{release.Version}")</b></span>
                        <i class="@(release?.Version is null ? "is-offline" : "")"></i>
                    </article>
                }
            </section>

            <div class="release-grid">
                <section class="release-main">
                    <div class="section-heading">
                        <span>01</span>
                        <div><h2>选择构建产物</h2><p>支持 Windows .zip、Android .apk、macOS .pkg 与 iOS .ipa，浏览器不会把文件发送给官网。</p></div>
                    </div>

                    <input @ref="_fileInput" class="visually-hidden" type="file" accept=".zip,.apk,.pkg,.ipa"
                           @onchange="InspectPackageAsync" />

                    @if (_analysis is null)
                    {
                        <button class="drop-zone" type="button" @onclick="OpenFilePickerAsync" disabled="@_busy">
                            <span class="drop-visual"><span class="mdi mdi-package-variant-closed" aria-hidden="true"></span></span>
                            <b>选择本地安装包</b>
                            <small>文件在浏览器中识别，最大 2 GB</small>
                            <em>浏览文件 <span class="mdi mdi-arrow-up-right"></span></em>
                        </button>
                    }
                    else
                    {
                        <article class="package-card">
                            <div class="package-type @PlatformClass(_analysis.Platform)">
                                <span class="mdi @PlatformFor(_analysis.Platform).Icon"></span>
                                <small>@_analysis.Extension.TrimStart('.').ToUpperInvariant()</small>
                            </div>
                            <div class="package-meta">
                                <small>LOCAL BUILD</small>
                                <h3>@_analysis.Name</h3>
                                <p>@FormatSize(_analysis.Size) · @_analysis.PlatformName · 本地读取完成</p>
                            </div>
                            <div class="package-status">
                                <span class="mdi mdi-check-circle"></span>已识别
                            </div>
                            <button class="icon-action" type="button" title="重新选择" @onclick="OpenFilePickerAsync" disabled="@_busy">
                                <span class="mdi mdi-swap-horizontal"></span>
                            </button>
                        </article>
                    }

                    <div class="section-heading metadata-heading">
                        <span>02</span>
                        <div><h2>确认版本信息</h2><p>自动识别结果可以修正；发布后客户端将按这里的版本判断更新。</p></div>
                    </div>

                    <div class="form-grid">
                        <label class="field-block">
                            <span>版本号 <small>@(_analysis?.VersionSource ?? "等待识别")</small></span>
                            <div class="version-field"><i>v</i><input placeholder="1.2.20" @bind="_version" @bind:event="oninput" disabled="@_busy" /></div>
                        </label>
                        <div class="field-block readonly-block">
                            <span>目标平台 <small>自动识别</small></span>
                            <div class="readonly-value">
                                @if (_analysis is null) { <span>—</span> }
                                else { <span class="mdi @PlatformFor(_analysis.Platform).Icon"></span><b>@_analysis.PlatformName</b> }
                            </div>
                        </div>
                    </div>

                    <label class="field-block changelog-field">
                        <span>更新日志 <small>@_memo.Length / 4000</small></span>
                        <textarea maxlength="4000" rows="7" placeholder="这次更新带来了什么？建议每行一项，例如：&#10;• 新增批量导出的后台队列&#10;• 优化 16-bit 调色预览性能&#10;• 修复若干已知问题" @bind="_memo" @bind:event="oninput" disabled="@_busy"></textarea>
                    </label>
                </section>

                <aside class="release-sidebar">
                    <div class="summary-card">
                        <p class="summary-kicker">RELEASE MANIFEST</p>
                        <h2>发布清单</h2>

                        <dl class="manifest-list">
                            <div><dt>来源文件</dt><dd>@(_analysis?.Name ?? "尚未选择")</dd></div>
                            <div><dt>七牛对象名</dt><dd class="mono">@(ReleaseObjectName ?? "—")</dd></div>
                            <div><dt>版本记录</dt><dd>@(string.IsNullOrWhiteSpace(_version) ? "—" : $"v{_version}")</dd></div>
                            <div><dt>线上当前版本</dt><dd>@CurrentVersionText</dd></div>
                        </dl>

                        <div class="route-preview">
                            <span class="mdi mdi-cloud-outline"></span>
                            <div><small>DATABASE DOWNLOAD URL</small><p>@(ReleaseDownloadUrl ?? "选择文件并确认版本后生成地址")</p></div>
                        </div>

                        <div class="publish-checks">
                            <p class="@CheckClass(_analysis is not null)"><span class="mdi @CheckIcon(_analysis is not null)"></span>安装包格式与平台匹配</p>
                            <p class="@CheckClass(IsVersionValid)"><span class="mdi @CheckIcon(IsVersionValid)"></span>版本号格式有效</p>
                            <p class="@CheckClass(!string.IsNullOrWhiteSpace(_memo))"><span class="mdi @CheckIcon(!string.IsNullOrWhiteSpace(_memo))"></span>已填写更新日志</p>
                        </div>

                        <label class="confirm-row">
                            <input type="checkbox" @bind="_confirmed" disabled="@_busy" />
                            <span>确认上传此版本文件，并将下载地址发布到数据库</span>
                        </label>

                        @if (_publishState != PublishState.Idle)
                        {
                            <div class="publish-progress @PublishStateClass">
                                <div class="progress-copy">
                                    <span class="mdi @PublishStateIcon"></span>
                                    <div><b>@PublishStateTitle</b><small>@PublishStateDescription</small></div>
                                </div>
                                @if (_publishState == PublishState.Uploading)
                                {
                                    <div class="progress-track"><i style="width:@_uploadProgress%"></i></div>
                                    <p>@_uploadProgress%</p>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(_error))
                        {
                            <p class="inline-message is-error"><span class="mdi mdi-alert-circle-outline"></span>@_error</p>
                        }

                        <button class="publish-action" type="button" @onclick="PublishAsync" disabled="@(!CanPublish)">
                            <span>@PublishButtonText</span>
                            <span class="mdi mdi-rocket-launch-outline" aria-hidden="true"></span>
                        </button>
                        <p class="publish-footnote">发布顺序：浏览器直传七牛 → 后端写入版本记录</p>
                    </div>
                </aside>
            </div>
    </main>
</div>

@code {
    private const string ModulePath = "./deploy.js?v=20260715d";
    private static readonly PlatformInfo[] Platforms =
    [
        new("macos", "macOS", "mdi-apple", ".pkg"),
        new("windows", "Windows", "mdi-microsoft-windows", ".zip"),
        new("android", "Android", "mdi-android", ".apk"),
        new("ios", "iOS", "mdi-cellphone", ".ipa")
    ];

    private IJSObjectReference? _module;
    private DotNetObjectReference<Deploy>? _selfReference;
    private ElementReference _fileInput;
    private PackageAnalysis? _analysis;
    private readonly List<CurrentRelease> _currentReleases = [];
    private string _version = string.Empty;
    private string _memo = string.Empty;
    private string _error = string.Empty;
    private string _clockText = DateTime.Now.ToString("yyyy.MM.dd / HH:mm");
    private bool _busy;
    private bool _confirmed;
    private bool _fileUploaded;
    private string? _uploadedVersion;
    private int _uploadProgress;
    private PublishState _publishState;

    private bool IsVersionValid => System.Text.RegularExpressions.Regex.IsMatch(_version.Trim(), @"^\d+\.\d+(?:\.\d+){0,2}$");
    private bool CanPublish => !_busy && _analysis is not null && IsVersionValid && !string.IsNullOrWhiteSpace(_memo) && _confirmed;
    private bool HasUploadedCurrentVersion => _fileUploaded
        && string.Equals(_uploadedVersion, _version.Trim(), StringComparison.Ordinal);
    private string CurrentVersionText => _analysis is null
        ? "—"
        : CurrentReleaseFor(_analysis.Platform)?.Version is { } version ? $"v{version}" : "暂无记录";
    private string PublishButtonText => _publishState switch
    {
        PublishState.Uploading => "正在上传",
        PublishState.Recording => "正在写入版本",
        PublishState.Success => "发布完成",
        _ => HasUploadedCurrentVersion ? "继续写入版本" : "发布此版本"
    };
    private string PublishStateClass => _publishState is PublishState.Failed ? "is-error" : _publishState is PublishState.Success ? "is-success" : string.Empty;
    private string PublishStateIcon => _publishState switch
    {
        PublishState.Uploading => "mdi-cloud-upload-outline",
        PublishState.Recording => "mdi-database-arrow-up-outline",
        PublishState.Success => "mdi-check-decagram-outline",
        _ => "mdi-alert-circle-outline"
    };
    private string PublishStateTitle => _publishState switch
    {
        PublishState.Uploading => "正在直传七牛",
        PublishState.Recording => "文件已上传，正在发布版本",
        PublishState.Success => "新版本已经发布",
        _ => HasUploadedCurrentVersion ? "文件已上传，版本记录失败" : "发布未完成"
    };
    private string PublishStateDescription => _publishState switch
    {
        PublishState.Uploading => $"{ReleaseObjectName} · 不经过官网服务器",
        PublishState.Recording => $"{_analysis?.PlatformName} v{_version}",
        PublishState.Success => $"{_analysis?.PlatformName} v{_version} 已生效",
        _ => "可检查信息后重试；已经上传的文件不会重复上传"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", ModulePath);
        _selfReference = DotNetObjectReference.Create(this);
        var catalog = await _module.InvokeAsync<CurrentRelease[]>("loadCatalog");
        _currentReleases.AddRange(catalog);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenFilePickerAsync()
    {
        if (_module is not null) await _module.InvokeVoidAsync("openFilePicker", _fileInput);
    }

    private async Task InspectPackageAsync(ChangeEventArgs _)
    {
        if (_module is null) return;
        _busy = true;
        _error = string.Empty;
        _publishState = PublishState.Idle;
        _fileUploaded = false;
        _uploadedVersion = null;
        _confirmed = false;
        _uploadProgress = 0;
        try
        {
            _analysis = await _module.InvokeAsync<PackageAnalysis>("inspectPackage", _fileInput);
            _version = _analysis.Version ?? string.Empty;
        }
        catch (JSException ex)
        {
            _analysis = null;
            _error = CleanJsError(ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task PublishAsync()
    {
        if (_module is null || _analysis is null || !CanPublish || _selfReference is null) return;

        _busy = true;
        _error = string.Empty;
        var releaseVersion = _version.Trim();
        try
        {
            if (!HasUploadedCurrentVersion)
            {
                _publishState = PublishState.Uploading;
                _uploadProgress = 0;
                await _module.InvokeVoidAsync("uploadPackage", _fileInput, _analysis.Platform, releaseVersion, _selfReference);
                _fileUploaded = true;
                _uploadedVersion = releaseVersion;
            }

            _publishState = PublishState.Recording;
            await _module.InvokeVoidAsync("publishRelease", _analysis.Platform, releaseVersion, _memo.Trim());
            _publishState = PublishState.Success;
            _confirmed = false;

            var catalog = await _module.InvokeAsync<CurrentRelease[]>("loadCatalog");
            _currentReleases.Clear();
            _currentReleases.AddRange(catalog);
        }
        catch (JSException ex)
        {
            _publishState = PublishState.Failed;
            _error = CleanJsError(ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    [JSInvokable]
    public Task ReportUploadProgress(int progress)
    {
        _uploadProgress = Math.Clamp(progress, 0, 100);
        StateHasChanged();
        return Task.CompletedTask;
    }

    private static string CleanJsError(string message)
    {
        var marker = message.LastIndexOf("Error:", StringComparison.Ordinal);
        return marker >= 0 ? message[(marker + 6)..].Trim() : message;
    }

    private CurrentRelease? CurrentReleaseFor(string platform) => _currentReleases.FirstOrDefault(item => item.Platform == platform);
    private string? ReleaseObjectName => _analysis?.Platform switch
    {
        "windows" when IsVersionValid => $"releases/windows/Litograph-Windows-{_version.Trim()}.zip",
        "android" when IsVersionValid => $"releases/android/Litograph-Android-{_version.Trim()}.apk",
        "macos" => "Litograph.pkg",
        "ios" => "Litograph.ipa",
        _ => null
    };
    private string? ReleaseDownloadUrl => ReleaseObjectName is { } objectName
        ? $"https://cdn.thankful.top/{string.Join("/", objectName.Split('/').Select(Uri.EscapeDataString))}"
        : null;
    private static PlatformInfo PlatformFor(string platform) => Platforms.First(item => item.Id == platform);
    private static string PlatformClass(string platform) => $"is-{platform}";
    private static string CheckClass(bool valid) => valid ? "is-ready" : string.Empty;
    private static string CheckIcon(bool valid) => valid ? "mdi-check-circle" : "mdi-circle-outline";
    private static string FormatSize(long bytes) => bytes switch
    {
        >= 1024L * 1024 * 1024 => $"{bytes / (1024d * 1024 * 1024):0.00} GB",
        >= 1024L * 1024 => $"{bytes / (1024d * 1024):0.0} MB",
        _ => $"{bytes / 1024d:0.0} KB"
    };

    public async ValueTask DisposeAsync()
    {
        _selfReference?.Dispose();
        if (_module is not null) await _module.DisposeAsync();
    }

    private sealed record PlatformInfo(string Id, string Name, string Icon, string Extension);
    private sealed class PackageAnalysis
    {
        public string Name { get; set; } = string.Empty;
        public string Extension { get; set; } = string.Empty;
        public long Size { get; set; }
        public string Platform { get; set; } = string.Empty;
        public string PlatformName { get; set; } = string.Empty;
        public string? Version { get; set; }
        public string VersionSource { get; set; } = string.Empty;
    }
    private sealed class CurrentRelease
    {
        public string Platform { get; set; } = string.Empty;
        public string? Version { get; set; }
        public string? DateTime { get; set; }
    }
    private enum PublishState { Idle, Uploading, Recording, Success, Failed }
}
