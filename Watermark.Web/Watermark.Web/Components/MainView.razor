                       data-release-client="WatermarkAndroid" aria-label="下载 Android 版轻影">
                        <span class="mdi mdi-android" aria-hidden="true"></span><b>Android</b><small>Android 8.0+</small>
                    </a>
                    <a href="https://apps.apple.com/cn/app/%E6%B0%B4%E5%8D%B0%E7%9B%B8%E6%A1%86%E5%A4%A7%E5%B8%88/id6541761957" aria-label="前往 App Store 下载 iOS 版轻影">
                        <span class="mdi mdi-cellphone" aria-hidden="true"></span><b>iOS</b><small>iPhone · iPad</small>
                    </a>
                </div>

                <div class="wm-final-cta">
                    <p class="wm-kicker">YOUR NEXT PHOTOGRAPH</p>
                    <h2>把下一张照片，做成你的作品</h2>
                    <div class="wm-actions wm-actions-centered">
                        <a class="wm-button" href="https://cdn.thankful.top/Litograph.pkg">下载轻影</a>
                        <a class="wm-text-link" href="#platforms-note">查看系统要求 <span class="mdi mdi-arrow-right" aria-hidden="true"></span></a>
