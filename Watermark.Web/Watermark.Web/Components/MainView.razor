                    </div>
                </div>

                <div class="wm-night-stage">
                    <img class="wm-night-photo" src="images/home/star-trails.jpg" alt="多帧合成后的星轨作品" />
                    <figure class="wm-night-workspace">
                        <div class="wm-workspace-composite">
                            <img class="wm-workspace-ui" src="images/home/multi-frame-workspace.jpg" alt="轻影多帧合成工作区" />
                            <div class="wm-workspace-canvas wm-workspace-canvas-landscape wm-workspace-canvas-night">
                                <img src="images/home/star-trails.jpg" alt="多帧合成工作区中的星轨成片" />
                            </div>
                        </div>
                    </figure>
                </div>
            </div>
        </section>

        <section class="wm-chapter wm-chapter-batch">
            <div class="wm-shell">
                <div class="wm-chapter-heading wm-chapter-heading-compact">
                    <span class="wm-chapter-number">05</span>
                    <div>
                        <p class="wm-kicker">BATCH WORKFLOW</p>
                        <h2>一次导入，成批完成</h2>
                        <div class="wm-tags" aria-label="批量处理能力">
                            <span>模板应用</span>
                            <span>预览缓存</span>
                            <span>全分辨率导出</span>
                            <span>EXIF / ICC 保留</span>
                        </div>
                    </div>
                </div>

                <div class="wm-pipeline" aria-label="批量处理流程">
                    <div class="wm-pipeline-step wm-pipeline-source">
                        <span class="mdi mdi-folder-multiple-image" aria-hidden="true"></span>
                        <b>导入照片</b>
                        <small>RAW · JPEG · HEIF</small>
                    </div>
                    <span class="mdi mdi-arrow-right wm-pipeline-arrow" aria-hidden="true"></span>
                    <div class="wm-filmstrip" aria-label="待处理照片">
                        <img src="images/home/misty-ridges.jpg" alt="" />
                        <img src="images/home/winter-lake.jpg" alt="" />
                        <img src="images/home/hero-mountain.jpg" alt="" />
                    </div>
                    <span class="mdi mdi-arrow-right wm-pipeline-arrow" aria-hidden="true"></span>
                    <div class="wm-pipeline-output">
                        <img src="images/home/exif-template.jpg" alt="批量导出的模板成片" />
                        <div><b>全分辨率成片</b><small>模板布局、调色与元数据一次写入</small></div>
                    </div>
                </div>
            </div>
        </section>

