@page "/"
@rendermode InteractiveServer
@using System.IO
@using System.Collections.Concurrent
@using Watermark.Shared.Models
@using Watermark.Web.Components.Pages
@using Color = MudBlazor.Color
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@* ===== 3.1: 固定导航栏 ===== *@
<nav class="sticky-nav" id="stickyNav">
    <div class="nav-brand">
        <LogoIcon />
        <span>轻影 Litograph</span>
    </div>
    <a href="#downloadSection" class="nav-download-btn">下载</a>
</nav>

@* ===== 3.1: Hero Section ===== *@
<section class="hero-section" id="heroSection">
    <h1 class="hero-title scroll-animate slide-up">轻影</h1>
    <p class="hero-subtitle scroll-animate slide-up stagger-delay-1">Litograph</p>
    <p class="hero-tagline scroll-animate slide-up stagger-delay-2">强大的全功能图片模板编辑工具</p>
    <a href="#downloadSection" class="hero-cta scroll-animate slide-up stagger-delay-3">立即下载</a>
</section>

@* ===== 3.2: Feature Section 功能卡片区 ===== *@
<section class="feature-section">
    <h2 class="section-title scroll-animate fade-in">产品特色</h2>
    <MudGrid Justify="Justify.Center" Style="max-width:1200px;margin:0 auto;">
        @for (int i = 0; i < features.Count; i++)
        {
            var feature = features[i];
            var delay = i + 1;
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="0" Class="@($"scroll-animate fade-in stagger-delay-{delay}")" Style="text-align:center;padding:32px 16px;background:#f5f5f7;border-radius:16px;">
                    <MudIcon Icon="@feature.Icon" Style="font-size:2.5rem;color:#0071e3;" />
                    <MudCardContent>
                        <MudText Typo="Typo.h6" Style="font-weight:600;margin-bottom:8px;">@feature.Title</MudText>
                        <MudText Typo="Typo.body2" Style="color:#6e6e73;">@feature.Description</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</section>

@* ===== 3.3: 产品截图展示区 ===== *@
<section class="showcase-section">
    <MudGrid Justify="Justify.Center" Style="max-width:1200px;margin:0 auto;align-items:center;">
        <MudItem xs="12" sm="6">
            <div class="scroll-animate slide-left">
                <h2 class="section-title">强大的模板编辑器</h2>
                <p class="section-desc">通过模板编辑器制作各式各样的照片模板</p>
                <p class="section-desc">更可以直接获取图片EXIF信息</p>
                <p class="section-desc">上百款模板供你选择，创作你自己的专属模板</p>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6">
            <div class="scroll-animate slide-right">
                <img src="https://cdn.thankful.top/C264A6182FBF486DBD4C755D743E4AB3.jpg"
                     alt="产品截图"
                     style="width:100%;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,0.1);"
                     onerror="this.style.display='none';this.parentElement.style.background='#e8e8ed';this.parentElement.style.minHeight='300px';this.parentElement.style.borderRadius='12px';" />
            </div>
        </MudItem>
    </MudGrid>
</section>

@* ===== 3.4: Download Section 下载区 ===== *@
<section class="download-section" id="downloadSection">
    <h2 class="section-title scroll-animate fade-in">下载轻影</h2>
    <div class="download-buttons scroll-animate slide-up stagger-delay-1">
        <a href="https://cdn.thankful.top/Watermark.Win.Update.exe" class="download-btn">
            <MudIcon Icon="@Icons.Custom.Brands.Microsoft" /> Windows
        </a>
        <a href="https://cdn.thankful.top/DaVinci%20Frame%20Master-%E6%B0%B4%E5%8D%B0%E7%9B%B8%E6%A1%86%E5%A4%A7%E5%B8%88.apk" class="download-btn">
            <MudIcon Icon="@Icons.Material.Filled.Android" /> Android
        </a>
        <a href="https://apps.apple.com/cn/app/davinci-frame-master/id6504527992?mt=12" class="download-btn">
            <MudIcon Icon="@Icons.Custom.Brands.Apple" /> macOS
        </a>
        <a href="https://apps.apple.com/cn/app/%E6%B0%B4%E5%8D%B0%E7%9B%B8%E6%A1%86%E5%A4%A7%E5%B8%88/id6541761957" class="download-btn">
            <MudIcon Icon="@Icons.Custom.Brands.Apple" /> iPhone
        </a>
    </div>
    <p class="privacy-text scroll-animate fade-in stagger-delay-2">
        使用轻影即表示你同意其<a href="http://thankful.top/private">许可 &amp; 隐私</a>声明
    </p>
</section>

@* ===== 3.5: Template Gallery Section 模板画廊 ===== *@
<section class="gallery-section">
    <h2 class="section-title scroll-animate fade-in">精选模板</h2>
    <div class="gallery-grid">
        @for (int i = 0; i < strings.Count; i++)
        {
            var src = strings[i];
            var delay = (i % 12) + 1;
            <div class="@($"gallery-item scroll-animate scale-in stagger-delay-{delay}")">
                <img src="@($"https://cdn.thankful.top/{src}.jpg")"
                     alt="模板预览"
                     loading="lazy"
                     onerror="this.style.display='none';this.parentElement.style.background='#e8e8ed';this.parentElement.style.minHeight='150px';" />
            </div>
        }
    </div>
</section>

@* ===== 3.6: Footer Section 页脚 ===== *@
<footer class="footer-section">
    <a href="https://beian.miit.gov.cn/">蜀ICP备2024092556号</a>
</footer>

