@code {
    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            APIHelper api = new();
            _ = api.PageVisitRecord(Shared.Enums.ProgramPage.Index, Shared.Enums.DeviceType.Web);
        }

        return Task.CompletedTask;
    }
}
