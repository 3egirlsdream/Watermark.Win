@using Masa.Blazor
@using Watermark.Shared.Enums;
<MButtonGroup Value="@Value" Mandatory ValueChanged="Changed" Dense Class="ma-1" Color="primary">
    @if (Type == GroupItemType.TopCenterBottom)
    {
        @foreach (var item in TopCenterBottom)
        {
            <MButton Value="(int)item.Value">
                <WmIcon Icon="@item.Icon" />
            </MButton>
        }
    }
    else if (Type == GroupItemType.HorizonVertical)
    {
        @foreach (var item in HorizonVertical)
        {
            <MButton Value="(int)item.Value">
                <WmIcon Icon="@item.Icon" />
            </MButton>
        }
    }
    else if (Type == GroupItemType.TBLR)
    {
        @foreach (var item in TBLR)
        {
            <MButton Value="(int)item.Value">
                <WmIcon Icon="@item.Icon" />
            </MButton>
        }
    }
    else if (Type == GroupItemType.LeftCenterRight)
    {
        @foreach (var item in LeftCenterRight)
        {
            <MButton Value="(int)item.Value">
                <WmIcon Icon="@item.Icon" />
            </MButton>
        }
    }
</MButtonGroup>

@code {
    [Parameter]
    public StringNumber Value { get; set; }
    List<GroupItem<VerticalAlignment>> TopCenterBottom = new()
    {
        new GroupItem<VerticalAlignment>(VerticalAlignment.Top, "align-top"),
        new GroupItem<VerticalAlignment>(VerticalAlignment.Center, "align-center-vertical"),
        new GroupItem<VerticalAlignment>(VerticalAlignment.Bottom, "align-bottom")
    };

    List<GroupItem<Orientation>> HorizonVertical = new()
    {
        new GroupItem<Orientation>(Orientation.Horizontal, "rows"),
        new GroupItem<Orientation>(Orientation.Vertical, "columns"),
    };

    List<GroupItem<ContainerAlignment>> TBLR = new()
    {
        new GroupItem<ContainerAlignment>(ContainerAlignment.Top, "align-top"),
        new GroupItem<ContainerAlignment>(ContainerAlignment.Bottom, "align-bottom"),
        new GroupItem<ContainerAlignment>(ContainerAlignment.Left, "align-left"),
        new GroupItem<ContainerAlignment>(ContainerAlignment.Right, "align-right"),
    };

    List<GroupItem<HorizontalAlignment>> LeftCenterRight = new()
    {
        new GroupItem<HorizontalAlignment>(HorizontalAlignment.Left, "align-left"),
        new GroupItem<HorizontalAlignment>(HorizontalAlignment.Center, "align-center-horizontal"),
        new GroupItem<HorizontalAlignment>(HorizontalAlignment.Right, "align-right"),
    };

    [Parameter]
    public GroupItemType Type { get; set; }

    [Parameter]
    public EventCallback<int> ValueChanged { get; set; }

    void Changed(StringNumber sn)
    {
        Value = sn;
        if(Value != null)
        {
            ValueChanged.InvokeAsync(sn.AsT1);
        }
        
    }

    public enum GroupItemType
    {
        TopCenterBottom = 1,
        HorizonVertical = 2,
        TBLR = 3,
        LeftCenterRight = 4
    }

    public class GroupItem<T>
    {
        public T Value { get; set; }
        public string Icon { get; set; }
        public GroupItem(T value, string icon)
        {
            Value = value;
            Icon = icon;
        }
    }
}
