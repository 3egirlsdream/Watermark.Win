@using Watermark.Razor.Workspace
@implements IAsyncDisposable
@inject IWMExternalActionService External
@inject IJSRuntime JSRuntime

<section class="privacy-onboarding" role="dialog" aria-modal="true" aria-labelledby="privacy-title">
    <div class="privacy-scroll-region" @ref="scrollRegion">
        <header class="privacy-brand">
            <img class="privacy-app-icon" src="_content/Watermark.Razor/img/app-icon.svg" alt="轻影应用图标" />
            <span><strong>水印相框软件</strong><small>轻影 · LITOGRAPH</small></span>
            <span class="privacy-step">首次使用设置</span>
        </header>

        <main class="privacy-content">
            <section class="privacy-hero">
                <span class="privacy-kicker">隐私优先 · 本地创作</span>
                <h1 id="privacy-title">你的照片，只留在设备里</h1>
                <p>模板、调色与导出默认在本机完成，不会为了处理照片而上传原图。</p>
                <div class="privacy-local-badge"><WmIcon Icon="device-mobile" /><span>默认本地处理 · 启动时不索取相册权限</span></div>
            </section>

            <section class="privacy-access" aria-labelledby="privacy-access-title">
                <header>
                    <span>按需授权</span>
                    <h2 id="privacy-access-title">只在你使用对应功能时访问</h2>
                </header>
                <div class="privacy-access-list">
                    <article>
                        <span class="privacy-access-icon is-photo"><WmIcon Icon="images" /></span>
                        <div><strong>选择照片</strong><p>点击导入时才打开系统相册，不扫描整个相册。</p></div>
                    </article>
                    <article>
                        <span class="privacy-access-icon is-save"><WmIcon Icon="tray-arrow-down" /></span>
                        <div><strong>保存作品</strong><p>点击导出时才写入照片或你选择的位置。</p></div>
                    </article>
                    <article>
                        <span class="privacy-access-icon is-network"><WmIcon Icon="cloud" /></span>
                        <div><strong>联网服务</strong><p>仅用于账号、模板市场、收藏与版本更新。</p></div>
                    </article>
                </div>
                <div class="privacy-commitment">
                    <WmIcon Icon="eye-slash" /><span>创作图片默认不上云，权限可在系统设置中随时修改。</span>
                </div>
            </section>
        </main>
    </div>

    <footer class="privacy-actions">
        <p>继续即表示你已阅读并同意
            <button type="button" @onclick="OpenProtocolAsync">《用户协议》</button>和
            <button type="button" @onclick="OpenPrivacyAsync">《隐私协议》</button>
        </p>
        <button type="button" class="privacy-primary" @onclick="AgreeAsync">
            <span>同意并开始使用</span><WmIcon Icon="arrow-right" />
        </button>
        <button type="button" class="privacy-secondary" @onclick="DeclineAsync">暂不同意，先浏览应用</button>
    </footer>
</section>

@code {
    [Parameter] public EventCallback<bool> OnClosed { get; set; }

    private ElementReference scrollRegion;
    private IJSObjectReference? scrollModule;
    private IJSObjectReference? scrollAttachment;

    private Task AgreeAsync() => OnClosed.HasDelegate ? OnClosed.InvokeAsync(true) : Task.CompletedTask;
    private Task DeclineAsync() => OnClosed.HasDelegate ? OnClosed.InvokeAsync(false) : Task.CompletedTask;
    private Task OpenProtocolAsync() => External.OpenUrlAsync("https://thankful.top/protocol");
    private Task OpenPrivacyAsync() => External.OpenUrlAsync("https://thankful.top/private");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || scrollAttachment is not null) return;
        try
        {
            scrollModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./_content/Watermark.Razor/js/wm-app-shell-scroll.js");
            scrollAttachment = await scrollModule.InvokeAsync<IJSObjectReference>(
                "attachAndroidMouseDragScroll", scrollRegion);
        }
        catch (JSDisconnectedException) { }
        catch (JSException) { }
    }

    public async ValueTask DisposeAsync()
    {
        if (scrollAttachment is not null)
        {
            try { await scrollAttachment.InvokeVoidAsync("dispose"); }
            catch (JSDisconnectedException) { }
            catch (JSException) { }
            try { await scrollAttachment.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
        if (scrollModule is not null)
        {
            try { await scrollModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }
}
