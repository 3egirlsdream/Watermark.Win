@page "/settings"
@using Watermark.Razor.Components.Layout
@using Watermark.Razor.Workspace
@layout WMAppShellLayout
@inject IWMAccountService Accounts
@inject IWMAppSettingsService Settings
@inject IWMCacheMaintenanceService Cache
@inject IWMAppUpdateService Updates
@inject IWMExternalActionService External
@inject IPopupService Popup
@inject NavigationManager Navigation
@inject IWMNavigationHistory NavigationHistory

<section class="settings-page" aria-labelledby="settings-title">
    <header>
        <button type="button" @onclick="GoBack" aria-label="返回"><MIcon>mdi-arrow-left</MIcon></button>
        <div><span>APPLICATION</span><h1 id="settings-title">设置</h1></div>
    </header>

    @if (loading)
    {
        <div class="settings-loading" role="status"><MProgressCircular Indeterminate Size="30" Width="3" /><span>正在加载设置…</span></div>
    }
    else if (draft is not null)
    {
        <div class="settings-grid">
            <section class="settings-card" id="account">
                <h2><MIcon>mdi-account-cog-outline</MIcon><span>账号与会员</span></h2>
                @if (Accounts.State.IsAuthenticated)
                {
                    <div class="settings-account"><strong>@Accounts.State.DisplayName</strong><small>@Accounts.State.UserName · @(Accounts.State.IsVip ? "会员" : "免费版")</small></div>
                    <button type="button" @onclick="OpenMembership"><span>会员与权益</span><MIcon>mdi-chevron-right</MIcon></button>
                    <button type="button" @onclick="OpenChangePassword"><span>修改密码</span><MIcon>mdi-chevron-right</MIcon></button>
                    <button type="button" @onclick="SwitchAccountAsync"><span>切换账号</span><MIcon>mdi-login-variant</MIcon></button>
                    <button type="button" class="is-danger" @onclick="OpenDeleteAccount"><span>永久删除账号</span><MIcon>mdi-chevron-right</MIcon></button>
                }
                else
                {
                    <button type="button" @onclick="OpenLogin"><span>登录或注册账号</span><MIcon>mdi-chevron-right</MIcon></button>
                }
            </section>

            <section class="settings-card" id="application">
                <h2><MIcon>mdi-tune-variant</MIcon><span>处理设置</span></h2>
                <label class="settings-switch"><span><strong>增强EXIF解析</strong><small>尝试读取厂商扩展元数据</small></span><input type="checkbox" @bind="enhancedExif" /></label>
                <label class="settings-range"><span><strong>最大处理线程</strong><small>1–@draft.MaximumAllowedThreads，受设备预算限制</small></span><output>@maximumThreads</output><input type="range" min="1" max="@draft.MaximumAllowedThreads" step="1" @bind="maximumThreads" @bind:event="oninput" /></label>
                <button class="is-primary" type="button" disabled="@saving" @onclick="SaveSettingsAsync"><span>@(saving ? "正在保存…" : "保存处理设置")</span><MIcon>mdi-content-save-outline</MIcon></button>
            </section>

            <section class="settings-card" id="resources">
                <h2><MIcon>mdi-shape-outline</MIcon><span>资源与缓存</span></h2>
                <button type="button" @onclick="OpenResources"><span>图标与字体</span><MIcon>mdi-chevron-right</MIcon></button>
                <button type="button" disabled="@cacheBusy" @onclick="() => ClearCacheAsync(WMCacheArea.Temporary)"><span>清理临时缓存 <small>@FormatBytes(cacheSummary?.TemporaryBytes ?? 0)</small></span><MIcon>mdi-delete-sweep-outline</MIcon></button>
                <button type="button" disabled="@cacheBusy" @onclick="() => ClearCacheAsync(WMCacheArea.MarketPreviews)"><span>重置市场预览 <small>@FormatBytes(cacheSummary?.MarketPreviewBytes ?? 0)</small></span><MIcon>mdi-refresh</MIcon></button>
                <button type="button" disabled="@cacheBusy" @onclick="() => ClearCacheAsync(WMCacheArea.LogoLibrary)"><span>重置内置图标库 <small>@FormatBytes(cacheSummary?.LogoBytes ?? 0)</small></span><MIcon>mdi-refresh</MIcon></button>
            </section>

            <section class="settings-card" id="update">
                <h2><MIcon>mdi-update</MIcon><span>版本与诊断</span></h2>
                <div class="settings-version"><span><strong>轻影 @Updates.State.CurrentVersion</strong><small>@(Updates.State.Message ?? "点击检查是否有新版本")</small></span><button type="button" disabled="@Updates.State.IsChecking" @onclick="CheckUpdateAsync">检查</button></div>
                @if (Updates.State.UpdateAvailable)
                {
                    <button class="is-primary" type="button" @onclick="StartUpdateAsync"><span>获取版本 @Updates.State.AvailableVersion</span><MIcon>mdi-open-in-new</MIcon></button>
                }
                <button type="button" @onclick="OpenDiagnostics"><span>诊断与日志</span><MIcon>mdi-chevron-right</MIcon></button>
            </section>

            <section class="settings-card" id="privacy">
                <h2><MIcon>mdi-shield-lock-outline</MIcon><span>隐私与帮助</span></h2>
                <button type="button" @onclick="OpenProtocolAsync"><span>用户协议</span><MIcon>mdi-open-in-new</MIcon></button>
                <button type="button" @onclick="OpenPrivacyPolicy"><span>隐私协议</span><MIcon>mdi-chevron-right</MIcon></button>
                <button type="button" @onclick="CopyGroupAsync"><span>交流群：836325187</span><MIcon>mdi-content-copy</MIcon></button>
                <button type="button" @onclick="OpenWebsiteAsync"><span>官网与帮助</span><MIcon>mdi-open-in-new</MIcon></button>
                <button type="button" class="is-danger" @onclick="RevokePrivacyAsync"><span>撤回本地隐私授权</span><MIcon>mdi-shield-off-outline</MIcon></button>
            </section>
        </div>
    }
</section>

@code {
    [Parameter] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "returnUrl")] private string? QueryReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "section")] public string? Section { get; set; }
    private WMAppSettingsState? draft;
    private WMCacheSummary? cacheSummary;
    private bool enhancedExif;
    private int maximumThreads = 1;
    private bool loading = true;
    private bool saving;
    private bool cacheBusy;
    private string ReturnTarget => WMReturnUrl.Normalize(ReturnUrl ?? QueryReturnUrl);

    protected override async Task OnInitializedAsync()
    {
        draft = await Settings.LoadAsync();
        enhancedExif = draft.EnhancedExif;
        maximumThreads = draft.MaximumThreads;
        cacheSummary = await Cache.MeasureAsync();
        loading = false;
        if (string.Equals(Section, "update", StringComparison.OrdinalIgnoreCase)) await CheckUpdateAsync();
    }

    private async Task SaveSettingsAsync()
    {
        if (saving || draft is null) return;
        saving = true;
        try
        {
            draft = await Settings.UpdateAsync(enhancedExif, maximumThreads);
            ShowToast("设置已保存。");
        }
        catch (Exception ex) { ShowToast(ex.Message, true); }
        finally { saving = false; }
    }

    private async Task ClearCacheAsync(WMCacheArea area)
    {
        if (cacheBusy) return;
        var destructive = area is WMCacheArea.MarketPreviews or WMCacheArea.LogoLibrary;
        if (destructive)
        {
            var confirmed = await Popup.ConfirmAsync("确认重置", area == WMCacheArea.LogoLibrary ? "将删除个人导入图标并重新下载内置图标，是否继续？" : "将删除市场预览缓存，是否继续？", AlertTypes.Warning);
            if (confirmed != true) return;
        }
        cacheBusy = true;
        var result = await Cache.ClearAsync(area);
        cacheSummary = result.Summary;
        cacheBusy = false;
        ShowToast(result.Message, !result.Succeeded);
    }

    private async Task RevokePrivacyAsync()
    {
        var confirmed = await Popup.ConfirmAsync("撤回隐私授权", "将退出本机账号，下次进入应用需要重新确认隐私协议。继续吗？", AlertTypes.Warning);
        if (confirmed != true) return;
        await Settings.RevokePrivacyConsentAsync();
        NavigationHistory.NavigateRoot("/profile");
    }

    private async Task SwitchAccountAsync()
    {
        await Accounts.SignOutAsync();
        OpenLogin();
    }

    private async Task CheckUpdateAsync()
    {
        await Updates.CheckAsync();
        ShowToast(Updates.State.Message ?? "检查完成。", Updates.State.HasError);
    }

    private async Task StartUpdateAsync()
    {
        var result = await Updates.StartUpdateAsync();
        ShowToast(result.Message, !result.Succeeded);
    }

    private string CurrentPage => new Uri(Navigation.Uri).PathAndQuery;
    private void OpenLogin() => NavigationHistory.NavigateTo($"/account/login?returnUrl={Uri.EscapeDataString(CurrentPage)}");
    private void OpenMembership() => NavigationHistory.NavigateTo($"/membership?returnUrl={Uri.EscapeDataString(CurrentPage)}");
    private void OpenChangePassword() => NavigationHistory.NavigateTo($"/account/change-password?returnUrl={Uri.EscapeDataString(CurrentPage)}");
    private void OpenDeleteAccount() => NavigationHistory.NavigateTo($"/account/delete?returnUrl={Uri.EscapeDataString(CurrentPage)}");
    private void OpenResources() => NavigationHistory.NavigateTo($"/settings/resources?returnUrl={Uri.EscapeDataString(CurrentPage)}");
    private void OpenDiagnostics() => NavigationHistory.NavigateTo($"/settings/imaging?returnUrl={Uri.EscapeDataString(CurrentPage)}");
    private void GoBack() => NavigationHistory.GoBack(ReturnTarget);
    private Task OpenProtocolAsync() => External.OpenUrlAsync("http://thankful.top/protocol");
    private void OpenPrivacyPolicy() => NavigationHistory.NavigateTo($"/privacy-policy?returnUrl={Uri.EscapeDataString(CurrentPage)}");
    private Task OpenWebsiteAsync() => External.OpenUrlAsync("http://thankful.top/");
    private async Task CopyGroupAsync() { await External.CopyTextAsync("836325187"); ShowToast("群号已复制。"); }
    private void ShowToast(string? value, bool error = false) => Common.ShowToast(Popup, value, error);
    private static string FormatBytes(long value) => value < 1024 * 1024 ? $"{value / 1024d:0.#} KB" : $"{value / 1024d / 1024d:0.#} MB";
}
