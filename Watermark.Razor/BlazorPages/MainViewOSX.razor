@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Web
@using Watermark.Razor.Components
@using Watermark.Razor.Components.Desktop
@using Watermark.Razor.Components.Mac
@using Watermark.Razor.Workspace
@using Watermark.Razor.Workspace.Components
@using Watermark.Shared.Models
@inject WMWorkspaceController Controller
@inject IWMWorkspaceSessionStore SessionStore
@inject IWMPhotoPicker PhotoPicker
@inject WMTemplateLibraryService TemplateLibrary
@inject IWMImagingCapabilityProvider ImagingCapabilities
@inject IWMHapticFeedback HapticFeedback
@inject IWMSystemAppearance SystemAppearance
@inject NavigationManager Navigation
@inject IWMAccountService Accounts
@inject IWMExternalActionService ExternalActions
@inject IWMDesktopStartupService DesktopStartup
@inject IWMAdminDashboardService AdminDashboard

<MacWorkspaceShell>
    <ToolbarContent>
        <WMDesktopAppToolbar Mode="@DesktopMode" Account="Accounts.State" CanUndo="@(State.CanUndo && !IsCropEditing)" CanRedo="@(State.CanRedo && !IsCropEditing)" History="State.History"
                             ImportImages="AppendMediaAsync" Undo="() => Controller.UndoAsync()" Redo="() => Controller.RedoAsync()" HistorySelected="cursor => Controller.SetHistoryCursorAsync(cursor)"
                             Export="ToggleExportPanel" CreateTemplate="OpenNewTemplateDialog" OpenTemplates='() => NavigateDesktopSection("templates")' OpenMarket='() => NavigateDesktopSection("market")'
                             OpenLogos='() => NavigateDesktopSection("resources")' OpenAccount='() => OpenAccountDialog("login")' OpenMembership="OpenVipDialog"
                             SignUp='() => OpenAccountDialog("register")' LogoutAccount='() => OpenAccountDialog("delete")'
                             OpenSettings='() => NavigateDesktopSection("settings")' OpenDashboard='() => NavigateDesktopSection("admin")' CanOpenDashboard="@AdminDashboard.IsAuthorized"
                             SignOut="SignOutAsync" OpenLink="ExternalActions.OpenUrlAsync" OpenCommonDialog="OpenCommonDialog" />
    </ToolbarContent>
    <WorkspaceContent>
        <div class="main-workspace">
            <WMDesktopFeatureRail Mode="@DesktopMode" ColorEngineAvailable="@ColorEngineAvailable" ModeChanged="SetModeAsync" />
            <WMDesktopModeSidebar Mode="@DesktopMode" Templates="templates" TemplateId="@State.TemplateId" Presets="State.ColorGradeTool.Presets" SelectedPresetId="@State.ColorGradeTool.SelectedPresetId"
                                  ReferenceUrl="@State.ColorGradeTool.Reference.PreviewUrl" ReferenceName="@State.ColorGradeTool.Reference.DisplayName" Media="State.Media" SelectedFrameIds="SelectedFrameIds"
                                  MediaPreviewUrl="MediaPreviewById" TemplateSelected="SelectTemplateAsync" SplitTemplateSelected="SelectSplitTemplateAsync" EditTemplate="item => OpenDesignerAsync(item.ID)"
                                  CreateTemplate="OpenNewTemplateDialog" OpenTemplates='() => NavigateDesktopSection("templates")' OpenMarket='() => NavigateDesktopSection("market")' ChooseReference="ChooseReferenceAsync"
                                  ResetColor="ResetColorAsync" PresetSelected="ApplyPresetAsync" FrameToggled="ToggleFrameAsync" />
            @if (ShowAppliedTemplateEditor)
            {
                <WMDesktopAppliedTemplateEditor State="State"
                                                SelectedCount="SelectedCount"
                                                MediaPreviewUrl="MediaPreviewById"
                                                MediaSelected="id => Controller.SelectMediaAsync(id)"
                                                MediaToggled="id => Controller.ToggleMediaSelectionAsync(id)"
                                                ScopeChanged="ChangeApplyScopeAsync"
                                                PreviewChanged="PreviewTemplateAsync"
                                                CommitRequested="CommitTemplateAsync"
                                                DiscardRequested="() => Controller.DiscardTransientEditsAsync()"
                                                OpenDesignerRequested="OpenDesignerAsync" />
            }
            else
            {
            <div class="workspace-main-column @(IsCropEditing ? "is-crop" : null)" style="@WorkspaceMainStyle" @onpointermove="ResizeMediaStrip" @onpointerup="EndMediaStripResize" @onpointerleave="EndMediaStripResize" @onpointercancel="EndMediaStripResize">
                <section class="workspace-preview-pane">
                    @if (State.Recovery is not null)
                    {
                        <WMWorkspaceRecoveryPanel Result="State.Recovery" Busy="recovering" RecoveryRequested="RecoverAsync" />
                    }
                    else
                    {
                        <div class="desktop-preview-persistent @(IsCropEditing ? "is-hidden" : null)">
                            <WMDesktopPreviewWorkspace Presentation="PreviewPresentation" ModeLabel="@PreviewModeLabel" Busy="@IsBusy" IsOriginal="State.IsComparingOriginal" Message="State.Message"
                                                       ShowOriginal="ShowOriginalAsync" HideOriginal="HideOriginalAsync" CapabilityChanged="HandleColorPreviewCapabilityAsync" PerformanceMeasured="HandleColorPreviewPerformanceAsync" />
                        </div>
                        @if (IsCropEditing)
                        {
                            <div class="desktop-crop-canvas-host">
                                <WMCropCanvas ImageUrl="@CropSourceUrl"
                                              SourceWidth="CropSourceWidth"
                                              SourceHeight="CropSourceHeight"
                                              Settings="State.CropTool.Draft"
                                              SettingsChanged="UpdateCropDraftAsync"
                                              ApplyRequested="() => Controller.CommitCropDraftAsync()"
                                              CancelRequested="() => Controller.DiscardTransientEditsAsync()" />
                            </div>
                        }
                    }
                </section>
                <div class="workspace-splitter-grip" @onpointerdown="StartMediaStripResize" @onpointerdown:preventDefault="true"><span></span></div>
                <section class="workspace-media-pane"><WMDesktopMediaStrip Media="State.Media" CurrentMediaId="State.CurrentMediaId" PreviewUrl="MediaPreviewById" StarTrailSelectionIds="SelectedFrameIds" Selected="id => Controller.SelectMediaAsync(id)" Toggled="id => Controller.ToggleMediaSelectionAsync(id)" /></section>
            </div>
            <WMDesktopModeInspector Mode="DesktopMode"
                                    ExportOpen="showExportPanel"
                                    HasPendingOperation="State.HasTransientEdits"
                                    ToggleExport="ToggleExportPanel"
                                    CropSettings="State.CropTool.Draft"
                                    CropSourceWidth="CropSourceWidth"
                                    CropSourceHeight="CropSourceHeight"
                                    CropSettingsChanged="UpdateCropDraftAsync"
                                    ApplyCrop="() => Controller.CommitCropDraftAsync()"
                                    CancelCrop="() => Controller.DiscardTransientEditsAsync()"
                                    ColorRecipe="State.ColorGradeTool.Draft"
                                    ColorPresetCount="State.ColorGradeTool.Presets.Count"
                                    ColorReferenceUrl="@State.ColorGradeTool.Reference.PreviewUrl"
                                    ColorReferenceName="@State.ColorGradeTool.Reference.DisplayName"
                                    CanApplyColor="@(State.CurrentMediaId is not null && ColorEngineAvailable)"
                                    ColorPreviewChanged="PreviewColorAsync"
                                    ApplyColor="ApplyColorAsync"
                                    SaveColorPreset="SavePresetAsync"
                                    RematchColorReference="ChooseReferenceAsync"
                                    ClearColorReference="ClearReferenceAsync"
                                    ResetColorAdjustments="ResetColorAsync"
                                    MultiFrameMedia="State.Media"
                                    MultiFrameDraft="State.MultiFrameTool.Draft"
                                    MultiFrameCapability="State.MultiFrameTool.Capability"
                                    MultiFrameCapabilityMessage="@MultiFrameCapabilityMessage"
                                    MultiFrameBusy="State.MultiFrameTool.IsBusy"
                                    Message="@State.Message"
                                    MultiFrameDraftChanged="draft => Controller.UpdateMultiFrameDraftAsync(draft)"
                                    PreviewMultiFrame="PreviewStackAsync"
                                    ApplyMultiFrame="RunStackAsync"
                                    ExportDraft="State.ExportTool.Draft"
                                    SelectedMediaCount="SelectedCount"
                                    ExportBusy="State.ExportTool.IsBusy"
                                    ExportProgress="State.ActiveJob.Progress"
                                    ExportResults="State.ExportTool.Results"
                                    ExportFailedCount="State.ExportTool.FailedMediaIds.Count"
                                    CanExportPng16="CanPng16"
                                    CanExportTiff16="CanTiff16"
                                    ExportFormatChanged="SetExportFormatAsync"
                                    ExportMaximumLongEdgeChanged="SetExportMaximumLongEdgeAsync"
                                    ExportCustomMaximumLongEdgeChanged="SetCustomExportMaximumLongEdgeAsync"
                                    ExportQualityChanged="SetExportQualityAsync"
                                    ExportDestinationChanged="SetExportDestinationAsync"
                                    RetryFailedExport="RetryFailedAsync"
                                    RunExport="ExportOrCancelAsync" />
            }
        </div>
    </WorkspaceContent>
    <DialogContent>
        @if (!string.IsNullOrWhiteSpace(State.ErrorMessage) || !string.IsNullOrWhiteSpace(message))
        {
            <div class="desktop-toast @(State.ErrorMessage is null ? null : "is-error")" role="status"><span>@(State.ErrorMessage ?? message)</span><button type="button" @onclick="() => message = null"><MIcon>mdi-close</MIcon></button></div>
        }
        <MDialog Persistent @bind-Value="showDesigner" Fullscreen ContentStyle="padding:0;overflow:hidden;">@if (showDesigner) { <WMDesktopTemplateDesigner CanvasId="@designerTemplateId" OnSaved="OnTemplateSavedAsync" OnClose="CloseDesignerAsync" /> }</MDialog>
        <MDialog @bind-Value="showNewTemplate" Width="400" ContentStyle="padding:0;background:transparent;box-shadow:none;overflow:visible;">
            @if (showNewTemplate)
            {
                <WMDesktopNewTemplateDialog OnClose="CloseNewTemplateDialog" OnCreated="OnTemplateCreatedAsync" />
            }
        </MDialog>
        <MDialog @bind-Value="showAccount" Width="390" ContentStyle="padding:0;background:transparent;box-shadow:none;overflow:visible;">
            @if (showAccount)
            {
                <WMDesktopAccountDialog @bind-Mode="accountDialogMode" OnClose="CloseAccountDialog" OnCompleted="OnAccountCompleted" />
            }
        </MDialog>
        <MDialog @bind-Value="showCommonDialog" Width="300">
            <MImage Height="300" Width="300" Contain Src="@commonDialogUrl" />
        </MDialog>
        <MDialog @bind-Value="showVipPurchase" Width="720" ContentStyle="padding:0;background:transparent;box-shadow:none;">
            @if (showVipPurchase)
            {
                <WMDesktopMembershipDialog OnClose="() => showVipPurchase = false" OnPaid="OnVipPaid" />
            }
        </MDialog>
    </DialogContent>
</MacWorkspaceShell>

@code {
    [Parameter] public string? SessionId { get; set; }
    private readonly List<WMTemplateList> templates = [];
    private bool opened;
    private bool showDesigner;
    private bool showNewTemplate;
    private bool showAccount;
    private bool showVipPurchase;
    private bool showCommonDialog;
    private bool showExportPanel;
    private bool recovering;
    private bool mediaStripDragging;
    private bool desktopMultiFrameInitialized;
    private double mediaStripDragStartY;
    private int mediaStripDragStartHeight = 126;
    private int mediaStripHeight = 126;
    private string? message;
    private string? commonDialogUrl;
    private string accountDialogMode = "login";
    private string designerTemplateId = string.Empty;
    private WMWorkspaceState State => Controller.State;
    private WMWorkspacePreviewPresentation PreviewPresentation => State.IsComparingOriginal
        ? State.PreviewPresentation with
        {
            BaseUrl = State.PreviewUrl,
            StableUrl = State.PreviewUrl,
            ColorProgram = null,
            Backend = WMInteractivePreviewBackend.CpuSkia,
            IsSettled = true
        }
        : State.PreviewPresentation;
    private int SelectedCount => State.Media.Count(item => item.IsSelected);
    private bool CanPng16 => ImagingCapabilities.Probe(WMImagingFeature.Png16).IsAvailable;
    private bool CanTiff16 => ImagingCapabilities.Probe(WMImagingFeature.Tiff16).IsAvailable;
    private bool ColorEngineAvailable => Controller.ColorEngineCapability.IsAvailable;
    private string? MultiFrameCapabilityMessage => ImagingCapabilities.Current switch
    {
        { CanAlignScene: false, CanAlignStars: false } => "场景 ECC 与星点配准不可用，仅开放无需对齐的星轨模式。",
        { CanAlignScene: false } => "场景 ECC 配准不可用，场景降噪已禁用。",
        { CanAlignStars: false } => "星点配准不可用，静态星空已禁用。",
        _ => null
    };
    private WMWorkspaceMode DesktopMode => State.Mode is WMWorkspaceMode.Crop or WMWorkspaceMode.Template or WMWorkspaceMode.ColorGrade or WMWorkspaceMode.MultiFrame ? State.Mode : WMWorkspaceMode.Template;
    private bool IsCropEditing => DesktopMode == WMWorkspaceMode.Crop
                                  && State.TransientEditMode == WMWorkspaceMode.Crop;
    private string? CropSourceUrl => State.CurrentMediaId is { Length: > 0 } mediaId
        ? Controller.GetMediaPreviewUrl(mediaId)
        : null;
    private int CropSourceWidth => Math.Max(1, State.CurrentMedia?.Artifact.Width ?? 1);
    private int CropSourceHeight => Math.Max(1, State.CurrentMedia?.Artifact.Height ?? 1);
    private string WorkspaceMainStyle => $"grid-template-rows:minmax(0,1fr) 7px {mediaStripHeight}px;";
    private string PreviewModeLabel => DesktopMode switch { WMWorkspaceMode.Crop => "裁切", WMWorkspaceMode.ColorGrade => "调色预览", WMWorkspaceMode.MultiFrame => "星轨预览", _ => "模板预览" };
    private bool IsBusy => State.Activity is WMWorkspaceActivity.Previewing or WMWorkspaceActivity.Exporting || State.MultiFrameTool.IsBusy;
    private bool ShowAppliedTemplateEditor => State.Mode == WMWorkspaceMode.Template
        && State.HasTransientEdits
        && State.TransientEditMode == WMWorkspaceMode.Template
        && State.TemplateEdit is { TemplateId.Length: > 0, CanvasJson.Length: > 0 };
    private List<string> SelectedFrameIds => State.Media.Where(item => State.MultiFrameTool.Draft.Roles.TryGetValue(item.Id, out var role) && role is not null).Select(item => item.Id).ToList();
    private string DesktopRootUrl => Global.DeviceType == Watermark.Shared.Enums.DeviceType.Win ? "/desktop" : "/mac";
    private string DesktopReturnUrl => string.IsNullOrWhiteSpace(State.SessionId) ? DesktopRootUrl : $"{DesktopRootUrl}/workspace/{State.SessionId}";

    private Task HandleColorPreviewCapabilityAsync(WMColorPreviewCapability capability) =>
        Controller.SetColorPreviewCapabilityAsync(capability);

    private Task HandleColorPreviewPerformanceAsync(WMColorPreviewPerformanceSample sample) =>
        Controller.RecordColorPreviewPerformanceAsync(sample);

    protected override async Task OnInitializedAsync()
    {
        Controller.Changed += OnWorkspaceChanged;
        TemplateLibrary.Changed += OnTemplatesChanged;
        Accounts.Changed += OnAccountChanged;
        SystemAppearance.SetWorkspaceActive(true);
        await DesktopStartup.InitializeAsync();
        await RefreshTemplatesAsync();
        if (!string.IsNullOrWhiteSpace(SessionId))
        {
            opened = await Controller.OpenAsync(SessionId);
        }
        else
        {
            var recent = await SessionStore.ListRecentAsync(5);
            var candidate = recent.FirstOrDefault(item => item.Mode != WMWorkspaceMode.TemplateDesign);
            if (candidate is not null) opened = await Controller.OpenAsync(candidate.Id);
        }
        if (opened && State.Mode == WMWorkspaceMode.TemplateDesign)
        {
            designerTemplateId = State.TemplateId ?? string.Empty;
            showDesigner = true;
        }
    }

    private async Task AppendMediaAsync()
    {
        try { var sources = await PhotoPicker.PickMultipleAsync(); if (sources.Count > 0) await Controller.ImportMediaAsync(sources); }
        catch (Exception ex) { message = ex.Message; }
    }

    private async Task SetModeAsync(WMWorkspaceMode mode)
    {
        await Controller.SetModeAsync(mode);
        if (mode != WMWorkspaceMode.MultiFrame
            || desktopMultiFrameInitialized
            || State.Media.Count != 0
            || State.MultiFrameTool.Draft.Roles.Count != 0)
            return;

        desktopMultiFrameInitialized = true;
        var defaults = WMMultiFrameStackSettings.CreateDefault(WMStackMode.StaticSky);
        await Controller.UpdateMultiFrameDraftAsync(
            State.MultiFrameTool.Draft with
            {
                Mode = WMStackMode.StaticSky,
                NormalizeExposure = defaults.NormalizeExposure,
                RepairHotPixels = defaults.RepairHotPixels,
                AutoCrop = defaults.AutoCrop,
                Advanced = WMMultiFrameAdvancedDraft.CreateDefault(WMStackMode.StaticSky)
            });
        await Controller.CommitMultiFrameDraftAsync();
    }

    private Task UpdateCropDraftAsync(WMCropSettings settings) =>
        Controller.UpdateCropDraftAsync(settings);
    private async Task SelectTemplateAsync(WMTemplateList template)
    {
        if (State.Media.Count == 0)
        {
            message = "请先导入图片，再选择水印模板。";
            return;
        }
        await Controller.PreviewTemplateAsync(new WMWorkspaceTemplateEdit(template.ID, null), State.ApplyScope);
    }

    private async Task SelectSplitTemplateAsync(WMTemplateList template)
    {
        try
        {
            var sources = await PhotoPicker.PickMultipleAsync();
            if (sources.Count == 0) return;
            await Controller.CreateTemplateCollageAsync(new WMWorkspaceTemplateEdit(template.ID, Global.CanvasSerialize(template.Canvas)), sources);
            await Controller.SetModeAsync(WMWorkspaceMode.Template);
        }
        catch (Exception ex) { message = ex.Message; }
    }

    private Task ToggleFrameAsync(string mediaId)
    {
        var roles = new Dictionary<string, WMFrameRole?>(State.MultiFrameTool.Draft.Roles, StringComparer.Ordinal);
        roles[mediaId] = roles.TryGetValue(mediaId, out var existing) && existing is not null ? null : WMFrameRole.Light;
        return Controller.UpdateMultiFrameDraftAsync(State.MultiFrameTool.Draft with { Roles = roles });
    }

    private void ToggleExportPanel() => showExportPanel = !showExportPanel;
    private void StartMediaStripResize(PointerEventArgs args) { mediaStripDragging = true; mediaStripDragStartY = args.ClientY; mediaStripDragStartHeight = mediaStripHeight; }
    private void ResizeMediaStrip(PointerEventArgs args) { if (mediaStripDragging) mediaStripHeight = Math.Clamp(mediaStripDragStartHeight + (int)(mediaStripDragStartY - args.ClientY), 96, 220); }
    private void EndMediaStripResize() => mediaStripDragging = false;
    private string? MediaPreviewById(string mediaId)
    {
        var media = State.Media.FirstOrDefault(item => item.Id == mediaId);
        return media is null ? null : MediaPreview(media);
    }

    private async Task SignOutAsync() { await Accounts.SignOutAsync(); showAccount = false; }
    private void OpenAccountDialog(string mode)
    {
        accountDialogMode = mode;
        showAccount = true;
    }
    private void CloseAccountDialog()
    {
        showAccount = false;
        accountDialogMode = "login";
    }
    private Task OnAccountCompleted() { StateHasChanged(); return Task.CompletedTask; }
    private void OpenNewTemplateDialog() => showNewTemplate = true;
    private void CloseNewTemplateDialog() => showNewTemplate = false;
    private async Task OnTemplateCreatedAsync(string templateId)
    {
        showNewTemplate = false;
        TemplateLibrary.Invalidate(templateId);
        await RefreshTemplatesAsync();
        await OpenDesignerAsync(templateId);
    }
    private void NavigateDesktopSection(string section)
    {
        var safeSection = section is "templates" or "market" or "resources" or "settings" or "admin" ? section : "templates";
        Navigation.NavigateTo($"{DesktopRootUrl}/{safeSection}?returnUrl={Uri.EscapeDataString(DesktopReturnUrl)}");
    }
    private void OpenCommonDialog(string src)
    {
        commonDialogUrl = src;
        showCommonDialog = true;
    }
    private void OpenVipDialog()
    {
        if (!Accounts.State.IsAuthenticated)
        {
            OpenAccountDialog("login");
            return;
        }

        showVipPurchase = true;
    }
    private Task OnVipPaid()
    {
        showVipPurchase = false;
        StateHasChanged();
        return Task.CompletedTask;
    }
    private Task PreviewTemplateAsync(WMWorkspaceTemplateEdit edit) => Controller.PreviewTemplateAsync(edit, State.ApplyScope);
    private Task CommitTemplateAsync(WMWorkspaceTemplateEdit edit) => Controller.CommitTemplateAsync(edit, State.ApplyScope);
    private Task ChangeApplyScopeAsync(WMApplyScope scope)
    {
        Controller.SetApplyScope(scope);
        return Task.CompletedTask;
    }
    private Task ShowOriginalAsync(PointerEventArgs _) => Controller.SetCompareOriginalAsync(true);
    private Task HideOriginalAsync(PointerEventArgs _) => Controller.SetCompareOriginalAsync(false);
    private string? MediaPreview(WMWorkspaceMedia media) =>
        Controller.GetMediaPreviewUrl(media.Id)
        ?? (string.Equals(media.Id, State.CurrentMediaId, StringComparison.Ordinal) ? State.PreviewUrl : null);

    private Task PreviewColorAsync(WMColorRecipe recipe) => Controller.UpdateColorDraftAsync(recipe);
    private async Task CommitColorAsync(WMColorRecipe recipe)
    {
        await Controller.UpdateColorDraftAsync(recipe);
        await Controller.CommitColorDraftAsync(State.ApplyScope);
    }

    private Task ApplyColorAsync() => Controller.CommitColorDraftAsync(WMApplyScope.Current);
    private Task ResetColorAsync() => Controller.UpdateColorDraftAsync(new WMColorRecipe { Name = "桌面调整" });

    private Task ApplyPresetAsync(WMColorRecipe preset) => Controller.ApplyColorPresetAsync(preset.Id);
    private Task SavePresetAsync()
    {
        var name = State.ColorGradeTool.Draft.Name;
        if (string.IsNullOrWhiteSpace(name) || name is "桌面调整" or "未命名调色")
            name = $"调色预设 {DateTime.Now:MMdd HHmm}";
        return Controller.SaveColorPresetAsync(name);
    }

    private Task DeletePresetAsync() =>
        string.IsNullOrWhiteSpace(State.ColorGradeTool.SelectedPresetId)
            ? Task.CompletedTask
            : Controller.DeleteColorPresetAsync(State.ColorGradeTool.SelectedPresetId);

    private async Task ChooseReferenceAsync()
    {
        if (State.ColorGradeTool.IsBusy || string.IsNullOrWhiteSpace(State.SessionId)) return;
        var sources = await PhotoPicker.PickMultipleAsync();
        var source = sources.FirstOrDefault();
        if (source is null) return;
        try { await Controller.ImportColorReferenceAsync(source); }
        catch (Exception ex) { message = ex.Message; }
        finally
        {
            await source.DisposeAsync();
            foreach (var extra in sources.Skip(1)) await extra.DisposeAsync();
        }
    }
    private Task ClearReferenceAsync() => Controller.ClearColorReferenceAsync();

    private Task SetFrameRole(WMFrameRoleChange change)
    {
        var roles = new Dictionary<string, WMFrameRole?>(State.MultiFrameTool.Draft.Roles, StringComparer.Ordinal)
        {
            [change.MediaId] = change.Role
        };
        HapticFeedback.Perform();
        return Controller.UpdateMultiFrameDraftAsync(State.MultiFrameTool.Draft with { Roles = roles });
    }

    private Task SetStackModeAsync(WMStackMode mode)
    {
        var defaults = WMMultiFrameStackSettings.CreateDefault(mode);
        return Controller.UpdateMultiFrameDraftAsync(State.MultiFrameTool.Draft with
        {
            Mode = mode,
            NormalizeExposure = defaults.NormalizeExposure,
            RepairHotPixels = defaults.RepairHotPixels,
            AutoCrop = defaults.AutoCrop
        });
    }

    private Task SetNormalizeExposureAsync(bool value) =>
        Controller.UpdateMultiFrameDraftAsync(State.MultiFrameTool.Draft with { NormalizeExposure = value });

    private Task SetRepairHotPixelsAsync(bool value) =>
        Controller.UpdateMultiFrameDraftAsync(State.MultiFrameTool.Draft with { RepairHotPixels = value });

    private Task SetAutoCropAsync(bool value) =>
        Controller.UpdateMultiFrameDraftAsync(State.MultiFrameTool.Draft with { AutoCrop = value });

    private async Task RunStackAsync()
    {
        try { await Controller.ExecuteMultiFrameAsync(); }
        catch (Exception ex) { message = ex.Message; }
    }

    private async Task PreviewStackAsync()
    {
        try { await Controller.PreviewMultiFrameAsync(); }
        catch (Exception ex) { message = ex.Message; }
    }

    private Task RetryFailedAsync() => Controller.RetryFailedExportAsync();

    private Task SetExportFormatAsync(WMExportFormat value) =>
        Controller.UpdateExportDraftAsync(State.ExportTool.Draft with { Format = value });

    private Task SetExportMaximumLongEdgeAsync(int value) =>
        Controller.UpdateExportDraftAsync(State.ExportTool.Draft with { MaximumLongEdge = value == 0 ? null : value });

    private Task SetCustomExportMaximumLongEdgeAsync(int value) =>
        Controller.UpdateExportDraftAsync(State.ExportTool.Draft with { CustomMaximumLongEdge = value });

    private Task SetExportQualityAsync(int value) =>
        Controller.UpdateExportDraftAsync(State.ExportTool.Draft with { Quality = value });

    private Task SetExportDestinationAsync(WMExportDestinationKind value) =>
        Controller.UpdateExportDraftAsync(State.ExportTool.Draft with { Destination = value });

    private Task ExportOrCancelAsync() =>
        State.ExportTool.IsBusy ? Controller.CancelActiveJobAsync() : Controller.StartExportAsync();

    private async Task RefreshTemplatesAsync() { var items = await TemplateLibrary.GetOrRefreshAsync(); templates.Clear(); templates.AddRange(items); }
    private void OnTemplatesChanged() => _ = InvokeAsync(() => { templates.Clear(); templates.AddRange(TemplateLibrary.Templates); StateHasChanged(); });
    private void OnWorkspaceChanged(WMWorkspaceState next) => _ = InvokeAsync(() => { opened = !string.IsNullOrWhiteSpace(next.SessionId) && next.Activity != WMWorkspaceActivity.Failed; StateHasChanged(); });

    private async Task OpenDesignerAsync(string templateId)
    {
        designerTemplateId = templateId;
        showDesigner = true;
        await Task.CompletedTask;
    }

    private async Task RecoverAsync(WMWorkspaceRecoveryRequest request)
    {
        if (recovering) return;
        recovering = true;
        try
        {
            opened = await Controller.RecoverAsync(request.Action, request.AffectedIds);
            if (request.Action == WMWorkspaceRecoveryAction.DiscardSession)
                Navigation.NavigateTo(DesktopRootUrl, replace: true);
        }
        finally { recovering = false; }
    }

    private async Task CloseDesignerAsync()
    {
        showDesigner = false;
        await Controller.DiscardTransientEditsAsync();
    }
    private async Task OnTemplateSavedAsync(string id) { TemplateLibrary.Invalidate(id); await RefreshTemplatesAsync(); }
    private void OnAccountChanged() => _ = InvokeAsync(StateHasChanged);
    public async ValueTask DisposeAsync()
    {
        Controller.Changed -= OnWorkspaceChanged; TemplateLibrary.Changed -= OnTemplatesChanged; Accounts.Changed -= OnAccountChanged; if (opened) await Controller.CloseAsync(); SystemAppearance.SetWorkspaceActive(false);
    }
}
