    async Task ChangeTemplate(WMTemplateList template)
    {
        var version = ++templateApplyVersion;
        try
        {
            if (ColorEditSession.IsActive || ColorPreviewBaseSrc != null)
            {
                ColorEditSession.Seal();
                await CancelPendingOperation();
            }
            if (PendingTemplate != null)
                await CancelPendingOperation();
            showConfig = false;
            WorkspaceMode = MacWorkspaceMode.Template;
            CurrentTemplate = template;
            if (CurrentImage == null)
            {
                Common.ShowMsg(PopupService, "请先导入图片，再选择模板。", AlertTypes.Info);
                StateHasChanged();
                return;
            }

            var targetImage = CurrentImage;
            EnsureSessionSource(targetImage);
            var inputArtifact = EditingSession.GetCurrent(targetImage.ID);
            PendingTemplate = new PendingTemplateOperation(
                targetImage.ID,
                inputArtifact,
                targetImage.Path,
                targetImage.Src,
                Global.CanvasSerialize(targetImage.Canvas));
            WorkspaceCoordinator.BeginPreview("正在生成模板预览…");
            SrcLoading = true;
            StateHasChanged();
            var cvs = MacCanvasApplication.CreateForImage(template.Canvas, targetImage);
            targetImage.Canvas = cvs;
            await InitLogoCacheDic(targetImage.ID, template);
            if (version != templateApplyVersion || !ReferenceEquals(CurrentImage, targetImage))
                return;
            showConfig = true;
            WorkspaceCoordinator.PreviewReady("模板编辑器已就绪");
        }
        catch (Exception ex)
        {
            WorkspaceCoordinator.Fail(ex);
            if (PendingTemplate != null)
                await CancelPendingOperation();
            if (version == templateApplyVersion)
                Common.ShowMsg(PopupService, ex.Message, AlertTypes.Error);
        }
        finally
        {
            if (version == templateApplyVersion)
            {
                SrcLoading = false;
                StateHasChanged();
            }
        }
    }

    async Task ExportAsync(IReadOnlyList<WMTemplateList> images)
    {
        if (images.Count == 0) return;

        showExportPanel = false;
        try
        {
            WorkspaceCoordinator.BeginProcessing($"正在导出 {images.Count} 张图片…");
            var operationToken = BeginActiveOperation();
            LoadingEvt(true, $"正在导出图片，一共{images.Count}张，目前第1张", 0);
            var outputPaths = CreateUniqueExportPaths(images);
            var failures = new ConcurrentBag<(string Name, string Error)>();
            var completed = 0;
            await Parallel.ForEachAsync(
                Enumerable.Range(0, images.Count),
                new ParallelOptions
                {
                    CancellationToken = operationToken,
                    MaxDegreeOfParallelism = ProcessingOptions.MaxConcurrentImages
                },
                async (index, token) =>
                {
                    var item = images[index];
                    try
                    {
                        EnsureSessionSource(item);
                        var renderPlan = EditingSession.BuildRenderPlan(item.ID);
                        var itemProgress = new Progress<WMOperationProgress>(value =>
                        {
                            var mapped = new WMOperationProgress(
                                Volatile.Read(ref completed),
                                images.Count,
                                value.Message,
                                value.Stage,
                                item.ID,
                                value.CanCancel,
                                value.Percentage);
                            _ = ReportProgressAsync(mapped);
                        });
                        await FullResolutionRenderService.RenderAsync(new MacFullResolutionRenderRequest(
                            renderPlan,
                            outputPaths[index],
                            GetOriginalImagePath(item),
                            Global.Resolution,
                            Global.Quality,
                            Path.Combine(EditingSession.SessionDirectory, "export-render"),
                            ProcessingOptions,
                            ExportFormat), itemProgress, token);
                    }
                    catch (Exception ex) when (ex is not OperationCanceledException)
                    {
                        failures.Add((Path.GetFileName(GetOriginalImagePath(item)), ex.Message));
                    }
                    var done = Interlocked.Increment(ref completed);
                    var progress = new WMOperationProgress(done, images.Count, $"已导出 {done}/{images.Count}", WMOperationStage.Writing);
                    await ReportProgressAsync(progress);
                });

            if (failures.Count == images.Count)
                throw new InvalidOperationException($"全部图片导出失败：{failures.First().Error}");

            LoadingEvt(false, "", 100);
            CompleteActiveOperation();
            WorkspaceCoordinator.Complete(failures.IsEmpty ? "导出完成" : $"导出完成，{failures.Count} 张失败");
            await InvokeAsync(StateHasChanged);
            var completionMessage = failures.IsEmpty
                ? "导出完成，打开输出文件夹？"
                : $"已导出 {images.Count - failures.Count} 张，{failures.Count} 张失败。打开输出文件夹？";
            Common.ShowMsg(PopupService, completionMessage, "好的", async () =>
            {
                await OpenFolder();
            });
        }
        catch (OperationCanceledException)
        {
            CompleteActiveOperation();
            WorkspaceCoordinator.Reset();
            LoadingEvt(false, "", 0);
        }
        catch (Exception ex)
        {
            CompleteActiveOperation();
            WorkspaceCoordinator.Fail(ex);
            LoadingEvt(false, "", 0);
            await InvokeAsync(StateHasChanged);
            Common.ShowMsg(PopupService, $"导出失败: {ex.Message}", AlertTypes.Error);
        }
    }

    async Task ApplyColorToCurrent()
    {
        if (!CanApplyColor || CurrentImage is null)
        {
            Common.ShowMsg(PopupService, "请先导入图片并选择调色风格或进行手工调色", AlertTypes.Info);
            return;
        }

        ColorCompareBeforeSrc = GetOriginalPreviewSrc(CurrentImage);
        await ExecuteColorOperationAsync([CurrentImage]);
        ColorEditSession.Seal();
        var releasedPreviewUrls = new[] { ColorPreviewBaseSrc, ColorPreviewDisplaySrc, ColorCompareBeforeSrc }
            .Where(url => !string.IsNullOrWhiteSpace(url))
            .Distinct(StringComparer.Ordinal)
            .ToArray();
        ColorPreviewBaseSrc = null;
        ColorPreviewDisplaySrc = null;
        ColorCompareBeforeSrc = null;
        foreach (var url in releasedPreviewUrls)
            await TryRevokeUnreferencedBlobAsync(url);
        await InvokeAsync(StateHasChanged);
    }

    async Task ExecuteColorOperationAsync(IReadOnlyList<WMTemplateList> targets)
    {
        ActiveOperationCancellation?.Cancel();
        await ColorCommitGate.WaitAsync();
        try
        {
            await ExecuteColorOperationCoreAsync(targets);
        }
        finally
        {
            ColorCommitGate.Release();
        }
    }

    async Task ExecuteColorOperationCoreAsync(IReadOnlyList<WMTemplateList> targets)
    {
        try
        {
            var targetIds = targets.Select(target => target.ID).ToArray();
            if (!ColorEditSession.IsActive || !ColorEditSession.Matches(targetIds))
            {
                ColorEditSession.Seal();
                var bases = new Dictionary<string, MacColorEditBase>(StringComparer.Ordinal);
                foreach (var target in targets)
                {
                    EnsureSessionSource(target);
                    bases[target.ID] = new MacColorEditBase(
                        EditingSession.GetCurrent(target.ID),
                        target.Src ?? GetOriginalPreviewSrc(target));
                }
                ColorEditSession.Begin(bases);
            }
            var editVersion = ColorEditSession.Version;
            WorkspaceCoordinator.BeginProcessing($"正在生成 {targets.Count} 张代理预览…");
            var operationToken = BeginActiveOperation();
            await LoadingEvtAsync(true, $"正在生成 {targets.Count} 张代理预览…", 0);
            ColorPreviewCancellation?.Cancel();
            if (!string.IsNullOrWhiteSpace(ColorPreviewPath))
            {
                EditingSession.DeletePreviewFiles([ColorPreviewPath]);
                ColorPreviewPath = null;
            }
            ColorPreviewDisplaySrc = null;
            foreach (var target in targets) EnsureSessionSource(target);
            var progress = new Progress<WMOperationProgress>(value =>
            {
                _ = ReportProgressAsync(value);
            });
            var inputs = targets.Select(target => CreateColorPreviewInput(
                target, ColorEditSession.GetBaseArtifact(target.ID))).ToArray();
            var result = await ColorGradeProcessor.ExecuteAsync(new WMOperationRequest(
                inputs,
                CloneColorRecipe(CurrentColorRecipe),
                true,
                EditingSession.GetWorkingDirectory(WMImageOperationKind.ColorGrade),
                progress,
                ProcessingOptions), operationToken);
            var outputs = targets.Select((target, index) => (target.ID, Artifact: result.Outputs[index]))
                .ToDictionary(pair => pair.ID, pair => pair.Artifact);
            if (editVersion != ColorEditSession.Version)
            {
                EditingSession.DeletePreviewFiles(outputs.Values.Select(output => output.FilePath));
                return;
            }
            if (ColorEditSession.CommittedOperationId is { } previousOperationId)
                EditingSession.ReplaceLast(previousOperationId, result.Operation, outputs);
            else
                EditingSession.Commit(result.Operation, outputs);
            ColorEditSession.MarkCommitted(result.Operation.Id);
            foreach (var target in targets)
                await ApplyArtifactToMediaAsync(target, outputs[target.ID]);
            if (CurrentImage is not null)
            {
                ColorPreviewBaseSrc = ColorEditSession.GetBasePreview(CurrentImage.ID) ?? CurrentImage.Src;
                ColorCompareBeforeSrc = ColorPreviewBaseSrc;
            }
            WorkspaceMode = MacWorkspaceMode.ColorMatch;
            await PrepareGeneratedLookAsync(CurrentColorRecipe, operationToken);
            await LoadingEvtAsync(false, "调色处理完成", 100);
            WorkspaceCoordinator.Complete("调色处理完成");
            CompleteActiveOperation();
            StateHasChanged();
        }
        catch (OperationCanceledException)
        {
            CompleteActiveOperation();
            WorkspaceCoordinator.Reset();
            LoadingEvt(false, "", 0);
        }
        catch (Exception ex)
        {
            CompleteActiveOperation();
            WorkspaceCoordinator.Fail(ex);
            LoadingEvt(false, "", 0);
            Common.ShowMsg(PopupService, $"调色失败: {ex.Message}", AlertTypes.Error);
        }
    }

    void RegisterOriginalImage(WMTemplateList image, string path = null, string previewSrc = null)
    {
        if (image == null || string.IsNullOrWhiteSpace(image.ID))
        {
            return;
        }

        var originalPath = path ?? image.Path;
        if (!string.IsNullOrWhiteSpace(originalPath) && !OriginalImagePaths.ContainsKey(image.ID))
        {
            OriginalImagePaths[image.ID] = originalPath;
        }

        var originalPreview = previewSrc ?? image.Src;
        if (!string.IsNullOrWhiteSpace(originalPreview) && !OriginalImagePreviewSources.ContainsKey(image.ID))
        {
            OriginalImagePreviewSources[image.ID] = originalPreview;
        }
    }

    string GetOriginalImagePath(WMTemplateList image)
    {
        if (image != null
            && !string.IsNullOrWhiteSpace(image.ID)
            && OriginalImagePaths.TryGetValue(image.ID, out var originalPath)
            && File.Exists(originalPath))
        {
            return originalPath;
        }

        return image?.Path;
    }

    string GetOriginalPreviewSrc(WMTemplateList image)
    {
        if (image != null
            && !string.IsNullOrWhiteSpace(image.ID)
            && OriginalImagePreviewSources.TryGetValue(image.ID, out var originalSrc)
            && !string.IsNullOrWhiteSpace(originalSrc))
        {
            return originalSrc;
        }

        return image?.Src;
    }

