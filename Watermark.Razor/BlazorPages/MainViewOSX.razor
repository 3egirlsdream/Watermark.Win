    string GetInteractiveColorSourcePath(WMTemplateList image, WMImageArtifact input)
    {
        if (input?.SourceOperation == WMImageOperationKind.Source
            && MediaProxyPaths.TryGetValue(image.ID, out var proxyPath)
            && File.Exists(proxyPath))
            return proxyPath;
        return input?.FilePath ?? image.Path;
    }

    WMImageArtifact CreateColorPreviewInput(WMTemplateList image)
        => CreateColorPreviewInput(image, GetColorBaseArtifact(image));

    WMImageArtifact CreateColorPreviewInput(WMTemplateList image, WMImageArtifact input)
    {
        var previewPath = GetInteractiveColorSourcePath(image, input);
        if (string.Equals(previewPath, input.FilePath, StringComparison.Ordinal)) return input;

        using var codec = SKCodec.Create(previewPath)
            ?? throw new InvalidOperationException($"无法读取代理图片：{Path.GetFileName(previewPath)}");
        return input with
        {
            FilePath = previewPath,
            PreviewPath = previewPath,
            Width = codec.Info.Width,
            Height = codec.Info.Height
        };
    }

    WMImageArtifact GetColorBaseArtifact(WMTemplateList image) => ColorEditSession.IsActive
        && ColorEditSession.Bases.ContainsKey(image.ID)
            ? ColorEditSession.GetBaseArtifact(image.ID)
            : EditingSession.GetCurrent(image.ID);

    async Task<WMGeneratedColorLook?> PrepareGeneratedLookAsync(WMColorRecipe recipe, CancellationToken cancellationToken = default)
    {
        if (recipe.ReferenceProfile is null || !recipe.ReferenceMapping.Enabled || CurrentImage is null)
        {
            recipe.GeneratedBaseGrade = null;
            return null;
        }
        var input = EditingSession.TryGetCurrent(CurrentImage.ID, out var artifact)
            ? GetColorBaseArtifact(CurrentImage)
            : null;
        var path = GetInteractiveColorSourcePath(CurrentImage, input);
        var targetKey = input?.ContentHash ?? path;
        if (!ColorTargetProfileCache.TryGetValue(targetKey, out var target))
        {
            target = await ProcessingScheduler.RunAsync(_ =>
            {
                using var codec = SKCodec.Create(path) ?? throw new InvalidOperationException("无法读取当前图片。");
                using var decoded = SKBitmap.Decode(codec) ?? throw new InvalidOperationException("无法分析当前图片。");
                var oriented = WatermarkHelper.AutoOrient(codec, decoded);
                using var source = ReferenceEquals(oriented, decoded) ? decoded.Copy() : oriented;
                var analyzed = ColorAnalysisService.Analyze(source, targetKey, cancellationToken);
                analyzed.SourceHash = targetKey;
                return analyzed;
            }, ProcessingOptions, 128L * 1024 * 1024, cancellationToken);
            ColorTargetProfileCache[targetKey] = target;
        }
        var generated = await ProcessingScheduler.RunAsync(_ =>
            ColorLookMapper.Map(new WMColorLookMappingRequest(
                recipe.ReferenceProfile,
                target,
                recipe.ReferenceMapping,
                recipe.MappingVersion,
                33), cancellationToken),
            ProcessingOptions,
            32L * 1024 * 1024,
            cancellationToken);
        recipe.GeneratedBaseGrade = generated.AutomaticBaseGrade ?? generated.BaseGrade;
        await InvokeAsync(StateHasChanged);
        return generated;
    }

    async Task ApplyCurrentMode()
    {
        if (WorkspaceMode == MacWorkspaceMode.ColorMatch)
        {
            await ApplyColorToCurrent();
            return;
        }

        if (WorkspaceMode == MacWorkspaceMode.StarTrail) return;

        if (CurrentImage is null)
            return;

        if (PendingTemplate != null)
        {
            showExportPanel = false;
            WorkspaceCoordinator.BeginProcessing("正在同步最新预览…", WMOperationStage.Synchronizing);
            await LoadingEvtAsync(true, "正在同步最新预览…", 0);
            // Give Blazor a render opportunity before FlushAsync performs editor work.
            await Task.Yield();
            var preparedPreview = homepageEditor is null ? null : await homepageEditor.FlushAsync();
            if (homepageEditor is not null && preparedPreview is null)
            {
                WorkspaceCoordinator.Reset();
                await LoadingEvtAsync(false, "", 0);
                Common.ShowMsg(PopupService, "当前编辑尚未生成成功，请先处理画面中的错误。", AlertTypes.Warning);
                return;
            }
            await CommitTemplateOperationAsync(preparedPreview);
            return;
        }

        if (CurrentTemplate != null)
            await ChangeTemplate(CurrentTemplate);
    }

