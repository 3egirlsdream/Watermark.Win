    void ImportLocalImages()
    {
        var action = new Action(async () =>
        {
            var result = await ClientInstance.PickMultipleAsync();
            if (result.Any())
            {
                try
                {
                    var files = result.ToList();
                    ResetColorStateForNewImport();
                    Images = new List<WMTemplateList>();
                    EditingSession.Reset();
                    MediaArchive.Clear();
                    PendingTemplate = null;
                    OriginalImagePaths.Clear();
                    OriginalImagePreviewSources.Clear();
                    MediaProxyPaths.Clear();
                    StarTrailSelectionIds = [];
                    StackDialogInputs = [];
                    StackDialogSourceImages = [];
                    MultiFramePreviewSrc = null;
                    LoadingEvt(true, $"正在导入图片，一共{files.Count}, 当前第1个...", 0);
                    WorkspaceCoordinator.BeginProcessing($"正在导入 {files.Count} 张图片…");
                    var operationToken = BeginActiveOperation();
                    var previewMaxEdge = await GetRecommendedProxyEdgeAsync();
                    var importedImages = await ImageImportService.ImportAsync(
                        files,
                        new Progress<WMOperationProgress>(progress =>
                        {
                            WorkspaceCoordinator.Report(progress);
                            LoadingEvt(true, progress.Message, (int)progress.Percentage);
                        }),
                        operationToken,
                        previewMaxEdge);
                    foreach (var imported in importedImages)
                    {
                        WMCanvas canvas = new WMCanvas { ID = imported.Id, Path = imported.SourcePath };
                        canvas.Exif[canvas.ID] = new Dictionary<string, string>(imported.Exif);
                        var b64 = await Global.GetBase64(imported.ThumbnailPath);
                        var src = await Global.Byte2Url(JSRuntime, b64);
                        var image = new WMTemplateList
                        {
                            Canvas = canvas,
                            Src = src,
                            ID = canvas.ID,
                            Path = imported.SourcePath,
                            IsChecked = true
                        };
                        Images.Add(image);
                        MediaProxyPaths[image.ID] = imported.ThumbnailPath;
                        var sourceArtifact = EditingSession.RegisterSource(
                            image.ID,
                            imported.SourcePath,
                            FlattenExif(canvas),
                            imported.ThumbnailPath);
                        if (imported.ColorProfile is not null)
                        {
                            imported.ColorProfile.SourceHash = sourceArtifact.ContentHash ?? sourceArtifact.Id;
                            ColorTargetProfileCache[imported.ColorProfile.SourceHash] = imported.ColorProfile;
                        }
                        RegisterOriginalImage(image, imported.SourcePath, src);
                        if (!StarTrailSelectionIds.Contains(canvas.ID))
                        {
                            StarTrailSelectionIds.Add(canvas.ID);
                        }
                    }

                    // Import can be started while the multi-frame workspace is already open.
                    // Synchronize its artifact inputs immediately instead of waiting for a
                    // mode switch or a selection toggle to call RefreshMultiFrameInputs().
                    RefreshMultiFrameInputs();
                    CurrentImage = Images.FirstOrDefault();
                    if (CurrentImage?.Canvas is not null)
                        CurrentImage.Canvas.Path = EditingSession.TryGetCurrent(CurrentImage.ID, out var currentArtifact)
                            ? currentArtifact.FilePath
                            : CurrentImage.Path;
                    showConfig = false;
                    LoadingEvt(false, $"导入完成", 100);
                    WorkspaceCoordinator.Complete($"已导入 {files.Count} 张图片");
                    CompleteActiveOperation();
                    await InvokeAsync(StateHasChanged);
                }
                catch (OperationCanceledException)
                {
                    CompleteActiveOperation();
                    WorkspaceCoordinator.Reset();
                    LoadingEvt(false, "", 0);
                }
                catch (Exception e)
                {
                    CompleteActiveOperation();
                    WorkspaceCoordinator.Fail(e);
                    LoadingEvt(false, "", 0);
                    Common.ShowMsg(PopupService, $"导入失败: {e.Message}", AlertTypes.Error);
                }
            }
        });
        OpenWinHelper.Open(action);
    }

    async Task<int> GetRecommendedProxyEdgeAsync()
    {
        try
        {
            await using var module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./_content/Watermark.Razor/js/mac-color-preview.js");
            return Math.Clamp(await module.InvokeAsync<int>("getRecommendedProxyEdge"), 1600, 2560);
