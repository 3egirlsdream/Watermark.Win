    public async Task Help()
    {
        WMMainLoading.Show = true;
        StateHasChanged();
        int idx = 1;
        foreach (var img in Images)
        {
            WMMainLoading.Message = $"正在应用模板，一共{Images.Count}张，目前第{idx}张";
            WMMainLoading.Value = idx++ * 100.0 / Images.Count;
            StateHasChanged();
