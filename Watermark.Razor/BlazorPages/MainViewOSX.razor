    async Task EditHistoryOperation(MacSessionHistoryEntry entry)
    {
        if (!entry.IsApplied || entry.Operation.Kind != WMImageOperationKind.Template) return;
        if (PendingTemplate != null || ColorPreviewBaseSrc != null) await CancelPendingOperation();
        while (EditingSession.History.LastOrDefault(item => item.IsApplied) is { } latest
               && latest.Operation.Id != entry.Operation.Id)
        {
            await ApplySessionChangeAsync(EditingSession.Undo());
        }
        await ApplySessionChangeAsync(EditingSession.Undo());
        var templateArtifact = entry.After.Values.FirstOrDefault();
        var mediaId = entry.After.Keys.FirstOrDefault();
        if (templateArtifact?.CanvasSnapshotJson == null || mediaId == null) return;
        var image = Images.FirstOrDefault(item => item.ID == mediaId);
        if (image == null) return;
        CurrentImage = image;
        WorkspaceMode = MacWorkspaceMode.Template;
        var canvas = Global.ReadConfig(templateArtifact.CanvasSnapshotJson);
        await ChangeTemplate(new WMTemplateList { ID = canvas.ID, Canvas = canvas });
    }

    async Task ApplySessionChangeAsync(MacSessionChange change)
    {
        if (change.Operation == null) return;
        foreach (var mediaId in change.RemovedMediaIds)
        {
            var image = Images.FirstOrDefault(item => item.ID == mediaId);
            if (image != null)
            {
                MediaArchive[mediaId] = image;
                Images.Remove(image);
            }
        }
        foreach (var mediaId in change.AddedMediaIds)
        {
            if (!Images.Any(item => item.ID == mediaId) && MediaArchive.TryGetValue(mediaId, out var image))
                Images.Add(image);
        }
        foreach (var pair in change.CurrentArtifacts)
        {
            var image = Images.FirstOrDefault(item => item.ID == pair.Key);
            if (image != null) await ApplyArtifactToMediaAsync(image, pair.Value);
        }
        if (CurrentImage == null || !Images.Contains(CurrentImage)) CurrentImage = Images.LastOrDefault();
        StarTrailSelectionIds = StarTrailSelectionIds.Where(id => Images.Any(image => image.ID == id)).ToList();
        ColorCompareBeforeSrc = null;
        showConfig = false;
        await InvokeAsync(StateHasChanged);
    }

    Task QueueColorRecipePreview(WMColorRecipe recipe)
