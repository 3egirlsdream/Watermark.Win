@page "/mac"
@implements IDisposable
@using System.IO
@using System.Diagnostics
@using System.Collections.Concurrent
@using Masa.Blazor
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using System.ComponentModel
@using System.Text.Json
@using SkiaSharp
@using Watermark.Razor
@using Watermark.Razor.Components
@using Watermark.Razor.Components.Mac
@using Watermark.Razor.Components.Mac.Editing
@using Watermark.Razor.Components.Dashboard
@using Watermark.Razor.Parts
@using Watermark.Shared.Models
@using Watermark.Razor.BlazorPages
@using Watermark.Shared.Enums
@*@inject IMainInterop MainInterop*@
@inject IPopupService PopupService
@inject IJSRuntime JSRuntime
@inject IWMWatermarkHelper helper
@inject APIHelper api
@inject IClientInstance ClientInstance
@inject MacTemplateLibraryService TemplateLibrary
@inject MacEditingSession EditingSession
@inject MacWorkspaceCoordinator WorkspaceCoordinator
@inject MacImageImportService ImageImportService
@inject MacFullResolutionRenderService FullResolutionRenderService
@inject WMTemplateOperationProcessor TemplateProcessor
@inject WMColorGradeOperationProcessor ColorGradeProcessor
@inject IWMColorLookMapper ColorLookMapper
@inject IWMColorAnalysisService ColorAnalysisService
@inject IWMProcessingScheduler ProcessingScheduler
@inject NavigationManager NavController
<MacWorkspaceShell>
    <ToolbarContent>
        <MacAppToolbar Title="@ClientInstance.AppTitle"
                       CurrentUser="@Global.CurrentUser"
                       Mode="@WorkspaceMode"
                       CanApplyCurrent="@CanApplyCurrent"
                       CanSavePreset="@(CurrentColorRecipe != null)"
                       CanUndo="@EditingSession.CanUndo"
                       CanRedo="@EditingSession.CanRedo"
                       HasPendingOperation="@(PendingTemplate != null)"
                       ApplyToSelected="@ApplyToSelected"
                       ApplyToSelectedChanged="value => ApplyToSelected = value"
                       History="@EditingSession.History"
                       EditHistory="EditHistoryOperation"
                       ImportLocalImages="ImportLocalImages"
                       CreateTemplate="@(() => openCreateNew = true)"
                       OpenMyTemplate="@(() => openMyTemplate = true)"
                       OpenMarket="@(() => openMarket = true)"
                       ToggleExport="ToggleExportPanel"
                       ApplyCurrent="ApplyCurrentMode"
                       SavePreset="SaveCurrentColorPreset"
                       Undo="UndoOperation"
                       Redo="RedoOperation"
                       CancelPending="CancelPendingOperation"
                       OpenLogoStore="@(() => showLogoStore = true)"
                       OpenSettings="@(() => showSetting = true)"
                       OpenDashboard="@(() => showDashboard = true)"
                       Login="@(() => showLogin = true)"
                       SignUp="@(() => showSignUp = true)"
                       Logout="LogoutCurrentUser"
                       LogoutAccount="@(() => showLogout = true)"
                       OpenVip="OpenVipDialog"
                       OpenLink="OpenLink"
                       OpenCommonDialog="OpenCommonDialog" />
    </ToolbarContent>
    <WorkspaceContent>
        <div class="main-workspace">
            <MacFeatureRail Mode="@WorkspaceMode" ModeChanged="SetWorkspaceMode" />
            <MacModeSidebar Mode="@WorkspaceMode"
                            Templates="@wMTemplates"
                            Images="@Images"
                            CurrentTemplate="@CurrentTemplate"
                            TemplateSearch="@TemplateSearch"
                            ColorPresets="@ColorRecipes"
                            CurrentColorPreset="@CurrentColorRecipe"
                            ColorReferenceSrc="@ColorReferenceSrc"
                            ColorReferenceName="@ColorReferenceName"
                            StarTrailSelectionIds="@StarTrailSelectionIds"
                            TemplateSearchChanged="value => TemplateSearch = value"
                            ChangeTemplate="ChangeTemplate"
                            SelectSplitImages="SelectSplitImages"
                            EditTemplate="EditTemplate"
                            CreateTemplate="@(() => openCreateNew = true)"
                            OpenMyTemplate="@(() => openMyTemplate = true)"
                            OpenMarket="@(() => openMarket = true)"
                            ChooseColorReference="ChooseColorReference"
                            ApplyColorReference="ApplyCurrentColorStyleFromSidebar"
                            CreateBlankColor="CreateBlankColorRecipe"
                            SaveColorPreset="SaveCurrentColorPreset"
                            SelectColorPreset="SelectColorRecipe"
                            ToggleStarTrailImage="ToggleStarTrailImage" />
            @if (IsHomepageTemplateEditing && CurrentImage is not null)
            {
                <MacAppliedTemplateEditor @ref="homepageEditor"
                                          CurrentImage="@CurrentImage"
                                          Embedded="true"
                                          Images="@Images"
                                          StarTrailSelectionIds="@StarTrailSelectionIds"
                                          ClickImage="ClickImage"
                                          ExportSelectionChanged="HandleExportSelectionChanged"
                                          Changed="HandleHomepageImageChanged"
                                          ApplyToSelected="@ApplyToSelected"
                                          SelectedMediaCount="@Images.Count(image => image.IsChecked)"
                                          ApplyToSelectedChanged="value => ApplyToSelected = value"
                                          ApplyPending="ApplyCurrentMode"
                                          CancelPending="CancelPendingOperation"
                                          ShowInspectorContent="@showExportPanel">
                    <InspectorContent>
                        <MacModeInspector Mode="@WorkspaceMode"
                                          Visible="true"
                                          ExportOpen="true"
                                          HasPendingOperation="@(PendingTemplate != null)"
                                          SelectedMediaCount="@Images.Count(image => image.IsChecked)"
                                          AllExportSelected="@AllExportSelected"
                                          Resolution="@Global.Resolution"
                                          Quality="@Global.Quality"
                                          ExportFormat="@ExportFormat"
                                          OutputPath="@Global.OutPutPath"
                                          ToggleExport="ToggleExportPanel"
                                          ChooseOutputFolder="ChooseOutputFolder"
                                          ExportSelected="ExportSelectedFromPanel"
                                          ApplyPendingBeforeExport="ApplyPendingThenExport"
                                          ExportCommittedVersion="ExportCommittedFromPanel"
                                          AllExportSelectedChanged="SetExportSelectionAll"
                                          ResolutionChanged="SetResolution"
                                          QualityChanged="SetQuality"
                                          ExportFormatChanged="SetExportFormat" />
                    </InspectorContent>
                </MacAppliedTemplateEditor>
            }
            else
            {
                <div class="@WorkspaceMainClass"
                     style="@WorkspaceMainStyle"
                     @onpointermove="ResizeMediaStrip"
                     @onpointermove:preventDefault="IsMediaStripDragging"
                     @onpointerup="EndMediaStripResize"
                     @onpointerleave="EndMediaStripResize"
                     @onpointercancel="EndMediaStripResize">
                    <section class="workspace-preview-pane">
                        <MacPreviewWorkspace CurrentImage="@CurrentImage"
                                             SrcLoading="@SrcLoading"
                                             PreviewMode="@PreviewMode"
                                             PreviewSrc="@ActiveWorkspacePreviewSrc"
                                             CompareBeforeSrc="@ActiveCompareBeforeSrc"
                                             ModeLabel="@PreviewModeLabel"
                                             UseColorPreview="@UseGpuColorPreview"
                                             ColorPreviewLook="@CurrentColorPreviewLook"
                                             ColorAdjustments="@CurrentColorPreviewParameters"
                                             ColorPreviewCapabilityChanged="HandleColorPreviewCapabilityChanged"
                                             ShowExif="@(() => showExif = true)"
                                             SelectSourceImageExif="SelectSourceImageExif" />
                    </section>
                    <div class="workspace-splitter-grip"
                         title="拖拽调整素材栏高度"
                         @onpointerdown="StartMediaStripResize"
                         @onpointerdown:preventDefault="true"
                         @onpointerdown:stopPropagation="true">
                        <span></span>
                    </div>
                    <section class="workspace-media-pane">
                        <MacMediaStrip Images="@Images"
                                       CurrentImage="@CurrentImage"
                                       StarTrailSelectionIds="@StarTrailSelectionIds"
                                       ClickImage="ClickImage"
                                       ExportSelectionChanged="HandleExportSelectionChanged" />
                    </section>
                </div>
                <MacModeInspector Mode="@WorkspaceMode"
                                  Visible="@showConfig"
                                  ExportOpen="@showExportPanel"
                                  HasPendingOperation="@(PendingTemplate != null || ColorPreviewBaseSrc != null)"
                                  Canvas="@CurrentImage?.Canvas"
                                  CurrentColorPreset="@CurrentColorPreset"
                                  CurrentColorRecipe="@CurrentColorRecipe"
                                  ColorPresetCount="@ColorRecipes.Count"
                                  CanApplyColor="@CanApplyColor"
                                  ApplyColor="ApplyColorToCurrent"
                                  SelectedMediaCount="@Images.Count(image => image.IsChecked)"
                                  StarTrailSelectedCount="@StarTrailSelectionIds.Count"
                                  AllExportSelected="@AllExportSelected"
                                  Resolution="@Global.Resolution"
                                  Quality="@Global.Quality"
                                  ExportFormat="@ExportFormat"
                                  OutputPath="@Global.OutPutPath"
                                  PropertyChanged="PropertyChanged"
                                  SelectContainer="SelectContainerImage"
                                  ToggleExport="ToggleExportPanel"
                                  ColorRecipeChanged="QueueColorRecipePreview"
                                  ColorGradeChanged="QueueColorGradePreview"
                                  ColorCurvesChanged="QueueColorCurvesPreview"
                                  SaveColorPreset="SaveCurrentColorPreset"
                                  RematchColorReference="RematchCurrentColorReference"
                                  ClearColorReference="ClearColorReference"
                                  ResetColorAdjustments="ResetColorAdjustments"
                                  MultiFrameInputs="@StackDialogInputs"
                                  MultiFrameWorkingDirectory="@EditingSession.GetWorkingDirectory(WMImageOperationKind.MultiFrameStack)"
                                  MultiFramePreviewChanged="HandleMultiFramePreviewChanged"
                                  MultiFrameApplied="HandleMultiFrameCompleted"
                                  ChooseOutputFolder="ChooseOutputFolder"
                                  ExportSelected="ExportSelectedFromPanel"
                                  ApplyPendingBeforeExport="ApplyPendingThenExport"
                                  ExportCommittedVersion="ExportCommittedFromPanel"
                                  AllExportSelectedChanged="SetExportSelectionAll"
                                  ResolutionChanged="SetResolution"
                                  QualityChanged="SetQuality"
                                  ExportFormatChanged="SetExportFormat" />
            }
        </div>
    </WorkspaceContent>
    <DialogContent>
        @if (WMMainLoading.Show)
        {
            <section class="mac-task-panel" role="status" aria-live="polite" aria-label="图片处理进度">
                <div class="task-panel-heading">
                    <div>
                        <small>@GetOperationStageLabel(WorkspaceCoordinator.State.Stage)</small>
                        <strong>@WMMainLoading.Message</strong>
                    </div>
                    @if (WorkspaceCoordinator.State.CanCancel)
                    {
                        <MButton Text Small Class="task-cancel-button" OnClick="CancelActiveOperation">取消任务</MButton>
                    }
                </div>
                <MProgressLinear Value="@WMMainLoading.Value"
                                 Indeterminate="@WorkspaceCoordinator.State.IsIndeterminate"
                                 Rounded Height="6" Color="primary" />
                <span class="task-progress-label">@Math.Round(WMMainLoading.Value)%</span>
            </section>
        }
        @if (openMyTemplate)
        {
            <Watermark.Razor.Components.MyTemplates @bind-Visible="openMyTemplate" EditTemplateEvt="OpenDesignAction" OnCloseEvt="InitTemplates" />
        }

        <MDialog @bind-Value="openMarket" ContentStyle="height: 90%;overflow:hidden;scrollbar-width: none;">
            @if (openMarket)
            {
                <TemplatesMarket ClipboardAction="ClipboardAction()" OnCloseEvt="InitTemplates" />
            }
        </MDialog>

        <MDialog @bind-Value="@CommonDialog.Show" Width="300">
            <MImage Height="300" Width="300" Contain Src="@CommonDialog.Message" />
        </MDialog>
        <MDialog ContentStyle="width:350px;padding:10px;" @bind-Value="showLogin">
            @if (showLogin)
            {
                <LoginContent CloseEvent="() => showLogin = false" />
            }
        </MDialog>
        <MDialog ContentStyle="width:350px;padding:10px;" @bind-Value="showSignUp">
            @if (showSignUp)
            {
                <SignUpContent CloseEvent="() => showSignUp = false" />
            }
        </MDialog>
        <MDialog ContentStyle="width:350px;padding:10px;" @bind-Value="showLogout">
            @if (showLogout)
            {
                <LogoutContent CloseEvent="() => showLogout = false" />
            }
        </MDialog>
        <MDialog @bind-Value="showVipPurchase" Width="720" ContentStyle="padding:0;background:transparent;box-shadow:none;">
            @if (showVipPurchase)
            {
                <MacVipPurchaseDialog OnClose="() => showVipPurchase = false" OnPaid="OnVipPaid" />
            }
        </MDialog>

        <MDialog @bind-Value="openCreateNew" Width="380" ContentStyle="padding:0;">
            @if (openCreateNew)
            {
                <NewTemplateDialog ID="@(Guid.NewGuid().ToString("N").ToUpper())" Ok="OpenDesignAction" SelectDefaultImageAction="ClientInstance.PickAsync" OnClose="() => openCreateNew = false" />
            }
        </MDialog>

        <MDialog @bind-Value="showLogoStore" ContentStyle="height: 90%;overflow:hidden;scrollbar-width: none;border: 15px solid #fff;">
            @if (showLogoStore)
            {
                <LogoDialogContent />
            }
        </MDialog>
        @if (CurrentImage != null && CurrentImage.Canvas != null && CurrentImage.Canvas.Exif != null)
        {
            //<ExifInfo @bind-Value="showExif" Exifs="ExifHelper.ReadAllExif(CurrentImage.Canvas.Exif.FirstOrDefault().Value)" />
        }

        <MDialog @bind-Value="showSetting" ContentStyle="height:550px;width:800px">
            @if (showSetting)
            {
                <Setting />
            }
        </MDialog>
        <MDialog Persistent @bind-Value="showDashboard" Fullscreen="true" ContentStyle="padding:0;overflow:hidden;">
            @if (showDashboard)
            {
                <AdminDashboard ShowClose="true" Close="() => showDashboard = false" />
            }
        </MDialog>
        <MDialog Persistent @bind-Value="showDesign" Fullscreen="true" ContentStyle="padding:0;overflow:hidden;">
            @if (showDesign)
            {
                <MacTemplateDesigner CanvasId="@watermarkId"
                                     OnSaved="HandleTemplateSaved"
                                     OnClose="() => showDesign = false" />
            }
        </MDialog>
    </DialogContent>
</MacWorkspaceShell>


@code {
    bool openCreateNew = false;
    WMainLoading CommonDialog = new();
    bool showLogoStore = false;
    bool showExportPanel = false;
    WMExportFormat ExportFormat = WMExportFormat.Jpeg8;
    bool openMarket = false;
    bool openMyTemplate = false;
    bool SrcLoading = false;
    bool showLogin = false;
    bool showSignUp = false;
    bool showLogout = false;
    bool showVipPurchase = false;
    bool showConfig = false;
    bool showExif = false;
    bool showSetting = false;
    bool showDashboard = false;
    bool showDesign = false;
    IReadOnlyList<WMImageArtifact> StackDialogInputs = [];
    List<WMTemplateList> StackDialogSourceImages = [];
    MacWorkspaceMode WorkspaceMode
    {
        get => WorkspaceCoordinator.State.Mode;
        set => WorkspaceCoordinator.SetMode(value);
    }
    string TemplateSearch = string.Empty;
    string watermarkId = null;
    long templateApplyVersion;
    List<WMTemplateList> wMTemplates = [];
    WMTemplateList CurrentTemplate;
    WMTemplateList CurrentImage;
    MacAppliedTemplateEditor homepageEditor;
    List<WMColorPreset> ColorPresets = [];
    List<WMColorRecipe> ColorRecipes = [];
    WMColorPreset CurrentColorPreset;
    WMColorRecipe CurrentColorRecipe = new();
    string ColorReferenceSrc = null;
    string ColorReferenceName = null;
    string ColorReferencePath = null;
    string ColorCompareBeforeSrc = null;
    Dictionary<string, string> OriginalImagePaths = new();
    Dictionary<string, string> OriginalImagePreviewSources = new();
    Dictionary<string, string> MediaProxyPaths = new(StringComparer.Ordinal);
    List<string> StarTrailSelectionIds = [];
    Dictionary<string, Dictionary<string, string>> LogoCacheDic = new();
    ConcurrentDictionary<string, string> LogoBase64 = new ConcurrentDictionary<string, string>();
    ConcurrentDictionary<string, WMColorReferenceProfile> ColorTargetProfileCache = new(StringComparer.Ordinal);
    List<string> LogoStore = new List<string>();
    List<WMTemplateList> Images = new List<WMTemplateList>();
    Dictionary<string, WMTemplateList> MediaArchive = new();
    PendingTemplateOperation PendingTemplate;
    CancellationTokenSource ColorPreviewCancellation;
    readonly MacColorEditSession ColorEditSession = new();
    readonly SemaphoreSlim ColorCommitGate = new(1, 1);
    CancellationTokenSource ActiveOperationCancellation;
    Task InitializationTask = Task.CompletedTask;
    long ColorPreviewVersion;
    bool ColorPreviewHintChecked;
    MacColorPreviewLook CurrentColorPreviewLook = MacColorPreviewLook.Identity;
    MacColorPreviewCapability ColorPreviewCapability;
    WMGeneratedColorLook CurrentGeneratedColorLook;
    string CurrentColorMappingSignature;
    string ColorPreviewPath;
    string ColorPreviewBaseSrc;
    string ColorPreviewDisplaySrc;
    string MultiFramePreviewSrc;
    bool ApplyToSelected;
    Debouncer debouncedAction = null;
    const int MediaStripMinHeight = 96;
    const int MediaStripMaxHeight = 220;
    int MediaStripHeight = 126;
    bool IsMediaStripDragging = false;
    double MediaStripDragStartY = 0;
    int MediaStripDragStartHeight = 126;
    MacPreviewMode PreviewMode => (WorkspaceMode == MacWorkspaceMode.ColorMatch && !string.IsNullOrEmpty(ColorCompareBeforeSrc))
        || (WorkspaceMode == MacWorkspaceMode.StarTrail && !string.IsNullOrEmpty(MultiFramePreviewSrc))
        ? MacPreviewMode.Compare
        : MacPreviewMode.Single;
    string ActiveWorkspacePreviewSrc => WorkspaceMode switch
    {
        MacWorkspaceMode.StarTrail => MultiFramePreviewSrc,
        MacWorkspaceMode.ColorMatch when UseGpuColorPreview => ColorPreviewBaseSrc,
        MacWorkspaceMode.ColorMatch => ColorPreviewDisplaySrc,
        _ => null
    };
    string ActiveCompareBeforeSrc => WorkspaceMode switch
    {
        MacWorkspaceMode.StarTrail when !string.IsNullOrEmpty(MultiFramePreviewSrc) => CurrentImage?.Src,
        MacWorkspaceMode.ColorMatch => ColorCompareBeforeSrc,
        _ => null
    };
    string WorkspaceMainClass => IsMediaStripDragging ? "workspace-main-column resizing" : "workspace-main-column";
    string WorkspaceMainStyle => $"grid-template-rows:minmax(0,1fr) 7px {MediaStripHeight}px;";
    string PreviewModeLabel => WorkspaceMode switch
    {
        MacWorkspaceMode.ColorMatch => "调色预览",
        MacWorkspaceMode.StarTrail => "星轨预览",
        _ => "模板预览"
    };
    bool CanApplyColor => CurrentImage != null && !string.IsNullOrWhiteSpace(CurrentImage.Path)
        && ((CurrentColorRecipe.ReferenceMapping.Enabled && CurrentColorRecipe.ReferenceProfile != null)
            || HasManualColorAdjustments(CurrentColorRecipe.Grade));
    bool UseGpuColorPreview => WorkspaceMode == MacWorkspaceMode.ColorMatch
        && ColorPreviewBaseSrc != null
        && ColorPreviewCapability?.Supported != false;
    bool CanEditCurrent => WorkspaceMode == MacWorkspaceMode.Template
        && PendingTemplate != null
        && CurrentImage?.Canvas?.Children.Any() == true;
    bool IsHomepageTemplateEditing => showConfig && CanEditCurrent;
    bool CanApplyCurrent => WorkspaceMode switch
    {
        MacWorkspaceMode.ColorMatch => CanApplyColor,
        MacWorkspaceMode.StarTrail => false,
        _ => PendingTemplate != null
    };
    bool AllExportSelected => Images.Count > 0 && Images.All(x => x.IsChecked);
    WMOperationExecutionOptions ProcessingOptions => WMOperationExecutionOptions.Balanced(GlobalConfig.MAX_THREAD) with
    {
        PreviewMaxEdge = 2048,
        MaxConcurrentImages = 2
    };
    WMOperationExecutionOptions InteractivePreviewOptions => ProcessingOptions;
    MacColorPreviewParameters CurrentColorPreviewParameters = MacColorPreviewParameters.From(new WMColorGradeSettings());

    void StartMediaStripResize(PointerEventArgs args)
    {
        IsMediaStripDragging = true;
        MediaStripDragStartY = args.ClientY;
        MediaStripDragStartHeight = MediaStripHeight;
    }

    void ResizeMediaStrip(PointerEventArgs args)
    {
        if (!IsMediaStripDragging)
        {
            return;
        }

        var delta = args.ClientY - MediaStripDragStartY;
        MediaStripHeight = Math.Clamp((int)Math.Round(MediaStripDragStartHeight - delta), MediaStripMinHeight, MediaStripMaxHeight);
    }

    void EndMediaStripResize(PointerEventArgs args)
    {
        IsMediaStripDragging = false;
    }

    protected override Task OnInitializedAsync()
    {
        TemplateLibrary.Changed += OnTemplateLibraryChanged;
        WorkspaceCoordinator.Changed += OnWorkspaceStateChanged;
        LoadColorPresets();
        Global.OutPutPath = Global.AppPath.OutputFolder;
        Global.PrimaryKey = ClientInstance.Key();
        InitializationTask = InitializeWorkspaceAsync();
        return Task.CompletedTask;
    }

    async Task InitializeWorkspaceAsync()
    {
        try
        {
            await GlobalConfig.InitConfig();
            await Task.WhenAll(
                RefreshTemplatesIncremental(),
                InitializeAccountAssetsAsync());
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            await InvokeAsync(() => Common.ShowMsg(PopupService, ex.Message, AlertTypes.Error));
        }
    }

    async Task InitializeAccountAssetsAsync()
    {
        await Global.Login();
        await api.DownloadLogoes();
        await InitLogoStore();
    }

    private async void OnTemplateLibraryChanged()
    {
        await InvokeAsync(() =>
        {
            var currentTemplateId = CurrentTemplate?.Canvas?.ID;
            wMTemplates = TemplateLibrary.Templates.ToList();
            if (!string.IsNullOrWhiteSpace(currentTemplateId))
                CurrentTemplate = wMTemplates.FirstOrDefault(x => x.Canvas?.ID == currentTemplateId) ?? CurrentTemplate;
            StateHasChanged();
        });
    }

    private void OnWorkspaceStateChanged(MacWorkspaceState state)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    void LogoutCurrentUser()
    {
        Global.CurrentUser = new WMLoginChildModel();
        StateHasChanged();
    }

    void OpenVipDialog()
    {
        if (Global.CurrentUser == null || string.IsNullOrWhiteSpace(Global.CurrentUser.ID))
        {
            showLogin = true;
            return;
        }

        showVipPurchase = true;
    }

    Task OnVipPaid()
    {
        showVipPurchase = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    async Task SetWorkspaceMode(MacWorkspaceMode mode)
    {
        if (WorkspaceMode == MacWorkspaceMode.ColorMatch && mode != WorkspaceMode)
        {
            ColorEditSession.Seal();
            ColorPreviewBaseSrc = null;
            ColorPreviewDisplaySrc = null;
            ColorCompareBeforeSrc = null;
        }
        if ((PendingTemplate != null || ColorPreviewBaseSrc != null) && mode != WorkspaceMode)
        {
            await CancelPendingOperation();
        }
        WorkspaceMode = mode;
        if (mode != MacWorkspaceMode.StarTrail) MultiFramePreviewSrc = null;
        showExportPanel = false;
        if (mode == MacWorkspaceMode.ColorMatch)
        {
            LoadColorPresets();
        }
        if (mode == MacWorkspaceMode.StarTrail && !StarTrailSelectionIds.Any() && Images.Any())
        {
            StarTrailSelectionIds = Images.Select(x => x.ID).ToList();
        }
        if (mode == MacWorkspaceMode.StarTrail) RefreshMultiFrameInputs();
        StateHasChanged();
    }

    Task HandleHomepageImageChanged(WMTemplateList image)
    {
        if (!ReferenceEquals(CurrentImage, image))
            return Task.CompletedTask;

        showConfig = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    void ToggleExportPanel()
    {
        showExportPanel = !showExportPanel;
    }

    void LoadColorPresets()
    {
        try
        {
            ColorPresets = PresetManager.LoadAll();
            ColorRecipes = PresetManager.LoadAllRecipes();
            if (PresetManager.LastLoadErrors.Count > 0)
                Common.ShowMsg(PopupService,
                    $"已跳过 {PresetManager.LastLoadErrors.Count} 个损坏的调色风格：{PresetManager.LastLoadErrors[0]}",
                    AlertTypes.Warning);
            CurrentColorPreset ??= ColorPresets.FirstOrDefault();
        }
        catch (Exception ex)
        {
            Common.ShowMsg(PopupService, $"加载调色风格失败: {ex.Message}", AlertTypes.Error);
        }
    }

    async Task ChooseColorReference()
    {
        var path = await ClientInstance.PickAsync();
        if (string.IsNullOrWhiteSpace(path))
        {
            return;
        }

        try
        {
            WorkspaceCoordinator.BeginProcessing("正在分析参考图…", WMOperationStage.Decoding);
            await LoadingEvtAsync(true, "正在分析参考图…", 10);
            var profile = await ProcessingScheduler.RunAsync(
                _ => ColorAnalysisService.Analyze(path),
                ProcessingOptions,
                96L * 1024 * 1024);
            CurrentColorRecipe = new WMColorRecipe
            {
                Name = Path.GetFileNameWithoutExtension(path),
                ReferenceProfile = profile,
                ReferenceMapping = new WMColorReferenceMappingSettings
                {
                    IsConfigured = true,
                    Enabled = true,
                    Strength = 55f,
                    MatchMode = WMColorMappingMode.Natural
                },
                Grade = new WMColorGradeSettings()
            };
            CurrentColorPreset = profile.ToLegacyPreset(new WMColorMatchSettings { Enabled = true, Strength = 55f });
            ColorReferencePath = path;
            ColorReferenceName = Path.GetFileName(path);
            ColorReferenceSrc = await Global.Byte2Url(JSRuntime, await Global.GetBase64(path));
            WorkspaceMode = MacWorkspaceMode.ColorMatch;
            await PreviewColorRecipe(CurrentColorRecipe);
            await LoadingEvtAsync(false, "参考风格已生成", 100);
            WorkspaceCoordinator.PreviewReady("参考风格已生成");
        }
        catch (Exception ex)
        {
            LoadingEvt(false, "", 0);
            WorkspaceCoordinator.Fail(ex);
            Common.ShowMsg(PopupService, $"生成参考风格失败: {ex.Message}", AlertTypes.Error);
        }
    }

    async Task SelectColorRecipe(WMColorRecipe recipe)
    {
        CurrentColorRecipe = CloneColorRecipe(recipe);
        CurrentColorRecipe.UpgradeToCurrentSchema();
        CurrentColorPreset = recipe.ReferenceProfile?.ToLegacyPreset(new WMColorMatchSettings
        {
            Enabled = recipe.ReferenceMapping.Enabled,
            Strength = recipe.ReferenceMapping.Strength,
            PreserveLuminance = recipe.ReferenceMapping.PreserveLuminance,
            Mode = recipe.ReferenceMapping.Mode
        });
        if (CurrentColorPreset != null)
        {
            CurrentColorPreset.Id = recipe.Id;
            CurrentColorPreset.Name = recipe.Name;
        }
        var thumbnailPath = PresetManager.GetReferenceThumbnailPath(recipe);
        ColorReferencePath = thumbnailPath;
        ColorReferenceName = recipe.ReferenceProfile?.SourceName;
        ColorReferenceSrc = thumbnailPath is null
            ? null
            : await Global.Byte2Url(JSRuntime, await Global.GetBase64(thumbnailPath));
        WorkspaceMode = MacWorkspaceMode.ColorMatch;
        await PreviewColorRecipe(CurrentColorRecipe);
    }

    async Task ApplyCurrentColorStyleFromSidebar()
    {
        if (CanApplyColor)
            await PreviewColorRecipe(CurrentColorRecipe);
    }

    async Task SaveCurrentColorPreset()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(CurrentColorRecipe.Name) || CurrentColorRecipe.Name == "未命名调色")
                CurrentColorRecipe.Name = $"调色预设 {DateTime.Now:MMdd HHmm}";
            await PresetManager.SaveRecipeAsync(CurrentColorRecipe, ColorReferencePath);
            LoadColorPresets();
            Common.ShowMsg(PopupService, "调色风格已保存", AlertTypes.Info);
        }
        catch (Exception ex)
        {
            Common.ShowMsg(PopupService, $"保存调色风格失败: {ex.Message}", AlertTypes.Error);
        }
    }

