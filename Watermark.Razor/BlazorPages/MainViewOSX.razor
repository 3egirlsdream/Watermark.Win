    Task QueueColorGradePreview(WMColorRecipe recipe)
    {
        _ = ShowColorPreviewHintOnceAsync();
        CurrentColorRecipe = recipe;
        CurrentColorPreviewParameters = MacColorPreviewParameters.FromGradeAndHsl(
            recipe.Grade, CurrentColorPreviewParameters);
        if (CurrentImage == null) return Task.CompletedTask;

        EnsureSessionSource(CurrentImage);
        ColorPreviewBaseSrc = ColorEditSession.GetBasePreview(CurrentImage.ID) ?? CurrentImage.Src;
        ColorCompareBeforeSrc = ColorPreviewBaseSrc;

        // Unsupported GPUs keep the existing idle CPU fallback. Supported GPUs only
        // receive the latest uniforms and do not enter the coordinator/task pipeline.
        if (ColorPreviewCapability is { Supported: false })
            _ = PreviewColorRecipe(recipe);
        return Task.CompletedTask;
    }

