@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Web
@using Watermark.Razor.Components
@using Watermark.Razor.Components.Mac
@using Watermark.Razor.Workspace
@using Watermark.Razor.Workspace.Components
@using Watermark.Shared.Models
@inject WMWorkspaceController Controller
@inject IWMWorkspaceLauncher WorkspaceLauncher
@inject IWMWorkspaceSessionStore SessionStore
@inject IWMPhotoPicker PhotoPicker
@inject WMTemplateLibraryService TemplateLibrary
@inject IWMImagingCapabilityProvider ImagingCapabilities
@inject IWMHapticFeedback HapticFeedback
@inject IWMSystemAppearance SystemAppearance
@inject NavigationManager Navigation
@inject IWMNavigationHistory NavigationHistory

<MacWorkspaceShell>
    <ToolbarContent>
        <header class="desktop-commandbar">
            <div class="desktop-brand"><span class="desktop-brand-mark">影</span><div><strong>轻影</strong><small>跨端工作台</small></div></div>
            <div class="desktop-command-group">
                <button type="button" @onclick="ImportNewSessionAsync"><MIcon>mdi-folder-image</MIcon><span>导入</span></button>
                <button type="button" disabled="@(!opened)" @onclick="AppendMediaAsync"><MIcon>mdi-image-plus-outline</MIcon><span>添加素材</span></button>
            </div>
            <div class="desktop-command-group is-history">
                <button type="button" disabled="@(!State.CanUndo)" @onclick="() => Controller.UndoAsync()" title="撤销"><MIcon>mdi-undo</MIcon></button>
                <button type="button" disabled="@(!State.CanRedo)" @onclick="() => Controller.RedoAsync()" title="重做"><MIcon>mdi-redo</MIcon></button>
                <select value="@State.HistoryCursor" disabled="@(!opened)" @onchange="SetHistoryCursorAsync" aria-label="编辑历史">
                    <option value="0">原始状态</option>
                    @foreach (var item in State.History) { <option value="@item.Cursor">@item.Label</option> }
                </select>
            </div>
            <div class="desktop-command-spacer"></div>
            <div class="desktop-command-group">
                <button type="button" @onclick='() => Navigation.NavigateTo("/templates")'><MIcon>mdi-view-grid-outline</MIcon><span>模板库</span></button>
                <button type="button" @onclick='() => Navigation.NavigateTo("/templates?tab=market")'><MIcon>mdi-storefront-outline</MIcon><span>市场</span></button>
                <button type="button" @onclick='() => Navigation.NavigateTo("/templates")'><MIcon>mdi-vector-square-edit</MIcon><span>设计模板</span></button>
                <button type="button" @onclick="OpenSettings"><MIcon>mdi-cog-outline</MIcon><span>设置</span></button>
                <button type="button" class="is-primary" disabled="@(!opened)" @onclick="ExportOrCancelAsync"><MIcon>mdi-export-variant</MIcon><span>@(State.ExportTool.IsBusy ? "取消" : "导出")</span></button>
            </div>
        </header>
    </ToolbarContent>
    <WorkspaceContent>
        @if (!opened)
        {
            <section class="desktop-empty">
                @if (State.Recovery is not null)
                {
                    <WMWorkspaceRecoveryPanel Result="State.Recovery" Busy="recovering" RecoveryRequested="RecoverAsync" />
                }
                else
                {
                    <span class="desktop-empty-orbit"><MIcon>mdi-image-multiple-outline</MIcon></span>
                    <h1>从照片开始创作</h1>
                    <p>模板、调色、多帧与导出现在共用同一份可恢复会话。</p>
                    <button type="button" @onclick="ImportNewSessionAsync"><MIcon>mdi-folder-image</MIcon><span>导入照片</span></button>
                    @if (!string.IsNullOrWhiteSpace(message)) { <small role="alert">@message</small> }
                }
            </section>
        }
        else
        {
            <div class="desktop-workspace">
                <nav class="desktop-mode-rail" aria-label="工作模式">
                    <button type="button" class="@(State.Mode == WMWorkspaceMode.Template ? "is-active" : null)" @onclick="() => SetModeAsync(WMWorkspaceMode.Template)"><MIcon>mdi-palette-swatch-outline</MIcon><span>模板</span></button>
                    <button type="button" class="@(State.Mode == WMWorkspaceMode.ColorGrade ? "is-active" : null)" @onclick="() => SetModeAsync(WMWorkspaceMode.ColorGrade)"><MIcon>mdi-tune-variant</MIcon><span>调色</span></button>
                    <button type="button" class="@(State.Mode == WMWorkspaceMode.MultiFrame ? "is-active" : null)" @onclick="() => SetModeAsync(WMWorkspaceMode.MultiFrame)"><MIcon>mdi-weather-night</MIcon><span>多帧</span></button>
                    <button type="button" class="@(State.Mode == WMWorkspaceMode.Collage ? "is-active" : null)" @onclick="() => SetModeAsync(WMWorkspaceMode.Collage)"><MIcon>mdi-view-split-vertical</MIcon><span>拼图</span></button>
                </nav>
                <main class="desktop-stage-column">
                    <section class="desktop-stage" @onpointerdown="ShowOriginalAsync" @onpointerup="HideOriginalAsync" @onpointerleave="HideOriginalAsync">
                        <WMWorkspacePreviewSurface Presentation="PreviewPresentation"
                                                   CapabilityChanged="HandleColorPreviewCapabilityAsync"
                                                   PerformanceMeasured="HandleColorPreviewPerformanceAsync"
                                                   Alt="当前图片预览">
                            <EmptyContent><MIcon>mdi-image-outline</MIcon></EmptyContent>
                        </WMWorkspacePreviewSurface>
                        @if (State.Activity == WMWorkspaceActivity.Exporting
                             || State.Activity == WMWorkspaceActivity.Previewing
                             && State.PreviewPresentation.Backend != WMInteractivePreviewBackend.WebGl2)
                        {
                            <div class="desktop-progress" role="status"><MProgressCircular Indeterminate Size="28" Width="3" /><span>@State.Message</span></div>
                        }
                        @if (State.IsComparingOriginal) { <span class="desktop-original-chip">原图</span> }
                    </section>
                    <section class="desktop-media-strip" aria-label="素材列表">
                        @foreach (var media in State.Media)
                        {
                            <article class="@(media.Id == State.CurrentMediaId ? "is-active" : null)">
                                <button type="button" class="desktop-media-preview" @onclick="() => Controller.SelectMediaAsync(media.Id)">
                                    @if (MediaPreview(media) is { Length: > 0 } preview) { <img src="@preview" alt="" /> }
                                    else { <span class="desktop-media-placeholder"><MIcon>mdi-image-outline</MIcon></span> }
                                    <span>@media.DisplayName</span>
                                </button>
                                <button type="button" class="desktop-media-check @(media.IsSelected ? "is-selected" : null)" @onclick="() => Controller.ToggleMediaSelectionAsync(media.Id)" aria-label="切换导出选择"><MIcon>@(media.IsSelected ? "mdi-check" : "mdi-plus")</MIcon></button>
                            </article>
                        }
                    </section>
                </main>
                <aside class="desktop-inspector">
                    <div class="desktop-inspector-scroll">
                        @if (State.Mode == WMWorkspaceMode.Template)
                        {
                            <WMTemplatePanel Templates="templates" TemplateId="State.TemplateId" Draft="State.TemplateEdit" Scope="State.ApplyScope" ScopeChanged="ChangeApplyScopeAsync" SelectedCount="SelectedCount" RefreshRequested="RefreshTemplatesAsync" PreviewChanged="PreviewTemplateAsync" CommitRequested="CommitTemplateAsync" />
                            @if (!string.IsNullOrWhiteSpace(State.TemplateId)) { <button class="desktop-edit-template" type="button" @onclick="() => OpenDesignerAsync(State.TemplateId!)"><MIcon>mdi-vector-square-edit</MIcon><span>编辑当前模板</span></button> }
                        }
                        else if (State.Mode == WMWorkspaceMode.ColorGrade)
                        {
                            <WMColorGradePanel Recipe="State.ColorGradeTool.Draft" Presets="State.ColorGradeTool.Presets" SelectedPresetId="State.ColorGradeTool.SelectedPresetId" ReferenceUrl="State.ColorGradeTool.Reference.PreviewUrl" ReferenceName="State.ColorGradeTool.Reference.DisplayName" Busy="State.ColorGradeTool.IsBusy" Scope="State.ApplyScope" ScopeChanged="ChangeApplyScopeAsync" SelectedCount="SelectedCount" PreviewChanged="PreviewColorAsync" CommitRequested="CommitColorAsync" ChooseReferenceRequested="ChooseReferenceAsync" ClearReferenceRequested="ClearReferenceAsync" ResetRequested="ResetColorAsync" PresetSelected="ApplyPresetAsync" SavePresetRequested="SavePresetAsync" DeletePresetRequested="DeletePresetAsync" />
                        }
                        else if (State.Mode == WMWorkspaceMode.MultiFrame)
                        {
                            <WMMultiFramePanel Media="State.Media" Roles="State.MultiFrameTool.Draft.Roles" Mode="State.MultiFrameTool.Draft.Mode" ModeChanged="SetStackModeAsync" NormalizeExposure="State.MultiFrameTool.Draft.NormalizeExposure" NormalizeExposureChanged="SetNormalizeExposureAsync" RepairHotPixels="State.MultiFrameTool.Draft.RepairHotPixels" RepairHotPixelsChanged="SetRepairHotPixelsAsync" AutoCrop="State.MultiFrameTool.Draft.AutoCrop" AutoCropChanged="SetAutoCropAsync" Capability="State.MultiFrameTool.Capability" Busy="State.MultiFrameTool.IsBusy" Message="State.Message" RoleChanged="SetFrameRole" RunRequested="RunStackAsync" />
                        }
                        else if (State.Mode == WMWorkspaceMode.Collage)
                        {
                            <WMCollagePanel Media="State.Media" MediaPreviewUrl="MediaPreview" OrderedMediaIds="State.CollageTool.Draft.OrderedMediaIds" Direction="State.CollageTool.Draft.Direction" Busy="State.CollageTool.IsBusy" DraftChanged="UpdateCollageDraftAsync" RunOrCancelRequested="RunOrCancelCollageAsync" />
                        }
                        <WMExportPanel SelectedCount="SelectedCount" Format="State.ExportTool.Draft.Format" FormatChanged="SetExportFormatAsync" MaximumLongEdge="@(State.ExportTool.Draft.MaximumLongEdge ?? 0)" MaximumLongEdgeChanged="SetExportMaximumLongEdgeAsync" CustomMaximumLongEdge="State.ExportTool.Draft.CustomMaximumLongEdge" CustomMaximumLongEdgeChanged="SetCustomExportMaximumLongEdgeAsync" Quality="State.ExportTool.Draft.Quality" QualityChanged="SetExportQualityAsync" Destination="State.ExportTool.Draft.Destination" DestinationChanged="SetExportDestinationAsync" Progress="State.ActiveJob.Progress" Results="State.ExportTool.Results" CanExportPng16="CanPng16" CanExportTiff16="CanTiff16" FailedCount="State.ExportTool.FailedMediaIds.Count" Busy="State.ExportTool.IsBusy" RetryFailedRequested="RetryFailedAsync" RunOrCancelRequested="ExportOrCancelAsync" />
                    </div>
                </aside>
            </div>
        }
    </WorkspaceContent>
    <DialogContent>
        @if (!string.IsNullOrWhiteSpace(State.ErrorMessage) || !string.IsNullOrWhiteSpace(message))
        {
            <div class="desktop-toast @(State.ErrorMessage is null ? null : "is-error")" role="status"><span>@(State.ErrorMessage ?? message)</span><button type="button" @onclick="() => message = null"><MIcon>mdi-close</MIcon></button></div>
        }
        <MDialog Persistent @bind-Value="showDesigner" Fullscreen ContentStyle="padding:0;overflow:hidden;">@if (showDesigner) { <WMTemplateDesigner CanvasId="@designerTemplateId" OnSaved="OnTemplateSavedAsync" OnClose="CloseDesignerAsync" /> }</MDialog>
    </DialogContent>
</MacWorkspaceShell>

@code {
    [Parameter] public string? SessionId { get; set; }
    private readonly List<WMTemplateList> templates = [];
    private bool opened;
    private bool showDesigner;
    private bool recovering;
    private string? message;
    private string designerTemplateId = string.Empty;
    private WMWorkspaceState State => Controller.State;
    private WMWorkspacePreviewPresentation PreviewPresentation => State.IsComparingOriginal
        ? State.PreviewPresentation with
        {
            BaseUrl = State.PreviewUrl,
            StableUrl = State.PreviewUrl,
            ColorProgram = null,
            Backend = WMInteractivePreviewBackend.CpuSkia,
            IsSettled = true
        }
        : State.PreviewPresentation;
    private int SelectedCount => State.Media.Count(item => item.IsSelected);
    private bool CanPng16 => ImagingCapabilities.Probe(WMImagingFeature.Png16).IsAvailable;
    private bool CanTiff16 => ImagingCapabilities.Probe(WMImagingFeature.Tiff16).IsAvailable;

    private void OpenSettings()
    {
        var returnUrl = string.IsNullOrWhiteSpace(State.SessionId) ? "/create" : $"/workspace/{State.SessionId}";
        NavigationHistory.NavigateTo($"/settings?returnUrl={Uri.EscapeDataString(returnUrl)}");
    }

    private Task HandleColorPreviewCapabilityAsync(WMColorPreviewCapability capability) =>
        Controller.SetColorPreviewCapabilityAsync(capability);

    private Task HandleColorPreviewPerformanceAsync(WMColorPreviewPerformanceSample sample) =>
        Controller.RecordColorPreviewPerformanceAsync(sample);

    protected override async Task OnInitializedAsync()
    {
        Controller.Changed += OnWorkspaceChanged;
        TemplateLibrary.Changed += OnTemplatesChanged;
        SystemAppearance.SetWorkspaceActive(true);
        await RefreshTemplatesAsync();
        if (!string.IsNullOrWhiteSpace(SessionId))
        {
            opened = await Controller.OpenAsync(SessionId);
        }
        else
        {
            var recent = await SessionStore.ListRecentAsync(5);
            var candidate = recent.FirstOrDefault(item => item.Mode != WMWorkspaceMode.TemplateDesign);
            if (candidate is not null) opened = await Controller.OpenAsync(candidate.Id);
        }
        if (opened && State.Mode == WMWorkspaceMode.TemplateDesign)
        {
            designerTemplateId = State.TemplateId ?? string.Empty;
            showDesigner = true;
        }
    }

    private async Task ImportNewSessionAsync()
    {
        try
        {
            var sources = await PhotoPicker.PickMultipleAsync();
            if (sources.Count == 0) return;
            if (opened) await Controller.CloseAsync();
            var id = await WorkspaceLauncher.CreateFromSourcesAsync(WMWorkspaceMode.Template, sources, null, CancellationToken.None);
            opened = await Controller.OpenAsync(id);
        }
        catch (Exception ex) { message = ex.Message; }
    }

    private async Task AppendMediaAsync()
    {
        try { var sources = await PhotoPicker.PickMultipleAsync(); if (sources.Count > 0) await Controller.ImportMediaAsync(sources); }
        catch (Exception ex) { message = ex.Message; }
    }

    private Task SetModeAsync(WMWorkspaceMode mode) => Controller.SetModeAsync(mode);
    private Task PreviewTemplateAsync(WMWorkspaceTemplateEdit edit) => Controller.PreviewTemplateAsync(edit, State.ApplyScope);
    private Task CommitTemplateAsync(WMWorkspaceTemplateEdit edit) => Controller.CommitTemplateAsync(edit, State.ApplyScope);
    private Task ChangeApplyScopeAsync(WMApplyScope scope)
    {
        Controller.SetApplyScope(scope);
        return Task.CompletedTask;
    }
    private Task SetHistoryCursorAsync(ChangeEventArgs args) => int.TryParse(args.Value?.ToString(), out var cursor) ? Controller.SetHistoryCursorAsync(cursor) : Task.CompletedTask;
    private Task ShowOriginalAsync(PointerEventArgs _) => Controller.SetCompareOriginalAsync(true);
    private Task HideOriginalAsync(PointerEventArgs _) => Controller.SetCompareOriginalAsync(false);
    private string? MediaPreview(WMWorkspaceMedia media) =>
        Controller.GetMediaPreviewUrl(media.Id)
        ?? (string.Equals(media.Id, State.CurrentMediaId, StringComparison.Ordinal) ? State.PreviewUrl : null);

    private Task PreviewColorAsync(WMColorRecipe recipe) => Controller.UpdateColorDraftAsync(recipe);
    private async Task CommitColorAsync(WMColorRecipe recipe)
    {
        await Controller.UpdateColorDraftAsync(recipe);
        await Controller.CommitColorDraftAsync(State.ApplyScope);
    }

    private async Task ResetColorAsync()
    {
        await Controller.UpdateColorDraftAsync(new WMColorRecipe { Name = "桌面调整" });
        await Controller.CommitColorDraftAsync(State.ApplyScope);
    }

    private Task ApplyPresetAsync(WMColorRecipe preset) => Controller.ApplyColorPresetAsync(preset.Id);
    private Task SavePresetAsync()
    {
        var name = State.ColorGradeTool.Draft.Name;
        if (string.IsNullOrWhiteSpace(name) || name is "桌面调整" or "未命名调色")
            name = $"调色预设 {DateTime.Now:MMdd HHmm}";
        return Controller.SaveColorPresetAsync(name);
    }

    private Task DeletePresetAsync() =>
        string.IsNullOrWhiteSpace(State.ColorGradeTool.SelectedPresetId)
            ? Task.CompletedTask
            : Controller.DeleteColorPresetAsync(State.ColorGradeTool.SelectedPresetId);

    private async Task ChooseReferenceAsync()
    {
        if (State.ColorGradeTool.IsBusy || string.IsNullOrWhiteSpace(State.SessionId)) return;
        var sources = await PhotoPicker.PickMultipleAsync();
        var source = sources.FirstOrDefault();
        if (source is null) return;
        try { await Controller.ImportColorReferenceAsync(source); }
        catch (Exception ex) { message = ex.Message; }
        finally
        {
            await source.DisposeAsync();
            foreach (var extra in sources.Skip(1)) await extra.DisposeAsync();
        }
    }
    private Task ClearReferenceAsync() => Controller.ClearColorReferenceAsync();

    private Task SetFrameRole(WMFrameRoleChange change)
    {
        var roles = new Dictionary<string, WMFrameRole?>(State.MultiFrameTool.Draft.Roles, StringComparer.Ordinal)
        {
            [change.MediaId] = change.Role
        };
        HapticFeedback.Perform();
        return Controller.UpdateMultiFrameDraftAsync(State.MultiFrameTool.Draft with { Roles = roles });
    }

    private Task SetStackModeAsync(WMStackMode mode)
    {
        var defaults = WMMultiFrameStackSettings.CreateDefault(mode);
        return Controller.UpdateMultiFrameDraftAsync(State.MultiFrameTool.Draft with
        {
            Mode = mode,
            NormalizeExposure = defaults.NormalizeExposure,
            RepairHotPixels = defaults.RepairHotPixels,
            AutoCrop = defaults.AutoCrop
        });
    }

    private Task SetNormalizeExposureAsync(bool value) =>
        Controller.UpdateMultiFrameDraftAsync(State.MultiFrameTool.Draft with { NormalizeExposure = value });

    private Task SetRepairHotPixelsAsync(bool value) =>
        Controller.UpdateMultiFrameDraftAsync(State.MultiFrameTool.Draft with { RepairHotPixels = value });

    private Task SetAutoCropAsync(bool value) =>
        Controller.UpdateMultiFrameDraftAsync(State.MultiFrameTool.Draft with { AutoCrop = value });

    private async Task RunStackAsync()
    {
        try { await Controller.ExecuteMultiFrameAsync(); }
        catch (Exception ex) { message = ex.Message; }
    }

    private Task RetryFailedAsync() => Controller.RetryFailedExportAsync();

    private Task SetExportFormatAsync(WMExportFormat value) =>
        Controller.UpdateExportDraftAsync(State.ExportTool.Draft with { Format = value });

    private Task SetExportMaximumLongEdgeAsync(int value) =>
        Controller.UpdateExportDraftAsync(State.ExportTool.Draft with { MaximumLongEdge = value == 0 ? null : value });

    private Task SetCustomExportMaximumLongEdgeAsync(int value) =>
        Controller.UpdateExportDraftAsync(State.ExportTool.Draft with { CustomMaximumLongEdge = value });

    private Task SetExportQualityAsync(int value) =>
        Controller.UpdateExportDraftAsync(State.ExportTool.Draft with { Quality = value });

    private Task SetExportDestinationAsync(WMExportDestinationKind value) =>
        Controller.UpdateExportDraftAsync(State.ExportTool.Draft with { Destination = value });

    private Task ExportOrCancelAsync() =>
        State.ExportTool.IsBusy ? Controller.CancelActiveJobAsync() : Controller.StartExportAsync();

    private async Task RunOrCancelCollageAsync()
    {
        if (State.CollageTool.IsBusy) await Controller.CancelActiveJobAsync();
        else await Controller.ExecuteCollageAsync();
    }

    private Task UpdateCollageDraftAsync(WMCollageDraft draft) =>
        Controller.UpdateCollageDraftAsync(draft);
    private async Task RefreshTemplatesAsync() { var items = await TemplateLibrary.GetOrRefreshAsync(); templates.Clear(); templates.AddRange(items); }
    private void OnTemplatesChanged() => _ = InvokeAsync(() => { templates.Clear(); templates.AddRange(TemplateLibrary.Templates); StateHasChanged(); });
    private void OnWorkspaceChanged(WMWorkspaceState next) => _ = InvokeAsync(() => { opened = !string.IsNullOrWhiteSpace(next.SessionId) && next.Activity != WMWorkspaceActivity.Failed; StateHasChanged(); });

    private async Task OpenDesignerAsync(string templateId)
    {
        var id = await SessionStore.CreateAsync(new WMWorkspaceCreateRequest(
            WMWorkspaceMode.TemplateDesign,
            [],
            templateId,
            !string.IsNullOrWhiteSpace(State.SessionId) ? $"/workspace/{State.SessionId}" : "/templates?tab=local"));
        Navigation.NavigateTo($"/workspace/{id}");
    }

    private async Task RecoverAsync(WMWorkspaceRecoveryRequest request)
    {
        if (recovering) return;
        recovering = true;
        try
        {
            opened = await Controller.RecoverAsync(request.Action, request.AffectedIds);
            if (request.Action == WMWorkspaceRecoveryAction.DiscardSession)
                Navigation.NavigateTo("/create");
        }
        finally { recovering = false; }
    }

    private async Task CloseDesignerAsync()
    {
        showDesigner = false;
        await Controller.DiscardAsync();
        opened = false;
        Navigation.NavigateTo("/templates");
    }
    private async Task OnTemplateSavedAsync(string id) { TemplateLibrary.Invalidate(id); await RefreshTemplatesAsync(); }
    public async ValueTask DisposeAsync()
    {
        Controller.Changed -= OnWorkspaceChanged; TemplateLibrary.Changed -= OnTemplatesChanged; if (opened) await Controller.CloseAsync(); SystemAppearance.SetWorkspaceActive(false);
    }
}
