    async Task HandleMultiFrameCompleted(WMOperationResult operationResult)
    {
        var artifact = operationResult.Outputs.Single();
        var src = await Global.Byte2Url(JSRuntime, await File.ReadAllBytesAsync(artifact.FilePath));
        var mediaId = Guid.NewGuid().ToString("N");
        var sourceImage = StackDialogSourceImages.FirstOrDefault();
        CurrentImage = new WMTemplateList
        {
            Canvas = CreatePlainCanvas(artifact),
            Src = src,
            ID = mediaId,
            Path = artifact.FilePath,
            IsChecked = true
        };
        Images.Add(CurrentImage);
        MediaArchive[mediaId] = CurrentImage;
        EditingSession.Commit(operationResult.Operation, new Dictionary<string, WMImageArtifact>
        {
            [mediaId] = artifact
        }, [mediaId]);
        RegisterOriginalImage(CurrentImage,
            sourceImage is null ? artifact.FilePath : GetOriginalImagePath(sourceImage), src);
        StarTrailSelectionIds = [mediaId];
        WorkspaceMode = MacWorkspaceMode.StarTrail;
        MultiFramePreviewSrc = null;
        RefreshMultiFrameInputs();
        WorkspaceCoordinator.Complete("多帧合成完成");
        await InvokeAsync(StateHasChanged);
        Common.ShowMsg(PopupService, "多帧结果已作为新的基础素材加入，可继续调色、套模板和撤销。", AlertTypes.Info);
    }

    async Task CommitTemplateOperationAsync(MacPreparedTemplatePreview? preparedPreview = null)
    {
        if (PendingTemplate == null || CurrentImage == null || CurrentImage.ID != PendingTemplate.MediaId)
            return;
        try
        {
            WorkspaceCoordinator.BeginProcessing("正在提交模板代理预览…");
            var operationToken = BeginActiveOperation();
            await LoadingEvtAsync(true, "正在提交模板代理预览…", 0);
            var targets = ApplyToSelected
                ? Images.Where(image => image.IsChecked).ToList()
                : [CurrentImage];
            if (targets.Count == 0) targets = [CurrentImage];
            foreach (var target in targets) EnsureSessionSource(target);
            var inputs = targets.Select(target => EditingSession.GetCurrent(target.ID)).ToArray();
            var settings = new WMTemplateOperationSettings(CurrentImage.Canvas);
            IReadOnlyDictionary<string, WMImageArtifact>? preparedOutputs = null;
            if (preparedPreview is not null
                && inputs.Any(input => string.Equals(input.Id, preparedPreview.InputArtifactId, StringComparison.Ordinal)))
            {
                preparedOutputs = new Dictionary<string, WMImageArtifact>(StringComparer.Ordinal)
                {
                    [preparedPreview.InputArtifactId] = preparedPreview.Artifact
                };
            }
            var result = await TemplateProcessor.ExecuteAsync(new WMOperationRequest(
                inputs,
                settings,
                true,
                EditingSession.GetWorkingDirectory(WMImageOperationKind.Template),
                new Progress<WMOperationProgress>(value =>
                {
                    _ = ReportProgressAsync(value);
                }),
                ProcessingOptions), preparedOutputs, operationToken);
            var outputs = targets.Select((target, index) => (target.ID, Artifact: result.Outputs[index]))
                .ToDictionary(pair => pair.ID, pair => pair.Artifact);
            EditingSession.Commit(result.Operation, outputs);
            PendingTemplate = null;
            foreach (var target in targets)
                await ApplyArtifactToMediaAsync(target, outputs[target.ID]);
            ApplyToSelected = false;
            showConfig = false;
            await LoadingEvtAsync(false, "模板操作完成", 100);
            WorkspaceCoordinator.Complete("模板操作完成");
            CompleteActiveOperation();
            Common.ShowMsg(PopupService, "模板已生成新版本，可以继续调色或再次应用模板。", AlertTypes.Info);
        }
        catch (OperationCanceledException)
        {
            CompleteActiveOperation();
            WorkspaceCoordinator.Reset();
            LoadingEvt(false, "", 0);
        }
        catch (Exception ex)
        {
            CompleteActiveOperation();
            WorkspaceCoordinator.Fail(ex);
            LoadingEvt(false, "", 0);
            Common.ShowMsg(PopupService, $"模板提交失败: {ex.Message}", AlertTypes.Error);
        }
    }

    async Task CancelPendingOperation()
    {
        var releasedPreviewUrls = new[] { ColorPreviewBaseSrc, ColorPreviewDisplaySrc, ColorCompareBeforeSrc }
            .Where(url => !string.IsNullOrWhiteSpace(url))
            .Distinct(StringComparer.Ordinal)
            .ToArray();
        if (PendingTemplate != null)
        {
            var pending = PendingTemplate;
            PendingTemplate = null;
            var image = Images.FirstOrDefault(item => item.ID == pending.MediaId);
            if (image != null)
            {
                image.Path = pending.Path;
                image.Src = pending.Src;
                image.Canvas = Global.ReadConfig(pending.CanvasJson);
                image.Canvas.Path = pending.Path;
            }
        }
        ColorPreviewCancellation?.Cancel();
        if (!string.IsNullOrWhiteSpace(ColorPreviewPath)) EditingSession.DeletePreviewFiles([ColorPreviewPath]);
        ColorPreviewPath = null;
        ColorPreviewBaseSrc = null;
        ColorPreviewDisplaySrc = null;
        ColorCompareBeforeSrc = null;
        CurrentColorPreviewLook = MacColorPreviewLook.Identity;
        showConfig = false;
        SrcLoading = false;
        WorkspaceCoordinator.Reset();
        foreach (var url in releasedPreviewUrls)
            await TryRevokeUnreferencedBlobAsync(url);
        await InvokeAsync(StateHasChanged);
    }

