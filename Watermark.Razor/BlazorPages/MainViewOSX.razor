    async Task ShowColorPreviewHintOnceAsync()
    {
        if (ColorPreviewHintChecked) return;
        ColorPreviewHintChecked = true;
        const string key = "watermark.mac.color-preview-hint.v1";
        try
        {
            if (await JSRuntime.InvokeAsync<string>("localStorage.getItem", key) == "1") return;
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", key, "1");
        }
        catch
        {
            // The in-memory flag still guarantees one prompt for this session.
        }
        await InvokeAsync(() => Common.ShowMsg(PopupService,
            "实时预览\n参数会立即作用于当前调色会话，并在停止操作后写入同一个历史节点。",
            AlertTypes.Info));
    }

    async Task PreviewColorRecipe(WMColorRecipe recipe)
    {
        CurrentColorRecipe = recipe;
        if (CurrentImage == null) return;
        EnsureSessionSource(CurrentImage);
        ColorPreviewCancellation?.Cancel();
        ColorPreviewCancellation?.Dispose();
        var cancellation = ColorPreviewCancellation = CancellationTokenSource.CreateLinkedTokenSource(
            WorkspaceCoordinator.BeginPreview("正在更新调色预览…"));
        var version = ++ColorPreviewVersion;
        ColorPreviewBaseSrc = ColorEditSession.GetBasePreview(CurrentImage.ID) ?? CurrentImage.Src;
        var mediaId = CurrentImage.ID;
        var recipeSnapshot = CloneColorRecipe(recipe);
        try
        {
            // Manual adjustments are rendered by WebGL on the next animation frame.
            // Only reference changes need background analysis/LUT generation.
            WMGeneratedColorLook generated = null;
            if (recipeSnapshot.ReferenceMapping.Enabled && recipeSnapshot.ReferenceProfile is not null)
            {
                var input = GetColorBaseArtifact(CurrentImage);
                var mappingSignature = CreateColorMappingSignature(recipeSnapshot, input);
                if (string.Equals(mappingSignature, CurrentColorMappingSignature, StringComparison.Ordinal)
                    && CurrentGeneratedColorLook is not null)
                {
                    generated = CurrentGeneratedColorLook;
                    recipeSnapshot.GeneratedBaseGrade = generated.AutomaticBaseGrade ?? generated.BaseGrade;
                }
                else
                {
                    generated = await PrepareGeneratedLookAsync(recipeSnapshot, cancellation.Token);
                    CurrentGeneratedColorLook = generated;
                    CurrentColorMappingSignature = mappingSignature;
                }
            }
            else
            {
                CurrentGeneratedColorLook = null;
                CurrentColorMappingSignature = null;
            }
            if (version != ColorPreviewVersion || cancellation.IsCancellationRequested || CurrentImage?.ID != mediaId) return;

            CurrentColorPreviewLook = generated is null
                ? MacColorPreviewLook.Identity
                : MacColorPreviewLook.From(generated);
            CurrentColorPreviewParameters = MacColorPreviewParameters.From(CurrentColorRecipe.Grade);
            ColorCompareBeforeSrc = ColorPreviewBaseSrc;
            CurrentColorRecipe.GeneratedBaseGrade = recipeSnapshot.GeneratedBaseGrade;
            WorkspaceCoordinator.PreviewReady("调色预览已更新");
            await InvokeAsync(StateHasChanged);

            if (ColorPreviewCapability is { Supported: false })
            {
                await Task.Delay(250, cancellation.Token);
                await PreviewColorRecipeCpuFallbackAsync(recipeSnapshot, mediaId, version, cancellation.Token);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            WorkspaceCoordinator.Fail(ex);
            Common.ShowMsg(PopupService, $"调色预览失败: {ex.Message}", AlertTypes.Error);
        }
    }

    async Task PreviewColorRecipeCpuFallbackAsync(
        WMColorRecipe recipe,
        string mediaId,
        long version,
        CancellationToken cancellationToken)
    {
        var image = Images.First(item => item.ID == mediaId);
        var input = GetColorBaseArtifact(image);
        var result = await ColorGradeProcessor.ExecuteAsync(new WMOperationRequest(
            [input],
            recipe,
            true,
            EditingSession.GetWorkingDirectory(WMImageOperationKind.ColorGrade, preview: true),
            Execution: InteractivePreviewOptions), cancellationToken);
        var artifact = result.Outputs.Single();
        if (version != ColorPreviewVersion || cancellationToken.IsCancellationRequested || CurrentImage?.ID != mediaId)
        {
            EditingSession.DeletePreviewFiles([artifact.FilePath]);
            return;
        }
        if (!string.IsNullOrWhiteSpace(ColorPreviewPath)) EditingSession.DeletePreviewFiles([ColorPreviewPath]);
        ColorPreviewPath = artifact.FilePath;
        ColorPreviewDisplaySrc = await Global.Byte2Url(JSRuntime,
            await File.ReadAllBytesAsync(artifact.FilePath, cancellationToken));
        await InvokeAsync(StateHasChanged);
    }

    async Task HandleColorPreviewCapabilityChanged(MacColorPreviewCapability capability)
    {
        ColorPreviewCapability = capability;
        if (!capability.Supported && ColorPreviewBaseSrc != null)
            await PreviewColorRecipe(CurrentColorRecipe);
    }

    static string CreateColorMappingSignature(WMColorRecipe recipe, WMImageArtifact input) => string.Join('|',
        input.ContentHash ?? input.Id,
        recipe.ReferenceProfile?.SourceHash,
        recipe.MappingVersion,
        recipe.AnalysisVersion,
        recipe.ReferenceMapping.Strength,
        recipe.ReferenceMapping.MatchMode,
        recipe.ReferenceMapping.Mode,
        recipe.ReferenceMapping.PreserveLuminance,
        recipe.ReferenceMapping.Enabled);

    void EnsureSessionSource(WMTemplateList image)
    {
        if (EditingSession.TryGetCurrent(image.ID, out _)) return;
        EditingSession.RegisterSource(
            image.ID,
            image.Path,
            FlattenExif(image.Canvas),
            MediaProxyPaths.GetValueOrDefault(image.ID));
    }

    async Task ApplyArtifactToMediaAsync(WMTemplateList image, WMImageArtifact artifact)
    {
        // WMTemplateList.Path remains the immutable imported source path. The current
        // committed proxy lives in the editing session and Canvas.Path.
        RegisterOriginalImage(image);
        image.Canvas = CreatePlainCanvas(artifact);
        var previousSrc = image.Src;
        var nextSrc = await Global.Byte2Url(JSRuntime, await File.ReadAllBytesAsync(artifact.FilePath));
        image.Src = nextSrc;
        if (!string.Equals(previousSrc, nextSrc, StringComparison.Ordinal))
            await TryRevokeUnreferencedBlobAsync(previousSrc);
        if (CurrentImage?.ID == image.ID) CurrentImage = image;
        if (ColorPreviewPath == artifact.FilePath
            || (artifact.SourceOperation == WMImageOperationKind.ColorGrade && !ColorEditSession.IsActive))
        {
            ColorPreviewPath = null;
            ColorPreviewBaseSrc = null;
            ColorPreviewDisplaySrc = null;
        }
        await InvokeAsync(StateHasChanged);
    }

    async Task TryRevokeUnreferencedBlobAsync(string url)
    {
        if (string.IsNullOrWhiteSpace(url)
            || !url.StartsWith("blob:", StringComparison.OrdinalIgnoreCase)
            || Images.Any(item => string.Equals(item.Src, url, StringComparison.Ordinal))
            || OriginalImagePreviewSources.Values.Any(value => string.Equals(value, url, StringComparison.Ordinal))
            || string.Equals(PendingTemplate?.Src, url, StringComparison.Ordinal)
            || string.Equals(ColorPreviewBaseSrc, url, StringComparison.Ordinal)
            || string.Equals(ColorPreviewDisplaySrc, url, StringComparison.Ordinal)
            || string.Equals(ColorCompareBeforeSrc, url, StringComparison.Ordinal)
            || string.Equals(MultiFramePreviewSrc, url, StringComparison.Ordinal))
            return;

        try { await Global.RevokeUrl(JSRuntime, url); }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException) { }
    }

    static string GetOperationStageLabel(WMOperationStage stage) => stage switch
    {
        WMOperationStage.Synchronizing => "同步预览",
        WMOperationStage.Queued => "等待处理",
        WMOperationStage.Decoding => "解码",
        WMOperationStage.Processing => "处理",
        WMOperationStage.Encoding => "编码",
        WMOperationStage.Writing => "写入",
        WMOperationStage.Completed => "完成",
        _ => "处理"
    };

    static WMCanvas CreatePlainCanvas(WMImageArtifact artifact)
    {
        var canvas = new WMCanvas { Path = artifact.FilePath };
        if (artifact.Exif.Count > 0)
            canvas.Exif[canvas.ID] = new Dictionary<string, string>(artifact.Exif);
        return canvas;
    }

    static Dictionary<string, string> FlattenExif(WMCanvas canvas) =>
        canvas?.Exif?.FirstOrDefault().Value is { } exif
            ? new Dictionary<string, string>(exif)
            : [];

    IReadOnlyList<string> CreateUniqueExportPaths(IReadOnlyList<WMTemplateList> images)
    {
        var used = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var paths = new string[images.Count];
        for (var index = 0; index < images.Count; index++)
        {
            var baseName = $"DFX_{Path.GetFileNameWithoutExtension(GetOriginalImagePath(images[index]))}";
            used.TryGetValue(baseName, out var occurrence);
            occurrence++;
            used[baseName] = occurrence;
            var extension = ExportFormat switch
            {
                WMExportFormat.Png16 => ".png",
                WMExportFormat.Tiff16 => ".tiff",
                _ => ".jpg"
            };
            var fileName = occurrence == 1 ? $"{baseName}{extension}" : $"{baseName}_{occurrence}{extension}";
            paths[index] = Path.Combine(Global.OutPutPath, fileName);
        }
        return paths;
    }

    static bool HasManualColorAdjustments(WMColorGradeSettings settings)
    {
        if (new[]
            {
                settings.Exposure, settings.Contrast, settings.Highlights, settings.Shadows,
                settings.Whites, settings.Blacks, settings.Temperature, settings.Tint,
                settings.Vibrance, settings.Saturation
            }.Any(value => Math.Abs(value) > 0.001f)) return true;
        if (settings.Hsl.Values.Any(value => Math.Abs(value.Hue) > 0.001f || Math.Abs(value.Saturation) > 0.001f || Math.Abs(value.Luminance) > 0.001f)) return true;
        return !IsIdentity(settings.MasterCurve) || !IsIdentity(settings.RedCurve)
            || !IsIdentity(settings.GreenCurve) || !IsIdentity(settings.BlueCurve);
    }

    static bool IsIdentity(IReadOnlyList<WMCurvePoint> curve) => curve.Count == 2
        && Math.Abs(curve[0].X) < 0.001f && Math.Abs(curve[0].Y) < 0.001f
        && Math.Abs(curve[1].X - 1) < 0.001f && Math.Abs(curve[1].Y - 1) < 0.001f;

    static WMColorRecipe CloneColorRecipe(WMColorRecipe recipe) =>
        JsonSerializer.Deserialize<WMColorRecipe>(JsonSerializer.Serialize(recipe))
        ?? throw new InvalidOperationException("无法复制调色参数。");

    public void Dispose()
    {
        ActiveOperationCancellation?.Cancel();
        ActiveOperationCancellation?.Dispose();
        ColorPreviewCancellation?.Cancel();
        ColorPreviewCancellation?.Dispose();
        EditingSession.Dispose();
        TemplateLibrary.Changed -= OnTemplateLibraryChanged;
        WorkspaceCoordinator.Changed -= OnWorkspaceStateChanged;
    }

    sealed record PendingTemplateOperation(
        string MediaId,
        WMImageArtifact InputArtifact,
        string Path,
        string Src,
        string CanvasJson);
}
