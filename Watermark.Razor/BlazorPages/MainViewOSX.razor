    private async Task ApplyCanvasToAllAsync(WMCanvas sourceCanvas)
    {
        try
        {
            WMMainLoading.Show = true;
            StateHasChanged();
            int idx = 1;
            var cacheTemplate = new WMTemplateList
            {
                ID = CurrentTemplate?.ID ?? sourceCanvas.ID,
                Canvas = sourceCanvas
            };
            foreach (var img in Images)
            {
                WMMainLoading.Message = $"正在应用模板，一共{Images.Count}张，目前第{idx}张";
                WMMainLoading.Value = idx++ * 100.0 / Images.Count;
                StateHasChanged();
                var cvs = MacCanvasApplication.CreateForImage(sourceCanvas, img);
                var b64 = await helper.GenerationAsync(cvs, null, true);
                if (b64.Length == 0)
                    throw new InvalidOperationException($"{Path.GetFileName(img.Path)} 图片生成失败。");

                var src = await Global.Byte2Url(JSRuntime, b64);
                img.Canvas = cvs;
                img.Src = src;
                await InitLogoCacheDic(img.ID, cacheTemplate);
            }

            Common.ShowMsg(PopupService, "当前编辑已应用。", AlertTypes.Info);
        }
        catch (Exception ex)
        {
            Common.ShowMsg(PopupService, $"应用失败: {ex.Message}", AlertTypes.Error);
        }
        finally
        {
            WMMainLoading.Value = 100;
            WMMainLoading.Show = false;
            StateHasChanged();
        }
    }

