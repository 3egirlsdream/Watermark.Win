@page "/"
@using Watermark.Shared.Enums
@using Watermark.Shared.Models
@inject NavigationManager Navigation

@code {
    protected override void OnInitialized() => Navigation.NavigateTo(Global.DeviceType switch
    {
        DeviceType.Mac => "/mac",
        DeviceType.Win => "/desktop",
        _ => "/create"
    }, replace: true);
}
