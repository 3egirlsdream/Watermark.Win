@page "/mac"
@page "/desktop"
@using Watermark.Razor.Workspace
@using Watermark.Shared.Enums
@using Watermark.Shared.Models
@inject IWMWorkspaceSessionStore SessionStore
@inject NavigationManager Navigation

@code {
    protected override async Task OnInitializedAsync()
    {
        var id = await SessionStore.CreateEmptyAsync(WMWorkspaceMode.Template);
        var prefix = Global.DeviceType == DeviceType.Win ? "/desktop" : "/mac";
        Navigation.NavigateTo($"{prefix}/workspace/{id}", replace: true);
    }
}
