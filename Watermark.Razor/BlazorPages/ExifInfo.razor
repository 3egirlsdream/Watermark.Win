@using Microsoft.AspNetCore.Components.Forms
@using Watermark.Shared.Models
@using Microsoft.AspNetCore.Components
@using System.ComponentModel.DataAnnotations

<MDialog Value="@Value" ValueChanged="@ValueChanged" Fullscreen ContentStyle="width:100%;height:100%">
    <MCard Flat Style="height:100%;display:flex;flex-direction:column;">
        <WmPaper Style="height:calc(100vh - 135px);overflow-y:auto;" Elevation="0">
            @foreach (var row in Exifs.OrderBy(x => x.Key))
            {
                <WmTextField Value="@row.Value" Label="@row.Key" ReadOnly Variant="Variant.Text" Margin="Margin.Dense"></WmTextField>
            }
        </WmPaper>
        <MCardActions>
        <WmButton OnClick="Cancel">关闭</WmButton>
        </MCardActions>
    </MCard>
</MDialog>



@code {
    [Parameter]
    public Dictionary<string, string> Exifs { get; set; } = [];
    [Parameter] public bool Value { get; set; } = true;
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    void Cancel() => ValueChanged.InvokeAsync(false);
}
