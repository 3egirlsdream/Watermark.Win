@using Watermark.Shared.Models
@namespace Watermark.Razor.Workspace.Components

<section class="wm-mobile-dock @SpaceClass" aria-label="移动编辑工具">
    <div class="wm-dock-context">
        <div class="wm-dock-control-region">
            @ActiveToolContent
        </div>

        <nav class="wm-dock-tools" aria-label="@($"{ModeLabel}功能")">
            <div>
                @foreach (var tool in CurrentTools)
                {
                    <button type="button" class="@(ActiveTool == tool.Tool ? "is-active" : null)"
                            data-mobile-tool="@tool.Tool" aria-pressed="@(ActiveTool == tool.Tool)"
                            @onclick="() => SelectToolAsync(tool.Tool)">
                        <MIcon>@tool.Icon</MIcon><span>@tool.Label</span>
                    </button>
                }
            </div>
        </nav>
    </div>

    <nav class="wm-dock-modes" role="tablist" aria-label="编辑分类">
        @ModeButton(WMWorkspaceMode.Template, "模板", "mdi-view-grid-outline")
        @ModeButton(WMWorkspaceMode.ColorGrade, "调色", "mdi-tune-variant")
        @ModeButton(WMWorkspaceMode.MultiFrame, "多帧", "mdi-layers-triple-outline")
        @ModeButton(WMWorkspaceMode.Collage, "拼图", "mdi-view-split-vertical")
    </nav>
</section>

@code {
    [Parameter, EditorRequired] public WMWorkspaceState State { get; set; } = new();
    [Parameter] public IReadOnlyList<WMTemplateList> Templates { get; set; } = [];
    [Parameter] public Func<WMWorkspaceMedia, string?>? MediaPreviewUrl { get; set; }
    [Parameter] public EventCallback<WMWorkspaceMode> ModeChanged { get; set; }
    [Parameter] public EventCallback<WMWorkspaceMode> EditConfirmed { get; set; }
    [Parameter] public EventCallback<WMMobileToolPresentation> PresentationChanged { get; set; }
    [Parameter] public EventCallback<WMApplyScope> ScopeChanged { get; set; }
    [Parameter] public EventCallback<WMWorkspaceTemplateEdit> TemplatePreviewChanged { get; set; }
    [Parameter] public EventCallback<WMColorRecipe> ColorPreviewChanged { get; set; }
    [Parameter] public EventCallback ChooseReferenceRequested { get; set; }
    [Parameter] public EventCallback ClearReferenceRequested { get; set; }
    [Parameter] public EventCallback SavePresetRequested { get; set; }
    [Parameter] public EventCallback DeletePresetRequested { get; set; }
    [Parameter] public EventCallback<WMStackMode> MultiFrameModeChanged { get; set; }
    [Parameter] public EventCallback<WMFrameRoleChange> FrameRoleChanged { get; set; }
    [Parameter] public EventCallback<bool> NormalizeExposureChanged { get; set; }
    [Parameter] public EventCallback<bool> RepairHotPixelsChanged { get; set; }
    [Parameter] public EventCallback<bool> AutoCropChanged { get; set; }
    [Parameter] public EventCallback MultiFrameRunRequested { get; set; }
    [Parameter] public EventCallback<WMCollageDraft> CollageDraftChanged { get; set; }
    [Parameter] public EventCallback CollageRunOrCancelRequested { get; set; }

    private WMMobileEditorTool templateTool = WMMobileEditorTool.TemplatePicker;
    private WMMobileEditorTool colorTool = WMMobileEditorTool.ColorStyle;
    private WMMobileEditorTool multiFrameTool = WMMobileEditorTool.MultiFrameMaterial;
    private WMMobileEditorTool collageTool = WMMobileEditorTool.CollageMaterial;
    private WMHslBand colorBand = WMHslBand.Red;
    private WMWorkspaceMode? lastMode;
    private WMMobileToolPresentation? lastPresentation;

    public bool TryCloseTransient() => false;

    public Task ConfirmCurrentEditAsync() =>
        State.HasTransientEdits && State.TransientEditMode == State.Mode
            ? EditConfirmed.InvokeAsync(State.Mode)
            : Task.CompletedTask;

    private int SelectedCount => State.Media.Count(item => item.IsSelected);
    private bool HasCategoryDraft => State.HasTransientEdits && State.TransientEditMode is not null;
    private string ModeLabel => State.Mode switch
    {
        WMWorkspaceMode.ColorGrade => "调色",
        WMWorkspaceMode.MultiFrame => "多帧",
        WMWorkspaceMode.Collage => "拼图",
        _ => "模板"
    };
    private WMMobileEditorTool ActiveTool => State.Mode switch
    {
        WMWorkspaceMode.ColorGrade => colorTool,
        WMWorkspaceMode.MultiFrame => multiFrameTool,
        WMWorkspaceMode.Collage => collageTool,
        _ => templateTool
    };
    private IReadOnlyList<MobileToolSpec> CurrentTools => State.Mode switch
    {
        WMWorkspaceMode.ColorGrade => ColorTools,
        WMWorkspaceMode.MultiFrame => MultiFrameTools,
        WMWorkspaceMode.Collage => CollageTools,
        _ => TemplateTools
    };
    private MobileToolSpec ActiveSpec => CurrentTools.First(item => item.Tool == ActiveTool);
    private WMMobileToolPresentation Presentation => new(
        State.Mode, ActiveTool, ActiveSpec.Space, WMMobileEditorHostKind.Dock);
    private string SpaceClass => $"is-{Presentation.Space.ToString().ToLowerInvariant()}";

    protected override Task OnParametersSetAsync()
    {
        if (lastMode == State.Mode && Equals(lastPresentation, Presentation)) return Task.CompletedTask;
        lastMode = State.Mode;
        return PublishPresentationAsync();
    }

    private RenderFragment ModeButton(WMWorkspaceMode mode, string label, string icon) => __builder =>
    {
        var active = State.Mode == mode;
        <button type="button" class="@(active ? "is-active" : null)" role="tab"
                aria-selected="@active" disabled="@ModeSwitchDisabled(mode)"
                @onclick="() => ChangeModeAsync(mode)">
            <MIcon>@icon</MIcon><span>@label</span>
            @if (!active && HasCategoryDraft) { <MIcon Class="wm-dock-lock">mdi-lock</MIcon> }
        </button>
    };

    private RenderFragment ActiveToolContent => ActiveTool switch
    {
        WMMobileEditorTool.TemplatePicker => TemplatePickerContent,
        WMMobileEditorTool.TemplateScope or WMMobileEditorTool.ColorScope => ScopeContent,
        WMMobileEditorTool.TemplateBorderTop or WMMobileEditorTool.TemplateBorderRight
            or WMMobileEditorTool.TemplateBorderBottom or WMMobileEditorTool.TemplateBorderLeft => TemplateBorderContent,
        WMMobileEditorTool.ColorStyle => ColorStyleContent,
        WMMobileEditorTool.ColorPresets => ColorPresetContent,
        WMMobileEditorTool.ColorCurve => ColorCurveContent,
        WMMobileEditorTool.ColorReference => ColorReferenceContent,
        WMMobileEditorTool.ColorHslHue or WMMobileEditorTool.ColorHslSaturation
            or WMMobileEditorTool.ColorHslLuminance => HslContent,
        WMMobileEditorTool.ColorExposure or WMMobileEditorTool.ColorContrast
            or WMMobileEditorTool.ColorHighlights or WMMobileEditorTool.ColorShadows
            or WMMobileEditorTool.ColorWhites or WMMobileEditorTool.ColorBlacks
            or WMMobileEditorTool.ColorTemperature or WMMobileEditorTool.ColorTint
            or WMMobileEditorTool.ColorVibrance or WMMobileEditorTool.ColorSaturation => ColorParameterContent,
        WMMobileEditorTool.MultiFrameMaterial => MultiFrameMaterialContent,
        WMMobileEditorTool.MultiFrameMode => MultiFrameModeContent,
        WMMobileEditorTool.MultiFrameParameters => MultiFrameParametersContent,
        WMMobileEditorTool.MultiFrameGenerate => MultiFrameGenerateContent,
        WMMobileEditorTool.CollageMaterial => CollageMaterialContent,
        WMMobileEditorTool.CollageLayout => CollageLayoutContent,
        WMMobileEditorTool.CollageGenerate => CollageGenerateContent,
        _ => __builder => { }
    };

    private RenderFragment TemplatePickerContent => __builder =>
    {
        <div class="wm-dock-heading">
            <div><strong>选择模板</strong><small>@Templates.Count 个模板</small></div>
            <div class="wm-dock-scope-pills" role="group" aria-label="模板应用范围">
                <button type="button" class="@(State.ApplyScope == WMApplyScope.Current ? "is-active" : null)" @onclick="() => ChangeScopeAsync(WMApplyScope.Current)">当前图片</button>
                <button type="button" class="@(State.ApplyScope == WMApplyScope.Selected ? "is-active" : null)" @onclick="() => ChangeScopeAsync(WMApplyScope.Selected)">已选 @SelectedCount</button>
            </div>
        </div>
        <WMToolRail AriaLabel="模板列表" CssClass="wm-dock-card-rail">
            <button type="button" class="wm-dock-template-card @(State.TemplateId is null ? "is-active" : null)"
                    @onclick="() => PreviewTemplateAsync(null)"><span><MIcon>mdi-cancel</MIcon></span><small>无模板</small></button>
            @foreach (var template in Templates)
            {
                <button type="button" class="wm-dock-template-card wm-template-card @(State.TemplateId == template.ID ? "is-active" : null)"
                        data-template-id="@template.ID" @onclick="() => PreviewTemplateAsync(template.ID)">
                    <span>@if (!string.IsNullOrWhiteSpace(template.Src)) { <img src="@template.Src" alt="" /> } else { <MIcon>mdi-image-outline</MIcon> }</span>
                    <small>@(template.Canvas?.Name ?? "未命名")</small>
                </button>
            }
        </WMToolRail>
    };

    private RenderFragment TemplateBorderContent => __builder =>
    {
        if (CurrentCanvas is not { } canvas)
        {
            <p class="wm-dock-empty">先选择一个模板，再调整画布边框。</p>
            return;
        }
        var side = BorderSide(ActiveTool);
        var parameter = BorderParameter(canvas, side);
        <div class="wm-dock-parameter-editor">
            <header><strong>@parameter.Label</strong><output>@parameter.Value.ToString("0.#")</output></header>
            <WMTemplateBorderControl Label="@parameter.Label" Value="@parameter.Value" ShowHeader="false"
                PreviewValueChanged="value => ChangeBorderAsync(side, value)"
                CommitValueChanged="value => ChangeBorderAsync(side, value)" />
        </div>
    };

    private RenderFragment ScopeContent => __builder =>
    {
        <div class="wm-dock-centered-control">
            <WMApplyScopeSelector Value="State.ApplyScope" ValueChanged="ChangeScopeAsync" SelectedCount="SelectedCount" />
        </div>
    };

    private RenderFragment ColorStyleContent => __builder =>
    {
        <div class="wm-dock-look-content">
            <div class="wm-dock-heading"><div><strong>快捷风格</strong><small>预览中 · 顶部应用后写入历史</small></div></div>
            <WMToolRail AriaLabel="快捷风格" CssClass="wm-dock-card-rail wm-dock-look-rail">
                @LookCard("自然", "mdi-leaf", 0, 0, 0, 0)
                @LookCard("清透", "mdi-weather-sunny", .2f, 12, 8, 10)
                @LookCard("电影", "mdi-movie-open-outline", -.1f, 18, -10, 8)
                @LookCard("明亮", "mdi-white-balance-sunny", .35f, -5, 16, 10)
                @ChoiceCard("重置", "mdi-restore", false, ResetColorPreviewAsync)
            </WMToolRail>
        </div>
    };

    private RenderFragment ColorParameterContent => __builder =>
    {
        var parameter = ColorParameter(ActiveTool);
        <div class="wm-dock-parameter-editor">
            <header><strong>@parameter.Label</strong><output>@DisplayValue(parameter.Value, parameter.Unit)</output></header>
            <WMColorParameterControl Label="@parameter.Label" Value="@parameter.Value"
                Minimum="@parameter.Minimum" Maximum="@parameter.Maximum" Step="@parameter.Step" Unit="@parameter.Unit"
                ShowHeader="false" PreviewValueChanged="value => ChangeColorAsync(parameter.Key, value)"
                CommitValueChanged="value => ChangeColorAsync(parameter.Key, value)" />
        </div>
    };

    private RenderFragment HslContent => __builder =>
    {
        var parameter = HslParameter(ActiveTool);
        <div class="wm-dock-hsl-control">
            <nav class="wm-dock-hsl-bands" aria-label="HSL 色彩范围">
                @foreach (var band in Enum.GetValues<WMHslBand>())
                {
                    <button type="button" class="@(colorBand == band ? "is-active" : null)" aria-pressed="@(colorBand == band)" @onclick="() => colorBand = band">@BandName(band)</button>
                }
            </nav>
            <div class="wm-dock-parameter-editor">
                <header><strong>@parameter.Label</strong><output>@parameter.Value.ToString("0")</output></header>
                <WMColorParameterControl Label="@parameter.Label" Value="@parameter.Value" Minimum="-100" Maximum="100" Step="1"
                    ShowHeader="false" PreviewValueChanged="value => ChangeHslAsync(parameter.Key, value)"
                    CommitValueChanged="value => ChangeHslAsync(parameter.Key, value)" />
            </div>
        </div>
    };

    private RenderFragment ColorPresetContent => __builder =>
    {
        <div class="wm-dock-heading"><div><strong>调色预设</strong><small>选择后先预览，不会直接提交</small></div></div>
        <WMToolRail AriaLabel="调色预设" CssClass="wm-dock-card-rail wm-dock-preset-rail">
            @foreach (var preset in State.ColorGradeTool.Presets)
            {
                <button type="button" class="wm-dock-preset-card @(State.ColorGradeTool.SelectedPresetId == preset.Id ? "is-active" : null)"
                        @onclick="() => PreviewPresetAsync(preset)"><MIcon>mdi-palette-outline</MIcon><span>@preset.Name</span><small>预览</small></button>
            }
            @ChoiceCard("重置", "mdi-restore", false, ResetColorPreviewAsync)
            @UtilityCard("保存预设", "mdi-content-save-outline", SavePresetRequested)
            @if (!string.IsNullOrWhiteSpace(State.ColorGradeTool.SelectedPresetId))
            {
                @UtilityCard("删除预设", "mdi-delete-outline", DeletePresetRequested, danger: true)
            }
        </WMToolRail>
    };

    private RenderFragment ColorCurveContent => __builder =>
    {
        <WMMobileMasterCurve Points="State.ColorGradeTool.Draft.Grade.MasterCurve" PointsChanged="ChangeCurvePointsAsync" />
    };

    private RenderFragment ColorReferenceContent => __builder =>
    {
        <div class="wm-dock-reference">
            @if (!string.IsNullOrWhiteSpace(State.ColorGradeTool.Reference.PreviewUrl))
            {
                <figure><img src="@State.ColorGradeTool.Reference.PreviewUrl" alt="参考图片" /><figcaption><strong>@(State.ColorGradeTool.Reference.DisplayName ?? "参考图")</strong><small>已生成调色预览草稿</small></figcaption></figure>
                <button type="button" @onclick="ClearReferenceRequested"><MIcon>mdi-image-remove-outline</MIcon><span>清除</span></button>
            }
            else
            {
                <button type="button" class="is-picker" disabled="@State.ColorGradeTool.IsBusy" @onclick="ChooseReferenceRequested"><MIcon>mdi-image-search-outline</MIcon><span><strong>选择参考图</strong><small>分析色彩后生成预览草稿</small></span></button>
            }
        </div>
    };

    private RenderFragment MultiFrameMaterialContent => __builder =>
    {
        <div class="wm-dock-heading"><div><strong>素材排序</strong><small>@State.Media.Count 张素材</small></div></div>
        <WMToolRail AriaLabel="多帧素材角色" CssClass="wm-dock-media-rail">
            @foreach (var media in State.Media)
            {
                var role = FrameRole(media.Id);
                <article class="wm-dock-media-card">
                    @MediaThumbnail(media)<strong>@media.DisplayName</strong>
                    <div><button type="button" class="@(role == WMFrameRole.Light ? "is-active" : null)" @onclick="() => ChangeFrameRoleAsync(media.Id, WMFrameRole.Light)">亮场</button><button type="button" class="@(role == WMFrameRole.Dark ? "is-active" : null)" @onclick="() => ChangeFrameRoleAsync(media.Id, WMFrameRole.Dark)">暗场</button></div>
                </article>
            }
        </WMToolRail>
    };

    private RenderFragment MultiFrameModeContent => __builder =>
    {
        if (State.MultiFrameTool.Capability?.IsAvailable != true)
        {
            <div class="wm-dock-unavailable"><MIcon>mdi-weather-night</MIcon><span>@(State.MultiFrameTool.Capability?.UnavailableReason ?? "当前设备暂未开放多帧处理")</span></div>
        }
        else
        {
            <WMToolRail AriaLabel="多帧模式" CssClass="wm-dock-card-rail">
                @ChoiceCard("星轨", "mdi-star-four-points-outline", State.MultiFrameTool.Draft.Mode == WMStackMode.StarTrail, () => ChangeMultiFrameModeAsync(WMStackMode.StarTrail))
                @ChoiceCard("静态星空 / 降噪", "mdi-weather-night", State.MultiFrameTool.Draft.Mode == WMStackMode.StaticSky, () => ChangeMultiFrameModeAsync(WMStackMode.StaticSky))
            </WMToolRail>
        }
    };

    private RenderFragment MultiFrameParametersContent => __builder =>
    {
        <WMToolRail AriaLabel="多帧参数" CssClass="wm-dock-card-rail">
            @ToggleCard("曝光归一", State.MultiFrameTool.Draft.NormalizeExposure, NormalizeExposureChanged)
            @ToggleCard("坏点修复", State.MultiFrameTool.Draft.RepairHotPixels, RepairHotPixelsChanged)
            @ToggleCard("自动裁剪", State.MultiFrameTool.Draft.AutoCrop, AutoCropChanged)
        </WMToolRail>
    };

    private RenderFragment MultiFrameGenerateContent => __builder =>
    {
        <div class="wm-dock-generate">
            <div><strong>@State.MultiFrameTool.Draft.Roles.Count(pair => pair.Value == WMFrameRole.Light) 张亮场</strong><span>@(State.MultiFrameTool.Draft.Mode == WMStackMode.StarTrail ? "星轨合成" : "静态星空 / 降噪")</span></div>
            <button type="button" disabled="@(State.MultiFrameTool.IsBusy || State.MultiFrameTool.Capability?.IsAvailable != true)" @onclick="MultiFrameRunRequested"><MIcon>mdi-layers-triple-outline</MIcon><span>@(State.MultiFrameTool.IsBusy ? "处理中…" : "生成多帧结果")</span></button>
        </div>
    };

    private RenderFragment CollageMaterialContent => __builder =>
    {
        <div class="wm-dock-heading"><div><strong>素材排序</strong><small>@State.CollageTool.Draft.OrderedMediaIds.Count 张素材</small></div></div>
        <WMToolRail AriaLabel="拼图素材" CssClass="wm-dock-media-rail">
            @foreach (var media in OrderedCollageMedia)
            {
                var index = IndexOfCollage(media.Id);
                <article class="wm-dock-media-card">
                    @MediaThumbnail(media)<strong>@(index + 1). @media.DisplayName</strong>
                    <div><button type="button" disabled="@(index == 0)" @onclick="() => MoveCollageAsync(media.Id, -1)" aria-label="前移"><MIcon>mdi-chevron-left</MIcon></button><button type="button" @onclick="() => ToggleCollageAsync(media.Id)" aria-label="移除"><MIcon>mdi-close</MIcon></button></div>
                </article>
            }
            @foreach (var media in AvailableCollageMedia)
            {
                <button type="button" class="wm-dock-media-add" @onclick="() => ToggleCollageAsync(media.Id)">@MediaThumbnail(media)<span><MIcon>mdi-plus</MIcon>@media.DisplayName</span></button>
            }
        </WMToolRail>
    };

    private RenderFragment CollageLayoutContent => __builder =>
    {
        <WMToolRail AriaLabel="拼图布局" CssClass="wm-dock-card-rail">
            @ChoiceCard("横向", "mdi-arrow-expand-horizontal", State.CollageTool.Draft.Direction == WMCollageDirection.Horizontal, () => ChangeCollageDirectionAsync(WMCollageDirection.Horizontal))
            @ChoiceCard("纵向", "mdi-arrow-expand-vertical", State.CollageTool.Draft.Direction == WMCollageDirection.Vertical, () => ChangeCollageDirectionAsync(WMCollageDirection.Vertical))
        </WMToolRail>
    };

    private RenderFragment CollageGenerateContent => __builder =>
    {
        <div class="wm-dock-generate">
            <div><strong>@State.CollageTool.Draft.OrderedMediaIds.Count 张素材</strong><span>@(State.CollageTool.Draft.Direction == WMCollageDirection.Horizontal ? "横向拼接" : "纵向拼接") · 间距 0 · 白色背景</span></div>
            <button type="button" disabled="@(!State.CollageTool.IsBusy && State.CollageTool.Draft.OrderedMediaIds.Count < 2)" @onclick="CollageRunOrCancelRequested"><MIcon>@(State.CollageTool.IsBusy ? "mdi-stop-circle-outline" : "mdi-view-split-vertical")</MIcon><span>@(State.CollageTool.IsBusy ? "取消生成" : "生成拼图")</span></button>
        </div>
    };

    private RenderFragment LookCard(string label, string icon, float exposure, float contrast, float temperature, float vibrance) =>
        ChoiceCard(label, icon, string.Equals(State.ColorGradeTool.Draft.Name, label, StringComparison.Ordinal),
            () => ApplyLookAsync(label, exposure, contrast, temperature, vibrance));

    private RenderFragment ChoiceCard(string label, string icon, bool active, Func<Task> action) => __builder =>
    {
        <button type="button" class="wm-dock-control-card @(active ? "is-active" : null)" aria-pressed="@active" @onclick="action"><MIcon>@icon</MIcon><span>@label</span></button>
    };

    private RenderFragment ToggleCard(string label, bool value, EventCallback<bool> changed) => __builder =>
    {
        <button type="button" class="wm-dock-control-card @(value ? "is-active" : null)" role="switch" aria-checked="@value" @onclick="() => changed.InvokeAsync(!value)"><MIcon>@(value ? "mdi-toggle-switch" : "mdi-toggle-switch-off-outline")</MIcon><span>@label</span></button>
    };

    private RenderFragment UtilityCard(string label, string icon, EventCallback action, bool danger = false) => __builder =>
    {
        <button type="button" class="wm-dock-control-card @(danger ? "is-danger" : null)" @onclick="action"><MIcon>@icon</MIcon><span>@label</span></button>
    };

    private async Task SelectToolAsync(WMMobileEditorTool tool)
    {
        switch (State.Mode)
        {
            case WMWorkspaceMode.ColorGrade: colorTool = tool; break;
            case WMWorkspaceMode.MultiFrame: multiFrameTool = tool; break;
            case WMWorkspaceMode.Collage: collageTool = tool; break;
            default: templateTool = tool; break;
        }
        await PublishPresentationAsync();
    }

    private async Task ChangeModeAsync(WMWorkspaceMode mode)
    {
        if (State.Mode == mode || ModeSwitchDisabled(mode)) return;
        await ModeChanged.InvokeAsync(mode);
    }

    private bool ModeSwitchDisabled(WMWorkspaceMode mode) =>
        State.Mode != mode && (HasCategoryDraft || State.MultiFrameTool.IsBusy || State.CollageTool.IsBusy);

    private async Task PublishPresentationAsync()
    {
        var next = Presentation;
        if (Equals(lastPresentation, next)) return;
        lastPresentation = next;
        await PresentationChanged.InvokeAsync(next);
    }

    private Task ChangeScopeAsync(WMApplyScope scope) => ScopeChanged.InvokeAsync(scope);

    private Task PreviewTemplateAsync(string? templateId)
    {
        if (string.Equals(State.TemplateId, templateId, StringComparison.Ordinal) && !State.HasTransientEdits)
            return Task.CompletedTask;
        return TemplatePreviewChanged.InvokeAsync(CreateTemplateEdit(templateId));
    }

    private WMWorkspaceTemplateEdit CreateTemplateEdit(string? templateId)
    {
        if (templateId is null) return new WMWorkspaceTemplateEdit(null, null);
        if (State.TemplateEdit?.TemplateId == templateId) return State.TemplateEdit;
        var canvas = Templates.FirstOrDefault(item => item.ID == templateId)?.Canvas;
        return new WMWorkspaceTemplateEdit(
            templateId,
            canvas is null ? null : Global.CanvasSerialize(canvas));
    }

    private Task ChangeBorderAsync(string side, double value)
    {
        if (CurrentCanvas is not { } current) return Task.CompletedTask;
        var next = WMWorkspacePanelMutations.SetBorder(current, side, value);
        return TemplatePreviewChanged.InvokeAsync(new WMWorkspaceTemplateEdit(State.TemplateId, Global.CanvasSerialize(next)));
    }

    private WMCanvas? CurrentCanvas
    {
        get
        {
            try
            {
                if (State.TemplateEdit is { CanvasJson.Length: > 0 } && State.TemplateEdit.TemplateId == State.TemplateId)
                    return Global.ReadConfig(State.TemplateEdit.CanvasJson);
                return Templates.FirstOrDefault(item => item.ID == State.TemplateId)?.Canvas;
            }
            catch { return null; }
        }
    }

    private Task ChangeColorAsync(string key, float value)
    {
        var next = WMWorkspacePanelMutations.SetColorValue(State.ColorGradeTool.Draft, key, value);
        return ColorPreviewChanged.InvokeAsync(next);
    }

    private Task ChangeHslAsync(string key, float value)
    {
        var next = WMColorRecipeSnapshot.Copy(State.ColorGradeTool.Draft)!;
        var adjustment = next.Grade.Hsl[colorBand];
        switch (key)
        {
            case "HslSaturation": adjustment.Saturation = value; break;
            case "HslLuminance": adjustment.Luminance = value; break;
            default: adjustment.Hue = value; break;
        }
        next.UserAdjustments = next.Grade;
        return ColorPreviewChanged.InvokeAsync(next);
    }

    private Task ChangeCurvePointsAsync(IReadOnlyList<WMCurvePoint> points)
    {
        var next = WMColorRecipeSnapshot.Copy(State.ColorGradeTool.Draft)!;
        next.Grade.MasterCurve = points.Select(point => new WMCurvePoint { X = point.X, Y = point.Y }).ToList();
        next.UserAdjustments = next.Grade;
        return ColorPreviewChanged.InvokeAsync(next);
    }

    private Task ApplyLookAsync(string name, float exposure, float contrast, float temperature, float vibrance) =>
        ColorPreviewChanged.InvokeAsync(WMWorkspacePanelMutations.QuickLook(name, exposure, contrast, temperature, vibrance));

    private Task PreviewPresetAsync(WMColorRecipe preset) => ColorPreviewChanged.InvokeAsync(preset);
    private Task ResetColorPreviewAsync() => ColorPreviewChanged.InvokeAsync(new WMColorRecipe { Name = "移动端调整" });

    private Task ChangeMultiFrameModeAsync(WMStackMode mode) => MultiFrameModeChanged.InvokeAsync(mode);
    private Task ChangeFrameRoleAsync(string mediaId, WMFrameRole role) => FrameRoleChanged.InvokeAsync(new WMFrameRoleChange(mediaId, role));

    private Task ChangeCollageDirectionAsync(WMCollageDirection direction) =>
        CollageDraftChanged.InvokeAsync(State.CollageTool.Draft with { Direction = direction });

    private WMFrameRole? FrameRole(string mediaId) =>
        State.MultiFrameTool.Draft.Roles.TryGetValue(mediaId, out var role) ? role : null;

    private IReadOnlyList<WMWorkspaceMedia> OrderedCollageMedia
    {
        get
        {
            var byId = State.Media.ToDictionary(item => item.Id, StringComparer.Ordinal);
            return State.CollageTool.Draft.OrderedMediaIds.Where(byId.ContainsKey).Select(id => byId[id]).ToArray();
        }
    }

    private IReadOnlyList<WMWorkspaceMedia> AvailableCollageMedia
    {
        get
        {
            var selected = State.CollageTool.Draft.OrderedMediaIds.ToHashSet(StringComparer.Ordinal);
            return State.Media.Where(item => !selected.Contains(item.Id)).ToArray();
        }
    }

    private int IndexOfCollage(string mediaId)
    {
        for (var index = 0; index < State.CollageTool.Draft.OrderedMediaIds.Count; index++)
            if (string.Equals(State.CollageTool.Draft.OrderedMediaIds[index], mediaId, StringComparison.Ordinal)) return index;
        return -1;
    }

    private Task ToggleCollageAsync(string mediaId)
    {
        var next = State.CollageTool.Draft.OrderedMediaIds.ToList();
        if (!next.Remove(mediaId)) next.Add(mediaId);
        return CollageDraftChanged.InvokeAsync(State.CollageTool.Draft with { OrderedMediaIds = next });
    }

    private Task MoveCollageAsync(string mediaId, int offset)
    {
        var next = State.CollageTool.Draft.OrderedMediaIds.ToList();
        var current = next.FindIndex(id => string.Equals(id, mediaId, StringComparison.Ordinal));
        var target = current + offset;
        if (current < 0 || target < 0 || target >= next.Count) return Task.CompletedTask;
        (next[current], next[target]) = (next[target], next[current]);
        return CollageDraftChanged.InvokeAsync(State.CollageTool.Draft with { OrderedMediaIds = next });
    }

    private (string Key, string Label, float Value, double Minimum, double Maximum, double Step, string Unit) ColorParameter(WMMobileEditorTool tool)
    {
        var key = tool switch
        {
            WMMobileEditorTool.ColorContrast => "Contrast",
            WMMobileEditorTool.ColorHighlights => "Highlights",
            WMMobileEditorTool.ColorShadows => "Shadows",
            WMMobileEditorTool.ColorWhites => "Whites",
            WMMobileEditorTool.ColorBlacks => "Blacks",
            WMMobileEditorTool.ColorTemperature => "Temperature",
            WMMobileEditorTool.ColorTint => "Tint",
            WMMobileEditorTool.ColorVibrance => "Vibrance",
            WMMobileEditorTool.ColorSaturation => "Saturation",
            _ => "Exposure"
        };
        return key switch
        {
            "Exposure" => (key, "曝光", State.ColorGradeTool.Draft.Grade.Exposure, -5, 5, .05, "EV"),
            "Contrast" => (key, "对比度", State.ColorGradeTool.Draft.Grade.Contrast, -100, 100, 1, ""),
            "Highlights" => (key, "高光", State.ColorGradeTool.Draft.Grade.Highlights, -100, 100, 1, ""),
            "Shadows" => (key, "阴影", State.ColorGradeTool.Draft.Grade.Shadows, -100, 100, 1, ""),
            "Whites" => (key, "白色", State.ColorGradeTool.Draft.Grade.Whites, -100, 100, 1, ""),
            "Blacks" => (key, "黑色", State.ColorGradeTool.Draft.Grade.Blacks, -100, 100, 1, ""),
            "Temperature" => (key, "色温", State.ColorGradeTool.Draft.Grade.Temperature, -100, 100, 1, ""),
            "Tint" => (key, "色调", State.ColorGradeTool.Draft.Grade.Tint, -100, 100, 1, ""),
            "Vibrance" => (key, "自然饱和度", State.ColorGradeTool.Draft.Grade.Vibrance, -100, 100, 1, ""),
            _ => (key, "饱和度", State.ColorGradeTool.Draft.Grade.Saturation, -100, 100, 1, "")
        };
    }

    private (string Key, string Label, float Value) HslParameter(WMMobileEditorTool tool)
    {
        var adjustment = State.ColorGradeTool.Draft.Grade.Hsl[colorBand];
        return tool switch
        {
            WMMobileEditorTool.ColorHslSaturation => ("HslSaturation", $"{BandName(colorBand)}饱和度", adjustment.Saturation),
            WMMobileEditorTool.ColorHslLuminance => ("HslLuminance", $"{BandName(colorBand)}明度", adjustment.Luminance),
            _ => ("HslHue", $"{BandName(colorBand)}色相", adjustment.Hue)
        };
    }

