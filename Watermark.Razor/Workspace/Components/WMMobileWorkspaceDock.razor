@using Watermark.Shared.Models
@namespace Watermark.Razor.Workspace.Components

<section class="wm-mobile-dock @(State.PanelSize == WMWorkspacePanelSize.Collapsed ? "is-collapsed" : null) @(advancedOpen ? "is-advanced" : null) @(isEditing ? "is-editing" : "is-mode-picker")"
         aria-label="移动编辑工具">
    <button type="button" class="wm-dock-handle"
            role="separator" aria-orientation="horizontal"
            aria-label="拖动调整工具坞高度"><span aria-hidden="true"></span></button>
    <span class="wm-dock-safe-bottom-probe" aria-hidden="true"></span>

    @if (State.PanelSize != WMWorkspacePanelSize.Collapsed)
    {
        <div class="wm-dock-context">
            @if (advancedOpen)
            {
                <header class="wm-dock-advanced-heading">
                    <button type="button" @onclick="CloseAdvanced" aria-label="返回常用工具"><MIcon>mdi-chevron-down</MIcon></button>
                    <div><strong>@AdvancedTitle</strong><small>高级设置</small></div>
                    <button type="button" class="wm-dock-confirm-edit" disabled="@(!isEditing || isConfirming)" @onclick="ConfirmEditAsync" @onclick:stopPropagation="true" aria-label="确认并完成@ModeLabel编辑"><MIcon>mdi-check</MIcon></button>
                </header>
                <div class="wm-dock-advanced-content">
                    @AdvancedContent
                </div>
            }
            else
            {
                @if (isEditing)
                {
                    <div class="wm-dock-active-row">
                        <div class="wm-dock-active-slot">
                            @if (activeAdjustmentVisible)
                            {
                                @ActiveControl
                            }
                            else
                            {
                                <div class="wm-dock-edit-summary"><strong>@ModeLabel</strong><small>完成当前功能设置</small></div>
                            }
                        </div>
                        <button type="button" class="wm-dock-confirm-edit" disabled="@isConfirming" @onclick="ConfirmEditAsync" @onclick:stopPropagation="true" aria-label="确认并完成@ModeLabel编辑"><MIcon>mdi-check</MIcon></button>
                    </div>
                }
                <div class="wm-dock-configuration">
                    @SubcategoryRail
                    <div class="wm-dock-content">
                        @StandardContent
                    </div>
                </div>
            }
        </div>
    }

    <nav class="wm-dock-modes" role="tablist" aria-label="编辑模式">
        <button type="button" class="@(State.Mode == WMWorkspaceMode.Template ? "is-active" : null)"
                role="tab" aria-selected="@(State.Mode == WMWorkspaceMode.Template)"
                disabled="@ModeSwitchDisabled(WMWorkspaceMode.Template)"
                @onclick="() => ChangeModeAsync(WMWorkspaceMode.Template)"><span class="wm-dock-mode-label">模板</span></button>
        <button type="button" class="@(State.Mode == WMWorkspaceMode.ColorGrade ? "is-active" : null)"
                role="tab" aria-selected="@(State.Mode == WMWorkspaceMode.ColorGrade)"
                disabled="@ModeSwitchDisabled(WMWorkspaceMode.ColorGrade)"
                @onclick="() => ChangeModeAsync(WMWorkspaceMode.ColorGrade)"><span class="wm-dock-mode-label">调色</span></button>
        <button type="button" class="@(State.Mode == WMWorkspaceMode.MultiFrame ? "is-active" : null)"
                role="tab" aria-selected="@(State.Mode == WMWorkspaceMode.MultiFrame)"
                disabled="@ModeSwitchDisabled(WMWorkspaceMode.MultiFrame)"
                @onclick="() => ChangeModeAsync(WMWorkspaceMode.MultiFrame)"><span class="wm-dock-mode-label">多帧</span></button>
        <button type="button" class="@(State.Mode == WMWorkspaceMode.Collage ? "is-active" : null)"
                role="tab" aria-selected="@(State.Mode == WMWorkspaceMode.Collage)"
                disabled="@ModeSwitchDisabled(WMWorkspaceMode.Collage)"
                @onclick="() => ChangeModeAsync(WMWorkspaceMode.Collage)"><span class="wm-dock-mode-label">拼图</span></button>
    </nav>
</section>

@code {
    [Parameter, EditorRequired] public WMWorkspaceState State { get; set; } = new();
    [Parameter] public IReadOnlyList<WMTemplateList> Templates { get; set; } = [];
    [Parameter] public EventCallback<WMWorkspaceMode> ModeChanged { get; set; }
    [Parameter] public EventCallback<WMWorkspaceMode> EditConfirmed { get; set; }
    [Parameter] public EventCallback<WMApplyScope> ScopeChanged { get; set; }
    [Parameter] public EventCallback<WMWorkspaceTemplateEdit> TemplatePreviewChanged { get; set; }
    [Parameter] public EventCallback<WMColorRecipe> ColorPreviewChanged { get; set; }
    [Parameter] public EventCallback ChooseReferenceRequested { get; set; }
    [Parameter] public EventCallback ClearReferenceRequested { get; set; }
    [Parameter] public EventCallback SavePresetRequested { get; set; }
    [Parameter] public EventCallback DeletePresetRequested { get; set; }
    [Parameter] public EventCallback<WMStackMode> MultiFrameModeChanged { get; set; }
    [Parameter] public EventCallback<WMFrameRoleChange> FrameRoleChanged { get; set; }
    [Parameter] public EventCallback<bool> NormalizeExposureChanged { get; set; }
    [Parameter] public EventCallback<bool> RepairHotPixelsChanged { get; set; }
    [Parameter] public EventCallback<bool> AutoCropChanged { get; set; }
    [Parameter] public EventCallback MultiFrameRunRequested { get; set; }
    [Parameter] public EventCallback<WMCollageDraft> CollageDraftChanged { get; set; }
    [Parameter] public EventCallback CollageRunOrCancelRequested { get; set; }

    private TemplateSection templateSection = TemplateSection.Template;
    private ColorSection colorSection = ColorSection.Light;
    private MultiFrameSection multiFrameSection = MultiFrameSection.Mode;
    private CollageSection collageSection = CollageSection.Material;
    private string colorParameter = "Exposure";
    private string borderSide = "Top";
    private bool advancedOpen;
    private bool isEditing;
    private bool isConfirming;
    private bool activeAdjustmentVisible;

    public bool TryCloseTransient()
    {
        if (!advancedOpen) return false;
        advancedOpen = false;
        _ = InvokeAsync(StateHasChanged);
        return true;
    }

    private int SelectedCount => State.Media.Count(item => item.IsSelected);
    private string ModeLabel => State.Mode switch
    {
        WMWorkspaceMode.ColorGrade => "调色",
        WMWorkspaceMode.MultiFrame => "多帧",
        WMWorkspaceMode.Collage => "拼图",
        _ => "模板"
    };
    private string AdvancedTitle => State.Mode switch
    {
        WMWorkspaceMode.ColorGrade => "高级调色",
        WMWorkspaceMode.MultiFrame => "多帧详情",
        WMWorkspaceMode.Collage => "拼图详情",
        _ => "模板详情"
    };

    private RenderFragment ActiveControl => __builder =>
    {
        if (State.Mode == WMWorkspaceMode.ColorGrade && colorSection is ColorSection.Light or ColorSection.Color)
        {
            var parameter = ColorParameter(colorParameter);
            <div class="wm-dock-active-control">
                <WMColorParameterControl Label="@parameter.Label" Value="@parameter.Value"
                    Minimum="@parameter.Minimum" Maximum="@parameter.Maximum" Step="@parameter.Step" Unit="@parameter.Unit"
                    ShowHeader="false"
                    PreviewValueChanged="value => ChangeColorAsync(colorParameter, value)"
                    CommitValueChanged="value => ChangeColorAsync(colorParameter, value)" />
            </div>
        }
        else if (State.Mode == WMWorkspaceMode.Template && templateSection == TemplateSection.Border && CurrentCanvas is { } canvas)
        {
            var parameter = BorderParameter(canvas, borderSide);
            <div class="wm-dock-active-control">
                <WMTemplateBorderControl Label="@parameter.Label" Value="@parameter.Value"
                    ShowHeader="false"
                    PreviewValueChanged="value => ChangeBorderAsync(borderSide, value)"
                    CommitValueChanged="value => ChangeBorderAsync(borderSide, value)" />
            </div>
        }
    };

    private RenderFragment SubcategoryRail => __builder =>
    {
        <nav class="wm-dock-subcategories" aria-label="工具分类">
            @if (State.Mode == WMWorkspaceMode.Template)
            {
                @SectionButton("模板", templateSection == TemplateSection.Template, () => SelectTemplateSection(TemplateSection.Template))
                @SectionButton("边框", templateSection == TemplateSection.Border, () => SelectTemplateSection(TemplateSection.Border))
                @SectionButton("范围", templateSection == TemplateSection.Scope, () => SelectTemplateSection(TemplateSection.Scope))
            }
            else if (State.Mode == WMWorkspaceMode.ColorGrade)
            {
                @SectionButton("风格", colorSection == ColorSection.Style, () => SelectColorSection(ColorSection.Style))
                @SectionButton("光影", colorSection == ColorSection.Light, () => SelectColorSection(ColorSection.Light))
                @SectionButton("颜色", colorSection == ColorSection.Color, () => SelectColorSection(ColorSection.Color))
                @SectionButton("高级", false, OpenAdvancedAsync)
            }
            else if (State.Mode == WMWorkspaceMode.MultiFrame)
            {
                @SectionButton("模式", multiFrameSection == MultiFrameSection.Mode, () => SelectMultiFrameSection(MultiFrameSection.Mode))
                @SectionButton("素材", multiFrameSection == MultiFrameSection.Material, () => SelectMultiFrameSection(MultiFrameSection.Material))
                @SectionButton("参数", multiFrameSection == MultiFrameSection.Parameter, () => SelectMultiFrameSection(MultiFrameSection.Parameter))
            }
            else if (State.Mode == WMWorkspaceMode.Collage)
            {
                @SectionButton("素材", collageSection == CollageSection.Material, () => SelectCollageSection(CollageSection.Material))
                @SectionButton("布局", collageSection == CollageSection.Layout, () => SelectCollageSection(CollageSection.Layout))
                @SectionButton("生成", collageSection == CollageSection.Generate, () => SelectCollageSection(CollageSection.Generate))
            }
        </nav>
    };

    private RenderFragment SectionButton(string label, bool active, Action action) => __builder =>
    {
        <button type="button" class="@(active ? "is-active" : null)" aria-pressed="@active" @onclick="action">@label</button>
    };

    private RenderFragment SectionButton(string label, bool active, Func<Task> action) => __builder =>
    {
        <button type="button" class="@(active ? "is-active" : null)" aria-pressed="@active" @onclick="action">@label</button>
    };

    private RenderFragment StandardContent => State.Mode switch
    {
        WMWorkspaceMode.Template => TemplateContent,
        WMWorkspaceMode.ColorGrade => ColorContent,
        WMWorkspaceMode.MultiFrame => MultiFrameContent,
        WMWorkspaceMode.Collage => CollageContent,
        _ => __builder => { }
    };

    private RenderFragment TemplateContent => __builder =>
    {
        if (templateSection == TemplateSection.Template)
        {
            <WMToolRail AriaLabel="模板列表" CssClass="wm-dock-card-rail">
                <button type="button" class="wm-dock-template-card @(State.TemplateId is null ? "is-active" : null)"
                        @onclick="() => PreviewTemplateAsync(null)"><span><MIcon>mdi-cancel</MIcon></span><small>无模板</small></button>
                @foreach (var template in Templates)
                {
                    <button type="button" class="wm-dock-template-card wm-template-card @(State.TemplateId == template.ID ? "is-active" : null)"
                            data-template-id="@template.ID" @onclick="() => PreviewTemplateAsync(template.ID)">
                        <span>@if (!string.IsNullOrWhiteSpace(template.Src)) { <img src="@template.Src" alt="" /> } else { <MIcon>mdi-image-outline</MIcon> }</span>
                        <small>@(template.Canvas?.Name ?? "未命名")</small>
                    </button>
                }
            </WMToolRail>
        }
        else if (templateSection == TemplateSection.Border)
        {
            if (CurrentCanvas is null)
            {
                <p class="wm-dock-empty">先选择一个模板，再调整画布边框。</p>
            }
            else
            {
                <WMToolRail AriaLabel="边框参数" CssClass="wm-dock-card-rail">
                    @ParameterCard("上", CurrentCanvas.BorderThickness.Top, borderSide == "Top", () => borderSide = "Top")
                    @ParameterCard("右", CurrentCanvas.BorderThickness.Right, borderSide == "Right", () => borderSide = "Right")
                    @ParameterCard("下", CurrentCanvas.BorderThickness.Bottom, borderSide == "Bottom", () => borderSide = "Bottom")
                    @ParameterCard("左", CurrentCanvas.BorderThickness.Left, borderSide == "Left", () => borderSide = "Left")
                </WMToolRail>
            }
        }
        else
        {
            <WMApplyScopeSelector Value="State.ApplyScope" ValueChanged="ChangeScopeAsync" SelectedCount="SelectedCount" />
        }
    };

    private RenderFragment ColorContent => __builder =>
    {
        if (colorSection == ColorSection.Style)
        {
            <WMToolRail AriaLabel="调色风格" CssClass="wm-dock-card-rail">
                @LookCard("自然", "mdi-leaf", () => ApplyLookAsync("自然", 0, 0, 0, 0))
                @LookCard("清透", "mdi-weather-sunny", () => ApplyLookAsync("清透", .2f, 12, 8, 10))
                @LookCard("电影", "mdi-movie-open-outline", () => ApplyLookAsync("电影", -.1f, 18, -10, 8))
                @LookCard("明亮", "mdi-white-balance-sunny", () => ApplyLookAsync("明亮", .35f, -5, 16, 10))
                <button type="button" class="wm-dock-tool-card" disabled="@State.ColorGradeTool.IsBusy" @onclick="ChooseReferenceAsync">
                    @if (!string.IsNullOrWhiteSpace(State.ColorGradeTool.Reference.PreviewUrl))
                    {
                        <img src="@State.ColorGradeTool.Reference.PreviewUrl" alt="" />
                    }
                    else
                    {
                        <MIcon>mdi-image-search-outline</MIcon>
                    }
                    <span>参考图</span>
                </button>
                @foreach (var preset in State.ColorGradeTool.Presets)
                {
                    <button type="button" class="wm-dock-tool-card @(State.ColorGradeTool.SelectedPresetId == preset.Id ? "is-active" : null)"
                            @onclick="() => PreviewPresetAsync(preset)"><MIcon>mdi-palette-outline</MIcon><span>@preset.Name</span></button>
                }
            </WMToolRail>
        }
        else
        {
            var keys = colorSection == ColorSection.Color ? ColorKeys : LightKeys;
            <WMToolRail AriaLabel="调色参数" CssClass="wm-dock-card-rail">
                @foreach (var key in keys)
                {
                    var parameter = ColorParameter(key);
                    @ParameterCard(parameter.Label, parameter.Value, colorParameter == key, () => colorParameter = key, parameter.Icon)
                }
            </WMToolRail>
        }
    };

    private RenderFragment MultiFrameContent => __builder =>
    {
        if (State.MultiFrameTool.Capability?.IsAvailable != true)
        {
            <div class="wm-dock-unavailable"><MIcon>mdi-weather-night</MIcon><span>@(State.MultiFrameTool.Capability?.UnavailableReason ?? "当前设备暂未开放多帧处理")</span></div>
        }
        else if (multiFrameSection == MultiFrameSection.Mode)
        {
            <WMToolRail AriaLabel="多帧模式" CssClass="wm-dock-card-rail">
                @ChoiceCard("星轨", "mdi-star-four-points-outline", State.MultiFrameTool.Draft.Mode == WMStackMode.StarTrail, () => MultiFrameModeChanged.InvokeAsync(WMStackMode.StarTrail))
                @ChoiceCard("静态星空 / 降噪", "mdi-weather-night", State.MultiFrameTool.Draft.Mode == WMStackMode.StaticSky, () => MultiFrameModeChanged.InvokeAsync(WMStackMode.StaticSky))
            </WMToolRail>
        }
        else if (multiFrameSection == MultiFrameSection.Material)
        {
            <WMToolRail AriaLabel="多帧素材角色" CssClass="wm-dock-media-rail">
                @foreach (var media in State.Media)
                {
                    var role = FrameRole(media.Id);
                    <article class="wm-dock-media-card">
                        <img src="@Preview(media)" alt="" /><strong>@media.DisplayName</strong>
                        <div><button type="button" class="@(role == WMFrameRole.Light ? "is-active" : null)" @onclick="() => ChangeFrameRoleAsync(media.Id, WMFrameRole.Light)">Light</button><button type="button" class="@(role == WMFrameRole.Dark ? "is-active" : null)" @onclick="() => ChangeFrameRoleAsync(media.Id, WMFrameRole.Dark)">Dark</button></div>
                    </article>
                }
            </WMToolRail>
        }
        else
        {
            <WMToolRail AriaLabel="多帧参数" CssClass="wm-dock-card-rail">
                @ToggleCard("曝光归一", State.MultiFrameTool.Draft.NormalizeExposure, NormalizeExposureChanged)
                @ToggleCard("坏点修复", State.MultiFrameTool.Draft.RepairHotPixels, RepairHotPixelsChanged)
                @ToggleCard("自动裁剪", State.MultiFrameTool.Draft.AutoCrop, AutoCropChanged)
            </WMToolRail>
        }
        @if (State.MultiFrameTool.Capability?.IsAvailable == true)
        {
            <button type="button" class="wm-dock-primary-action" disabled="@State.MultiFrameTool.IsBusy" @onclick="MultiFrameRunRequested">
                <MIcon>mdi-layers-triple-outline</MIcon><span>@(State.MultiFrameTool.IsBusy ? "处理中…" : "开始合成")</span>
            </button>
        }
    };

    private RenderFragment CollageContent => __builder =>
    {
        if (collageSection == CollageSection.Material)
        {
            <WMToolRail AriaLabel="拼图素材" CssClass="wm-dock-media-rail">
                @foreach (var media in OrderedCollageMedia)
                {
                    var index = IndexOfCollage(media.Id);
                    <article class="wm-dock-media-card">
                        <img src="@Preview(media)" alt="" /><strong>@(index + 1). @media.DisplayName</strong>
                        <div><button type="button" disabled="@(index == 0)" @onclick="() => MoveCollageAsync(media.Id, -1)" aria-label="前移"><MIcon>mdi-chevron-left</MIcon></button><button type="button" @onclick="() => ToggleCollageAsync(media.Id)" aria-label="移除"><MIcon>mdi-close</MIcon></button></div>
                    </article>
                }
                @foreach (var media in AvailableCollageMedia)
                {
                    <button type="button" class="wm-dock-media-add" @onclick="() => ToggleCollageAsync(media.Id)"><img src="@Preview(media)" alt="" /><span><MIcon>mdi-plus</MIcon>@media.DisplayName</span></button>
                }
            </WMToolRail>
        }
        else if (collageSection == CollageSection.Layout)
        {
            <WMToolRail AriaLabel="拼图布局" CssClass="wm-dock-card-rail">
                @ChoiceCard("横向", "mdi-arrow-expand-horizontal", State.CollageTool.Draft.Direction == WMCollageDirection.Horizontal, () => ChangeCollageDirectionAsync(WMCollageDirection.Horizontal))
                @ChoiceCard("纵向", "mdi-arrow-expand-vertical", State.CollageTool.Draft.Direction == WMCollageDirection.Vertical, () => ChangeCollageDirectionAsync(WMCollageDirection.Vertical))
            </WMToolRail>
        }
        else
        {
            <div class="wm-dock-generate-summary"><strong>@State.CollageTool.Draft.OrderedMediaIds.Count 张素材</strong><span>@(State.CollageTool.Draft.Direction == WMCollageDirection.Horizontal ? "横向拼接" : "纵向拼接") · 间距 0 · 白色背景</span></div>
        }
        <button type="button" class="wm-dock-primary-action" disabled="@(!State.CollageTool.IsBusy && State.CollageTool.Draft.OrderedMediaIds.Count < 2)" @onclick="CollageRunOrCancelRequested">
            <MIcon>@(State.CollageTool.IsBusy ? "mdi-stop-circle-outline" : "mdi-view-split-vertical")</MIcon><span>@(State.CollageTool.IsBusy ? "取消生成" : "生成拼图")</span>
        </button>
    };

    private RenderFragment AdvancedContent => __builder =>
    {
        if (State.Mode == WMWorkspaceMode.ColorGrade)
        {
            <WMColorGradePanel Recipe="State.ColorGradeTool.Draft" Presets="State.ColorGradeTool.Presets"
                SelectedPresetId="State.ColorGradeTool.SelectedPresetId" ReferenceUrl="State.ColorGradeTool.Reference.PreviewUrl"
                ReferenceName="State.ColorGradeTool.Reference.DisplayName" Busy="State.ColorGradeTool.IsBusy"
                Scope="State.ApplyScope" ScopeChanged="ChangeScopeAsync" SelectedCount="SelectedCount"
                PreviewChanged="PreviewColorAsync" CommitRequested="PreviewColorAsync"
                ChooseReferenceRequested="ChooseReferenceAsync" ClearReferenceRequested="ClearReferenceAsync"
                ResetRequested="ResetColorPreviewAsync" PresetSelected="PreviewPresetAsync"
                SavePresetRequested="SavePresetRequested" DeletePresetRequested="DeletePresetRequested" />
        }
        else if (State.Mode == WMWorkspaceMode.MultiFrame && State.MultiFrameTool.Capability is { } capability)
        {
            <WMMultiFramePanel Media="State.Media" Roles="State.MultiFrameTool.Draft.Roles" Mode="State.MultiFrameTool.Draft.Mode"
                ModeChanged="ChangeMultiFrameModeAsync" NormalizeExposure="State.MultiFrameTool.Draft.NormalizeExposure"
                NormalizeExposureChanged="value => ChangeToggleAsync(NormalizeExposureChanged, value)" RepairHotPixels="State.MultiFrameTool.Draft.RepairHotPixels"
                RepairHotPixelsChanged="value => ChangeToggleAsync(RepairHotPixelsChanged, value)" AutoCrop="State.MultiFrameTool.Draft.AutoCrop"
                AutoCropChanged="value => ChangeToggleAsync(AutoCropChanged, value)" Capability="capability" Busy="State.MultiFrameTool.IsBusy"
                Message="State.Message" RoleChanged="ChangeFrameRoleAsync" RunRequested="MultiFrameRunRequested" />
        }
        else if (State.Mode == WMWorkspaceMode.Collage)
        {
            <WMCollagePanel Media="State.Media" OrderedMediaIds="State.CollageTool.Draft.OrderedMediaIds"
                Direction="State.CollageTool.Draft.Direction" Busy="State.CollageTool.IsBusy"
                DraftChanged="ChangeCollageDraftAsync" RunOrCancelRequested="CollageRunOrCancelRequested" />
        }
        else
        {
            <WMTemplatePanel Templates="Templates" TemplateId="State.TemplateId" Draft="State.TemplateEdit"
                Scope="State.ApplyScope" ScopeChanged="ChangeScopeAsync" SelectedCount="SelectedCount"
                PreviewChanged="PreviewTemplateEditAsync" CommitRequested="PreviewTemplateEditAsync" />
        }
    };

    private RenderFragment ParameterCard(string label, double value, bool active, Action action, string icon = "mdi-tune-variant") => __builder =>
    {
        <button type="button" class="wm-dock-tool-card @(active ? "is-active" : null)" aria-pressed="@active" @onclick="() => SelectParameter(action)"><MIcon>@icon</MIcon><span>@label</span><output>@value.ToString(value % 1 == 0 ? "0" : "0.0")</output></button>
    };

    private RenderFragment LookCard(string label, string icon, Func<Task> action) =>
        ChoiceCard(label, icon, false, action);

    private RenderFragment ChoiceCard(string label, string icon, bool active, Func<Task> action) => __builder =>
    {
        <button type="button" class="wm-dock-tool-card @(active ? "is-active" : null)" aria-pressed="@active" @onclick="() => RunEditActionAsync(action)"><MIcon>@icon</MIcon><span>@label</span></button>
    };

    private RenderFragment ToggleCard(string label, bool value, EventCallback<bool> changed) => __builder =>
    {
        <button type="button" class="wm-dock-tool-card @(value ? "is-active" : null)" role="switch" aria-checked="@value" @onclick="() => ChangeToggleAsync(changed, !value)"><MIcon>@(value ? "mdi-toggle-switch" : "mdi-toggle-switch-off-outline")</MIcon><span>@label</span></button>
    };

    private async Task ChangeModeAsync(WMWorkspaceMode mode)
    {
        if (State.Mode == mode || ModeSwitchDisabled(mode)) return;
        advancedOpen = false;
        activeAdjustmentVisible = false;
        await ModeChanged.InvokeAsync(mode);
    }

    private bool ModeSwitchDisabled(WMWorkspaceMode mode) =>
        State.Mode != mode && (isEditing || State.HasTransientEdits || isConfirming ||
            State.MultiFrameTool.IsBusy || State.CollageTool.IsBusy);

    private Task OpenAdvancedAsync()
    {
        advancedOpen = true;
        activeAdjustmentVisible = false;
        return Task.CompletedTask;
    }

    private void CloseAdvanced() => advancedOpen = false;

    private async Task ConfirmEditAsync()
    {
        if (isConfirming) return;
        isConfirming = true;
        try
        {
            var mode = State.Mode;
            await EditConfirmed.InvokeAsync(mode);
            advancedOpen = false;
            activeAdjustmentVisible = false;
            isEditing = false;
        }
        finally
        {
            isConfirming = false;
        }
    }

    private Task ChangeColorAsync(string key, float value)
    {
        StartEditing(showAdjustment: true);
        var next = WMWorkspacePanelMutations.SetColorValue(State.ColorGradeTool.Draft, key, value);
        return ColorPreviewChanged.InvokeAsync(next);
    }

    private Task ApplyLookAsync(string name, float exposure, float contrast, float temperature, float vibrance) =>
        PreviewColorAsync(WMWorkspacePanelMutations.QuickLook(name, exposure, contrast, temperature, vibrance));

    private Task PreviewPresetAsync(WMColorRecipe preset) => PreviewColorAsync(preset);

    private Task ResetColorPreviewAsync() =>
        PreviewColorAsync(new WMColorRecipe { Name = "移动端调整" });

    private Task PreviewTemplateAsync(string? templateId)
    {
        if (string.Equals(State.TemplateId, templateId, StringComparison.Ordinal) && !State.HasTransientEdits)
            return Task.CompletedTask;
        return PreviewTemplateEditAsync(CreateTemplateEdit(templateId));
    }

    private WMWorkspaceTemplateEdit CreateTemplateEdit(string? templateId)
    {
        if (templateId is null) return new WMWorkspaceTemplateEdit(null, null);
        if (State.TemplateEdit?.TemplateId == templateId) return State.TemplateEdit;
        return new WMWorkspaceTemplateEdit(templateId, null);
    }

    private Task ChangeBorderAsync(string side, double value)
    {
        if (CurrentCanvas is not { } current) return Task.CompletedTask;
        StartEditing(showAdjustment: true);
        var next = WMWorkspacePanelMutations.SetBorder(current, side, value);
        var edit = new WMWorkspaceTemplateEdit(State.TemplateId, Global.CanvasSerialize(next));
        return TemplatePreviewChanged.InvokeAsync(edit);
    }

    private WMCanvas? CurrentCanvas
    {
        get
        {
            try
            {
                if (State.TemplateEdit is { CanvasJson.Length: > 0 } && State.TemplateEdit.TemplateId == State.TemplateId)
                    return Global.ReadConfig(State.TemplateEdit.CanvasJson);
                return Templates.FirstOrDefault(item => item.ID == State.TemplateId)?.Canvas;
            }
            catch { return null; }
        }
    }

    private (string Label, float Value, double Minimum, double Maximum, double Step, string Unit, string Icon) ColorParameter(string key) => key switch
    {
        "Exposure" => ("曝光", State.ColorGradeTool.Draft.Grade.Exposure, -5, 5, .05, "EV", "mdi-plus-minus-variant"),
        "Contrast" => ("对比度", State.ColorGradeTool.Draft.Grade.Contrast, -100, 100, 1, "", "mdi-contrast-box"),
        "Highlights" => ("高光", State.ColorGradeTool.Draft.Grade.Highlights, -100, 100, 1, "", "mdi-brightness-7"),
        "Shadows" => ("阴影", State.ColorGradeTool.Draft.Grade.Shadows, -100, 100, 1, "", "mdi-brightness-4"),
        "Whites" => ("白色", State.ColorGradeTool.Draft.Grade.Whites, -100, 100, 1, "", "mdi-circle-outline"),
        "Blacks" => ("黑色", State.ColorGradeTool.Draft.Grade.Blacks, -100, 100, 1, "", "mdi-circle"),
        "Temperature" => ("色温", State.ColorGradeTool.Draft.Grade.Temperature, -100, 100, 1, "", "mdi-thermometer"),
        "Tint" => ("色调", State.ColorGradeTool.Draft.Grade.Tint, -100, 100, 1, "", "mdi-eyedropper-variant"),
        "Vibrance" => ("自然饱和度", State.ColorGradeTool.Draft.Grade.Vibrance, -100, 100, 1, "", "mdi-flower-tulip-outline"),
        _ => ("饱和度", State.ColorGradeTool.Draft.Grade.Saturation, -100, 100, 1, "", "mdi-palette-outline")
    };

    private static (string Label, double Value) BorderParameter(WMCanvas canvas, string side) => side switch
    {
        "Right" => ("右边框", canvas.BorderThickness.Right),
        "Bottom" => ("下边框", canvas.BorderThickness.Bottom),
        "Left" => ("左边框", canvas.BorderThickness.Left),
        _ => ("上边框", canvas.BorderThickness.Top)
    };

    private void EnsureColorParameter(bool color)
    {
        if (color && !ColorKeys.Contains(colorParameter)) colorParameter = "Temperature";
        if (!color && !LightKeys.Contains(colorParameter)) colorParameter = "Exposure";
    }

    private void StartEditing(bool showAdjustment = false)
    {
        isEditing = true;
        if (showAdjustment) activeAdjustmentVisible = true;
    }

    private void SelectParameter(Action action)
    {
        action();
        StartEditing(showAdjustment: true);
    }

    private async Task RunEditActionAsync(Func<Task> action)
    {
        StartEditing();
        await action();
    }

    private void SelectTemplateSection(TemplateSection section)
    {
        templateSection = section;
        activeAdjustmentVisible = false;
    }

    private void SelectColorSection(ColorSection section)
    {
        colorSection = section;
        EnsureColorParameter(section == ColorSection.Color);
        activeAdjustmentVisible = false;
    }

    private void SelectMultiFrameSection(MultiFrameSection section)
    {
        multiFrameSection = section;
        activeAdjustmentVisible = false;
    }

    private void SelectCollageSection(CollageSection section)
    {
        collageSection = section;
        activeAdjustmentVisible = false;
    }

    private Task ChangeScopeAsync(WMApplyScope scope) => ScopeChanged.InvokeAsync(scope);

    private Task PreviewColorAsync(WMColorRecipe recipe)
    {
        StartEditing();
        return ColorPreviewChanged.InvokeAsync(recipe);
    }

    private Task PreviewTemplateEditAsync(WMWorkspaceTemplateEdit edit)
    {
        StartEditing();
        return TemplatePreviewChanged.InvokeAsync(edit);
    }

    private Task ChooseReferenceAsync()
    {
        StartEditing();
        return ChooseReferenceRequested.InvokeAsync();
    }

    private Task ClearReferenceAsync()
    {
        StartEditing();
        return ClearReferenceRequested.InvokeAsync();
    }

    private Task ChangeMultiFrameModeAsync(WMStackMode mode)
    {
        StartEditing();
        return MultiFrameModeChanged.InvokeAsync(mode);
    }

    private Task ChangeToggleAsync(EventCallback<bool> changed, bool value)
    {
        StartEditing();
        return changed.InvokeAsync(value);
    }

    private Task ChangeFrameRoleAsync(WMFrameRoleChange change)
    {
        StartEditing();
        return FrameRoleChanged.InvokeAsync(change);
    }

    private Task ChangeFrameRoleAsync(string mediaId, WMFrameRole role) =>
        ChangeFrameRoleAsync(new WMFrameRoleChange(mediaId, role));

    private Task ChangeCollageDraftAsync(WMCollageDraft draft)
    {
        StartEditing();
        return CollageDraftChanged.InvokeAsync(draft);
    }

    private WMFrameRole? FrameRole(string mediaId) =>
        State.MultiFrameTool.Draft.Roles.TryGetValue(mediaId, out var role) ? role : null;

    private IReadOnlyList<WMWorkspaceMedia> OrderedCollageMedia
    {
        get
        {
            var byId = State.Media.ToDictionary(item => item.Id, StringComparer.Ordinal);
            return State.CollageTool.Draft.OrderedMediaIds.Where(byId.ContainsKey).Select(id => byId[id]).ToArray();
        }
    }

    private IReadOnlyList<WMWorkspaceMedia> AvailableCollageMedia
    {
        get
        {
            var selected = State.CollageTool.Draft.OrderedMediaIds.ToHashSet(StringComparer.Ordinal);
            return State.Media.Where(item => !selected.Contains(item.Id)).ToArray();
        }
    }

    private int IndexOfCollage(string mediaId)
    {
        for (var index = 0; index < State.CollageTool.Draft.OrderedMediaIds.Count; index++)
            if (string.Equals(State.CollageTool.Draft.OrderedMediaIds[index], mediaId, StringComparison.Ordinal)) return index;
        return -1;
    }

    private Task ToggleCollageAsync(string mediaId)
    {
        var next = State.CollageTool.Draft.OrderedMediaIds.ToList();
        if (!next.Remove(mediaId)) next.Add(mediaId);
        return ChangeCollageDraftAsync(State.CollageTool.Draft with { OrderedMediaIds = next });
    }

    private Task MoveCollageAsync(string mediaId, int offset)
    {
        var next = State.CollageTool.Draft.OrderedMediaIds.ToList();
        var current = next.FindIndex(id => string.Equals(id, mediaId, StringComparison.Ordinal));
        var target = current + offset;
        if (current < 0 || target < 0 || target >= next.Count) return Task.CompletedTask;
        (next[current], next[target]) = (next[target], next[current]);
        return ChangeCollageDraftAsync(State.CollageTool.Draft with { OrderedMediaIds = next });
    }

    private Task ChangeCollageDirectionAsync(WMCollageDirection direction) =>
        ChangeCollageDraftAsync(State.CollageTool.Draft with { Direction = direction });

    private static string Preview(WMWorkspaceMedia media)
    {
        var path = media.Artifact.PreviewPath ?? media.Artifact.FilePath;
        return Uri.TryCreate(path, UriKind.Absolute, out var uri) ? uri.AbsoluteUri : path;
    }

    private static readonly string[] LightKeys = ["Exposure", "Contrast", "Highlights", "Shadows", "Whites", "Blacks"];
    private static readonly string[] ColorKeys = ["Temperature", "Tint", "Vibrance", "Saturation"];

    private enum TemplateSection { Template, Border, Scope }
    private enum ColorSection { Style, Light, Color }
    private enum MultiFrameSection { Mode, Material, Parameter }
    private enum CollageSection { Material, Layout, Generate }
}
