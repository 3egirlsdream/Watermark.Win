    };

    private RenderFragment MediaThumbnail(WMWorkspaceMedia media) => __builder =>
    {
        <span class="wm-dock-media-thumbnail">
            @if (MediaPreviewUrl?.Invoke(media) is { Length: > 0 } preview) { <img src="@preview" alt="" /> }
            else { <MIcon>mdi-image-outline</MIcon> }
        </span>
    };

