@using System.Globalization
@namespace Watermark.Razor.Workspace.Components

<label class="wm-template-border-control @CssClass">
    @if (ShowHeader)
    {
        <span><strong>@Label</strong><output>@Value.ToString("0.#")</output></span>
    }
    <input type="range" min="0" max="100" step="0.5"
           value="@Value.ToString(CultureInfo.InvariantCulture)"
           aria-label="@($"{Label}边框")" aria-valuetext="@Value.ToString("0.#")"
           @oninput="PreviewAsync" @onchange="CommitAsync" />
</label>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public double Value { get; set; }
    [Parameter] public bool ShowHeader { get; set; } = true;
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public EventCallback<double> PreviewValueChanged { get; set; }
    [Parameter] public EventCallback<double> CommitValueChanged { get; set; }

    private Task PreviewAsync(ChangeEventArgs args) =>
        TryValue(args, out var value) ? PreviewValueChanged.InvokeAsync(value) : Task.CompletedTask;

    private Task CommitAsync(ChangeEventArgs args) =>
        TryValue(args, out var value) ? CommitValueChanged.InvokeAsync(value) : Task.CompletedTask;

    private static bool TryValue(ChangeEventArgs args, out double value) =>
        double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out value);
}
