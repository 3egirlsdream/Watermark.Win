@using System.Globalization
@namespace Watermark.Razor.Workspace.Components

<label class="wm-color-parameter @CssClass">
    @if (ShowHeader)
    {
        <span><strong>@Label</strong><output>@DisplayValue</output></span>
    }
    <input type="range" min="@Minimum" max="@Maximum" step="@Step"
           value="@Value.ToString(CultureInfo.InvariantCulture)" disabled="@Disabled"
           aria-label="@Label" aria-valuetext="@DisplayValue"
           @oninput="PreviewAsync" @onchange="CommitAsync" />
</label>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public float Value { get; set; }
    [Parameter] public double Minimum { get; set; } = -100;
    [Parameter] public double Maximum { get; set; } = 100;
    [Parameter] public double Step { get; set; } = 1;
    [Parameter] public string Unit { get; set; } = string.Empty;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ShowHeader { get; set; } = true;
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public EventCallback<float> PreviewValueChanged { get; set; }
    [Parameter] public EventCallback<float> CommitValueChanged { get; set; }

    private string DisplayValue => $"{Value.ToString(Value % 1 == 0 ? "0" : "0.00")} {Unit}".TrimEnd();

    private Task PreviewAsync(ChangeEventArgs args) =>
        TryValue(args, out var value) ? PreviewValueChanged.InvokeAsync(value) : Task.CompletedTask;

    private Task CommitAsync(ChangeEventArgs args) =>
        TryValue(args, out var value) ? CommitValueChanged.InvokeAsync(value) : Task.CompletedTask;

    private static bool TryValue(ChangeEventArgs args, out float value) =>
        float.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out value);
}
