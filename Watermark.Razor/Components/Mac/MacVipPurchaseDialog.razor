@using Masa.Blazor
@using Masa.Blazor.Presets
@using Watermark.Shared.Models
@implements IDisposable
@inject APIHelper Api
@inject IClientInstance ClientInstance
@inject IPopupService PopupService

<div class="mac-vip-dialog">
    <header class="vip-header">
        <div>
            <div class="eyebrow">MEMBERSHIP</div>
            <h2>开通会员</h2>
            <p>选择套餐后前往支付宝网页付款，支付成功会自动刷新账号状态。</p>
        </div>
        <MButton Icon Small Text Class="vip-icon-button" OnClick="Close">
            <MIcon>mdi-close</MIcon>
        </MButton>
    </header>

    <section class="vip-plans">
        @foreach (var plan in Plans)
        {
            <button type="button"
                    class="@GetPlanClass(plan)"
                    @onclick="() => SelectPlan(plan)"
                    disabled="@IsBusy">
                <span class="plan-name">@plan.Name</span>
                <strong>¥@plan.Cost</strong>
                <small>@plan.Description</small>
                @if (plan.Recommend)
                {
                    <em>推荐</em>
                }
            </button>
        }
    </section>

    <section class="vip-pay-area">
        <div class="checkout-panel">
            @if (IsCreatingOrder)
            {
                <div class="checkout-placeholder">
                    <MProgressCircular Indeterminate Size="28" Color="primary" />
                    <span>正在创建支付宝收银台</span>
                </div>
            }
            else if (Order != null)
            {
                <div class="checkout-placeholder ready">
                    <MIcon Size="52">mdi-open-in-new</MIcon>
                    <strong>支付宝收银台已打开</strong>
                    <span>请在浏览器中扫码或登录付款</span>
                </div>
            }
            else
            {
                <div class="checkout-placeholder">
                    <MIcon Size="52">mdi-web</MIcon>
                    <strong>网页安全支付</strong>
                    <span>点击后将在系统浏览器打开</span>
                </div>
            }
        </div>

        <div class="pay-info">
            <div class="status-row">
                <span class="@StatusDotClass"></span>
                <strong>@StatusTitle</strong>
            </div>
            <p>@StatusMessage</p>
            @if (Order != null)
            {
                <dl>
                    <div>
                        <dt>订单号</dt>
                        <dd>@Order.OutTradeNo</dd>
                    </div>
                    <div>
                        <dt>套餐</dt>
                        <dd>@SelectedPlan.Name · ¥@SelectedPlan.Cost</dd>
                    </div>
                </dl>
            }
        </div>
    </section>

    <footer class="vip-actions">
        <MButton Text Class="vip-secondary-button" OnClick="OpenPaymentPage" Disabled="@(Order == null || string.IsNullOrWhiteSpace(Order.PayUrl))">
            <MIcon Left Small>mdi-open-in-new</MIcon>重新打开支付页
        </MButton>
        <MSpacer />
        <MButton Text Class="vip-secondary-button" OnClick="RefreshStatus" Disabled="@(Order == null || IsPolling)">
            <MIcon Left Small>mdi-refresh</MIcon>刷新状态
        </MButton>
        <MButton Color="primary" Class="vip-primary-button" OnClick="CreateOrder" Disabled="@IsBusy">
            <MIcon Left Small>mdi-open-in-new</MIcon>@PrimaryActionText
        </MButton>
    </footer>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnPaid { get; set; }

    private readonly VipPlan[] RegularPlans =
    [
        new("年度会员", 28, "适合长期批量处理", true),
        new("季度会员", 18, "适合阶段性创作"),
        new("月度会员", 8, "轻量体验高级能力")
    ];

    private VipPlan[] Plans => IsTestAccount
        ? [.. RegularPlans, new VipPlan("测试套餐", 0.01m, "支付成功后增加 1 分钟会员")]
        : RegularPlans;

    private VipPlan SelectedPlan;
    private DesktopPayOrder Order;
    private string StatusTitle = "等待选择套餐";
    private string StatusMessage = "请选择一个会员套餐，系统会打开支付宝网页收银台。";
    private bool IsCreatingOrder;
    private bool IsPolling;
    private CancellationTokenSource PollingTokenSource;

    private bool IsBusy => IsCreatingOrder || IsPolling;
    private bool IsTestAccount => string.Equals(Global.CurrentUser?.USER_NAME, "xlz", StringComparison.OrdinalIgnoreCase);
    private string PrimaryActionText => Order == null
        ? "前往支付宝付款"
        : IsPolling ? "等待支付" : "重新创建订单";
    private string StatusDotClass => IsPolling ? "status-dot polling" : Order == null ? "status-dot idle" : "status-dot";

    protected override void OnInitialized()
    {
        SelectedPlan = RegularPlans[0];
    }

    private void SelectPlan(VipPlan plan)
    {
        if (SelectedPlan == plan)
        {
            return;
        }

        StopPolling();
        SelectedPlan = plan;
        Order = null;
        StatusTitle = $"{plan.Name} · ¥{plan.Cost}";
        StatusMessage = "点击付款后，将在系统浏览器打开支付宝收银台。";
    }

    private string GetPlanClass(VipPlan plan)
    {
        var classes = "vip-plan";
        if (SelectedPlan == plan)
        {
            classes += " active";
        }
        if (plan.Recommend)
        {
            classes += " recommend";
        }
        return classes;
    }

    private async Task CreateOrder()
    {
        if (Global.CurrentUser == null || string.IsNullOrWhiteSpace(Global.CurrentUser.ID))
        {
            Common.ShowMsg(PopupService, "请先登录后再开通会员", AlertTypes.Info);
            await Close();
            return;
        }

        StopPolling();
        Order = null;
        IsCreatingOrder = true;
        StatusTitle = "正在创建订单";
        StatusMessage = "正在向服务端申请支付宝网页订单...";
        try
        {
            var result = await Api.CreateDesktopPay(SelectedPlan.Cost, SelectedPlan.Name, Global.CurrentUser.ID);
            if (result?.success == true && result.data != null)
            {
                Order = result.data;
                if (string.IsNullOrWhiteSpace(Order.PayUrl))
                {
                    throw new InvalidOperationException("服务端未返回支付宝支付页地址，请部署网页支付版本后重试");
                }

                StatusTitle = "等待网页支付";
                StatusMessage = result.data.Message ?? "请在浏览器中完成支付宝付款";
                await OpenPaymentPage();
                StartPolling();
            }
            else
            {
                StatusTitle = "创建订单失败";
                StatusMessage = FormatCreateOrderError(result?.message?.content);
                Common.ShowMsg(PopupService, StatusMessage, AlertTypes.Error);
            }
        }
        catch (Exception ex)
        {
            StatusTitle = "创建订单失败";
            StatusMessage = FormatCreateOrderError(ex.Message);
            Common.ShowMsg(PopupService, StatusMessage, AlertTypes.Error);
        }
        finally
        {
            IsCreatingOrder = false;
        }
    }

    private async Task RefreshStatus()
    {
        if (Order == null)
        {
            return;
        }

        await QueryStatus();
    }

    private void StartPolling()
    {
        PollingTokenSource = new CancellationTokenSource();
        IsPolling = true;
        _ = PollPaymentStatusAsync(PollingTokenSource.Token);
    }

    private async Task PollPaymentStatusAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(2000, token);
                await QueryStatus();
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task QueryStatus()
    {
        if (Order == null)
        {
            return;
        }

        var result = await Api.QueryDesktopPay(Order.OutTradeNo);
        if (result?.success != true || result.data == null)
        {
            StatusTitle = "状态查询失败";
            StatusMessage = result?.message?.content ?? "网络异常，请稍后刷新。";
            StateHasChanged();
            return;
        }

        var status = result.data.Status ?? string.Empty;
        if (string.Equals(status, "PAID", StringComparison.OrdinalIgnoreCase))
        {
            StopPolling();
            StatusTitle = "支付成功";
            StatusMessage = "会员已开通，正在刷新账号状态...";
            await ClientInstance.ReLogin();
            if (OnPaid.HasDelegate)
            {
                await OnPaid.InvokeAsync();
            }
            Common.ShowMsg(PopupService, "会员已开通", AlertTypes.Success);
            await Close();
            return;
        }

        if (string.Equals(status, "CLOSED", StringComparison.OrdinalIgnoreCase)
            || string.Equals(status, "FAILED", StringComparison.OrdinalIgnoreCase))
        {
            StopPolling();
            StatusTitle = status == "CLOSED" ? "订单已关闭" : "支付未完成";
            StatusMessage = result.data.Message ?? "请重新创建订单后再试。";
            StateHasChanged();
            return;
        }

        StatusTitle = "等待支付";
        StatusMessage = result.data.Message ?? "请在支付宝网页收银台完成付款。";
        StateHasChanged();
    }

    private async Task OpenPaymentPage()
    {
        if (Order == null || string.IsNullOrWhiteSpace(Order.PayUrl))
        {
            return;
        }

        try
        {
            await ClientInstance.OpenExternalUrlAsync(Order.PayUrl);
        }
        catch
        {
            StatusTitle = "支付页打开失败";
            StatusMessage = "订单已经创建，请点击“重新打开支付页”再次尝试。";
            Common.ShowMsg(PopupService, StatusMessage, AlertTypes.Error);
        }
    }

    private string FormatCreateOrderError(string message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return "暂时无法创建支付宝订单，请稍后重试。";
        }

        return message;
    }

    private async Task Close()
    {
        StopPolling();
        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync();
        }
    }

    private void StopPolling()
    {
        if (PollingTokenSource != null)
        {
            PollingTokenSource.Cancel();
            PollingTokenSource.Dispose();
            PollingTokenSource = null;
        }
        IsPolling = false;
    }

    public void Dispose()
    {
        StopPolling();
    }

    private sealed record VipPlan(string Name, decimal Cost, string Description, bool Recommend = false);
}
