@implements IAsyncDisposable
@using Microsoft.JSInterop
@using System.Security.Cryptography
@using System.Text
@using System.Text.Json
@using Watermark.Shared.Models
@inject IJSRuntime JSRuntime
@inject MacColorPreviewValidator Validator

<div class="mac-color-preview-canvas @Class">
    <canvas @ref="canvas" class="color-preview-surface" aria-label="实时调色预览"></canvas>
    @if (capability is { Supported: false })
    {
        <img src="@Source" class="color-preview-fallback" alt="调色预览" />
    }
</div>

@code {
    [Parameter] public string? Source { get; set; }
    [Parameter] public MacColorPreviewLook? Look { get; set; }
    [Parameter] public MacColorPreviewParameters? Adjustments { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public EventCallback<MacColorPreviewCapability> CapabilityChanged { get; set; }

    private ElementReference canvas;
    private IJSObjectReference? module;
    private IJSObjectReference? renderer;
    private MacColorPreviewCapability? capability;
    private string? appliedSource;
    private string? appliedLookKey;
    private MacColorPreviewParameters? appliedAdjustments;
    private bool disposed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (disposed) return;
        try
        {
            if (firstRender)
            {
                module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/Watermark.Razor/js/mac-color-preview.js");
                renderer = await module.InvokeAsync<IJSObjectReference>("createColorPreview", canvas);
                capability = await renderer.InvokeAsync<MacColorPreviewCapability>("getCapability");
                if (capability.Supported)
                    capability = await ValidateCapabilityAsync(capability);
                await CapabilityChanged.InvokeAsync(capability);
            }
            await SynchronizeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException ex)
        {
            capability = new MacColorPreviewCapability(false, ex.Message);
            await CapabilityChanged.InvokeAsync(capability);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SynchronizeAsync()
    {
        if (renderer is null || capability?.Supported != true) return;
        if (!string.Equals(appliedSource, Source, StringComparison.Ordinal) && !string.IsNullOrWhiteSpace(Source))
        {
            await renderer.InvokeVoidAsync("setSource", Source);
            appliedSource = Source;
        }
        var look = Look ?? MacColorPreviewLook.Identity;
        if (!string.Equals(appliedLookKey, look.CacheKey, StringComparison.Ordinal))
        {
            await renderer.InvokeVoidAsync("setGeneratedLook", look);
            appliedLookKey = look.CacheKey;
        }
        if (!ReferenceEquals(appliedAdjustments, Adjustments) && Adjustments is not null)
        {
            var changedCurve = GetSingleChangedCurve(appliedAdjustments, Adjustments);
            if (changedCurve is not null)
                await renderer.InvokeVoidAsync("setCurve", changedCurve.Value.Name, changedCurve.Value.Values);
            else
            {
                var curvesUnchanged = appliedAdjustments is not null
                    && ReferenceEquals(appliedAdjustments.MasterCurve, Adjustments.MasterCurve)
                    && ReferenceEquals(appliedAdjustments.RedCurve, Adjustments.RedCurve)
                    && ReferenceEquals(appliedAdjustments.GreenCurve, Adjustments.GreenCurve)
                    && ReferenceEquals(appliedAdjustments.BlueCurve, Adjustments.BlueCurve);
                await renderer.InvokeVoidAsync(curvesUnchanged ? "setGradeAndHsl" : "setAdjustments", Adjustments);
            }
            appliedAdjustments = Adjustments;
        }
        await renderer.InvokeVoidAsync("render");
    }

    private static (string Name, float[] Values)? GetSingleChangedCurve(
        MacColorPreviewParameters? previous,
        MacColorPreviewParameters current)
    {
        if (previous is null
            || !ReferenceEquals(previous.Grade, current.Grade)
            || !ReferenceEquals(previous.Hsl, current.Hsl)) return null;

        (string Name, float[] Values)? changed = null;
        if (!ReferenceEquals(previous.MasterCurve, current.MasterCurve))
            changed = ("masterCurve", current.MasterCurve);
        if (!ReferenceEquals(previous.RedCurve, current.RedCurve))
        {
            if (changed is not null) return null;
            changed = ("redCurve", current.RedCurve);
        }
        if (!ReferenceEquals(previous.GreenCurve, current.GreenCurve))
        {
            if (changed is not null) return null;
            changed = ("greenCurve", current.GreenCurve);
        }
        if (!ReferenceEquals(previous.BlueCurve, current.BlueCurve))
        {
            if (changed is not null) return null;
            changed = ("blueCurve", current.BlueCurve);
        }
        return changed;
    }

    private async Task<MacColorPreviewCapability> ValidateCapabilityAsync(MacColorPreviewCapability candidate)
    {
        if (renderer is null) return candidate with { Supported = false, Reason = "WebGL渲染器尚未初始化。" };
        var jsVersion = await renderer.InvokeAsync<int>("getPipelineVersion");
        if (jsVersion != WMColorPipelineVersion.Current || candidate.PipelineVersion != WMColorPipelineVersion.Current)
            return candidate with
            {
                Supported = false,
                Validated = true,
                Reason = $"调色Pipeline版本不一致：CPU={WMColorPipelineVersion.Current}，GPU={jsVersion}。"
            };

        var cacheIdentity = $"{WMColorPipelineVersion.Current}|{candidate.EnvironmentKey}|rgba16f-v1";
        var cacheKey = "watermark.mac.color-preview-validation."
            + Convert.ToHexString(SHA256.HashData(Encoding.UTF8.GetBytes(cacheIdentity)))[..24];
        try
        {
            var cachedJson = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", cacheKey);
            if (!string.IsNullOrWhiteSpace(cachedJson)
                && JsonSerializer.Deserialize<MacColorPreviewValidationResult>(cachedJson) is { } cached)
                return ApplyValidation(candidate, cached);
        }
        catch
        {
            // Validation still runs when persistent browser storage is unavailable.
        }

        var request = Validator.CreateRequest();
        var actual = await renderer.InvokeAsync<byte[]>("validatePipeline", request);
        var validation = Validator.Evaluate(request, actual);
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", cacheKey, JsonSerializer.Serialize(validation));
        }
        catch
        {
        }
#if DEBUG
        Console.WriteLine($"WebGL调色校验：renderer={candidate.Renderer}, avgΔE={validation.AverageDeltaE:0.###}, maxΔE={validation.MaximumDeltaE:0.###}, channelMax={validation.MaximumChannelError}, pass={validation.Passed}");
#endif
        return ApplyValidation(candidate, validation);
    }

    private static MacColorPreviewCapability ApplyValidation(
        MacColorPreviewCapability candidate,
        MacColorPreviewValidationResult validation) => candidate with
        {
            Supported = candidate.Supported && validation.Passed,
            Validated = true,
            Reason = validation.Passed ? candidate.Reason : validation.Reason,
            AverageDeltaE = validation.AverageDeltaE,
            MaximumDeltaE = validation.MaximumDeltaE,
            MaximumChannelError = validation.MaximumChannelError
        };

    public async ValueTask DisposeAsync()
    {
        if (disposed) return;
        disposed = true;
        try
        {
            if (renderer is not null)
            {
                await renderer.InvokeVoidAsync("dispose");
                await renderer.DisposeAsync();
            }
            if (module is not null) await module.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
    }
}
