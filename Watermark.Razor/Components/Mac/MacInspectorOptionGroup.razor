@typeparam TValue

<div class="mac-inspector-option-group @(Disabled ? "disabled" : null)">
    <span class="mac-inspector-option-label">@Label</span>
    <div class="mac-inspector-option-buttons" role="radiogroup" aria-label="@Label">
        @foreach (var option in Options)
        {
            var selected = EqualityComparer<TValue>.Default.Equals(Value, option.Value);
            <button type="button"
                    class="@(selected ? "selected" : null)"
                    role="radio"
                    aria-checked="@selected"
                    disabled="@Disabled"
                    title="@option.Label"
                    @onclick="() => Select(option.Value)">
                @if (!string.IsNullOrWhiteSpace(option.Icon))
                {
                    <MIcon Size="16">@option.Icon</MIcon>
                }
                <span>@option.Label</span>
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public TValue Value { get; set; } = default!;
    [Parameter] public IReadOnlyList<MacInspectorOption<TValue>> Options { get; set; } = [];
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private Task Select(TValue value) => Disabled ? Task.CompletedTask : ValueChanged.InvokeAsync(value);
}
