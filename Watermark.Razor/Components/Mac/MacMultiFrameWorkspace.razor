@using System.Text.Json
@using Masa.Blazor
@using Watermark.Shared.Models
@inject IWMImageStackEngine StackEngine
@inject IWMImagingCapabilities ImagingCapabilities
@implements IDisposable

<section class="multi-frame-workspace @(Embedded ? "embedded" : null)" aria-label="多帧影像工作区">
    @if (!Embedded)
    {
    <header>
        <div>
            <small>Multi-frame Imaging</small>
            <h2>星空与降噪堆栈</h2>
            <p>线性 16-bit 分块处理，源照片不会一次性全部载入内存。</p>
        </div>
        <MButton Text Icon Class="icon-button" OnClick="Close" Disabled="@IsRunning" aria-label="关闭多帧工作区">
            <MIcon>mdi-close</MIcon>
        </MButton>
    </header>
    }

    @if (!Capabilities.CanMultiFrame)
    {
        <div class="capability-note warning"><strong>桌面端可用</strong><span>@Capabilities.UnavailableReason</span></div>
    }
    else
    {
        @if (!Capabilities.CanDecodeRaw)
        {
            <div class="capability-note"><strong>RAW 后端未加载</strong><span>普通照片与无配准星轨仍可处理；RAW 和自动配准需要随包原生库。</span></div>
        }
        @if (!Capabilities.CanAlignScene || !Capabilities.CanAlignStars)
        {
            <div class="capability-note"><strong>配准能力受限</strong><span>@AlignmentCapabilityMessage</span></div>
        }

        <div class="mode-grid" role="radiogroup" aria-label="堆栈模式">
            @foreach (var mode in Modes)
            {
                <button type="button" class="mode-card @(Mode == mode.Value ? "active" : null)"
                        @onclick="() => SelectMode(mode.Value)" disabled="@(IsRunning || !IsModeSupported(mode.Value))"
                        title="@ModeAvailabilityTitle(mode.Value)">
                    <strong>@mode.Title</strong><span>@mode.Description</span>
                </button>
            }
        </div>

        <div class="stack-summary">
            <span><strong>@LightCount</strong> Light</span>
            <span><strong>@DarkCount</strong> Dark</span>
            <span><strong>@MinimumFrames</strong> 最少 Light</span>
            <span><strong>@FormatBytes(EstimatedBytes)</strong> 预计缓存</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(CacheHint))
        {
            <div class="cache-hint"><MIcon Small>mdi-database-check-outline</MIcon><span>@CacheHint</span></div>
        }

        <div class="frame-list" aria-label="输入帧">
            @foreach (var input in Inputs)
            {
                var state = Frames[input.Id];
                <article class="frame-row @(state.Rejected ? "rejected" : null)">
                    <div class="frame-main">
                        <strong title="@input.FilePath">@Path.GetFileName(input.FilePath)</strong>
                        <span>@DescribeMetadata(input)</span>
                        @if (!string.IsNullOrWhiteSpace(state.RejectionReason))
                        {
                            <em>@state.RejectionReason</em>
                        }
                    </div>
                    <div class="role-toggle">
                        <button type="button" class="@(state.Role == WMFrameRole.Light ? "active" : null)"
                                @onclick="() => SetRole(input.Id, WMFrameRole.Light)" disabled="@IsRunning">Light</button>
                        <button type="button" class="@(state.Role == WMFrameRole.Dark ? "active" : null)"
                                @onclick="() => SetRole(input.Id, WMFrameRole.Dark)" disabled="@IsRunning">Dark</button>
                    </div>
                    <button type="button" class="reference-button @(ReferenceId == input.Id ? "active" : null)"
                            disabled="@(IsRunning || state.Role == WMFrameRole.Dark)" @onclick="() => SetReference(input.Id)"
                            aria-pressed="@(ReferenceId == input.Id)"
                            title="@(ReferenceId == input.Id ? "当前参考帧" : "设为参考帧")">
                        参考
                    </button>
                </article>
            }
        </div>

        <details class="advanced" open="@AdvancedOpen">
            <summary @onclick="() => AdvancedOpen = !AdvancedOpen">高级设置</summary>
            <div class="advanced-grid">
                <label><span>对齐</span>
                    <MSelect Value="@Alignment"
                             ValueChanged="OnAlignmentSelected"
                             Items="@AvailableAlignmentOptions"
                             ItemText="item => item.Label"
                             ItemValue="item => item.Value"
                             TValue="WMAlignmentMode"
                             TItemValue="WMAlignmentMode"
                             TItem="StackSelectOption<WMAlignmentMode>"
                             Dense HideDetails="true" Disabled="@IsRunning" Class="stack-select" />
                </label>
                <label><span>合成算法</span>
                    <MSelect Value="@Reduction"
                             ValueChanged="OnReductionSelected"
                             Items="@ReductionOptions"
                             ItemText="item => item.Label"
                             ItemValue="item => item.Value"
                             TValue="WMReductionMode"
                             TItemValue="WMReductionMode"
                             TItem="StackSelectOption<WMReductionMode>"
                             Dense HideDetails="true" Disabled="@IsRunning" Class="stack-select" />
                </label>
                <label><span>Sigma Low</span><input type="number" min="1" max="8" step="0.1" @bind="SigmaLow" @bind:after="InvalidatePreview" disabled="@IsRunning" /></label>
                <label><span>Sigma High</span><input type="number" min="1" max="8" step="0.1" @bind="SigmaHigh" @bind:after="InvalidatePreview" disabled="@IsRunning" /></label>
                <label><span>迭代</span><input type="number" min="1" max="5" @bind="SigmaIterations" @bind:after="InvalidatePreview" disabled="@IsRunning" /></label>
                <label class="check"><input type="checkbox" @bind="NormalizeExposure" @bind:after="InvalidatePreview" disabled="@IsRunning" /><span>曝光归一化</span></label>
                <label class="check"><input type="checkbox" @bind="RepairHotPixels" @bind:after="InvalidatePreview" disabled="@IsRunning" /><span>坏点修复</span></label>
                <label class="check"><input type="checkbox" @bind="AutoCrop" @bind:after="InvalidatePreview" disabled="@IsRunning" /><span>有效区域自动裁切</span></label>
            </div>
        </details>

        @if (IsRunning || Progress is not null)
        {
            <div class="progress-panel" role="status" aria-live="polite">
                <div><strong>@StageLabel</strong><span>@Progress?.Message</span><b>@((int)(Progress?.Percentage ?? 0))%</b></div>
                <MProgressLinear Value="@(Progress?.Percentage ?? 0)" Color="primary" Rounded Height="6" />
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="error-message">@Error</div>
        }

        <footer>
            @if (IsRunning)
            {
                <MButton Color="error" Class="danger-button" OnClick="Cancel">停止处理</MButton>
            }
            else
            {
                <MButton Text Class="secondary-button" OnClick="PreviewAsync" Disabled="@(!CanExecute)">预览合成</MButton>
                <MButton Color="primary" Class="primary-button" OnClick="ApplyAsync" Disabled="@(!CanApply)">应用合成</MButton>
            }
        </footer>
    }
</section>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<WMImageArtifact> Inputs { get; set; } = [];
    [Parameter, EditorRequired] public string WorkingDirectory { get; set; } = string.Empty;
    [Parameter] public EventCallback<WMOperationResult> Completed { get; set; }
    [Parameter] public EventCallback<WMImageArtifact?> PreviewChanged { get; set; }
    [Parameter] public EventCallback Close { get; set; }
    [Parameter] public bool Embedded { get; set; }

    private readonly Dictionary<string, FrameState> Frames = new(StringComparer.Ordinal);
    private CancellationTokenSource? Cancellation;
    private WMStackMode Mode = WMStackMode.StaticSky;
    private WMAlignmentMode Alignment = WMAlignmentMode.Stars;
    private WMReductionMode Reduction = WMReductionMode.SigmaClippedMean;
    private bool AutomaticReduction = true;
    private bool NormalizeExposure = true;
    private bool RepairHotPixels = true;
    private bool AutoCrop = true;
    private bool AdvancedOpen;
    private double SigmaLow = 3;
    private double SigmaHigh = 3;
    private int SigmaIterations = 2;
    private string? ReferenceId;
    private WMOperationProgress? Progress;
    private string? Error;
    private bool IsRunning;
    private bool InitializedForCapabilities;
    private string? PreviewFingerprint;
    private string? PreviewFilePath;
    private string? ActiveFingerprint;
    private string? CacheHint;
    private WMImagingCapabilities Capabilities => ImagingCapabilities.Current;
    private int LightCount => Frames.Values.Count(x => x.Role == WMFrameRole.Light && !x.Rejected);
    private int DarkCount => Frames.Values.Count(x => x.Role == WMFrameRole.Dark && !x.Rejected);
    private int MinimumFrames => Mode == WMStackMode.StarTrail ? 2 : 3;
    private bool CanExecute => Capabilities.CanMultiFrame && IsModeSupported(Mode)
        && IsAlignmentSupported(Alignment) && LightCount >= MinimumFrames && Inputs.Count <= Capabilities.MaxFrames;
    // A preview is optional. Formal apply always runs the full-resolution pipeline
    // from the current inputs/settings and never promotes the 1600px preview.
    private bool CanApply => CanExecute;
    private long EstimatedBytes => WMImagingDiskEstimator.EstimateRequiredBytes(Inputs);
    private string StageLabel => Progress?.Stage switch
    {
        WMOperationStage.Staging => "暂存", WMOperationStage.Decoding => "解码",
        WMOperationStage.Calibrating => "校正", WMOperationStage.Analyzing => "分析",
        WMOperationStage.Aligning => "对齐", WMOperationStage.Processing => "合成",
        WMOperationStage.Encoding => "编码", WMOperationStage.Writing => "写入", _ => "准备"
    };

    protected override void OnParametersSet()
    {
        if (!InitializedForCapabilities)
        {
            InitializedForCapabilities = true;
            SelectMode(Capabilities.CanAlignStars ? WMStackMode.StaticSky : WMStackMode.StarTrail);
        }
        var ids = Inputs.Select(x => x.Id).ToHashSet(StringComparer.Ordinal);
        foreach (var removed in Frames.Keys.Where(x => !ids.Contains(x)).ToArray()) Frames.Remove(removed);
        foreach (var input in Inputs) Frames.TryAdd(input.Id, new FrameState());
        if (ReferenceId is null || !ids.Contains(ReferenceId)) ReferenceId = Inputs.FirstOrDefault()?.Id;
        if (IsRunning && ActiveFingerprint is not null && ActiveFingerprint != CreateFingerprint()) Cancellation?.Cancel();
        if (PreviewFingerprint is not null && PreviewFingerprint != CreateFingerprint()) InvalidatePreview();
    }

    private void SelectMode(WMStackMode mode)
    {
        if (!IsModeSupported(mode)) return;
        Mode = mode;
        var defaults = WMMultiFrameStackSettings.CreateDefault(mode).Normalize(LightCount);
        Alignment = defaults.Alignment; Reduction = defaults.Reduction;
        NormalizeExposure = defaults.NormalizeExposure; RepairHotPixels = defaults.RepairHotPixels;
        AutoCrop = defaults.AutoCrop; AutomaticReduction = true;
        InvalidatePreview();
    }

    private void SetRole(string id, WMFrameRole role)
    {
        Frames[id].Role = role;
        if (role == WMFrameRole.Dark && ReferenceId == id)
            ReferenceId = Inputs.FirstOrDefault(x => Frames[x.Id].Role == WMFrameRole.Light)?.Id;
        if (AutomaticReduction) Reduction = WMMultiFrameStackSettings.CreateDefault(Mode).Normalize(LightCount).Reduction;
        InvalidatePreview();
    }

    private void SetReference(string id)
    {
        ReferenceId = id;
        InvalidatePreview();
    }

    private Task OnAlignmentSelected(WMAlignmentMode value)
    {
        if (!IsAlignmentSupported(value)) return Task.CompletedTask;
        Alignment = value;
        InvalidatePreview();
        return Task.CompletedTask;
    }

    private bool IsModeSupported(WMStackMode mode) => mode switch
    {
        WMStackMode.StaticSky => Capabilities.CanAlignStars,
        _ => true
    };

    private bool IsAlignmentSupported(WMAlignmentMode mode) => mode switch
    {
        WMAlignmentMode.Stars => Capabilities.CanAlignStars,
        _ => true
    };

    private string? ModeAvailabilityTitle(WMStackMode mode) => IsModeSupported(mode)
        ? null
        : "当前发布包未包含星点配准能力";

    private string AlignmentCapabilityMessage => (Capabilities.CanAlignScene, Capabilities.CanAlignStars) switch
    {
        (false, false) => "当前原生库未包含星点配准，只开放不需要对齐的星轨模式。",
        (false, true) => "场景 ECC 配准不可用，场景降噪已禁用。",
        (true, false) => "星点配准不可用，静态星空已禁用。",
        _ => string.Empty
    };

    private Task OnReductionSelected(WMReductionMode value)
    {
        Reduction = value;
        AutomaticReduction = false;
        InvalidatePreview();
        return Task.CompletedTask;
    }

    private Task PreviewAsync() => ExecuteAsync(true);
    private Task ApplyAsync() => ExecuteAsync(false);

    private async Task ExecuteAsync(bool isPreview)
    {
        if (!CanExecute || IsRunning || (!isPreview && !CanApply)) return;
        Error = null; Progress = null; IsRunning = true;
        Cancellation = new CancellationTokenSource();
        ActiveFingerprint = CreateFingerprint();
        try
        {
            var settings = BuildSettings();
            var directory = isPreview ? Path.Combine(WorkingDirectory, "preview") : Path.Combine(WorkingDirectory, "artifacts");
            var execution = WMOperationExecutionOptions.Balanced() with
            {
                PreviewRenderMaxEdge = 1600,
                PreviewAnalysisMaxEdge = 1024,
                PreviewDecodeConcurrency = 2,
                PreviewResampler = WMPreviewResampler.Bicubic
            };
            var request = new WMOperationRequest(Inputs, settings, isPreview, directory,
                new Progress<WMOperationProgress>(value => InvokeAsync(() => { Progress = value; StateHasChanged(); })),
                execution);
            var result = await StackEngine.ExecuteAsync(request, settings, Cancellation.Token);
            if (isPreview)
            {
                DeletePreview();
                var artifact = result.Outputs.Single();
                PreviewFilePath = artifact.FilePath;
                PreviewFingerprint = CreateFingerprint();
                CacheHint = "线性预览、星点分析和配准结果已缓存；继续调整 Sigma 或合成算法无需重新解码。";
                await PreviewChanged.InvokeAsync(artifact);
                return;
            }
            var manifestPath = result.Outputs.Single().ProcessingManifestPath;
            if (manifestPath is not null && File.Exists(manifestPath))
            {
                var manifest = JsonSerializer.Deserialize<WMMultiFrameManifest>(await File.ReadAllTextAsync(manifestPath));
                if (manifest is not null)
                    foreach (var frame in manifest.Frames)
                        if (Frames.TryGetValue(frame.ArtifactId, out var state))
                        { state.Rejected = frame.Rejected; state.RejectionReason = frame.RejectionReason; }
            }
            await Completed.InvokeAsync(result);
        }
        catch (OperationCanceledException) { Error = "处理已取消，未完成的缓存和输出已清理。"; }
        catch (Exception ex) { Error = ex.Message; }
        finally { Cancellation?.Dispose(); Cancellation = null; ActiveFingerprint = null; IsRunning = false; await InvokeAsync(StateHasChanged); }
    }

    private void Cancel() => Cancellation?.Cancel();
    private WMMultiFrameStackSettings BuildSettings() => new()
    {
        Mode = Mode, Alignment = Alignment, Reduction = Reduction,
        AutomaticReduction = AutomaticReduction,
        DarkArtifactIds = Frames.Where(x => x.Value.Role == WMFrameRole.Dark).Select(x => x.Key).ToArray(),
        NormalizeExposure = NormalizeExposure, RepairHotPixels = RepairHotPixels, AutoCrop = AutoCrop,
        SigmaLow = SigmaLow, SigmaHigh = SigmaHigh, SigmaIterations = SigmaIterations,
        ReferenceArtifactId = ReferenceId
    };

    private string CreateFingerprint() => JsonSerializer.Serialize(new
    {
        Inputs = Inputs.Select(item => new { item.Id, item.ContentHash, Role = Frames.GetValueOrDefault(item.Id)?.Role }).ToArray(),
        Settings = BuildSettings()
    });

    private void InvalidatePreview()
    {
        PreviewFingerprint = null;
        CacheHint = Inputs.Count > 0 ? "源图解码缓存保留；下次预览会按参数复用星点分析与配准结果。" : null;
        DeletePreview();
        _ = PreviewChanged.InvokeAsync(null);
    }

    private void DeletePreview()
    {
        // The preview file is content-addressed cache data owned by the preview
        // engine. Removing it here breaks exact-setting hot-cache hits (and can
        // delete the path just returned by the engine).
        PreviewFilePath = null;
    }

    public void Dispose() { Cancellation?.Cancel(); Cancellation?.Dispose(); DeletePreview(); }
    private static string DescribeMetadata(WMImageArtifact item) =>
        $"{item.Metadata?.Model ?? "未知机型"} · {item.Width}×{item.Height} · ISO {item.Metadata?.Iso?.ToString() ?? "—"}";
    private static string FormatBytes(long value) => value >= 1024L * 1024 * 1024
        ? $"{value / 1024d / 1024d / 1024d:0.0} GB" : $"{value / 1024d / 1024d:0} MB";

    private sealed class FrameState { public WMFrameRole Role { get; set; } = WMFrameRole.Light; public bool Rejected { get; set; } public string? RejectionReason { get; set; } }
    private sealed record StackSelectOption<T>(T Value, string Label);
    private IList<StackSelectOption<WMAlignmentMode>> AvailableAlignmentOptions => AllAlignmentOptions
        .Where(item => IsAlignmentSupported(item.Value)).ToList();
    private static readonly List<StackSelectOption<WMAlignmentMode>> AllAlignmentOptions =
    [
        new(WMAlignmentMode.None, "不对齐"),
        new(WMAlignmentMode.Stars, "星点配准")
    ];
    private static readonly List<StackSelectOption<WMReductionMode>> ReductionOptions =
    [
        new(WMReductionMode.Maximum, "最大值 Maximum"),
        new(WMReductionMode.Lighten, "变亮 Lighten"),
        new(WMReductionMode.WinsorizedMean, "Winsorized Mean"),
        new(WMReductionMode.SigmaClippedMean, "Sigma-Clipped Mean")
    ];
    private static readonly (WMStackMode Value, string Title, string Description)[] Modes =
    [
        (WMStackMode.StarTrail, "星轨", "Maximum · 不对齐"),
        (WMStackMode.StaticSky, "银河堆栈", "星点配准 · Sigma")
    ];
}
