@using System.ComponentModel
@using Masa.Blazor
@using Watermark.Shared.Enums
@using Watermark.Shared.Models

<aside class="mac-mode-inspector">
    @if (ExportOpen)
    {
        <div class="inspector-scroll">
            <section class="inspector-block">
                <div class="block-heading">
                    <div>
                        <small>Export</small>
                        <h3>导出</h3>
                    </div>
                    <MButton Text Small Class="ghost-button" OnClick="ToggleExport">关闭</MButton>
                </div>

                <div class="control-card">
                    @if (HasPendingOperation)
                    {
                        <div class="pending-export-note" role="status">
                            <strong>当前画面是未应用的预览</strong>
                            <span>选择先应用新效果，或导出上次应用的版本。</span>
                            <div class="pending-export-actions">
                                <MButton Color="primary" Small OnClick="ApplyPendingBeforeExport">先应用再导出</MButton>
                                <MButton Text Small OnClick="ExportCommittedVersion">导出已应用版本</MButton>
                            </div>
                        </div>
                    }
                    <label class="field">
                        <span>分辨率</span>
                        <MSelect Value="@Resolution"
                                 ValueChanged="OnResolutionSelected"
                                 Items="@ResolutionOptions"
                                 ItemText="item => item.Label"
                                 ItemValue="item => item.Value"
                                 TValue="string"
                                 TItemValue="string"
                                 TItem="SelectOption<string>"
                                 Dense
                                 HideDetails="true" />
                    </label>
                    <label class="field">
                        <span>输出格式</span>
                        <MSelect Value="@ExportFormat"
                                 ValueChanged="OnExportFormatSelected"
                                 Items="@ExportFormatOptions"
                                 ItemText="item => item.Label"
                                 ItemValue="item => item.Value"
                                 TValue="WMExportFormat"
                                 TItemValue="WMExportFormat"
                                 TItem="SelectOption<WMExportFormat>"
                                 Dense
                                 HideDetails="true" />
                    </label>
                    <label class="field">
                        <span>图片质量</span>
                        <MSelect Value="@Quality"
                                 ValueChanged="OnQualitySelected"
                                 Items="@QualityOptions"
                                 ItemText="item => item.Label"
                                 ItemValue="item => item.Value"
                                 TValue="int"
                                 TItemValue="int"
                                 TItem="SelectOption<int>"
                                 Dense
                                 Disabled="@(ExportFormat != WMExportFormat.Jpeg8)"
                                 HideDetails="true" />
                    </label>
                    <label class="field">
                        <span>输出路径</span>
                        <div class="path-row">
                            <input value="@OutputPath" readonly />
                            <MButton Text Class="path-button" OnClick="ChooseOutputFolder">选择</MButton>
                        </div>
                    </label>
                    <label class="check-row">
                        <input type="checkbox" checked="@AllExportSelected" @onchange="OnSelectAllExport" />
                        <span>选择全部素材</span>
                    </label>
                    <MButton Color="primary" Class="primary-button" OnClick="ExportSelected" Disabled="@(HasPendingOperation || SelectedMediaCount == 0)">导出 @SelectedMediaCount 张图片</MButton>
                </div>
            </section>
        </div>
    }
    else if (Mode == MacWorkspaceMode.Template)
    {
        @if (Canvas != null && !string.IsNullOrEmpty(Canvas.Name) && Visible)
        {
            <div class="template-inspector-body">
                <Watermark.Razor.Components.DesignConfiguration Style="width:100%;height:100%;max-height:100%;min-height:0" canvas="@Canvas" PropertyChanged="PropertyChanged" SelectContainer="SelectContainer" />
            </div>
        }
        else
        {
            <div class="inspector-empty">
                <small>Template</small>
                <h3>未选择模板</h3>
                <p>导入图片并选择模板后，在这里调整画布、画幅和图层。</p>
            </div>
        }
    }
    else if (Mode == MacWorkspaceMode.ColorMatch)
    {
        <div class="color-inspector-layout">
            <div class="inspector-scroll color-inspector-scroll" tabindex="0" aria-label="调色参数">
                <section class="inspector-block">
                <div class="block-heading">
                    <div>
                        <small>Reference Look</small>
                        <h3>参考风格</h3>
                    </div>
                </div>

                <div class="control-card">
                    <div class="metric-grid">
                        <div>
                            <strong>@(CurrentColorRecipe?.Name ?? "未选择")</strong>
                            <span>当前预设</span>
                        </div>
                        <div>
                            <strong>@ColorPresetCount</strong>
                            <span>预设</span>
                        </div>
                    </div>

                    <label class="check-row">
                        <input type="checkbox" checked="@(CurrentColorRecipe?.ReferenceMapping.Enabled ?? false)" @onchange="OnMatchEnabledChanged" disabled="@(CurrentColorRecipe?.ReferenceProfile == null)" />
                        <span>启用参考图风格</span>
                    </label>

                    <MacSlider Label="风格强度"
                               Value="@(CurrentColorRecipe?.ReferenceMapping.Strength ?? 0)"
                               Min="0" Max="100" Step="1" Suffix="%"
                               Disabled="@(CurrentColorRecipe?.ReferenceProfile == null)"
                               ValueChanged="OnColorStrengthChanged" />

                    <label class="field">
                        <span>匹配风格</span>
                        <MSelect Value="@(CurrentColorRecipe?.ReferenceMapping.MatchMode ?? WMColorMappingMode.Natural)"
                                 ValueChanged="OnMatchModeSelected"
                                 Items="@MatchModeOptions"
                                 ItemText="item => item.Label"
                                 ItemValue="item => item.Value"
                                 TValue="WMColorMappingMode"
                                 TItemValue="WMColorMappingMode"
                                 TItem="SelectOption<WMColorMappingMode>"
                                 Dense
                                 Disabled="@(CurrentColorRecipe?.ReferenceProfile == null)"
                                 HideDetails="true" />
                    </label>

                    <label class="field">
                        <span>转移模式</span>
                        <MSelect Value="@(CurrentColorRecipe?.ReferenceMapping.Mode ?? ColorTransferMode.Full)"
                                 ValueChanged="OnColorModeSelected"
                                 Items="@ColorModeOptions"
                                 ItemText="item => item.Label"
                                 ItemValue="item => item.Value"
                                 TValue="ColorTransferMode"
                                 TItemValue="ColorTransferMode"
                                 TItem="SelectOption<ColorTransferMode>"
                                 Dense
                                 Disabled="@(CurrentColorRecipe?.ReferenceProfile == null)"
                                 HideDetails="true" />
                    </label>

                    <label class="check-row">
                        <input type="checkbox" checked="@(CurrentColorRecipe?.ReferenceMapping.PreserveLuminance ?? false)" @onchange="OnPreserveLuminanceChanged" disabled="@(CurrentColorRecipe?.ReferenceProfile == null)" />
                        <span>保留原图亮度</span>
                    </label>
                    @if (CurrentColorRecipe?.ReferenceProfile is { } profile)
                    {
                        <details class="analysis-details">
                            <summary>参考分析数据</summary>
                            <div class="analysis-grid">
                                <span>L 均值</span><strong>@profile.GlobalL.Mean.ToString("0.00")</strong>
                                <span>a 均值</span><strong>@profile.GlobalA.Mean.ToString("0.00")</strong>
                                <span>b 均值</span><strong>@profile.GlobalB.Mean.ToString("0.00")</strong>
                                <span>暗/中/亮像素</span><strong>@profile.Shadows.PixelCount / @profile.Midtones.PixelCount / @profile.Highlights.PixelCount</strong>
                            </div>
                        </details>
                        <div class="reference-actions">
                            <MButton Text Small OnClick="RematchColorReference">重新匹配当前图片</MButton>
                            <MButton Text Small OnClick="ClearColorReference">清除参考风格</MButton>
                        </div>
                    }
                </div>
            </section>

            @if (CurrentColorRecipe != null)
            {
                <section class="inspector-block adjustment-section @(ActiveColorSection == ColorInspectorSection.Basic ? "expanded" : null)">
                    <button type="button" class="adjustment-section-toggle" aria-expanded="@(ActiveColorSection == ColorInspectorSection.Basic)" @onclick="() => ToggleColorSection(ColorInspectorSection.Basic)">
                        <span><small>Basic</small><strong>基础调色</strong></span>
                        <span class="section-summary">10 项</span>
                        <span class="section-chevron" aria-hidden="true"><MIcon Size="16">mdi-chevron-down</MIcon></span>
                    </button>
                    @if (ActiveColorSection == ColorInspectorSection.Basic)
                    {
                    <div class="control-card grade-card adjustment-section-panel">
                        <div class="hint-line">滑杆表示人工微调；蓝色“自动”值来自当前参考风格。</div>
                        <MacColorGradeSlider Label="曝光" Baseline="@AutoGrade?.Exposure" Value="@CurrentColorRecipe.Grade.Exposure" Min="-5" Max="5" Step="0.05" Format="0.00" Suffix=" EV" ValueChanged="value => ChangeGrade(value, next => CurrentColorRecipe.Grade.Exposure = next)" />
                        <MacColorGradeSlider Label="对比度" Baseline="@AutoGrade?.Contrast" Value="@CurrentColorRecipe.Grade.Contrast" ValueChanged="value => ChangeGrade(value, next => CurrentColorRecipe.Grade.Contrast = next)" />
                        <MacColorGradeSlider Label="高光" Baseline="@AutoGrade?.Highlights" Value="@CurrentColorRecipe.Grade.Highlights" ValueChanged="value => ChangeGrade(value, next => CurrentColorRecipe.Grade.Highlights = next)" />
                        <MacColorGradeSlider Label="阴影" Baseline="@AutoGrade?.Shadows" Value="@CurrentColorRecipe.Grade.Shadows" ValueChanged="value => ChangeGrade(value, next => CurrentColorRecipe.Grade.Shadows = next)" />
                        <MacColorGradeSlider Label="白色" Baseline="@AutoGrade?.Whites" Value="@CurrentColorRecipe.Grade.Whites" ValueChanged="value => ChangeGrade(value, next => CurrentColorRecipe.Grade.Whites = next)" />
                        <MacColorGradeSlider Label="黑色" Baseline="@AutoGrade?.Blacks" Value="@CurrentColorRecipe.Grade.Blacks" ValueChanged="value => ChangeGrade(value, next => CurrentColorRecipe.Grade.Blacks = next)" />
                        <MacColorGradeSlider Label="色温" Baseline="@AutoGrade?.Temperature" Value="@CurrentColorRecipe.Grade.Temperature" ValueChanged="value => ChangeGrade(value, next => CurrentColorRecipe.Grade.Temperature = next)" />
                        <MacColorGradeSlider Label="色调" Baseline="@AutoGrade?.Tint" Value="@CurrentColorRecipe.Grade.Tint" ValueChanged="value => ChangeGrade(value, next => CurrentColorRecipe.Grade.Tint = next)" />
                        <MacColorGradeSlider Label="自然饱和度" Baseline="@AutoGrade?.Vibrance" Value="@CurrentColorRecipe.Grade.Vibrance" ValueChanged="value => ChangeGrade(value, next => CurrentColorRecipe.Grade.Vibrance = next)" />
                        <MacColorGradeSlider Label="饱和度" Baseline="@AutoGrade?.Saturation" Value="@CurrentColorRecipe.Grade.Saturation" ValueChanged="value => ChangeGrade(value, next => CurrentColorRecipe.Grade.Saturation = next)" />
                    </div>
                    }
                </section>

                <section class="inspector-block adjustment-section @(ActiveColorSection == ColorInspectorSection.Curves ? "expanded" : null)">
                    <button type="button" class="adjustment-section-toggle" aria-expanded="@(ActiveColorSection == ColorInspectorSection.Curves)" @onclick="() => ToggleColorSection(ColorInspectorSection.Curves)">
                        <span><small>Curves</small><strong>色调曲线</strong></span>
                        <span class="section-summary">RGB · R · G · B</span>
                        <span class="section-chevron" aria-hidden="true"><MIcon Size="16">mdi-chevron-down</MIcon></span>
                    </button>
                    @if (ActiveColorSection == ColorInspectorSection.Curves)
                    {
                    <div class="control-card curve-stack adjustment-section-panel">
                        @if (AutoGrade != null)
                        {
                            <div class="hint-line">总曲线和分色已包含自动基准，下面继续叠加人工调整。</div>
                        }
                        <div class="curve-channel-tabs" role="tablist" aria-label="曲线通道">
                            @foreach (var channel in CurveChannels)
                            {
                                <button type="button"
                                        role="tab"
                                        class="channel-@ChannelCss(channel) @(SelectedCurveChannel == channel ? "active" : null)"
                                        aria-selected="@(SelectedCurveChannel == channel)"
                                        @onclick="() => SelectCurveChannel(channel)">@ChannelLabel(channel)</button>
                            }
                        </div>
                        <MacCurveEditor @key="SelectedCurveChannel"
                                        Title="@SelectedCurveTitle"
                                        Channel="@ChannelCss(SelectedCurveChannel)"
                                        Points="@SelectedCurvePoints"
                                        PointsChanged="OnSelectedCurveChanged" />
                    </div>
                    }
                </section>

                <section class="inspector-block adjustment-section @(ActiveColorSection == ColorInspectorSection.Hsl ? "expanded" : null)">
                    <button type="button" class="adjustment-section-toggle" aria-expanded="@(ActiveColorSection == ColorInspectorSection.Hsl)" @onclick="() => ToggleColorSection(ColorInspectorSection.Hsl)">
                        <span><small>HSL</small><strong>分色调整</strong></span>
                        <span class="section-summary">@HslBandLabel(SelectedHslBand)</span>
                        <span class="section-chevron" aria-hidden="true"><MIcon Size="16">mdi-chevron-down</MIcon></span>
                    </button>
                    @if (ActiveColorSection == ColorInspectorSection.Hsl)
                    {
                    <div class="control-card grade-card adjustment-section-panel">
                        <div class="hsl-band-field">
                            <span>颜色范围</span>
                            <div class="hsl-band-buttons" role="radiogroup" aria-label="HSL 颜色范围">
                                @foreach (var option in HslBandOptions)
                                {
                                    <button type="button"
                                            role="radio"
                                            class="band-@HslBandCss(option.Value) @(SelectedHslBand == option.Value ? "active" : null)"
                                            aria-checked="@(SelectedHslBand == option.Value)"
                                            @onclick="() => OnHslBandSelected(option.Value)">
                                        <span class="hsl-band-swatch" aria-hidden="true"></span>
                                        <span>@option.Label</span>
                                    </button>
                                }
                            </div>
                        </div>
                        <MacColorGradeSlider Label="色相" Baseline="@SelectedAutoHsl?.Hue" Value="@SelectedHsl.Hue" ValueChanged="value => ChangeGrade(value, next => SelectedHsl.Hue = next)" />
                        <MacColorGradeSlider Label="饱和度" Baseline="@SelectedAutoHsl?.Saturation" Value="@SelectedHsl.Saturation" ValueChanged="value => ChangeGrade(value, next => SelectedHsl.Saturation = next)" />
                        <MacColorGradeSlider Label="明度" Baseline="@SelectedAutoHsl?.Luminance" Value="@SelectedHsl.Luminance" ValueChanged="value => ChangeGrade(value, next => SelectedHsl.Luminance = next)" />
                    </div>
                    }
                </section>
            }

            </div>
            <footer class="inspector-footer" aria-label="调色操作">
                <div class="action-stack">
                    <MButton Color="primary" Class="primary-button" OnClick="ApplyColor" Disabled="@(!CanApplyColor)">应用到当前照片</MButton>
                    <MButton Text Class="save-recipe-button" OnClick="SaveColorPreset" Disabled="@(CurrentColorRecipe == null)">保存调色风格</MButton>
                    <MButton Text Class="secondary-button" OnClick="ResetColorAdjustments" Disabled="@(CurrentColorRecipe == null)">重置人工调整</MButton>
                </div>
            </footer>
        </div>
    }
    else
    {
        <div class="inspector-scroll">
            <section class="inspector-block">
                <div class="block-heading">
                    <div>
                        <small>Multi-frame</small>
                        <h3>多帧影像</h3>
                    </div>
                    <span class="count-pill">@StarTrailSelectedCount 张</span>
                </div>

                <div class="control-card">
                    <div class="hint-line">可直接应用，或先用 1600px 代理预览；“应用合成”始终重新生成全分辨率 16-bit 母版。</div>
                </div>
                <MacMultiFrameWorkspace Inputs="@MultiFrameInputs"
                                        WorkingDirectory="@MultiFrameWorkingDirectory"
                                        Embedded="true"
                                        PreviewChanged="MultiFramePreviewChanged"
                                        Completed="MultiFrameApplied" />
            </section>
        </div>
    }
</aside>

@code {
    [Parameter] public MacWorkspaceMode Mode { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public bool ExportOpen { get; set; }
    [Parameter] public bool HasPendingOperation { get; set; }
    [Parameter] public WMCanvas? Canvas { get; set; }
    [Parameter] public WMColorPreset? CurrentColorPreset { get; set; }
    [Parameter] public WMColorRecipe? CurrentColorRecipe { get; set; }
    [Parameter] public int ColorPresetCount { get; set; }
    [Parameter] public bool CanApplyColor { get; set; }
    [Parameter] public int StarTrailSelectedCount { get; set; }
    [Parameter] public int SelectedMediaCount { get; set; }
    [Parameter] public bool AllExportSelected { get; set; }
    [Parameter] public string Resolution { get; set; } = "default";
    [Parameter] public int Quality { get; set; } = 100;
    [Parameter] public WMExportFormat ExportFormat { get; set; } = WMExportFormat.Jpeg8;
    [Parameter] public string OutputPath { get; set; } = string.Empty;
    [Parameter] public PropertyChangedEventHandler? PropertyChanged { get; set; }
    [Parameter] public Func<WMContainer, Task>? SelectContainer { get; set; }

    [Parameter] public EventCallback ToggleExport { get; set; }
    [Parameter] public EventCallback ApplyColor { get; set; }
    [Parameter] public EventCallback SaveColorPreset { get; set; }
    [Parameter] public EventCallback RematchColorReference { get; set; }
    [Parameter] public EventCallback ClearColorReference { get; set; }
    [Parameter] public EventCallback ResetColorAdjustments { get; set; }
    [Parameter] public EventCallback<WMColorRecipe> ColorRecipeChanged { get; set; }
    [Parameter] public EventCallback<WMColorRecipe> ColorGradeChanged { get; set; }
    [Parameter] public EventCallback<WMColorRecipe> ColorCurvesChanged { get; set; }
    [Parameter] public IReadOnlyList<WMImageArtifact> MultiFrameInputs { get; set; } = [];
    [Parameter] public string MultiFrameWorkingDirectory { get; set; } = string.Empty;
    [Parameter] public EventCallback<WMImageArtifact?> MultiFramePreviewChanged { get; set; }
    [Parameter] public EventCallback<WMOperationResult> MultiFrameApplied { get; set; }
    [Parameter] public EventCallback ChooseOutputFolder { get; set; }
    [Parameter] public EventCallback ExportSelected { get; set; }
    [Parameter] public EventCallback ApplyPendingBeforeExport { get; set; }
    [Parameter] public EventCallback ExportCommittedVersion { get; set; }
    [Parameter] public EventCallback<bool> AllExportSelectedChanged { get; set; }
    [Parameter] public EventCallback<string> ResolutionChanged { get; set; }
    [Parameter] public EventCallback<int> QualityChanged { get; set; }
    [Parameter] public EventCallback<WMExportFormat> ExportFormatChanged { get; set; }

    private WMHslBand SelectedHslBand { get; set; } = WMHslBand.Red;
    private ColorInspectorSection? ActiveColorSection { get; set; } = ColorInspectorSection.Basic;
    private CurveChannel SelectedCurveChannel { get; set; } = CurveChannel.Rgb;
    private WMColorGradeSettings? AutoGrade => CurrentColorRecipe?.GeneratedBaseGrade;
    private WMHslAdjustment SelectedHsl => CurrentColorRecipe?.Grade.Hsl.GetValueOrDefault(SelectedHslBand) ?? new WMHslAdjustment();
    private WMHslAdjustment? SelectedAutoHsl => AutoGrade?.Hsl.GetValueOrDefault(SelectedHslBand);
    private IReadOnlyList<WMCurvePoint> SelectedCurvePoints => SelectedCurveChannel switch
    {
        CurveChannel.Red => CurrentColorRecipe?.Grade.RedCurve ?? WMCurvePoint.Identity(),
        CurveChannel.Green => CurrentColorRecipe?.Grade.GreenCurve ?? WMCurvePoint.Identity(),
        CurveChannel.Blue => CurrentColorRecipe?.Grade.BlueCurve ?? WMCurvePoint.Identity(),
        _ => CurrentColorRecipe?.Grade.MasterCurve ?? WMCurvePoint.Identity()
    };
    private string SelectedCurveTitle => $"{ChannelLabel(SelectedCurveChannel)} 曲线";

    private static readonly CurveChannel[] CurveChannels = Enum.GetValues<CurveChannel>();

    private void ToggleColorSection(ColorInspectorSection section) =>
        ActiveColorSection = ActiveColorSection == section ? null : section;

    private void SelectCurveChannel(CurveChannel channel) => SelectedCurveChannel = channel;

    private async Task OnSelectedCurveChanged(List<WMCurvePoint> points)
    {
        if (CurrentColorRecipe == null) return;
        switch (SelectedCurveChannel)
        {
            case CurveChannel.Red: CurrentColorRecipe.Grade.RedCurve = points; break;
            case CurveChannel.Green: CurrentColorRecipe.Grade.GreenCurve = points; break;
            case CurveChannel.Blue: CurrentColorRecipe.Grade.BlueCurve = points; break;
            default: CurrentColorRecipe.Grade.MasterCurve = points; break;
        }
        await NotifyCurvesChanged();
    }

    private static string ChannelLabel(CurveChannel channel) => channel switch
    {
        CurveChannel.Red => "R",
        CurveChannel.Green => "G",
        CurveChannel.Blue => "B",
        _ => "RGB"
    };

    private static string ChannelCss(CurveChannel channel) => channel.ToString().ToLowerInvariant();

    private static string HslBandLabel(WMHslBand band) =>
        HslBandOptions.First(option => option.Value == band).Label;

    private static string HslBandCss(WMHslBand band) => band.ToString().ToLowerInvariant();

    private async Task OnColorStrengthChanged(double value)
    {
        if (CurrentColorRecipe != null)
        {
            CurrentColorRecipe.ReferenceMapping.IsConfigured = true;
            CurrentColorRecipe.ReferenceMapping.Strength = (float)value;
            await NotifyRecipeChanged();
        }
    }

    private async Task OnColorModeSelected(ColorTransferMode mode)
    {
        if (CurrentColorRecipe != null)
        {
            CurrentColorRecipe.ReferenceMapping.IsConfigured = true;
            CurrentColorRecipe.ReferenceMapping.Mode = mode;
            await NotifyRecipeChanged();
        }
    }

    private async Task OnMatchModeSelected(WMColorMappingMode mode)
    {
        if (CurrentColorRecipe == null) return;
        CurrentColorRecipe.ReferenceMapping.IsConfigured = true;
        CurrentColorRecipe.ReferenceMapping.MatchMode = mode;
        await NotifyRecipeChanged();
    }

    private async Task OnPreserveLuminanceChanged(ChangeEventArgs args)
    {
        if (CurrentColorRecipe != null)
        {
            CurrentColorRecipe.ReferenceMapping.IsConfigured = true;
            CurrentColorRecipe.ReferenceMapping.PreserveLuminance = args.Value is bool value && value;
            await NotifyRecipeChanged();
        }
    }

    private async Task OnMatchEnabledChanged(ChangeEventArgs args)
    {
        if (CurrentColorRecipe == null) return;
        CurrentColorRecipe.ReferenceMapping.IsConfigured = true;
        CurrentColorRecipe.ReferenceMapping.Enabled = args.Value is bool enabled && enabled;
        await NotifyRecipeChanged();
    }

    private async Task ChangeGrade(float value, Action<float> apply)
    {
        apply(value);
        await NotifyGradeChanged();
    }

    private Task OnHslBandSelected(WMHslBand band)
    {
        SelectedHslBand = band;
        return Task.CompletedTask;
    }

    private Task NotifyRecipeChanged() => CurrentColorRecipe == null
        ? Task.CompletedTask
        : ColorRecipeChanged.InvokeAsync(CurrentColorRecipe);

    private Task NotifyGradeChanged() => CurrentColorRecipe == null
        ? Task.CompletedTask
        : ColorGradeChanged.InvokeAsync(CurrentColorRecipe);

    private Task NotifyCurvesChanged() => CurrentColorRecipe == null
        ? Task.CompletedTask
        : ColorCurvesChanged.InvokeAsync(CurrentColorRecipe);

    private async Task OnSelectAllExport(ChangeEventArgs args)
    {
        await AllExportSelectedChanged.InvokeAsync(args.Value is bool value && value);
    }

    private async Task OnResolutionSelected(string value)
    {
        await ResolutionChanged.InvokeAsync(value);
    }

    private async Task OnQualitySelected(int value)
    {
        await QualityChanged.InvokeAsync(value);
    }

    private Task OnExportFormatSelected(WMExportFormat value) => ExportFormatChanged.InvokeAsync(value);

    private static readonly List<SelectOption<string>> ResolutionOptions =
    [
        new("default", "原图"),
        new("1080", "1080P"),
        new("2160", "4K")
    ];

    private static readonly List<SelectOption<int>> QualityOptions =
    [
        new(100, "原图"),
        new(85, "高"),
        new(70, "中")
    ];

    private static readonly List<SelectOption<WMExportFormat>> ExportFormatOptions =
    [
        new(WMExportFormat.Jpeg8, "JPEG · 8位"),
        new(WMExportFormat.Png16, "PNG · 16位无损"),
        new(WMExportFormat.Tiff16, "TIFF · 16位 / BigTIFF")
    ];

    private static readonly List<SelectOption<ColorTransferMode>> ColorModeOptions =
    [
        new(ColorTransferMode.Full, "全局 Reinhard"),
        new(ColorTransferMode.RegionalAdaptive, "分区自适应")
    ];

    private static readonly List<SelectOption<WMColorMappingMode>> MatchModeOptions =
    [
        new(WMColorMappingMode.Natural, "自然匹配"),
        new(WMColorMappingMode.Strong, "强烈匹配")
    ];

    private static readonly List<SelectOption<WMHslBand>> HslBandOptions =
    [
        new(WMHslBand.Red, "红"), new(WMHslBand.Orange, "橙"), new(WMHslBand.Yellow, "黄"),
        new(WMHslBand.Green, "绿"), new(WMHslBand.Aqua, "青"), new(WMHslBand.Blue, "蓝"),
        new(WMHslBand.Purple, "紫"), new(WMHslBand.Magenta, "洋红")
    ];

    private sealed record SelectOption<T>(T Value, string Label);

    private enum ColorInspectorSection { Basic, Curves, Hsl }
    private enum CurveChannel { Rgb, Red, Green, Blue }
}
