@using Watermark.Shared.Models

<section class="mac-media-strip" aria-label="素材">
    <header class="media-strip-header">
        <strong>素材</strong>
        <span>@Images.Count 张</span>
        @if (Images.Any(image => image.IsChecked))
        {
            <span class="selection-count">已勾选 @Images.Count(image => image.IsChecked) 张</span>
        }
    </header>
    <div class="media-scroll">
        @if (Images.Count == 0)
        {
            <div class="media-empty">导入图片后，素材会显示在这里</div>
        }
        else
        {
            @foreach (var image in Images)
            {
                <article class="@(CurrentImage?.ID == image.ID ? "media-tile active" : "media-tile")" @onclick="() => ClickImage.InvokeAsync(image)">
                    <div class="media-thumb" @onclick:stopPropagation="true" @onclick="() => ClickImage.InvokeAsync(image)">
                        <img src="@image.Src" alt="@DisplayName(image)" />
                    </div>
                    <label class="media-check" title="导出选择" @onclick:stopPropagation="true">
                        <input type="checkbox" checked="@image.IsChecked" @onchange="args => ToggleExportSelection(image, args)" />
                    </label>
                    @if (StarTrailSelectionIds.Contains(image.ID))
                    {
                        <span class="stack-badge">星轨</span>
                    }
                </article>
            }
        }
    </div>
</section>

@code {
    [Parameter] public IReadOnlyList<WMTemplateList> Images { get; set; } = [];
    [Parameter] public WMTemplateList? CurrentImage { get; set; }
    [Parameter] public IReadOnlyList<string> StarTrailSelectionIds { get; set; } = [];
    [Parameter] public EventCallback<WMTemplateList> ClickImage { get; set; }
    [Parameter] public EventCallback<WMTemplateList> ExportSelectionChanged { get; set; }

    private async Task ToggleExportSelection(WMTemplateList image, ChangeEventArgs args)
    {
        image.IsChecked = args.Value is bool value && value;
        await ExportSelectionChanged.InvokeAsync(image);
    }

    private static string DisplayName(WMTemplateList image)
    {
        if (!string.IsNullOrWhiteSpace(image.Path))
        {
            return System.IO.Path.GetFileName(image.Path);
        }

        return "素材图片";
    }
}
