@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Watermark.Razor.Workspace
@using Watermark.Shared.Models
@inject IJSRuntime JSRuntime
@implements IDisposable
@implements IAsyncDisposable

<aside class="mac-layer-tree" aria-label="模板图层" @ref="treeElement">
    <header class="layer-panel-header">
        <div>
            <h2>图层</h2>
            <span>@LayerCount</span>
        </div>
        <MMenu Bottom OffsetY>
            <ActivatorContent>
                <MButton Text Small Class="add-layer-trigger" title="添加图层" aria-label="添加图层" @attributes="@context.Attrs">
                    <MIcon Left Small>mdi-plus</MIcon>添加
                </MButton>
            </ActivatorContent>
            <ChildContent>
                <MList Dense Class="add-layer-options">
                    <MListItem Title="容器" PrependIcon="mdi-folder-outline" OnClick="() => AddControl(typeof(WMContainer))" />
                    <MListItem Title="文字" PrependIcon="mdi-format-text" OnClick="() => AddControl(typeof(WMText))" />
                    <MListItem Title="Logo" PrependIcon="mdi-image-outline" OnClick="() => AddControl(typeof(WMLogo))" />
                    <MListItem Title="分割线" PrependIcon="mdi-minus" OnClick="() => AddControl(typeof(WMLine))" />
                </MList>
            </ChildContent>
        </MMenu>
    </header>

    <div class="layer-tree-scroll" role="tree" aria-label="模板图层结构" @onclick="CloseContextMenu">
        @if (Editor.Draft.Children.Count == 0)
        {
            <div class="layer-empty-state">
                <MIcon>mdi-layers-outline</MIcon>
                <span>暂无图层</span>
            </div>
        }
        else
        {
            @for (var index = 0; index < Editor.Draft.Children.Count; index++)
            {
                var root = Editor.Draft.Children[index];
                @RenderNode(root, 0, null, index)
            }
            @RenderDropSlot(null, Editor.Draft.Children.Count, 0)
        }
    </div>

    @if (pendingDelete is not null)
    {
        <MDialog Persistent Value="true" ContentStyle="width:min(280px,calc(100vw - 32px));">
            <section class="layer-confirm" role="dialog" aria-modal="true" aria-labelledby="layer-delete-title">
                <h3 id="layer-delete-title">删除“@DisplayName(pendingDelete)”？</h3>
                <p>此容器包含 @pendingDescendantCount 个子图层，删除后仍可通过撤销恢复。</p>
                <div class="layer-confirm-actions">
                    <MButton Text Small Class="secondary" OnClick="CancelDelete">取消</MButton>
                    <MButton Text Small Class="danger" OnClick="ConfirmDelete">删除</MButton>
                </div>
            </section>
        </MDialog>
    }
</aside>

@code {
    [Parameter, EditorRequired] public WMTemplateEditorState Editor { get; set; } = null!;

    private readonly HashSet<string> collapsedIds = new(StringComparer.Ordinal);
    private string editingId;
    private string editingName = string.Empty;
    private string contextId;
    private string draggedId;
    private IWMControl pendingDelete;
    private int pendingDescendantCount;
    private string hoverExpandId;
    private CancellationTokenSource hoverExpandCancellation;
    private ElementReference treeElement;
    private IJSObjectReference layerTreeModule;
    private IJSObjectReference layerTreeReference;
    private DotNetObjectReference<MacLayerTree> dotNetReference;
    private bool disposed;

    private int LayerCount => WMControlTree.Flatten(Editor.Draft).Count;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || disposed) return;
        layerTreeModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/Watermark.Razor/js/mac-layer-tree.js");
        dotNetReference = DotNetObjectReference.Create(this);
        layerTreeReference = await layerTreeModule.InvokeAsync<IJSObjectReference>(
            "createLayerTree", treeElement, dotNetReference);
    }

    private RenderFragment RenderNode(IWMControl control, int depth, string parentId, int index) => @<div class="layer-node-group">
        @RenderDropSlot(parentId, index, depth)
        <div class="layer-node"
             style="--layer-depth:@depth"
             data-layer-control-id="@control.ID"
             data-layer-parent-id="@(parentId ?? string.Empty)"
             data-layer-index="@index"
             data-layer-container-count="@(control is WMContainer container ? container.Controls.Count : -1)">
            <div class="layer-row @(Editor.SelectedControlId == control.ID ? "selected" : null) @(control.Enabled ? null : "hidden-layer")"
                 role="treeitem"
                 aria-level="@(depth + 1)"
                 aria-selected="@(Editor.SelectedControlId == control.ID)"
                 tabindex="0"
                 @onclick="() => Select(control)"
                 @onkeydown="args => HandleRowKeyDown(control, args)"
                 @oncontextmenu="() => OpenContextMenu(control)"
                 @oncontextmenu:preventDefault>
                @if (control is WMContainer)
                {
                    <button type="button" class="tree-toggle" title="@(IsCollapsed(control.ID) ? "展开" : "收起")" aria-label="@(IsCollapsed(control.ID) ? "展开容器" : "收起容器")" @onclick:stopPropagation @onclick="() => ToggleCollapsed(control.ID)">
                        <MIcon Size="14">@(IsCollapsed(control.ID) ? "mdi-chevron-right" : "mdi-chevron-down")</MIcon>
                    </button>
                }
                else
                {
                    <span class="tree-toggle-spacer"></span>
                }

                <span class="drag-handle @(control.IsLocked ? "disabled" : null)"
                      title="@(control.IsLocked ? "图层已锁定" : "拖动图层")"
                      aria-label="@(control.IsLocked ? "图层已锁定" : "拖动图层")"
                      data-layer-drag-id="@(control.IsLocked ? null : control.ID)"
                      aria-disabled="@control.IsLocked"
                      @onclick:stopPropagation
                      >⋮⋮</span>

                <MIcon Size="15" Class="layer-type-icon">@IconFor(control)</MIcon>

                @if (editingId == control.ID)
                {
                    <input class="layer-name-input"
                           value="@editingName"
                           @oninput="UpdateRenameValue"
                           @onkeydown="args => HandleRenameKey(control, args)"
                           @onkeydown:stopPropagation
                           @onblur="() => CommitRename(control)"
                           @onclick:stopPropagation
                           aria-label="图层名称"
                           autofocus />
                }
                else
                {
                    <span class="layer-name" title="@DisplayName(control)" @ondblclick:stopPropagation @ondblclick="() => BeginRename(control)">@DisplayName(control)</span>
                }

                <div class="layer-row-actions">
                    <button type="button" class="layer-action" title="复制图层" aria-label="复制图层" @onclick:stopPropagation @onclick="() => Duplicate(control)">
                        <MIcon Size="14">mdi-content-copy</MIcon>
                    </button>
                    <button type="button" class="layer-action" title="删除图层" aria-label="删除图层" @onclick:stopPropagation @onclick="() => RequestDelete(control)">
                        <MIcon Size="14">mdi-trash-can-outline</MIcon>
                    </button>
                    <button type="button" class="layer-action persistent" title="显示或隐藏" aria-label="显示或隐藏图层" @onclick:stopPropagation @onclick="() => ToggleVisible(control)">
                        <MIcon Size="14">@(control.Enabled ? "mdi-eye-outline" : "mdi-eye-off-outline")</MIcon>
                    </button>
                    <button type="button" class="layer-action persistent" title="锁定或解锁" aria-label="锁定或解锁图层" @onclick:stopPropagation @onclick="() => ToggleLocked(control)">
                        <MIcon Size="14">@(control.IsLocked ? "mdi-lock-outline" : "mdi-lock-open-variant-outline")</MIcon>
                    </button>
                </div>
            </div>

            @if (contextId == control.ID)
            {
                <div class="layer-context-menu" role="menu" @onclick:stopPropagation>
                    <button type="button" role="menuitem" @onclick="() => BeginRename(control)">重命名</button>
                    <button type="button" role="menuitem" @onclick="() => Duplicate(control)">复制</button>
                    <button type="button" role="menuitem" class="danger-text" @onclick="() => RequestDelete(control)">删除</button>
                </div>
            }
        </div>

        @if (control is WMContainer childrenContainer && !IsCollapsed(control.ID))
        {
            <div class="layer-children" role="group">
                @for (var childIndex = 0; childIndex < childrenContainer.Controls.Count; childIndex++)
                {
                    var child = childrenContainer.Controls[childIndex];
                    @RenderNode(child, depth + 1, childrenContainer.ID, childIndex)
                }
                @RenderDropSlot(childrenContainer.ID, childrenContainer.Controls.Count, depth + 1)
            </div>
        }
    </div>;

    private RenderFragment RenderDropSlot(string parentId, int index, int depth) => @<div class="layer-drop-slot"
         style="--layer-depth:@depth"
         data-layer-drop-slot
         data-layer-parent-id="@(parentId ?? string.Empty)"
         data-layer-index="@index">
        <span></span>
    </div>;

    private void Select(IWMControl control)
    {
        contextId = null;
        Editor.Select(control.ID);
    }

    private void AddControl(Type type)
    {
        IWMControl added = null;
        Editor.Mutate("添加图层", () =>
        {
            added = WMControlTree.Add(Editor.Draft, type, PreferredParentId());
            added.Name = type == typeof(WMContainer) ? "新容器"
                : type == typeof(WMText) ? "新文字"
                : type == typeof(WMLogo) ? "新 Logo"
                : "新分割线";
        });
        if (added is not null) Editor.Select(added.ID);
    }

    private string PreferredParentId()
    {
        if (string.IsNullOrWhiteSpace(Editor.SelectedControlId)) return null;
        var selected = WMControlTree.Find(Editor.Draft, Editor.SelectedControlId);
        if (selected is WMContainer container) return container.ID;
        return WMControlTree.FindParent(Editor.Draft, Editor.SelectedControlId)?.ID;
    }

    private void BeginRename(IWMControl control)
    {
        contextId = null;
        editingId = control.ID;
        editingName = DisplayName(control);
    }

    private void UpdateRenameValue(ChangeEventArgs args) => editingName = args.Value?.ToString() ?? string.Empty;

    private void HandleRenameKey(IWMControl control, KeyboardEventArgs args)
    {
        if (args.Key == "Enter") CommitRename(control);
        else if (args.Key == "Escape") CancelRename();
    }

    private void CommitRename(IWMControl control)
    {
        if (editingId != control.ID) return;
        var value = editingName.Trim();
        editingId = null;
        if (string.IsNullOrWhiteSpace(value) || value == control.Name) return;
        Editor.Mutate("重命名图层", () => control.Name = value);
    }

    private void CancelRename()
    {
        editingId = null;
        editingName = string.Empty;
    }

    private void ToggleVisible(IWMControl control) =>
        Editor.Mutate("切换图层可见性", () => control.Enabled = !control.Enabled);

    private void ToggleLocked(IWMControl control) =>
        Editor.Mutate("切换图层锁定", () => control.IsLocked = !control.IsLocked);

    private void Duplicate(IWMControl control)
    {
        IWMControl copy = null;
        Editor.Mutate("复制图层", () =>
        {
            copy = WMControlTree.Duplicate(Editor.Draft, control.ID);
            copy.Name = $"{DisplayName(control)} 副本";
        });
        contextId = null;
        if (copy is not null) Editor.Select(copy.ID);
    }

    private void RequestDelete(IWMControl control)
    {
        contextId = null;
        var descendants = DescendantCount(control);
        if (control is WMContainer && descendants > 0)
        {
            pendingDelete = control;
            pendingDescendantCount = descendants;
            return;
        }
        Delete(control);
    }

    private void ConfirmDelete()
    {
        var control = pendingDelete;
        pendingDelete = null;
        pendingDescendantCount = 0;
        if (control is not null) Delete(control);
    }

    private void CancelDelete()
    {
        pendingDelete = null;
        pendingDescendantCount = 0;
    }

    private void Delete(IWMControl control)
    {
        var parentId = WMControlTree.FindParent(Editor.Draft, control.ID)?.ID;
        Editor.Mutate("删除图层", () =>
        {
            if (!WMControlTree.Remove(Editor.Draft, control.ID))
                throw new InvalidOperationException("无法删除图层。");
        });
        Editor.Select(parentId);
    }

    private void OpenContextMenu(IWMControl control)
    {
        Editor.Select(control.ID);
        contextId = contextId == control.ID ? null : control.ID;
    }

    private void CloseContextMenu()
    {
        if (contextId is not null) contextId = null;
    }

    private void HandleRowKeyDown(IWMControl control, KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or " ") Select(control);
        else if (args.Key == "F2") BeginRename(control);
        else if (args.Key == "Delete" || args.Key == "Backspace") RequestDelete(control);
        else if (args.Key == "ArrowRight" && control is WMContainer) collapsedIds.Remove(control.ID);
        else if (args.Key == "ArrowLeft" && control is WMContainer) collapsedIds.Add(control.ID);
    }

    private void ToggleCollapsed(string id)
    {
        if (!collapsedIds.Add(id)) collapsedIds.Remove(id);
    }

    private bool IsCollapsed(string id) => collapsedIds.Contains(id);

    [JSInvokable]
    public Task<bool> BeginLayerPointerDrag(string controlId)
    {
        var control = WMControlTree.Find(Editor.Draft, controlId);
        if (control is null || control.IsLocked) return Task.FromResult(false);
        draggedId = control.ID;
        ClearDropCandidate();
        return Task.FromResult(true);
    }

    [JSInvokable]
    public Task<bool> CanDropLayerPointer(string controlId, string parentId, int rawIndex)
    {
        draggedId = controlId;
        return Task.FromResult(CanDrop(NormalizeParentId(parentId), rawIndex));
    }

    [JSInvokable]
    public Task CommitLayerPointerDrop(string controlId, string parentId, int rawIndex)
    {
        draggedId = controlId;
        return DropAsync(NormalizeParentId(parentId), rawIndex);
    }

    [JSInvokable]
    public Task EndLayerPointerDrag()
    {
        EndDrag();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task HoverLayerContainer(string controlId)
    {
        ScheduleAutoExpand(controlId);
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task CancelLayerContainerHover()
    {
        CancelHoverExpand();
        return Task.CompletedTask;
    }

    private void EndDrag()
    {
        draggedId = null;
        ClearDropCandidate();
    }

    private bool CanDrop(string parentId, int rawIndex)
    {
        if (string.IsNullOrWhiteSpace(draggedId)) return false;
        var control = WMControlTree.Find(Editor.Draft, draggedId);
        if (control is null || control.IsLocked) return false;
        if (!WMControlTree.CanMove(Editor.Draft, draggedId, parentId, out _)) return false;

        var target = parentId is null ? null : WMControlTree.Find(Editor.Draft, parentId) as WMContainer;
        var targetCount = target?.Controls.Count ?? Editor.Draft.Children.Count;
        var alreadyInTarget = target is null
            ? control is WMContainer root && Editor.Draft.Children.Contains(root)
            : target.Controls.Contains(control);
        var maximum = alreadyInTarget ? targetCount - 1 : targetCount;
        var index = NormalizeDropIndex(parentId, rawIndex);
        return index >= 0 && index <= maximum;
    }

    private async Task DropAsync(string parentId, int rawIndex)
    {
        var movingId = draggedId;
        if (string.IsNullOrWhiteSpace(movingId) || !CanDrop(parentId, rawIndex))
        {
            EndDrag();
            return;
        }

        var index = NormalizeDropIndex(parentId, rawIndex);
        Editor.Mutate("移动图层", () =>
        {
            if (!WMControlTree.Move(Editor.Draft, movingId, parentId, index))
                throw new InvalidOperationException("无法移动到目标位置。");
        });
        Editor.Select(movingId);
        EndDrag();
        await Task.CompletedTask;
    }

    private int NormalizeDropIndex(string parentId, int rawIndex)
    {
        if (string.IsNullOrWhiteSpace(draggedId)) return rawIndex;
        var moving = WMControlTree.Find(Editor.Draft, draggedId);
        if (moving is null) return rawIndex;

        if (parentId is null && moving is WMContainer root)
        {
            var sourceIndex = Editor.Draft.Children.IndexOf(root);
            return sourceIndex >= 0 && sourceIndex < rawIndex ? rawIndex - 1 : rawIndex;
        }

        if (parentId is null) return rawIndex;
        var target = WMControlTree.Find(Editor.Draft, parentId) as WMContainer;
        if (target is null) return rawIndex;
        var childIndex = target.Controls.IndexOf(moving);
        return childIndex >= 0 && childIndex < rawIndex ? rawIndex - 1 : rawIndex;
    }

    private static string NormalizeParentId(string parentId) =>
        string.IsNullOrWhiteSpace(parentId) ? null : parentId;

    private void ClearDropCandidate() => CancelHoverExpand();

    private void ScheduleAutoExpand(string id)
    {
        if (!collapsedIds.Contains(id) || hoverExpandId == id) return;
        CancelHoverExpand();
        hoverExpandId = id;
        var cancellation = new CancellationTokenSource();
        hoverExpandCancellation = cancellation;
        _ = AutoExpandAsync(id, cancellation.Token);
    }

    private async Task AutoExpandAsync(string id, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(600, cancellationToken);
            await InvokeAsync(() =>
            {
                if (hoverExpandId == id && !cancellationToken.IsCancellationRequested)
                {
                    collapsedIds.Remove(id);
                    StateHasChanged();
                }
            });
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void CancelHoverExpand()
    {
        hoverExpandCancellation?.Cancel();
        hoverExpandCancellation?.Dispose();
        hoverExpandCancellation = null;
        hoverExpandId = null;
    }

    private static int DescendantCount(IWMControl control)
    {
        if (control is not WMContainer container) return 0;
        var count = 0;
        var pending = new Stack<IWMControl>(container.Controls.Reverse<IWMControl>());
        var visited = new HashSet<IWMControl>(ReferenceEqualityComparer.Instance);
        while (pending.Count > 0)
        {
            var current = pending.Pop();
            if (!visited.Add(current)) continue;
            count++;
            if (current is WMContainer childContainer)
                foreach (var child in childContainer.Controls) pending.Push(child);
        }
        return count;
    }

    private static string DisplayName(IWMControl control) =>
        string.IsNullOrWhiteSpace(control.Name) ? control switch
        {
            WMContainer => "未命名容器",
            WMText => "未命名文字",
            WMLogo => "未命名 Logo",
            WMLine => "未命名分割线",
            _ => "未命名图层"
        } : control.Name;

    private static string IconFor(IWMControl control) => control switch
    {
        WMContainer => "mdi-folder-outline",
        WMText => "mdi-format-text",
        WMLogo => "mdi-image-outline",
        WMLine => "mdi-minus",
        _ => "mdi-shape-outline"
    };

    public void Dispose() => CancelHoverExpand();

    public async ValueTask DisposeAsync()
    {
        if (disposed) return;
        disposed = true;
        CancelHoverExpand();
        try
        {
            if (layerTreeReference is not null)
                await layerTreeReference.InvokeVoidAsync("dispose");
        }
        catch (JSDisconnectedException)
        {
        }
        finally
        {
            if (layerTreeReference is not null) await layerTreeReference.DisposeAsync();
            if (layerTreeModule is not null) await layerTreeModule.DisposeAsync();
            dotNetReference?.Dispose();
        }
    }
}
