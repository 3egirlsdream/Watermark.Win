@using System.Globalization

<div class="mac-inspector-slider @(Disabled ? "disabled" : null)">
    <div class="inspector-slider-controls">
        <MacSlider Label="@Label"
                   Value="@Value"
                   Min="@Min"
                   Max="@Max"
                   Step="@Step"
                   Format="@(Step < 1 ? "0.##" : "0")"
                   Suffix="@Unit"
                   Compact
                   Disabled="@Disabled"
                   ValueChanged="HandleSliderAsync"
                   InteractionStarted="InteractionStarted"
                   InteractionEnded="InteractionEnded" />
        <input class="inspector-number-input"
               type="number"
               min="@MinString"
               max="@MaxString"
               step="@StepString"
               value="@ValueString"
               disabled="@Disabled"
               aria-label="@Label"
               @onchange="HandleInputAsync"
               @onkeydown:stopPropagation />
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public double Value { get; set; }
    [Parameter] public EventCallback<double> ValueChanged { get; set; }
    [Parameter] public double Min { get; set; }
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public double Step { get; set; } = 1;
    [Parameter] public string Unit { get; set; } = string.Empty;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback InteractionStarted { get; set; }
    [Parameter] public EventCallback InteractionEnded { get; set; }

    private string ValueString => Value.ToString("0.###", CultureInfo.InvariantCulture);
    private string MinString => Min.ToString("0.###", CultureInfo.InvariantCulture);
    private string MaxString => Max.ToString("0.###", CultureInfo.InvariantCulture);
    private string StepString => Step.ToString("0.###", CultureInfo.InvariantCulture);
    private Task HandleSliderAsync(double value) => Disabled
        ? Task.CompletedTask
        : ValueChanged.InvokeAsync(Math.Clamp(value, Min, Max));

    private async Task HandleInputAsync(ChangeEventArgs args)
    {
        if (Disabled) return;
        if (!double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var value))
            return;
        await ValueChanged.InvokeAsync(Math.Clamp(value, Min, Max));
    }

}
