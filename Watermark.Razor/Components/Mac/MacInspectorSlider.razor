@using System.Globalization

<div class="mac-inspector-slider @(Disabled ? "disabled" : null)">
    <div class="inspector-slider-label">
        <label for="@rangeId">@Label</label>
        <span>@FormattedValue@Unit</span>
    </div>
    <div class="inspector-slider-controls">
        <input id="@rangeId"
               type="range"
               min="@MinString"
               max="@MaxString"
               step="@StepString"
               value="@ValueString"
               disabled="@Disabled"
               @onfocus="StartInteractionAsync"
               @onpointerdown="StartInteractionAsync"
               @oninput="HandleInputAsync"
               @onchange="EndInteractionAsync"
               @onpointerup="EndInteractionAsync"
               @onpointercancel="EndInteractionAsync"
               @onblur="EndInteractionAsync" />
        <input class="inspector-number-input"
               type="number"
               min="@MinString"
               max="@MaxString"
               step="@StepString"
               value="@ValueString"
               disabled="@Disabled"
               aria-label="@Label"
               @onfocus="StartInteractionAsync"
               @oninput="HandleInputAsync"
               @onblur="EndInteractionAsync" />
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public double Value { get; set; }
    [Parameter] public EventCallback<double> ValueChanged { get; set; }
    [Parameter] public double Min { get; set; }
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public double Step { get; set; } = 1;
    [Parameter] public string Unit { get; set; } = string.Empty;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback InteractionStarted { get; set; }
    [Parameter] public EventCallback InteractionEnded { get; set; }

    private readonly string rangeId = $"inspector-slider-{Guid.NewGuid():N}";
    private bool interactionActive;
    private string ValueString => Value.ToString("0.###", CultureInfo.InvariantCulture);
    private string MinString => Min.ToString("0.###", CultureInfo.InvariantCulture);
    private string MaxString => Max.ToString("0.###", CultureInfo.InvariantCulture);
    private string StepString => Step.ToString("0.###", CultureInfo.InvariantCulture);
    private string FormattedValue => Value.ToString(Step < 1 ? "0.##" : "0", CultureInfo.InvariantCulture);

    private async Task StartInteractionAsync()
    {
        if (Disabled || interactionActive) return;
        interactionActive = true;
        try
        {
            await InteractionStarted.InvokeAsync();
        }
        catch
        {
            interactionActive = false;
            throw;
        }
    }

    private async Task HandleInputAsync(ChangeEventArgs args)
    {
        if (Disabled) return;
        await StartInteractionAsync();
        if (!double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var value))
            return;
        await ValueChanged.InvokeAsync(Math.Clamp(value, Min, Max));
    }

    private async Task EndInteractionAsync()
    {
        if (!interactionActive) return;
        interactionActive = false;
        await InteractionEnded.InvokeAsync();
    }
}
