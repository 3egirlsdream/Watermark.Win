@using Masa.Blazor

<nav class="mac-feature-rail" aria-label="工作模式">
    @foreach (var item in Items)
    {
        <MButton Text
                 Class="@FeatureClass(item.Mode)"
                 OnClick="() => ModeChanged.InvokeAsync(item.Mode)">
            <MIcon Size="22">@item.Icon</MIcon>
            <span>@item.Label</span>
        </MButton>
    }
</nav>

@code {
    [Parameter]
    public MacWorkspaceMode Mode { get; set; }

    [Parameter]
    public EventCallback<MacWorkspaceMode> ModeChanged { get; set; }

    private static readonly FeatureItem[] Items =
    [
        new(MacWorkspaceMode.Template, "预设", "mdi-palette-swatch-outline", "选择水印模板、拼图模板和模板库"),
        new(MacWorkspaceMode.ColorMatch, "调色", "mdi-tune-variant", "手工调色或从参考图生成可编辑风格"),
        new(MacWorkspaceMode.StarTrail, "多帧", "mdi-weather-night", "星轨、场景降噪与静态星空堆栈")
    ];

    private string FeatureClass(MacWorkspaceMode mode) => Mode == mode ? "feature-button active" : "feature-button";

    private sealed record FeatureItem(MacWorkspaceMode Mode, string Label, string Icon, string Description);
}
