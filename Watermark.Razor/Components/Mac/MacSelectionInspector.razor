@using Watermark.Razor.Workspace
@using Watermark.Shared.Enums
@using Watermark.Shared.Models
@implements IDisposable

<aside class="mac-selection-inspector" aria-label="属性检查器">
    <header class="selection-header">
        <div class="selection-heading-row">
            <input class="selection-name-input" value="@CurrentName" disabled="@IsReadOnly" @onchange="RenameCurrent" @onkeydown:stopPropagation aria-label="名称" />
            <span class="selection-type">@CurrentTypeName</span>
        </div>
        <div class="selection-breadcrumb" title="@Breadcrumb">@Breadcrumb</div>
        @if (SelectedControl is not null)
        {
            <div class="selection-header-actions">
                <MButton Icon Text Small title="显示或隐藏" aria-label="显示或隐藏图层" OnClick="ToggleSelectedVisible">
                    <MIcon Size="15">@(SelectedControl.Enabled ? "mdi-eye-outline" : "mdi-eye-off-outline")</MIcon>
                </MButton>
                <MButton Icon Text Small title="锁定或解锁" aria-label="锁定或解锁图层" OnClick="ToggleSelectedLocked">
                    <MIcon Size="15">@(SelectedControl.IsLocked ? "mdi-lock-outline" : "mdi-lock-open-variant-outline")</MIcon>
                </MButton>
                <MButton Icon Text Small title="复制" aria-label="复制图层" OnClick="DuplicateSelected">
                    <MIcon Size="15">mdi-content-copy</MIcon>
                </MButton>
                <MButton Icon Text Small title="删除" aria-label="删除图层" OnClick="RequestDeleteSelected">
                    <MIcon Size="15">mdi-trash-can-outline</MIcon>
                </MButton>
            </div>
        }
    </header>

    <div class="selection-inspector-scroll" @onkeydown:stopPropagation>
        @if (SelectedControl is null)
        {
            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>画布</h3></div>
                <label class="inspector-field">
                    <span>类型</span>
                    <MSelect Value="@Editor.Draft.CanvasType"
                             ValueChanged="SetCanvasType"
                             Items="@CanvasTypeOptions"
                             ItemText="item => item.Label"
                             ItemValue="item => item.Value"
                             TValue="CanvasType"
                             TItemValue="CanvasType"
                             TItem="SelectOption<CanvasType>"
                             Dense
                             HideDetails="true" />
                </label>
                <MacColorInput Label="背景颜色"
                               Value="@Editor.Draft.BackgroundColor"
                               ValueChanged='value => Mutate("修改画布背景", () => Editor.Draft.BackgroundColor = value)' />
                <div class="resource-field">
                    <div><span>默认图片</span><small>@ResourceName(Editor.Draft.Path)</small></div>
                    <MButton Text Small OnClick="PickCanvasImageAsync">选择</MButton>
                    <MButton Text Small Disabled="@string.IsNullOrWhiteSpace(Editor.Draft.Path)" OnClick="ClearCanvasImage">清除</MButton>
                </div>
                <div class="inspector-two-column">
                    <label class="inspector-field"><span>宽度</span><input type="number" value="@Editor.Draft.CustomWidth" min="1" @onchange="SetCanvasWidth" /></label>
                    <label class="inspector-field"><span>高度</span><input type="number" value="@Editor.Draft.CustomHeight" min="1" @onchange="SetCanvasHeight" /></label>
                </div>
                <label class="inspector-field"><span>画布比例</span><input value="@Editor.Draft.LengthWidthRatio" placeholder="例如 3:2" @onchange="SetCanvasRatio" /></label>
            </section>

            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>边距</h3></div>
                <MacInspectorSlider Label="上" Value="@Editor.Draft.BorderThickness.Top" Min="0" Max="500" Step="1" ValueChanged='value => SetSlider("调整画布边距", () => Editor.Draft.BorderThickness.Top = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="右" Value="@Editor.Draft.BorderThickness.Right" Min="0" Max="500" Step="1" ValueChanged='value => SetSlider("调整画布边距", () => Editor.Draft.BorderThickness.Right = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="下" Value="@Editor.Draft.BorderThickness.Bottom" Min="0" Max="500" Step="1" ValueChanged='value => SetSlider("调整画布边距", () => Editor.Draft.BorderThickness.Bottom = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="左" Value="@Editor.Draft.BorderThickness.Left" Min="0" Max="500" Step="1" ValueChanged='value => SetSlider("调整画布边距", () => Editor.Draft.BorderThickness.Left = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
            </section>

            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>外框</h3></div>
                <MacInspectorCheckbox Label="启用外框" Value="@Editor.Draft.FrameProperties.Enabled" ValueChanged='value => Mutate("切换外框", () => Editor.Draft.FrameProperties.Enabled = value)' />
                <MacInspectorSlider Label="外框留白" Value="@Editor.Draft.FrameProperties.BorderPadding" Min="0" Max="500" Step="1" ValueChanged='value => SetSlider("调整外框留白", () => Editor.Draft.FrameProperties.BorderPadding = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorCheckbox Label="背景透明" Value="@Editor.Draft.FrameProperties.BeforeBkTransparent" ValueChanged='value => Mutate("切换外框背景", () => Editor.Draft.FrameProperties.BeforeBkTransparent = value)' />
                <MacInspectorCheckbox Label="圆角" Value="@Editor.Draft.FrameProperties.EnableRadius" ValueChanged='value => Mutate("切换外框圆角", () => Editor.Draft.FrameProperties.EnableRadius = value)' />
                @if (Editor.Draft.FrameProperties.EnableRadius)
                {
                    <MacInspectorSlider Label="圆角半径" Value="@Editor.Draft.FrameProperties.CornerRadius" Min="0" Max="300" Step="1" ValueChanged='value => SetSlider("调整外框圆角", () => Editor.Draft.FrameProperties.CornerRadius = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                }
                <MacInspectorCheckbox Label="阴影" Value="@Editor.Draft.FrameProperties.EnableShadow" ValueChanged='value => Mutate("切换外框阴影", () => Editor.Draft.FrameProperties.EnableShadow = value)' />
                @if (Editor.Draft.FrameProperties.EnableShadow)
                {
                    <MacInspectorSlider Label="阴影范围" Value="@Editor.Draft.FrameProperties.ShadowRange" Min="0" Max="300" Step="1" ValueChanged='value => SetSlider("调整外框阴影", () => Editor.Draft.FrameProperties.ShadowRange = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                    <MacColorInput Label="阴影颜色" Value="@Editor.Draft.FrameProperties.ShadowColor" ValueChanged='value => Mutate("修改外框阴影颜色", () => Editor.Draft.FrameProperties.ShadowColor = value)' />
                }
                <MacInspectorCheckbox Label="背景模糊" Value="@Editor.Draft.FrameProperties.EnableGaussianBlur" ValueChanged='value => Mutate("切换外框模糊", () => Editor.Draft.FrameProperties.EnableGaussianBlur = value)' />
                @if (Editor.Draft.FrameProperties.EnableGaussianBlur)
                {
                    <MacInspectorSlider Label="模糊强度" Value="@Editor.Draft.FrameProperties.GaussianDeep" Min="0" Max="100" Step="1" ValueChanged='value => SetSlider("调整外框模糊", () => Editor.Draft.FrameProperties.GaussianDeep = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                }
            </section>

            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>图片效果</h3></div>
                <MacInspectorCheckbox Label="显示图片" Value="@Editor.Draft.ImageProperties.Show" ValueChanged='value => Mutate("切换默认图片", () => Editor.Draft.ImageProperties.Show = value)' />
                <MacInspectorCheckbox Label="阴影" Value="@Editor.Draft.ImageProperties.EnableShadow" ValueChanged='value => Mutate("切换阴影", () => Editor.Draft.ImageProperties.EnableShadow = value)' />
                @if (Editor.Draft.ImageProperties.EnableShadow)
                {
                    <MacInspectorSlider Label="阴影范围" Value="@Editor.Draft.ImageProperties.ShadowRange" Min="0" Max="300" Step="1" ValueChanged='value => SetSlider("调整阴影", () => Editor.Draft.ImageProperties.ShadowRange = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                    <MacColorInput Label="阴影颜色" Value="@Editor.Draft.ImageProperties.ShadowColor" ValueChanged='value => Mutate("修改阴影颜色", () => Editor.Draft.ImageProperties.ShadowColor = value)' />
                }
                <MacInspectorCheckbox Label="圆角" Value="@Editor.Draft.ImageProperties.EnableRadius" ValueChanged='value => Mutate("切换圆角", () => Editor.Draft.ImageProperties.EnableRadius = value)' />
                @if (Editor.Draft.ImageProperties.EnableRadius)
                {
                    <MacInspectorSlider Label="圆角半径" Value="@Editor.Draft.ImageProperties.CornerRadius" Min="0" Max="300" Step="1" ValueChanged='value => SetSlider("调整圆角", () => Editor.Draft.ImageProperties.CornerRadius = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                }
                <MacInspectorCheckbox Label="高斯模糊" Value="@Editor.Draft.ImageProperties.EnableGaussianBlur" ValueChanged='value => Mutate("切换模糊", () => Editor.Draft.ImageProperties.EnableGaussianBlur = value)' />
                @if (Editor.Draft.ImageProperties.EnableGaussianBlur)
                {
                    <MacInspectorSlider Label="模糊强度" Value="@Editor.Draft.ImageProperties.GaussianDeep" Min="0" Max="100" Step="1" ValueChanged='value => SetSlider("调整模糊", () => Editor.Draft.ImageProperties.GaussianDeep = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                }
            </section>
        }
        else if (SelectedControl is WMContainer container)
        {
            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>容器</h3></div>
                <div class="resource-field">
                    <div><span>图片</span><small>@ResourceName(container.Path)</small></div>
                    <MButton Text Small Disabled="@IsReadOnly" OnClick="() => PickContainerImageAsync(container)">选择</MButton>
                    <MButton Text Small Disabled="@(IsReadOnly || string.IsNullOrWhiteSpace(container.Path))" OnClick='() => Mutate("清除容器图片", () => container.Path = string.Empty)'>清除</MButton>
                </div>
                @if (Editor.Draft.CanvasType == CanvasType.Split)
                {
                    <MacInspectorCheckbox Label="固定图片" Value="@container.ContainerProperties.FixImage" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换固定图片", () => container.ContainerProperties.FixImage = value)' />
                }
                <MacInspectorCheckbox Label="裁切图片" Value="@container.EnableCrop" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换图片裁切", () => container.EnableCrop = value)' />
                <MacColorInput Label="背景颜色" Value="@container.BackgroundColor" Disabled="@IsReadOnly" ValueChanged='value => Mutate("修改容器背景", () => container.BackgroundColor = value)' />
                <label class="inspector-field">
                    <span>方向</span>
                    <MSelect Value="@container.Orientation" ValueChanged="value => SetContainerOrientation(container, value)"
                             Items="@OrientationOptions" ItemText="item => item.Label" ItemValue="item => item.Value"
                             TValue="Orientation" TItemValue="Orientation" TItem="SelectOption<Orientation>"
                             Dense HideDetails="true" Disabled="@IsReadOnly" />
                </label>
                <label class="inspector-field">
                    <span>水平对齐</span>
                    <MSelect Value="@container.HorizontalAlignment" ValueChanged="value => SetHorizontalAlignment(container, value)"
                             Items="@HorizontalAlignmentOptions" ItemText="item => item.Label" ItemValue="item => item.Value"
                             TValue="HorizontalAlignment" TItemValue="HorizontalAlignment" TItem="SelectOption<HorizontalAlignment>"
                             Dense HideDetails="true" Disabled="@IsReadOnly" />
                </label>
                <label class="inspector-field">
                    <span>垂直对齐</span>
                    <MSelect Value="@container.VerticalAlignment" ValueChanged="value => SetVerticalAlignment(container, value)"
                             Items="@VerticalAlignmentOptions" ItemText="item => item.Label" ItemValue="item => item.Value"
                             TValue="VerticalAlignment" TItemValue="VerticalAlignment" TItem="SelectOption<VerticalAlignment>"
                             Dense HideDetails="true" Disabled="@IsReadOnly" />
                </label>
                <label class="inspector-field">
                    <span>画布位置</span>
                    <MSelect Value="@container.ContainerAlignment" ValueChanged="value => SetContainerAlignment(container, value)"
                             Items="@ContainerAlignmentOptions" ItemText="item => item.Label" ItemValue="item => item.Value"
                             TValue="ContainerAlignment" TItemValue="ContainerAlignment" TItem="SelectOption<ContainerAlignment>"
                             Dense HideDetails="true" Disabled="@IsReadOnly" />
                </label>
                <MacInspectorSlider Label="宽度" Value="@container.WidthPercent" Min="1" Max="100" Step="1" Unit="%" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整容器宽度", () => container.WidthPercent = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="高度" Value="@container.HeightPercent" Min="1" Max="100" Step="1" Unit="%" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整容器高度", () => container.HeightPercent = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
            </section>
            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>外边距</h3></div>
                <MacInspectorSlider Label="上" Value="@container.Margin.Top" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => container.Margin.Top = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="右" Value="@container.Margin.Right" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => container.Margin.Right = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="下" Value="@container.Margin.Bottom" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => container.Margin.Bottom = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="左" Value="@container.Margin.Left" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => container.Margin.Left = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
            </section>
            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>容器效果</h3></div>
                <MacInspectorCheckbox Label="显示图片" Value="@container.ContainerProperties.Show" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换容器图片", () => container.ContainerProperties.Show = value)' />
                <MacInspectorCheckbox Label="阴影" Value="@container.ContainerProperties.EnableShadow" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换阴影", () => container.ContainerProperties.EnableShadow = value)' />
                @if (container.ContainerProperties.EnableShadow)
                {
                    <MacInspectorSlider Label="阴影范围" Value="@container.ContainerProperties.ShadowRange" Min="0" Max="300" Step="1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整阴影", () => container.ContainerProperties.ShadowRange = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                    <MacColorInput Label="阴影颜色" Value="@container.ContainerProperties.ShadowColor" Disabled="@IsReadOnly" ValueChanged='value => Mutate("修改阴影颜色", () => container.ContainerProperties.ShadowColor = value)' />
                }
                <MacInspectorCheckbox Label="圆角" Value="@container.ContainerProperties.EnableRadius" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换圆角", () => container.ContainerProperties.EnableRadius = value)' />
                @if (container.ContainerProperties.EnableRadius)
                {
                    <MacInspectorSlider Label="圆角半径" Value="@container.ContainerProperties.CornerRadius" Min="0" Max="300" Step="1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整圆角", () => container.ContainerProperties.CornerRadius = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                }
                <MacInspectorCheckbox Label="高斯模糊" Value="@container.ContainerProperties.EnableGaussianBlur" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换模糊", () => container.ContainerProperties.EnableGaussianBlur = value)' />
                @if (container.ContainerProperties.EnableGaussianBlur)
                {
                    <MacInspectorSlider Label="模糊强度" Value="@container.ContainerProperties.GaussianDeep" Min="0" Max="100" Step="1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整模糊", () => container.ContainerProperties.GaussianDeep = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                }
            </section>
            <MacTransformInspector Editor="@Editor" Control="@container" Bounds="@SelectedBounds" ReadOnly="@IsReadOnly" />
        }
        else if (SelectedControl is WMText text)
        {
            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>文字</h3></div>
                <div class="resource-field">
                    <div><span>EXIF 配置</span><small>@text.Exifs.Count 项</small></div>
                    <MButton Text Small Disabled="@IsReadOnly" OnClick="() => OpenExifEditor(text)">配置</MButton>
                </div>
                <label class="inspector-field">
                    <span>字体</span>
                    <MSelect Value="@text.FontFamily" ValueChanged="value => SetFontFamily(text, value)"
                             Items="@FontOptions" ItemText="item => item.Label" ItemValue="item => item.Value"
                             TValue="string" TItemValue="string" TItem="SelectOption<string>"
                             Dense HideDetails="true" Disabled="@IsReadOnly" />
                </label>
                <MButton Text Small Class="wide-secondary-command" Disabled="@IsReadOnly" OnClick="ImportFontAsync">导入字体</MButton>
                <MacInspectorSlider Label="字号" Value="@text.FontSize" Min="6" Max="300" Step="1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整字号", () => text.FontSize = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacColorInput Label="文字颜色" Value="@text.FontColor" Disabled="@IsReadOnly" ValueChanged='value => Mutate("修改文字颜色", () => text.FontColor = value)' />
                <MacInspectorCheckbox Label="粗体" Value="@text.IsBold" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换粗体", () => text.IsBold = value)' />
                <MacInspectorCheckbox Label="斜体" Value="@text.IsItalic" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换斜体", () => text.IsItalic = value)' />
                <MacInspectorCheckbox Label="自动换行" Value="@text.TextWrap" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换文字换行", () => text.TextWrap = value)' />
                <label class="inspector-field">
                    <span>关联容器</span>
                    <MSelect Value="@(text.BindedContainerId ?? string.Empty)" ValueChanged="value => SetBoundContainer(text, value)"
                             Items="@BoundContainerOptions" ItemText="item => item.Label" ItemValue="item => item.Value"
                             TValue="string" TItemValue="string" TItem="SelectOption<string>"
                             Dense HideDetails="true" Disabled="@IsReadOnly" />
                </label>
            </section>
            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>文字边框</h3></div>
                <MacInspectorCheckbox Label="启用边框" Value="@text.EnableBorder" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换文字边框", () => text.EnableBorder = value)' />
                @if (text.EnableBorder)
                {
                    <MacInspectorSlider Label="边框宽度" Value="@text.BorderWidth" Min="0" Max="30" Step="1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整文字边框", () => text.BorderWidth = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                    <MacInspectorSlider Label="内边距" Value="@text.BorderPadding" Min="0" Max="100" Step="1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整文字内边距", () => text.BorderPadding = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                    <MacInspectorSlider Label="圆角" Value="@text.BorderRadius" Min="0" Max="100" Step="1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整文字圆角", () => text.BorderRadius = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                    <MacColorInput Label="边框颜色" Value="@text.BorderColor" Disabled="@IsReadOnly" ValueChanged='value => Mutate("修改边框颜色", () => text.BorderColor = value)' />
                }
            </section>
            <MacTransformInspector Editor="@Editor" Control="@text" Bounds="@SelectedBounds" ReadOnly="@IsReadOnly" />
        }
        else if (SelectedControl is WMLogo logo)
        {
            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>Logo</h3></div>
                <div class="resource-field">
                    <div><span>图片</span><small>@ResourceName(logo.Path)</small></div>
                    <MButton Text Small Disabled="@IsReadOnly" OnClick="() => PickLogoImageAsync(logo)">选择</MButton>
                    <MButton Text Small Disabled="@(IsReadOnly || string.IsNullOrWhiteSpace(logo.Path))" OnClick='() => Mutate("清除 Logo", () => logo.Path = string.Empty)'>清除</MButton>
                </div>
                <MacInspectorCheckbox Label="白色转透明" Value="@logo.White2Transparent" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换白色转透明", () => logo.White2Transparent = value)' />
                <MacInspectorCheckbox Label="自动品牌色" Value="@logo.AutoSetLogo" Disabled="@IsReadOnly" ValueChanged='value => Mutate("切换自动品牌色", () => logo.AutoSetLogo = value)' />
                <MacInspectorSlider Label="尺寸" Value="@logo.Percent" Min="1" Max="100" Step="1" Unit="%" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整 Logo 尺寸", () => logo.Percent = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
            </section>
            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>外边距</h3></div>
                <MacInspectorSlider Label="上" Value="@logo.Margin.Top" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => logo.Margin.Top = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="右" Value="@logo.Margin.Right" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => logo.Margin.Right = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="下" Value="@logo.Margin.Bottom" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => logo.Margin.Bottom = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="左" Value="@logo.Margin.Left" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => logo.Margin.Left = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
            </section>
            <MacTransformInspector Editor="@Editor" Control="@logo" Bounds="@SelectedBounds" ReadOnly="@IsReadOnly" />
        }
        else if (SelectedControl is WMLine line)
        {
            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>分割线</h3></div>
                <label class="inspector-field">
                    <span>方向</span>
                    <MSelect Value="@line.Orientation" ValueChanged="value => SetLineOrientation(line, value)"
                             Items="@OrientationOptions" ItemText="item => item.Label" ItemValue="item => item.Value"
                             TValue="Orientation" TItemValue="Orientation" TItem="SelectOption<Orientation>"
                             Dense HideDetails="true" Disabled="@IsReadOnly" />
                </label>
                <MacInspectorSlider Label="粗细" Value="@line.Thickness" Min="1" Max="100" Step="1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整分割线粗细", () => line.Thickness = (int)value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="长度" Value="@line.Percent" Min="1" Max="100" Step="1" Unit="%" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整分割线长度", () => line.Percent = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacColorInput Label="颜色" Value="@line.Color" Disabled="@IsReadOnly" ValueChanged='value => Mutate("修改分割线颜色", () => line.Color = value)' />
            </section>
            <section class="inspector-group">
                <div class="inspector-group-heading"><h3>外边距</h3></div>
                <MacInspectorSlider Label="上" Value="@line.Margin.Top" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => line.Margin.Top = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="右" Value="@line.Margin.Right" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => line.Margin.Right = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="下" Value="@line.Margin.Bottom" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => line.Margin.Bottom = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
                <MacInspectorSlider Label="左" Value="@line.Margin.Left" Min="-500" Max="500" Step="0.1" Disabled="@IsReadOnly" ValueChanged='value => SetSlider("调整外边距", () => line.Margin.Left = value)' InteractionStarted="BeginSliderAsync" InteractionEnded="EndSliderAsync" />
            </section>
            <MacTransformInspector Editor="@Editor" Control="@line" Bounds="@SelectedBounds" ReadOnly="@IsReadOnly" />
        }
    </div>

    @if (pendingDelete is not null)
    {
        <MDialog Persistent Value="true" ContentStyle="width:min(280px,calc(100vw - 32px));">
            <section class="inspector-confirm" role="dialog" aria-modal="true" aria-labelledby="inspector-delete-title">
                <h3 id="inspector-delete-title">删除“@ControlName(pendingDelete)”？</h3>
                <p>将同时删除 @pendingDescendantCount 个子图层，此操作可以撤销。</p>
                <div>
                    <MButton Text Small Class="secondary" OnClick="CancelDelete">取消</MButton>
                    <MButton Text Small Class="danger" OnClick="ConfirmDelete">删除</MButton>
                </div>
            </section>
        </MDialog>
    }

    @if (showExifEditor && SelectedControl is WMText exifText)
    {
        <MDialog Persistent @bind-Value="showExifEditor" ContentStyle="width:min(920px,92vw);height:min(700px,88vh);">
            <div class="exif-editor-shell">
                <MButton Text Small Class="exif-cancel-command" OnClick="CancelExifEditor">取消</MButton>
                <ExifConfig mText="@exifText"
                            CanvasType="@Editor.Draft.CanvasType"
                            ContainerId2Name="@ContainerNames"
                            OnClose="CompleteExifEditor" />
            </div>
        </MDialog>
    }
</aside>

@code {
    [Parameter, EditorRequired] public WMTemplateEditorState Editor { get; set; } = null!;
    [Parameter] public WMDesignRenderResult? RenderResult { get; set; }
    [Parameter] public WMDesignFunc DesignFunc { get; set; }

    private bool sliderInteractionActive;
    private bool showExifEditor;
    private IWMControl pendingDelete;
    private int pendingDescendantCount;
    private List<string> fontNames = [];

    private IWMControl SelectedControl => string.IsNullOrWhiteSpace(Editor.SelectedControlId)
        ? null
        : WMControlTree.Find(Editor.Draft, Editor.SelectedControlId);
    private WMDesignBounds? SelectedBounds => string.IsNullOrWhiteSpace(Editor.SelectedControlId)
        ? null
        : RenderResult?.Bounds.FirstOrDefault(bounds => bounds.ControlId == Editor.SelectedControlId);
    private bool IsReadOnly => SelectedControl?.IsLocked == true;
    private string CurrentName => SelectedControl is null ? Editor.Draft.Name : ControlName(SelectedControl);
    private string CurrentTypeName => SelectedControl is null ? "画布" : TypeName(SelectedControl);
    private string Breadcrumb => SelectedControl is null
        ? "模板 / 画布"
        : $"模板 / {(WMControlTree.FindParent(Editor.Draft, SelectedControl.ID) is { } parent ? ControlName(parent) + " / " : string.Empty)}{ControlName(SelectedControl)}";
    private Dictionary<string, string> ContainerNames => Editor.Draft.Children
        .SelectMany(root => new[] { root }.Concat(root.Controls.OfType<WMContainer>()))
        .GroupBy(container => container.ID)
        .ToDictionary(group => group.Key, group => ControlName(group.First()));
    private List<SelectOption<string>> FontOptions =>
        [new(Global.DefaultFont, "默认字体"), .. fontNames
            .Where(font => !string.Equals(font, Global.DefaultFont, StringComparison.Ordinal))
            .Select(font => new SelectOption<string>(font, font))];
    private List<SelectOption<string>> BoundContainerOptions =>
        [new(string.Empty, "不关联"), .. ContainerNames
            .OrderBy(item => item.Value, StringComparer.CurrentCulture)
            .Select(item => new SelectOption<string>(item.Key, item.Value))];

    protected override void OnInitialized() => ReloadFonts();

    private Task BeginSliderAsync()
    {
        if (sliderInteractionActive) return Task.CompletedTask;
        Editor.BeginTransaction("调整属性");
        sliderInteractionActive = true;
        return Task.CompletedTask;
    }

    private Task EndSliderAsync()
    {
        if (!sliderInteractionActive) return Task.CompletedTask;
        sliderInteractionActive = false;
        Editor.CommitTransaction();
        return Task.CompletedTask;
    }

    private void SetSlider(string label, Action mutation)
    {
        if (IsReadOnly) return;
        Editor.Mutate(label, mutation);
    }

    private void Mutate(string label, Action mutation)
    {
        if (IsReadOnly && SelectedControl is not null) return;
        Editor.Mutate(label, mutation);
    }

    private void RenameCurrent(ChangeEventArgs args)
    {
        var name = TextValue(args).Trim();
        if (string.IsNullOrWhiteSpace(name) || IsReadOnly) return;
        if (SelectedControl is { } control) Mutate("重命名图层", () => control.Name = name);
        else Editor.Mutate("重命名模板", () => Editor.Draft.Name = name);
    }

    private void ToggleSelectedVisible()
    {
        if (SelectedControl is { } control) Editor.Mutate("切换图层可见性", () => control.Enabled = !control.Enabled);
    }

    private void ToggleSelectedLocked()
    {
        if (SelectedControl is { } control) Editor.Mutate("切换图层锁定", () => control.IsLocked = !control.IsLocked);
    }

    private void DuplicateSelected()
    {
        if (SelectedControl is not { } control) return;
        IWMControl copy = null;
        Editor.Mutate("复制图层", () =>
        {
            copy = WMControlTree.Duplicate(Editor.Draft, control.ID);
            copy.Name = $"{ControlName(control)} 副本";
        });
        if (copy is not null) Editor.Select(copy.ID);
    }

    private void RequestDeleteSelected()
    {
        if (SelectedControl is not { } control) return;
        var descendants = DescendantCount(control);
        if (control is WMContainer && descendants > 0)
        {
            pendingDelete = control;
            pendingDescendantCount = descendants;
            return;
        }
        DeleteSelected(control);
    }

    private void ConfirmDelete()
    {
        var control = pendingDelete;
        pendingDelete = null;
        pendingDescendantCount = 0;
        if (control is not null) DeleteSelected(control);
    }

    private void CancelDelete()
    {
        pendingDelete = null;
        pendingDescendantCount = 0;
    }

    private void DeleteSelected(IWMControl control)
    {
        var parentId = WMControlTree.FindParent(Editor.Draft, control.ID)?.ID;
        Editor.Mutate("删除图层", () =>
        {
            if (!WMControlTree.Remove(Editor.Draft, control.ID))
                throw new InvalidOperationException($"无法删除图层 {control.ID}。");
        });
        Editor.Select(parentId);
    }

    private Task SetCanvasType(CanvasType value)
    {
        Editor.Mutate("修改画布类型", () => Editor.Draft.CanvasType = value);
        return Task.CompletedTask;
    }

    private Task SetContainerOrientation(WMContainer container, Orientation value) =>
        MutateAsync("修改容器方向", () => container.Orientation = value);

    private Task SetHorizontalAlignment(WMContainer container, HorizontalAlignment value) =>
        MutateAsync("修改水平对齐", () => container.HorizontalAlignment = value);

    private Task SetVerticalAlignment(WMContainer container, VerticalAlignment value) =>
        MutateAsync("修改垂直对齐", () => container.VerticalAlignment = value);

    private Task SetContainerAlignment(WMContainer container, ContainerAlignment value) =>
        MutateAsync("修改画布位置", () => container.ContainerAlignment = value);

    private Task SetLineOrientation(WMLine line, Orientation value) =>
        MutateAsync("修改分割线方向", () => line.Orientation = value);

    private Task SetFontFamily(WMText text, string value) =>
        MutateAsync("修改字体", () => text.FontFamily = value);

    private Task SetBoundContainer(WMText text, string value) =>
        MutateAsync("修改关联容器", () => text.BindedContainerId = value);

    private Task MutateAsync(string label, Action mutation)
    {
        Mutate(label, mutation);
        return Task.CompletedTask;
    }

    private void SetCanvasWidth(ChangeEventArgs args) => Editor.Mutate("修改画布宽度", () => Editor.Draft.CustomWidth = IntValue(args, Editor.Draft.CustomWidth, 1));
    private void SetCanvasHeight(ChangeEventArgs args) => Editor.Mutate("修改画布高度", () => Editor.Draft.CustomHeight = IntValue(args, Editor.Draft.CustomHeight, 1));
    private void SetCanvasRatio(ChangeEventArgs args) => Editor.Mutate("修改画布比例", () => Editor.Draft.LengthWidthRatio = TextValue(args));

    private async Task PickCanvasImageAsync()
    {
        if (DesignFunc?.SelectDefaultImageEvt is null) return;
        var path = await DesignFunc.SelectDefaultImageEvt();
        if (!string.IsNullOrWhiteSpace(path)) Editor.Mutate("选择默认图片", () => Editor.Draft.Path = path);
    }

    private void ClearCanvasImage() => Editor.Mutate("清除默认图片", () => Editor.Draft.Path = string.Empty);

    private async Task PickContainerImageAsync(WMContainer container) =>
        await RunPickerTransactionAsync("选择容器图片", () => DesignFunc?.SelectContainer?.Invoke(container) ?? Task.CompletedTask);

    private async Task PickLogoImageAsync(WMLogo logo) =>
        await RunPickerTransactionAsync("选择 Logo", () => DesignFunc?.SelectLogo?.Invoke(logo) ?? Task.CompletedTask);

    private async Task RunPickerTransactionAsync(string label, Func<Task> picker)
    {
        if (IsReadOnly) return;
        Editor.BeginTransaction(label);
        try
        {
            await picker();
            Editor.CommitTransaction();
        }
        catch
        {
            Editor.CancelTransaction();
            throw;
        }
    }

    private async Task ImportFontAsync()
    {
        if (DesignFunc?.ImportFontEvt is null || IsReadOnly) return;
        await DesignFunc.ImportFontEvt();
        ReloadFonts();
    }

    private void ReloadFonts() => fontNames = Global.ReadFont().Keys.OrderBy(name => name).ToList();

    private void OpenExifEditor(WMText text)
    {
        if (IsReadOnly || showExifEditor) return;
        Editor.BeginTransaction("配置 EXIF");
        showExifEditor = true;
    }

    private void CompleteExifEditor(WMText text)
    {
        showExifEditor = false;
        Editor.CommitTransaction();
    }

    private void CancelExifEditor()
    {
        showExifEditor = false;
        Editor.CancelTransaction();
    }

    private static string TextValue(ChangeEventArgs args) => args.Value?.ToString() ?? string.Empty;
    private static int IntValue(ChangeEventArgs args, int fallback, int minimum = int.MinValue) => int.TryParse(TextValue(args), out var value) ? Math.Max(value, minimum) : fallback;
    private static string ResourceName(string path) => string.IsNullOrWhiteSpace(path) ? "未选择" : Path.GetFileName(path);
    private static string ControlName(IWMControl control) => string.IsNullOrWhiteSpace(control.Name) ? TypeName(control) : control.Name;
    private static string TypeName(IWMControl control) => control switch { WMContainer => "容器", WMText => "文字", WMLogo => "Logo", WMLine => "分割线", _ => "图层" };
    private static readonly List<SelectOption<CanvasType>> CanvasTypeOptions =
    [
        new(CanvasType.Normal, "普通画布"),
        new(CanvasType.Split, "拼图画布")
    ];

    private static readonly List<SelectOption<Orientation>> OrientationOptions =
    [
        new(Orientation.Horizontal, "横向"),
        new(Orientation.Vertical, "纵向")
    ];

    private static readonly List<SelectOption<HorizontalAlignment>> HorizontalAlignmentOptions =
    [
        new(HorizontalAlignment.Left, "左对齐"),
        new(HorizontalAlignment.Center, "居中对齐"),
        new(HorizontalAlignment.Right, "右对齐")
    ];

    private static readonly List<SelectOption<VerticalAlignment>> VerticalAlignmentOptions =
    [
        new(VerticalAlignment.Top, "顶部对齐"),
        new(VerticalAlignment.Center, "居中对齐"),
        new(VerticalAlignment.Bottom, "底部对齐")
    ];

    private static readonly List<SelectOption<ContainerAlignment>> ContainerAlignmentOptions =
    [
        new(ContainerAlignment.Left, "画布左侧"),
        new(ContainerAlignment.Top, "画布顶部"),
        new(ContainerAlignment.Right, "画布右侧"),
        new(ContainerAlignment.Bottom, "画布底部")
    ];

    private sealed record SelectOption<T>(T Value, string Label);

    private static int DescendantCount(IWMControl control)
    {
        if (control is not WMContainer container) return 0;
        var visited = new HashSet<IWMControl>(ReferenceEqualityComparer.Instance);
        var stack = new Stack<IWMControl>(container.Controls);
        while (stack.TryPop(out var current))
        {
            if (!visited.Add(current)) continue;
            if (current is WMContainer nested)
                foreach (var child in nested.Controls) stack.Push(child);
        }
        return visited.Count;
    }

    public void Dispose()
    {
        if (sliderInteractionActive) Editor.CancelTransaction();
        if (showExifEditor) Editor.CancelTransaction();
    }
}
