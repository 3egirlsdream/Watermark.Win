@using Watermark.Razor.Components.Mac.Editor
@using Watermark.Razor.Workspace
@using Watermark.Shared.Models

<section class="transform-inspector inspector-group">
    <div class="inspector-group-heading">
        <h3>变换</h3>
        <MButton Text Small Class="inspector-text-command" Disabled="@ReadOnly" OnClick="Reset">重置</MButton>
    </div>

    <MacInspectorSlider Label="水平坐标" Value="@Transform.OffsetXPercent" Min="-100" Max="100" Step="0.1" Unit="%"
                        Disabled="@ReadOnly" ValueChanged="SetOffsetX" InteractionStarted="BeginInteractionAsync" InteractionEnded="EndInteractionAsync" />
    <MacInspectorSlider Label="垂直坐标" Value="@Transform.OffsetYPercent" Min="-100" Max="100" Step="0.1" Unit="%"
                        Disabled="@ReadOnly" ValueChanged="SetOffsetY" InteractionStarted="BeginInteractionAsync" InteractionEnded="EndInteractionAsync" />

    <div class="inspector-group-heading compact"><h3>整体缩放（高级）</h3></div>
    <MacInspectorSwitch Label="保持宽高比例" Value="@keepRatio" Disabled="@ReadOnly" ValueChanged="ToggleKeepRatio" />

    <MacInspectorSlider Label="水平缩放" Value="@Transform.ScaleX" Min="0.1" Max="4" Step="0.01" Unit="×"
                        Disabled="@ReadOnly" ValueChanged="SetScaleX" InteractionStarted="BeginRasterInteractionAsync" InteractionEnded="EndInteractionAsync" />
    <MacInspectorSlider Label="垂直缩放" Value="@Transform.ScaleY" Min="0.1" Max="4" Step="0.01" Unit="×"
                        Disabled="@ReadOnly" ValueChanged="SetScaleY" InteractionStarted="BeginRasterInteractionAsync" InteractionEnded="EndInteractionAsync" />
    <MacInspectorSlider Label="旋转" Value="@Transform.Rotation" Min="-180" Max="179.9" Step="0.1" Unit="°"
                        Disabled="@ReadOnly" ValueChanged="SetRotation" InteractionStarted="BeginRasterInteractionAsync" InteractionEnded="EndInteractionAsync" />
</section>

@code {
    [Parameter, EditorRequired] public WMTemplateEditorState Editor { get; set; } = null!;
    [Parameter, EditorRequired] public IWMControl Control { get; set; } = null!;
    [Parameter] public WMDesignBounds? Bounds { get; set; }
    [Parameter] public bool ReadOnly { get; set; }

    private static readonly WMTransform Identity = new();
    private bool keepRatio = true;
    private bool interactionActive;
    private bool interactionRequiresRaster;
    private bool UsesStyleTransform => Editor.Draft.LayoutSchemaVersion >= WMLayoutMigration.CurrentSchemaVersion
        && Control.Style.Position == WMPosition.Absolute;
    private WMTransform Transform => UsesStyleTransform ? Control.Style.Transform : Control.Transform ?? Identity;

    private Task BeginInteractionAsync() => BeginInteractionAsync(requiresRaster: false);

    private Task BeginRasterInteractionAsync() => BeginInteractionAsync(requiresRaster: true);

    private Task BeginInteractionAsync(bool requiresRaster)
    {
        if (ReadOnly || interactionActive) return Task.CompletedTask;
        Editor.BeginTransaction(
            "调整变换",
            WMTemplateChangeKind.Geometry,
            [Control.ID]);
        interactionActive = true;
        interactionRequiresRaster = requiresRaster;
        return Task.CompletedTask;
    }

    private Task EndInteractionAsync()
    {
        if (!interactionActive) return Task.CompletedTask;
        interactionActive = false;
        var additionalKind = interactionRequiresRaster
            ? WMTemplateChangeKind.Paint
            : WMTemplateChangeKind.None;
        interactionRequiresRaster = false;
        Editor.CommitTransaction(additionalKind);
        return Task.CompletedTask;
    }

    private void ToggleKeepRatio(bool value) => keepRatio = value;

    private void SetOffsetX(double value) => Mutate(transform => transform.OffsetXPercent = value);
    private void SetOffsetY(double value) => Mutate(transform => transform.OffsetYPercent = value);

    private void SetScaleX(double value) => Mutate(transform =>
    {
        transform.ScaleX = value;
        if (keepRatio) transform.ScaleY = value;
    });

    private void SetScaleY(double value) => Mutate(transform =>
    {
        transform.ScaleY = value;
        if (keepRatio) transform.ScaleX = value;
    });

    private void SetRotation(double value) => Mutate(transform =>
    {
        transform.Rotation = value;
        if (!UsesStyleTransform && Control is WMContainer container)
            container.Angle = (int)Math.Round(transform.Rotation);
    });

    private void Mutate(Action<WMTransform> mutation)
    {
        if (ReadOnly) return;
        Editor.Mutate("调整变换", () =>
        {
            var transform = UsesStyleTransform ? Control.Style.Transform : Control.EnsureTransform();
            mutation(transform);
            if (Bounds is null) return;

            var constrained = MacCanvasBoundary.ConstrainTransform(
                Bounds,
                new MacCanvasInteraction(
                    Control.ID,
                    "inspector",
                    transform.OffsetXPercent,
                    transform.OffsetYPercent,
                    transform.ScaleX,
                    transform.ScaleY,
                    transform.Rotation));
            MacCanvasTransform.Apply(Control, constrained);
        }, WMTemplateChangeKind.Geometry, [Control.ID]);
    }

    private void Reset()
    {
        if (ReadOnly) return;
        Editor.Mutate("重置变换", () =>
        {
            var transform = UsesStyleTransform ? Control.Style.Transform : Control.EnsureTransform();
            transform.OffsetXPercent = 0;
            transform.OffsetYPercent = 0;
            transform.ScaleX = 1;
            transform.ScaleY = 1;
            transform.Rotation = 0;
            if (!UsesStyleTransform && Control is WMContainer container)
                container.Angle = 0;
        }, WMTemplateChangeKind.Geometry | WMTemplateChangeKind.Paint, [Control.ID]);
    }
}
