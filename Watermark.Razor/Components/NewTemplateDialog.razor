@using Masa.Blazor
@using Microsoft.JSInterop
@using System.Collections.Concurrent
@using Watermark.Razor.Parts
@using Watermark.Shared.Models
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<MCard Flat Class="new-template-dialog">
    <div class="template-dialog-header">
        <div>
            <small>Template</small>
            <h3>新建模板</h3>
        </div>
        <MButton Text Small Class="dialog-close-button" OnClick="Cancel">
            <MIcon Small>mdi-close</MIcon>
        </MButton>
    </div>

    <div class="template-dialog-body">
        <MTextField @bind-Value="TemplateName"
                    TValue="string"
                    Label="模板名称"
                    Dense
                    Outlined
                    Required="true"
                    RequiredMessage="模板名称不能为空" />

        <button type="button" class="image-select-card" @onclick="SelectExampleImage">
        @if (!string.IsNullOrEmpty(Base64Src))
        {
                <img class="template-preview-image" src="@Base64Src" alt="模板预览图" />
        }
        else
        {
                <div class="image-empty-state">
                    <span class="image-empty-icon">
                        <MIcon Size="28">mdi-image-plus</MIcon>
                    </span>
                    <span>选择默认预览图</span>
                    <small>用于模板编辑与预览画布</small>
                </div>
        }
        </button>

        @if (_processing)
        {
            <div class="processing-line">
                <MProgressCircular Size="14" Indeterminate="true" />
                <span>正在处理图片...</span>
            </div>
        }
    </div>

    <MCardActions Class="template-dialog-actions">
        <MSpacer />
        <MButton Text Class="secondary-action" OnClick="Cancel">取消</MButton>
        <MButton OnClick="OK" Color="primary" Class="primary-action" Disabled="@(_processing || string.IsNullOrWhiteSpace(TemplateName) || string.IsNullOrWhiteSpace(Base64Src))">
            <span>创建并编辑</span>
        </MButton>
    </MCardActions>
</MCard>




@code {
    [Parameter]
    public Action<WMCanvas> Ok { get; set; }
    [Parameter]
    public Func<Task<string>> SelectDefaultImageAction { get; set; }
    [Parameter]
    public string ID { get; set; }
    [Parameter]
    public EventCallback<bool> OnClose { get; set; }

    bool _processing = false;
    string TemplateName;
    string Base64Src;
    private readonly string legacyImageOwnerKey = $"new-template:{Guid.NewGuid():N}";

    async Task Cancel()
    {
        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync(false);
        }
    }

    void OK()
    {
        if (string.IsNullOrEmpty(TemplateName) || string.IsNullOrEmpty(Base64Src)) return;
        var canvas = new WMCanvas() { Name = TemplateName, ID = ID };
        var basePath = Global.AppPath.TemplatesFolder + canvas.ID;
        if (!Directory.Exists(basePath))
        {
            Directory.CreateDirectory(basePath);
        }
        canvas.Exif[canvas.ID] = ExifHelper.DefaultMeta;
        Ok?.Invoke(canvas);
        if (OnClose.HasDelegate)
        {
            OnClose.InvokeAsync(true);
        }
    }

    async Task SelectExampleImage()
    {
        if (SelectDefaultImageAction is null) return;
        var p = await SelectDefaultImageAction!.Invoke();
        if (string.IsNullOrEmpty(p)) return;
        _processing = true;
        StateHasChanged();
        var dic = new ConcurrentDictionary<string, byte[]>();
        var destFolder = Global.AppPath.TemplatesFolder + ID;
        if (!System.IO.Directory.Exists(destFolder))
        {
            System.IO.Directory.CreateDirectory(destFolder);
        }

        var name = Path.GetFileName(p);
        var destFile = destFolder + System.IO.Path.DirectorySeparatorChar + "default.jpg";
        await Task.Run(() =>
        {
            Global.ImageFile2Base64(dic, p, "default");
            SkiaSharp.SKBitmap bitmap = SkiaSharp.SKBitmap.Decode(p);
            Global.WriteThumbnailImage(bitmap, destFile);
        });

        Base64Src = await JSRuntime.InvokeAsync<string>(
            "byteToUrl", dic.First().Value, legacyImageOwnerKey);
        _processing = false;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("watermarkLegacyObjectUrls.release", legacyImageOwnerKey);
        }
        catch (JSDisconnectedException) { }
        catch (JSException) { }
    }
}
