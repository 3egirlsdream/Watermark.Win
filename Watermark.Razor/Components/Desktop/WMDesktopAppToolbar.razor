@using Watermark.Razor.Workspace
@using Watermark.Razor.Parts
@using Watermark.Shared.Models

<div class="mac-app-toolbar-host">
    <MToolbar Dense Elevation="0" Height="44" Class="mac-app-toolbar">
        <div class="toolbar-left">
            <div class="toolbar-brand"><div class="toolbar-icon"></div></div>
            <MButton Plain Small Class="toolbar-button" OnClick="ImportImages">
                <WmIcon Left Small Icon="image-square" />导入图片
            </MButton>
        </div>
        <div class="toolbar-center"><span>@ModeTitle</span><small>@ModeSubtitle</small></div>
        <div class="toolbar-fill"></div>
        <div class="toolbar-actions right">
            <MButton Plain Small Class="toolbar-button" OnClick="Undo" Disabled="@(!CanUndo)" title="撤销"><WmIcon Small Icon="arrow-counter-clockwise" /></MButton>
            <MButton Plain Small Class="toolbar-button" OnClick="Redo" Disabled="@(!CanRedo)" title="重做"><WmIcon Small Icon="arrow-clockwise" /></MButton>
            <MMenu OffsetY>
                <ActivatorContent>
                    <MButton @attributes="@context.Attrs" Plain Small Class="toolbar-button" Disabled="@(History.Count == 0)"><WmIcon Left Small Icon="clock-counter-clockwise" />历史</MButton>
                </ActivatorContent>
                <ChildContent>
                    <MList Dense Style="min-width:220px">
                        @foreach (var item in History.Reverse())
                        {
                            <MListItem OnClick="() => HistorySelected.InvokeAsync(item.Cursor)">
                                <MListItemIcon><WmIcon Icon="@(item.IsApplied ? "check-circle" : "clock-counter-clockwise")" /></MListItemIcon>
                                <MListItemContent>
                                    <MListItemTitle>@item.Label</MListItemTitle>
                                    <MListItemSubtitle>@(item.IsApplied ? item.CreatedAtUtc.ToLocalTime().ToString("HH:mm:ss") : "已撤销")</MListItemSubtitle>
                                </MListItemContent>
                            </MListItem>
                        }
                    </MList>
                </ChildContent>
            </MMenu>
            <MButton Color="primary" Small Class="toolbar-button primary-toolbar-button" OnClick="Export"><WmIcon Left Small Icon="export" />导出</MButton>
            <MMenu OffsetY>
                <ActivatorContent><MButton @attributes="@context.Attrs" Plain Small Class="toolbar-button"><WmIcon Left Small Icon="@ICONS.Setting" />更多</MButton></ActivatorContent>
                <ChildContent>
                    <MList Dense>
                        <MListItem Title="新建模板" OnClick="CreateTemplate"><MListItemIcon><WmIcon Icon="@ICONS.Pencil" /></MListItemIcon></MListItem>
                        <MListItem Title="我的模板" OnClick="OpenTemplates"><MListItemIcon><WmIcon Icon="@ICONS.Star" /></MListItemIcon></MListItem>
                        <MListItem Title="模板市场" OnClick="OpenMarket"><MListItemIcon><WmIcon Icon="@ICONS.Market" /></MListItemIcon></MListItem>
                        <MListItem Title="图标库" OnClick="OpenLogos"><MListItemIcon><WmIcon Icon="@ICONS.ImageStore" /></MListItemIcon></MListItem>
                        <MDivider />
                        <MListItem Title="注册账号" OnClick="SignUp"><MListItemIcon><WmIcon Icon="@ICONS.AccountAdd" /></MListItemIcon></MListItem>
                        <MListItem Title="注销账号" OnClick="LogoutAccount"><MListItemIcon><WmIcon Icon="@ICONS.Logout" /></MListItemIcon></MListItem>
                        <MDivider />
                        <MListItem Title="设置" OnClick="OpenSettings"><MListItemIcon><WmIcon Icon="@ICONS.Setting" /></MListItemIcon></MListItem>
                        @if (CanOpenDashboard)
                        {
                            <MListItem Title="运营看板" OnClick="OpenDashboard"><MListItemIcon><WmIcon Icon="squares-four" /></MListItemIcon></MListItem>
                        }
                        <MListItem Title="网页版" OnClick="OpenWeb"><MListItemIcon><WmIcon Icon="@ICONS.Web" /></MListItemIcon></MListItem>
                        <MListItem Title="提交反馈" OnClick="OpenFeedback"><MListItemIcon><WmIcon Icon="@ICONS.Feedback" /></MListItemIcon></MListItem>
                        <MListItem Title="安卓版" OnClick="OpenAndroidQr"><MListItemIcon><WmIcon Icon="@ICONS.Android" /></MListItemIcon></MListItem>
                        <MDivider />
                        <MListItem Title="交流群：836325187">
                            <MListItemIcon><WmIcon Icon="@ICONS.QQ" /></MListItemIcon>
                        </MListItem>
                    </MList>
                </ChildContent>
            </MMenu>
        </div>
        <MMenu Bottom OffsetY CloseOnContentClick="false" Class="mr-2">
            <ActivatorContent>
                <div @attributes="@context.Attrs" class="account-trigger">
                    @if (Account.IsAuthenticated)
                    {
                        <MAvatar Color="primary" Size="26" Class="account-avatar">
                            @if (!string.IsNullOrWhiteSpace(Account.AvatarUrl)) { <MImage Src="@Account.AvatarUrl" Width="26" Height="26" /> }
                            else { <span>@Account.DisplayName.FirstOrDefault()</span> }
                        </MAvatar>
                    }
                    else
                    {
                        <MButton Small Text Class="toolbar-button account-login-button">登录</MButton>
                    }
                </div>
            </ActivatorContent>
            <ChildContent>
                <MCard MinWidth="280">
                    @if (Account.IsAuthenticated)
                    {
                        <MList><MListItem>
                            <MListItemAvatar>
                                @if (!string.IsNullOrWhiteSpace(Account.AvatarUrl)) { <MImage Width="48" Height="48" Src="@Account.AvatarUrl" Contain /> }
                                else { <MAvatar Color="primary" Size="48"><span>@Account.DisplayName.FirstOrDefault()</span></MAvatar> }
                            </MListItemAvatar>
                            <MListItemContent><MListItemTitle>@Account.DisplayName</MListItemTitle><MListItemSubtitle>@Account.UserName</MListItemSubtitle></MListItemContent>
                            <MListItemAction>@if (Account.IsVip) { <Watermark.Razor.Parts.IconVip /> } else { <Watermark.Razor.Parts.IconVipExpired /> }</MListItemAction>
                        </MListItem></MList>
                        <MDivider />
                        <div class="account-meta">
                            <div class="coin-row"><Label Name="硬币：" Small="false" /><Watermark.Razor.Parts.IconCoin /><Label Name="@Account.Coins.ToString()" Small="false" /></div>
                            <div class="vip-row"><Label Name="@(Account.IsVip && Account.ExpiresAt.HasValue ? "会员到期时间：" + Account.ExpiresAt.Value.ToString("yyyy-MM-dd") : "会员已过期")" /><MButton Small Color="primary" Class="account-vip-button" OnClick="OpenMembership">@(Account.IsVip ? "续费会员" : "开通会员")</MButton></div>
                        </div>
                        <MCardActions><MSpacer /><MButton Plain OnClick="SignOut">退出登录</MButton></MCardActions>
                    }
                    else
                    {
                        <MCardActions><MSpacer /><MButton Color="primary" OnClick="OpenMembership">开通会员</MButton><MButton Plain Color="Color.Primary" OnClick="OpenAccount">登录</MButton><MButton Plain OnClick="SignUp">注册</MButton></MCardActions>
                    }
                </MCard>
            </ChildContent>
        </MMenu>
    </MToolbar>
</div>

@code {
    [Parameter] public WMWorkspaceMode Mode { get; set; }
    [Parameter] public WMAccountState Account { get; set; } = new(false, null, string.Empty, null, null, false, 0, null);
    [Parameter] public bool CanUndo { get; set; }
    [Parameter] public bool CanRedo { get; set; }
    [Parameter] public IReadOnlyList<WMWorkspaceHistoryItem> History { get; set; } = [];
    [Parameter] public EventCallback ImportImages { get; set; }
    [Parameter] public EventCallback Undo { get; set; }
    [Parameter] public EventCallback Redo { get; set; }
    [Parameter] public EventCallback<int> HistorySelected { get; set; }
    [Parameter] public EventCallback Export { get; set; }
    [Parameter] public EventCallback CreateTemplate { get; set; }
    [Parameter] public EventCallback OpenTemplates { get; set; }
    [Parameter] public EventCallback OpenMarket { get; set; }
    [Parameter] public EventCallback OpenLogos { get; set; }
    [Parameter] public EventCallback OpenAccount { get; set; }
    [Parameter] public EventCallback OpenMembership { get; set; }
    [Parameter] public EventCallback SignUp { get; set; }
    [Parameter] public EventCallback LogoutAccount { get; set; }
    [Parameter] public EventCallback OpenSettings { get; set; }
    [Parameter] public EventCallback OpenDashboard { get; set; }
    [Parameter] public bool CanOpenDashboard { get; set; }
    [Parameter] public EventCallback SignOut { get; set; }
    [Parameter] public EventCallback<string> OpenLink { get; set; }
    [Parameter] public EventCallback<string> OpenCommonDialog { get; set; }

    private string ModeTitle => Mode switch { WMWorkspaceMode.ColorGrade => "调色工作台", WMWorkspaceMode.MultiFrame => "多帧合成", _ => "模板预设" };
    private string ModeSubtitle => Mode switch { WMWorkspaceMode.ColorGrade => "参考风格与精细调色", WMWorkspaceMode.MultiFrame => "星轨 · 降噪 · 静态星空", _ => "水印与拼图模板" };
    private Task OpenWeb() => OpenLink.InvokeAsync("http://www.thankful.top");
    private Task OpenFeedback() => OpenLink.InvokeAsync("https://github.com/3egirlsdream/Watermark.Win/issues");
    private Task OpenAndroidQr() => OpenCommonDialog.InvokeAsync("https://cdn.thankful.top/andorid.png");
}
