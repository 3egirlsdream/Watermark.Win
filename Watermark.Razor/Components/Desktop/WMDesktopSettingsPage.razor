@namespace Watermark.Razor.Components.Desktop
@using Watermark.Razor.Workspace
@inject IWMAccountService Accounts
@inject IWMAppSettingsService Settings
@inject IWMCacheMaintenanceService Cache
@inject IWMAppUpdateService Updates
@inject IWMExternalActionService External
@inject IPopupService Popup

<section class="desktop-settings" aria-labelledby="desktop-settings-title">
    <header class="settings-heading"><div><small>PREFERENCES</small><h1 id="desktop-settings-title">设置</h1><p>账号、处理性能、本地资源与版本维护。</p></div>@if (saving){<span class="saving-state"><MProgressCircular Indeterminate Size="16" Width="2" />正在保存</span>}</header>
    @if (loading)
    {
        <div class="settings-loading"><MProgressCircular Indeterminate Size="28" Width="3" /><span>正在加载设置</span></div>
    }
    else if (draft is not null)
    {
        <div class="settings-scroll">
            <div class="settings-grid">
                <section class="settings-card account-card">
                    <header><span class="card-icon"><MIcon>mdi-account-outline</MIcon></span><div><small>ACCOUNT</small><h2>账号与会员</h2></div></header>
                    @if (Accounts.State.IsAuthenticated)
                    {
                        <div class="account-summary"><div class="account-avatar">@Accounts.State.DisplayName.FirstOrDefault()</div><span><strong>@Accounts.State.DisplayName</strong><small>@Accounts.State.UserName · @(Accounts.State.IsVip ? "会员" : "免费版")</small></span></div>
                        <button type="button" @onclick="OpenMembership"><span>会员与权益</span><MIcon Small>mdi-chevron-right</MIcon></button>
                        <button type="button" @onclick='() => OpenAccount.InvokeAsync("change-password")'><span>修改密码</span><MIcon Small>mdi-chevron-right</MIcon></button>
                        <button type="button" @onclick="SwitchAccountAsync"><span>切换账号</span><MIcon Small>mdi-login-variant</MIcon></button>
                        <button type="button" class="danger" @onclick='() => OpenAccount.InvokeAsync("delete")'><span>永久删除账号</span><MIcon Small>mdi-chevron-right</MIcon></button>
                    }
                    else
                    {
                        <div class="account-empty"><MIcon>mdi-account-circle-outline</MIcon><span>登录后同步会员和模板权益。</span></div>
                        <button type="button" class="primary-row" @onclick='() => OpenAccount.InvokeAsync("login")'><span>登录或注册账号</span><MIcon Small>mdi-chevron-right</MIcon></button>
                    }
                </section>

                <section class="settings-card processing-card">
                    <header><span class="card-icon"><MIcon>mdi-tune-variant</MIcon></span><div><small>PROCESSING</small><h2>处理设置</h2></div></header>
                    <label class="switch-row"><span><strong>增强 EXIF 解析</strong><small>尝试读取厂商扩展元数据</small></span><input type="checkbox" @bind="enhancedExif" /></label>
                    <label class="range-row"><span><strong>最大处理线程</strong><small>建议为处理器核心数减一</small></span><output>@maximumThreads / @draft.MaximumAllowedThreads</output><input type="range" min="1" max="@draft.MaximumAllowedThreads" step="1" @bind="maximumThreads" @bind:event="oninput" /></label>
                    <button type="button" class="save-command" disabled="@saving" @onclick="SaveSettingsAsync"><MIcon Small>mdi-content-save-outline</MIcon><span>保存处理设置</span></button>
                </section>

                <section class="settings-card resource-card">
                    <header><span class="card-icon"><MIcon>mdi-database-outline</MIcon></span><div><small>STORAGE</small><h2>资源与缓存</h2></div></header>
                    <button type="button" @onclick="OpenResources"><span>图标与字体</span><MIcon Small>mdi-chevron-right</MIcon></button>
                    <button type="button" disabled="@cacheBusy" @onclick="() => ClearCacheAsync(WMCacheArea.Temporary)"><span>清理临时缓存 <small>@FormatBytes(cacheSummary?.TemporaryBytes ?? 0)</small></span><MIcon Small>mdi-delete-sweep-outline</MIcon></button>
                    <button type="button" disabled="@cacheBusy" @onclick="() => ClearCacheAsync(WMCacheArea.MarketPreviews)"><span>重置市场预览 <small>@FormatBytes(cacheSummary?.MarketPreviewBytes ?? 0)</small></span><MIcon Small>mdi-refresh</MIcon></button>
                    <button type="button" disabled="@cacheBusy" @onclick="() => ClearCacheAsync(WMCacheArea.LogoLibrary)"><span>重置图标库 <small>@FormatBytes(cacheSummary?.LogoBytes ?? 0)</small></span><MIcon Small>mdi-refresh</MIcon></button>
                </section>

                <section class="settings-card update-card">
                    <header><span class="card-icon"><MIcon>mdi-update</MIcon></span><div><small>VERSION</small><h2>版本与帮助</h2></div></header>
                    <div class="version-row"><span><strong>轻影 @Updates.State.CurrentVersion</strong><small>@(Updates.State.Message ?? "当前桌面版本")</small></span><button type="button" disabled="@Updates.State.IsChecking" @onclick="CheckUpdateAsync">检查更新</button></div>
                    @if (Updates.State.UpdateAvailable)
                    {
                        <button type="button" class="primary-row" @onclick="StartUpdateAsync"><span>获取版本 @Updates.State.AvailableVersion</span><MIcon Small>mdi-open-in-new</MIcon></button>
                    }
                    <button type="button" @onclick='() => External.OpenUrlAsync("http://thankful.top/protocol")'><span>用户协议</span><MIcon Small>mdi-open-in-new</MIcon></button>
                    <button type="button" @onclick='() => External.OpenUrlAsync("http://thankful.top/private")'><span>隐私协议</span><MIcon Small>mdi-open-in-new</MIcon></button>
                    <button type="button" @onclick="CopyGroupAsync"><span>交流群：836325187</span><MIcon Small>mdi-content-copy</MIcon></button>
                    <button type="button" class="danger" @onclick="RevokePrivacyAsync"><span>撤回本地隐私授权</span><MIcon Small>mdi-shield-off-outline</MIcon></button>
                </section>
            </div>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="settings-message @(messageIsError ? "is-error" : null)" role="status">@message</div>
    }
</section>

@code {
    [Parameter] public EventCallback<string> OpenAccount { get; set; }
    [Parameter] public EventCallback OpenMembership { get; set; }
    [Parameter] public EventCallback OpenResources { get; set; }

    private WMAppSettingsState? draft;
    private WMCacheSummary? cacheSummary;
    private bool enhancedExif;
    private int maximumThreads = 1;
    private bool loading = true;
    private bool saving;
    private bool cacheBusy;
    private string? message;
    private bool messageIsError;

    protected override async Task OnInitializedAsync()
    {
        draft = await Settings.LoadAsync();
        enhancedExif = draft.EnhancedExif;
        maximumThreads = draft.MaximumThreads;
        cacheSummary = await Cache.MeasureAsync();
        loading = false;
    }

    private async Task SaveSettingsAsync()
    {
        if (saving || draft is null) return;
        saving = true;
        try
        {
            draft = await Settings.UpdateAsync(enhancedExif, maximumThreads);
            Show("设置已保存。", false);
        }
        catch (Exception ex) { Show(ex.Message, true); }
        finally { saving = false; }
    }

    private async Task ClearCacheAsync(WMCacheArea area)
    {
        if (cacheBusy) return;
        if (area is WMCacheArea.MarketPreviews or WMCacheArea.LogoLibrary)
        {
            var confirmed = await Popup.ConfirmAsync("确认重置", area == WMCacheArea.LogoLibrary ? "将删除个人导入图标并重新下载内置图标，是否继续？" : "将删除市场预览缓存，是否继续？", AlertTypes.Warning);
            if (confirmed != true) return;
        }
        cacheBusy = true;
        var result = await Cache.ClearAsync(area);
        cacheSummary = result.Summary;
        cacheBusy = false;
        Show(result.Message, !result.Succeeded);
    }

    private async Task SwitchAccountAsync()
    {
        await Accounts.SignOutAsync();
        await OpenAccount.InvokeAsync("login");
    }

    private async Task CheckUpdateAsync() { await Updates.CheckAsync(); Show(Updates.State.Message ?? "检查完成。", false); }
    private async Task StartUpdateAsync() { var result = await Updates.StartUpdateAsync(); Show(result.Message, !result.Succeeded); }
    private async Task CopyGroupAsync() { await External.CopyTextAsync("836325187"); Show("群号已复制。", false); }
    private async Task RevokePrivacyAsync()
    {
        var confirmed = await Popup.ConfirmAsync("撤回隐私授权", "将退出本机账号，下次进入移动端时需要重新确认隐私协议。继续吗？", AlertTypes.Warning);
        if (confirmed != true) return;
        await Settings.RevokePrivacyConsentAsync();
        Show("本地隐私授权已撤回。", false);
    }
    private void Show(string value, bool error) { message = value; messageIsError = error; }
    private static string FormatBytes(long value) => value < 1024 * 1024 ? $"{value / 1024d:0.#} KB" : $"{value / 1024d / 1024d:0.#} MB";
}
