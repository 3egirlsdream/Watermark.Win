@using Watermark.Razor.Workspace
<nav class="mac-feature-rail" aria-label="工作模式">
    <MButton Text Class="@ButtonClass(WMWorkspaceMode.Crop)" OnClick="() => ModeChanged.InvokeAsync(WMWorkspaceMode.Crop)"><WmIcon Size="22" Icon="crop" /><span>裁切</span></MButton>
    <MButton Text Class="@ButtonClass(WMWorkspaceMode.Template)" OnClick="() => ModeChanged.InvokeAsync(WMWorkspaceMode.Template)"><WmIcon Size="22" Icon="swatches" /><span>预设</span></MButton>
    <MButton Text Class="@ButtonClass(WMWorkspaceMode.ColorGrade)" Disabled="@(!ColorEngineAvailable)" OnClick="() => ModeChanged.InvokeAsync(WMWorkspaceMode.ColorGrade)"><WmIcon Size="22" Icon="sliders-horizontal" /><span>调色</span></MButton>
    <MButton Text Class="@ButtonClass(WMWorkspaceMode.MultiFrame)" OnClick="() => ModeChanged.InvokeAsync(WMWorkspaceMode.MultiFrame)"><WmIcon Size="22" Icon="moon-stars" /><span>多帧</span></MButton>
</nav>
@code {
    [Parameter] public WMWorkspaceMode Mode { get; set; }
    [Parameter] public bool ColorEngineAvailable { get; set; } = true;
    [Parameter] public EventCallback<WMWorkspaceMode> ModeChanged { get; set; }
    private string ButtonClass(WMWorkspaceMode mode) => Mode == mode ? "feature-button active" : "feature-button";
}
