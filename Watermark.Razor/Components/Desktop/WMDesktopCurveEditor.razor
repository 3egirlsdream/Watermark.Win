@using Microsoft.JSInterop
@using Watermark.Shared.Models
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="curve-editor curve-@Channel">
    <div class="curve-heading"><span>@Title</span><button type="button" @onclick="Reset" title="恢复为直线">重置</button></div>
    <svg viewBox="0 0 100 100" preserveAspectRatio="none" aria-label="@Title，使用鼠标拖动控制点调整" @ref="curveElement">
        <path class="curve-grid minor" d="M0 25H100 M0 50H100 M0 75H100 M25 0V100 M50 0V100 M75 0V100" />
        <path class="curve-grid major" d="M0 0H100V100H0Z M0 100L100 0" />
        <polyline class="identity-line" points="0,100 100,0" />
        <polyline class="curve-line" data-curve-polyline points="@Polyline" />
        @for (var index = 0; index < WorkingPoints.Count; index++)
        {
            var pointIndex = index;
            var point = WorkingPoints[pointIndex];
            <circle @key="pointIndex" class="curve-point-hit" data-curve-point="@pointIndex" cx="@(point.X * 100)" cy="@((1 - point.Y) * 100)" r="6" />
            <circle class="curve-point" data-curve-handle="@pointIndex" cx="@(point.X * 100)" cy="@((1 - point.Y) * 100)" r="2.15" />
        }
    </svg>
    <p class="curve-help">拖动控制点调整亮度映射</p>
</div>

@code {
    [Parameter] public string Title { get; set; } = "总曲线";
    [Parameter] public string Channel { get; set; } = "rgb";
    [Parameter] public IReadOnlyList<WMCurvePoint> Points { get; set; } = WMCurvePoint.Identity();
    [Parameter] public EventCallback<List<WMCurvePoint>> PointsChanged { get; set; }
    private ElementReference curveElement;
    private IJSObjectReference? module;
    private IJSObjectReference? editorReference;
    private DotNetObjectReference<WMDesktopCurveEditor>? dotNetReference;
    private bool disposed;
    private bool dragging;
    private List<WMCurvePoint> WorkingPoints => BuildEditablePoints(Points);
    private string Polyline => string.Join(" ", WorkingPoints.Select(point => $"{point.X * 100:0.##},{(1 - point.Y) * 100:0.##}"));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || disposed) return;
        try
        {
            module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./_content/Watermark.Razor/js/mac-curve-editor.js");
            dotNetReference = DotNetObjectReference.Create(this);
            editorReference = await module.InvokeAsync<IJSObjectReference>("createCurveEditor", curveElement, dotNetReference);
        }
        catch (JSDisconnectedException) { }
        catch (JSException) { }
    }

    [JSInvokable]
    public Task MovePoint(int index, double x, double y, bool final)
    {
        dragging = !final;
        var points = WorkingPoints;
        if (index < 0 || index >= points.Count) return Task.CompletedTask;
        const float gap = .01f;
        var point = points[index];
        var minimumY = index == 0 ? 0 : points[index - 1].Y;
        var maximumY = index == points.Count - 1 ? 1 : points[index + 1].Y;
        point.Y = Math.Clamp((float)y, minimumY, maximumY);
        point.X = index switch
        {
            0 => 0,
            _ when index == points.Count - 1 => 1,
            _ => Math.Clamp((float)x, points[index - 1].X + gap, points[index + 1].X - gap)
        };
        return PointsChanged.InvokeAsync(points);
    }

    protected override bool ShouldRender() => !dragging;
    private Task Reset() => PointsChanged.InvokeAsync(BuildFivePoints(WMCurvePoint.Identity()));
    private static List<WMCurvePoint> BuildEditablePoints(IReadOnlyList<WMCurvePoint> source)
    {
        var normalized = WMCurvePoint.Normalize(source);
        return normalized.Count <= 2 ? BuildFivePoints(normalized) : normalized.Select(point => new WMCurvePoint { X = point.X, Y = point.Y }).ToList();
    }
    private static List<WMCurvePoint> BuildFivePoints(IReadOnlyList<WMCurvePoint> source)
    {
        var normalized = WMCurvePoint.Normalize(source);
        return new[] { 0f, .25f, .5f, .75f, 1f }.Select(x => new WMCurvePoint { X = x, Y = Sample(normalized, x) }).ToList();
    }
    private static float Sample(IReadOnlyList<WMCurvePoint> points, float x)
    {
        for (var index = 0; index < points.Count - 1; index++)
        {
            var left = points[index]; var right = points[index + 1];
            if (x > right.X) continue;
            var width = right.X - left.X;
            return width <= float.Epsilon ? right.Y : left.Y + (right.Y - left.Y) * ((x - left.X) / width);
        }
        return points[^1].Y;
    }
    public async ValueTask DisposeAsync()
    {
        if (disposed) return;
        disposed = true;
        try { if (editorReference is not null) await editorReference.InvokeVoidAsync("dispose"); }
        catch (JSDisconnectedException) { }
        finally
        {
            if (editorReference is not null) await editorReference.DisposeAsync();
            if (module is not null) await module.DisposeAsync();
            dotNetReference?.Dispose();
        }
    }
}
