@using System.Collections.Concurrent
@using Masa.Blazor
@using Watermark.Shared.Enums
@using Watermark.Shared.Models
@using Watermark.Razor.Parts

<div class="layers-inspector">
    @if (canvas?.Children == null || canvas.Children.Count == 0)
    {
        <div class="empty-layer-state">
            <MIcon Size="34">mdi-layers-off-outline</MIcon>
            <strong>还没有图层</strong>
            <span>在结构页添加容器、文字、Logo 或分割线后，这里会显示可编辑属性。</span>
        </div>
    }
    else
    {
        @foreach (var container in canvas.Children)
        {
            <article class="layer-card">
                <header class="layer-header">
                    <div class="layer-identity">
                        <span class="layer-icon"><MIcon Size="18">mdi-image-filter-center-focus-strong-outline</MIcon></span>
                        <div>
                            <h3>@SafeName(container.Name, "容器")</h3>
                            <p>@container.Controls.Count 个组件 · @AlignmentText(container)</p>
                        </div>
                    </div>
                    <ToggleButton Elevation="0" On="@("mdi-eye-outline")" Off="@("mdi-eye-off-outline")" Open="@container.Enabled" OpenChanged="(e)=> container.Enabled = e" />
                </header>

                <section class="layer-section">
                    <div class="section-label">图片与背景</div>
                    <div class="layer-field-grid">
                        @if (canvas.CanvasType == CanvasType.Split)
                        {
                            <div class="inline-field">
                                <span>固定图片</span>
                                <MSwitch @bind-Value="@container.ContainerProperties.FixImage" Color="primary" Dense Inset HideDetails="true" />
                            </div>
                        }
                        <ImageSelect ImagesBase64="ImagesBase64" Key="@container.ID" Delete="() => RemoveImage(container)" Size="250" SelectDefaultImage="()=> SelectImage(container)" Simple="true" />
                        <ColorPicker Name="背景颜色" @bind-Color="@container.BackgroundColor" />
                    </div>
                </section>

                <section class="layer-section">
                    <div class="section-label">布局</div>
                    <div class="control-row">
                        <span>水平对齐</span>
                        <ButtonGroup Type="ButtonGroup.GroupItemType.LeftCenterRight" Value="(int)container.HorizontalAlignment" ValueChanged="(e) => container.HorizontalAlignment = (HorizontalAlignment)e" />
                    </div>
                    <div class="control-row">
                        <span>竖直对齐</span>
                        <ButtonGroup Type="ButtonGroup.GroupItemType.TopCenterBottom" Value="(int)container.VerticalAlignment" ValueChanged="(e) => container.VerticalAlignment = (VerticalAlignment)e" />
                    </div>
                    <div class="control-row">
                        <span>堆叠方向</span>
                        <ButtonGroup Type="ButtonGroup.GroupItemType.HorizonVertical" Value="(int)container.Orientation" ValueChanged="(e) => container.Orientation = (Orientation)e" />
                    </div>
                    <div class="control-row">
                        <span>依靠方向</span>
                        <ButtonGroup Type="ButtonGroup.GroupItemType.TBLR" Value="(int)container.ContainerAlignment" ValueChanged="(e) => container.ContainerAlignment = (ContainerAlignment)e" />
                    </div>
                    <div class="compact-sliders">
                        <SliderInput @bind-Value="@container.Margin.Top" Name="上边距" Unit="%" />
                        <SliderInput @bind-Value="@container.Margin.Bottom" Name="下边距" Unit="%" />
                        <SliderInput @bind-Value="@container.Margin.Left" Name="左边距" Unit="%" />
                        <SliderInput @bind-Value="@container.Margin.Right" Name="右边距" Unit="%" />
                        <SliderInput @bind-Value="@container.HeightPercent" Name="高度" Unit="%" />
                        <SliderInput @bind-Value="@container.WidthPercent" Name="宽度" Unit="%" />
                        <SliderInput @bind-Value="@container.Angle" Name="旋转" Unit="°" />
                    </div>
                </section>

                <section class="layer-section">
                    <div class="section-label">效果</div>
                    @ImageEffectGroup(container.ContainerProperties, "容器")
                </section>

                @if (container.Controls.Count > 0)
                {
                    <section class="layer-section nested-section">
                        <div class="section-label">容器内组件</div>
                        <div class="child-stack">
                            @foreach (var ctrl in container.Controls)
                            {
                                @ControlCard(ctrl, 1)
                            }
                        </div>
                    </section>
                }
            </article>
        }
    }
</div>

<MDialog ContentStyle="width:90%;height:90%;" @bind-Value="showExifConfig">
    @if (canvas != null && showExifConfig)
    {
        <ExifConfig CanvasType="@canvas.CanvasType" ContainerId2Name="@containerId2Name" mText="wMText" OnClose="()=>showExifConfig = false" />
    }
</MDialog>

<MDialog ContentStyle="width:90%;height:90%;" @bind-Value="showFontConfig">
    @if (showFontConfig && wMText != null)
    {
        <FontsDialog ID="@canvas.ID" OnClose="(e)=>{wMText.FontFamily = e.Key; showFontConfig = false;}" />
    }
</MDialog>

@code {
    [Parameter]
    public WMCanvas canvas { get; set; }

    [Parameter]
    public ConcurrentDictionary<string, string> ImagesBase64 { get; set; } = [];

    [Parameter]
    public EventCallback<IWMControl> SelectImageEvt { get; set; }

    [Parameter]
    public EventCallback<WMContainer> RemoveImageEvt { get; set; }

    WMText wMText;
    bool showExifConfig = false;

    Dictionary<string, string> containerId2Name
    {
        get
        {
            var dic = canvas.Children.Where(x => !x.ContainerProperties.FixImage).ToDictionary((k) => k.ID, (v) => v.Name);
            dic[canvas.ID] = canvas.Name;
            return dic.Reverse().ToDictionary();
        }
    }

    bool showFontConfig = false;

    protected override void OnParametersSet()
    {
        canvas ??= new WMCanvas();
        canvas.ID ??= Guid.NewGuid().ToString("N").ToUpper();
        canvas.Name ??= "未命名模板";
        canvas.Children ??= [];

        foreach (var container in canvas.Children)
        {
            EnsureContainerDefaults(container);
        }
    }

    RenderFragment ControlCard(IWMControl ctrl, int depth) => @<article class="@($"object-card depth-{depth}")">
        <header class="object-header">
            <div class="layer-identity">
                <span class="object-icon"><MIcon Size="16">@ControlIcon(ctrl)</MIcon></span>
                <div>
                    <h4>@SafeName(ctrl.Name, ControlTypeName(ctrl))</h4>
                    <p>@ControlTypeName(ctrl)</p>
                </div>
            </div>
            <ToggleButton Elevation="0" On="@("mdi-eye-outline")" Off="@("mdi-eye-off-outline")" Open="@ctrl.Enabled" OpenChanged="(e)=> ctrl.Enabled = e" />
        </header>

        <section class="object-section">
            <div class="section-label">布局</div>
            <div class="compact-sliders">
                <SliderInput @bind-Value="@ctrl.Margin.Top" Name="上边距" Unit="%" />
                <SliderInput @bind-Value="@ctrl.Margin.Bottom" Name="下边距" Unit="%" />
                <SliderInput @bind-Value="@ctrl.Margin.Left" Name="左边距" Unit="%" />
                <SliderInput @bind-Value="@ctrl.Margin.Right" Name="右边距" Unit="%" />
                <SliderInput @bind-Value="@ctrl.Percent" Name="占比" Unit="%" />
            </div>
        </section>

        @if (ctrl is WMContainer childContainer)
        {
            <section class="object-section">
                <div class="section-label">容器布局</div>
                <div class="control-row">
                    <span>水平对齐</span>
                    <ButtonGroup Type="ButtonGroup.GroupItemType.LeftCenterRight" Value="(int)childContainer.HorizontalAlignment" ValueChanged="(e) => childContainer.HorizontalAlignment = (HorizontalAlignment)e" />
                </div>
                <div class="control-row">
                    <span>竖直对齐</span>
                    <ButtonGroup Type="ButtonGroup.GroupItemType.TopCenterBottom" Value="(int)childContainer.VerticalAlignment" ValueChanged="(e) => childContainer.VerticalAlignment = (VerticalAlignment)e" />
                </div>
                <div class="compact-sliders">
                    <SliderInput @bind-Value="@childContainer.HeightPercent" Name="高度" Unit="%" />
                    <SliderInput @bind-Value="@childContainer.WidthPercent" Name="宽度" Unit="%" />
                </div>
            </section>
            @if (childContainer.Controls.Count > 0)
            {
                <section class="object-section">
                    <div class="section-label">子组件</div>
                    <div class="child-stack">
                        @foreach (var child in childContainer.Controls)
                        {
                            @ControlCard(child, depth + 1)
                        }
                    </div>
                </section>
            }
        }
        else if (ctrl is WMLine mLine)
        {
            @LineSettings(mLine)
        }
        else if (ctrl is WMLogo mLogo)
        {
            @LogoSettings(mLogo)
        }
        else if (ctrl is WMText mText)
        {
            @TextSettings(mText)
        }
    </article>;

    RenderFragment LineSettings(WMLine mLine) => @<section class="object-section">
        <div class="section-label">分割线</div>
        <ColorPicker Name="颜色" @bind-Color="mLine.Color" />
        <div class="control-row">
            <span>方向</span>
            <ButtonGroup Type="ButtonGroup.GroupItemType.HorizonVertical" Value="(int)mLine.Orientation" ValueChanged="(e) => mLine.Orientation = (Orientation)e" />
        </div>
        <SliderInput Name="粗细" @bind-Value="@mLine.Thickness" Unit="px" />
    </section>;

    RenderFragment LogoSettings(WMLogo mLogo) => @<section class="object-section">
        <div class="section-label">图片内容</div>
        <div class="option-list">
            <div class="inline-field">
                <span>白底转透明像素</span>
                <MSwitch @bind-Value="@mLogo.White2Transparent" Color="primary" Dense Inset HideDetails="true" />
            </div>
            <div class="inline-field">
                <span>自动识别品牌图标</span>
                <MSwitch @bind-Value="@mLogo.AutoSetLogo" Color="primary" Dense Inset HideDetails="true" />
            </div>
        </div>
        <div class="logo-picker">
            <ImageSelect ImagesBase64="@ImagesBase64" Key="@mLogo.ID" Size="46" ObjectFit="contain" SelectDefaultImage="()=> SelectImage(mLogo)" Delete="()=>{mLogo.Path = string.Empty; ImagesBase64.Remove(mLogo.ID, out string v);}" />
        </div>
    </section>;

    RenderFragment TextSettings(WMText mText) => @<section class="object-section">
        <div class="section-label">文字内容</div>
        <div class="metadata-box">
            <div class="metadata-copy">@(ExifSummary(mText))</div>
            <IconButton Icon="@("mdi-open-in-new")" OnClick="(()=>{ wMText = mText; showExifConfig = true; })" />
        </div>

        <ColorPicker Name="颜色" @bind-Color="mText.FontColor" />
        <div class="control-row">
            <span>样式</span>
            <div class="style-buttons">
                <ToggleButton @bind-Open="@mText.IsItalic" On="@ICONS.Italic" Off="@ICONS.Italic" />
                <ToggleButton @bind-Open="@mText.IsBold" On="@ICONS.Bold" Off="@ICONS.Bold" />
            </div>
        </div>
        <div class="font-row">
            <MSelect ItemText="e => e"
                     ItemValue="u => u"
                     @bind-Value="mText.FontFamily"
                     TValue="string"
                     TItem="string"
                     TItemValue="string"
                     Items="SkiaSharp.SKFontManager.Default.FontFamilies.ToList()"
                     Label="系统字体"
                     HideDetails="true"
                     Dense />
            <MButton Small OnClick="()=>{wMText = mText; showFontConfig = true;}" Class="font-library-button">
                <MIcon Size="16">mdi-format-font</MIcon>
                字体库
            </MButton>
        </div>
        <SliderInput @bind-Value="@mText.FontSize" Name="大小" Unit="px" />

        <div class="border-editor">
            <div class="inline-field">
                <span>文字边框</span>
                <MSwitch @bind-Value="@mText.EnableBorder" Color="primary" Dense Inset HideDetails="true" />
            </div>
            @if (mText.EnableBorder)
            {
                <SliderInput @bind-Value="@mText.BorderPadding" Name="内边距" Unit="px" />
                <SliderInput @bind-Value="@mText.BorderWidth" Name="边框宽度" Unit="px" />
                <SliderInput @bind-Value="@mText.BorderRadius" Name="圆角" Unit="px" />
                <ColorPicker Name="边框颜色" @bind-Color="@mText.BorderColor" />
            }
        </div>
    </section>;

    RenderFragment ImageEffectGroup(WMImage image, string title) => @<div class="effect-mini-stack">
        <div class="inline-field">
            <span>@title 阴影</span>
            <MSwitch @bind-Value="@image.EnableShadow" Color="primary" Dense Inset HideDetails="true" />
        </div>
        @if (image.EnableShadow)
        {
            <ColorPicker Name="阴影颜色" @bind-Color="image.ShadowColor" />
            <SliderInput @bind-Value="@image.ShadowRange" Name="阴影深度" />
        }

        <div class="inline-field">
            <span>@title 圆角</span>
            <MSwitch @bind-Value="@image.EnableRadius" Color="primary" Dense Inset HideDetails="true" />
        </div>
        @if (image.EnableRadius)
        {
            <SliderInput @bind-Value="@image.CornerRadius" Name="圆角半径" />
        }
    </div>;

    void SelectImage(IWMControl mLogo)
    {
        if (SelectImageEvt.HasDelegate)
        {
            SelectImageEvt.InvokeAsync(mLogo);
        }
    }

    void RemoveImage(WMContainer container)
    {
        if (RemoveImageEvt.HasDelegate)
        {
            RemoveImageEvt.InvokeAsync(container);
        }
    }

    string SafeName(string value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    string ControlTypeName(IWMControl ctrl)
    {
        return ctrl switch
        {
            WMContainer => "容器",
            WMText => "文字",
            WMLogo => "Logo",
            WMLine => "分割线",
            _ => "组件"
        };
    }

    string ControlIcon(IWMControl ctrl)
    {
        return ctrl switch
        {
            WMContainer => "mdi-folder-outline",
            WMText => "mdi-format-title",
            WMLogo => "mdi-image-outline",
            WMLine => "mdi-minus",
            _ => "mdi-shape-outline"
        };
    }

    string AlignmentText(WMContainer container)
    {
        var orientation = container.Orientation == Orientation.Horizontal ? "横向" : "纵向";
        return $"{orientation} · {container.ContainerAlignment}";
    }

    string ExifSummary(WMText text)
    {
        text.Exifs ??= [];
        var value = string.Join(" ", text.Exifs.Select(x => x.Prefix + x.Value + x.Suffix));
        return string.IsNullOrWhiteSpace(value) ? "未配置元数据参数" : value;
    }

    void EnsureContainerDefaults(WMContainer container)
    {
        container.ID ??= Guid.NewGuid().ToString("N").ToUpper();
        container.Name ??= "容器";
        container.Margin ??= new WMThickness(0);
        container.Path ??= string.Empty;
        container.ContainerProperties ??= new WMImage();
        container.Controls ??= [];

        foreach (var control in container.Controls)
        {
            EnsureControlDefaults(control);
        }
    }

    void EnsureControlDefaults(IWMControl control)
    {
        control.ID ??= Guid.NewGuid().ToString("N").ToUpper();
        control.Name ??= ControlTypeName(control);
        control.Margin ??= new WMThickness(0);

        if (control is WMContainer nestedContainer)
        {
            EnsureContainerDefaults(nestedContainer);
        }
        else if (control is WMText text)
        {
            text.Exifs ??= [];
            text.FontColor ??= "#000000ff";
            text.FontFamily ??= Global.DefaultFont;
            text.BorderColor ??= "#e3e3e3";
        }
        else if (control is WMLogo logo)
        {
            logo.Path ??= string.Empty;
        }
        else if (control is WMLine line)
        {
            line.Color ??= "#000000ff";
        }
    }
}
