<Watermark.Razor.Parts.ColorPicker Name="@Label" Color="@Text" ColorChanged="@TextChanged" Class="@Class" />

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string Text { get; set; } = "#FFFFFFFF";
    [Parameter] public EventCallback<string> TextChanged { get; set; }
    [Parameter] public string? ColorPickerView { get; set; }
    [Parameter] public string? Class { get; set; }
}
