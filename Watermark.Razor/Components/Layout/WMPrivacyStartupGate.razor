@using Watermark.Razor.BlazorPages
@using Watermark.Razor.Workspace
@inject IWMAppSettingsService SettingsService
@inject IWMApplicationStartupService StartupService

@if (!settingsResolved)
{
    <div class="wm-privacy-bootstrap" aria-label="正在启动轻影">
        <img src="_content/Watermark.Razor/img/app-icon.svg" alt="" />
    </div>
}
else if (privacyRequired)
{
    <MApp Class="wm-privacy-startup-app">
        <FirstPage OnClosed="OnPrivacyClosedAsync" />
    </MApp>
}
else
{
    @ChildContent
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool settingsResolved;
    private bool privacyRequired;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var settings = await SettingsService.LoadAsync();
            privacyRequired = !settings.PrivacyAccepted;
        }
        catch
        {
            privacyRequired = true;
        }
        finally
        {
            settingsResolved = true;
        }

        if (!privacyRequired)
        {
            StartApplicationInitialization();
        }
    }

    private async Task OnPrivacyClosedAsync(bool accepted)
    {
        await SettingsService.SetPrivacyConsentAsync(accepted);
        if (accepted)
        {
            StartApplicationInitialization();
        }
        privacyRequired = false;
    }

    private bool applicationInitializationStarted;

    private void StartApplicationInitialization()
    {
        if (applicationInitializationStarted) return;
        applicationInitializationStarted = true;
        _ = InitializeApplicationSafelyAsync();
    }

    private async Task InitializeApplicationSafelyAsync()
    {
        // Let the consented route paint before account recovery and first-run
        // resource downloads begin. Those operations remain best-effort and are
        // deduplicated by the scoped startup service.
        await Task.Yield();
        try
        {
            await StartupService.InitializeAfterPrivacyConsentAsync();
        }
        catch
        {
            // Startup performs best-effort network work. A transient account or
            // resource failure must not send an already-consented user back to the
            // privacy screen or prevent offline use.
        }
    }
}
