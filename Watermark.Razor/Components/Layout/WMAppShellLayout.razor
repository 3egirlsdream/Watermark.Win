@using Microsoft.AspNetCore.Components.Routing
@using Watermark.Razor.BlazorPages
@using Watermark.Razor.Workspace
@using Watermark.Shared.Models
@inherits LayoutComponentBase
@implements IDisposable
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject LoadingService LoadingService
@inject IWMWorkspaceSessionStore SessionStore
@inject IWMSystemBackDispatcher SystemBackDispatcher
@inject IWMNavigationHistory NavigationHistory

<MApp Class="wm-app-shell">
    <aside class="wm-shell-sidebar" aria-label="主导航">
        <button type="button" class="wm-shell-brand" @onclick="OpenCreate" aria-label="轻影创作">
            <span>影</span><strong>轻影</strong><small>Litograph</small>
        </button>
        <nav>
            <button type="button" class="wm-shell-nav-item @(IsActive("/create") ? "is-active" : null)"
                    aria-current="@(IsActive("/create") ? "page" : null)" @onclick='() => NavigateRoot("/create")'>
                <span class="wm-shell-nav-icon"><MIcon>mdi-image-plus-outline</MIcon></span><span>创作</span>
            </button>
            <button type="button" class="wm-shell-nav-item @(IsActive("/templates") ? "is-active" : null)"
                    aria-current="@(IsActive("/templates") ? "page" : null)" @onclick='() => NavigateRoot("/templates")'>
                <span class="wm-shell-nav-icon"><MIcon>mdi-view-grid-outline</MIcon></span><span>模板</span>
            </button>
            <button type="button" class="wm-shell-nav-item @(IsActive("/profile") ? "is-active" : null)"
                    aria-current="@(IsActive("/profile") ? "page" : null)" @onclick='() => NavigateRoot("/profile")'>
                <span class="wm-shell-nav-icon"><MIcon>mdi-account-outline</MIcon></span><span>我的</span>
            </button>
            <button type="button" class="wm-shell-nav-item @(IsActive("/settings") ? "is-active" : null)"
                    aria-current="@(IsActive("/settings") ? "page" : null)" @onclick='() => NavigateRoot("/settings")'>
                <span class="wm-shell-nav-icon"><MIcon>mdi-tune-variant</MIcon></span><span>设置</span>
            </button>
        </nav>
        @if (recentSessions.Count > 0)
        {
            <section class="wm-shell-recents" aria-label="最近会话">
                <span>最近会话</span>
                @foreach (var session in recentSessions)
                {
                    <button type="button" @onclick="() => OpenSession(session.Id)">
                        <MIcon>mdi-image-outline</MIcon><span>@SessionLabel(session)</span>
                    </button>
                }
            </section>
        }
    </aside>

    <MMain Class="wm-shell-main">
        <div class="wm-shell-content" id="wm-main-content" @ref="mainContent">
            @Body
        </div>
    </MMain>

    <nav class="wm-shell-bottom-navigation" aria-label="主导航">
        <button type="button" class="wm-shell-nav-item @(IsActive("/create") ? "is-active" : null)"
                aria-current="@(IsActive("/create") ? "page" : null)" @onclick='() => NavigateRoot("/create")'>
            <span class="wm-shell-nav-icon"><MIcon>mdi-image-plus-outline</MIcon></span><span>创作</span>
        </button>
        <button type="button" class="wm-shell-nav-item @(IsActive("/templates") ? "is-active" : null)"
                aria-current="@(IsActive("/templates") ? "page" : null)" @onclick='() => NavigateRoot("/templates")'>
            <span class="wm-shell-nav-icon"><MIcon>mdi-view-grid-outline</MIcon></span><span>模板</span>
        </button>
        <button type="button" class="wm-shell-nav-item @(IsMobileProfileActive ? "is-active" : null)"
                aria-current="@(IsMobileProfileActive ? "page" : null)" @onclick='() => NavigateRoot("/profile")'>
            <span class="wm-shell-nav-icon"><MIcon>mdi-account-outline</MIcon></span><span>我的</span>
        </button>
    </nav>
</MApp>

@if (loading)
{
    <div class="wm-shell-loading" role="status" aria-live="polite">
        <div><MProgressCircular Indeterminate Color="primary" Size="32" Width="3" /><span>@loadingMessage</span></div>
    </div>
}

@code {
    private readonly List<WMWorkspaceSession> recentSessions = [];
    private bool loading;
    private string loadingMessage = "正在处理…";
    private IDisposable? systemBackRegistration;
    private ElementReference mainContent;
    private IJSObjectReference? scrollModule;
    private IJSObjectReference? scrollAttachment;
    private bool disposed;
    private bool IsMobileProfileActive => IsActive("/profile") || IsActive("/settings");

    protected override async Task OnInitializedAsync()
    {
        LoadingService.OnShow += OnLoadingShown;
        LoadingService.OnHide += OnLoadingHidden;
        Navigation.LocationChanged += OnLocationChanged;
        systemBackRegistration = SystemBackDispatcher.Register(HandleSystemBack);
        var recent = await SessionStore.ListRecentAsync(3);
        recentSessions.AddRange(recent.Where(item => item.Mode != WMWorkspaceMode.TemplateDesign));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || scrollAttachment is not null) return;
        try
        {
            scrollModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./_content/Watermark.Razor/js/wm-app-shell-scroll.js");
            scrollAttachment = await scrollModule.InvokeAsync<IJSObjectReference>(
                "attachAndroidMouseDragScroll", mainContent);
        }
        catch (JSDisconnectedException) { }
        catch (JSException) { }
    }

    private void OpenCreate() => NavigateRoot("/create");

    private void OpenSession(string sessionId) => NavigateRoot($"/workspace/{sessionId}");

    private bool IsActive(string route)
    {
        var current = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/');
        if (current.Length == 0) current = "/";
        if (route == "/profile")
            return current == route || current.StartsWith("/account", StringComparison.OrdinalIgnoreCase)
                                    || current.StartsWith("/membership", StringComparison.OrdinalIgnoreCase);
        if (route == "/settings") return current.StartsWith("/settings", StringComparison.OrdinalIgnoreCase);
        return current.Equals(route, StringComparison.OrdinalIgnoreCase);
    }

    private void NavigateRoot(string route)
    {
        if (new Uri(Navigation.Uri).PathAndQuery == route) return;
        NavigationHistory.NavigateRoot(route);
    }

    private static string SessionLabel(WMWorkspaceSession session) =>
        session.MediaCatalog.FirstOrDefault()?.DisplayName
        ?? session.Media.FirstOrDefault()?.DisplayName
        ?? "未命名会话";

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args) => _ = InvokeAsync(StateHasChanged);

    private void OnLoadingShown(int progress, string[] messages) => _ = InvokeAsync(() =>
    {
        loading = true;
        loadingMessage = messages.FirstOrDefault(item => !string.IsNullOrWhiteSpace(item)) ?? "正在处理…";
        StateHasChanged();
    });

    private void OnLoadingHidden() => _ = InvokeAsync(() => { loading = false; StateHasChanged(); });

    private bool HandleSystemBack()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/');
        if (string.IsNullOrEmpty(path) || path.Equals("/create", StringComparison.OrdinalIgnoreCase)) return false;
        NavigationHistory.GoBack(DefaultBackTarget(path));
        return true;
    }

    private static string DefaultBackTarget(string path)
    {
        if (path.StartsWith("/settings/", StringComparison.OrdinalIgnoreCase)) return "/settings";
        if (path.Equals("/settings", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("/account", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("/membership", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("/admin", StringComparison.OrdinalIgnoreCase)) return "/profile";
        return "/create";
    }

    public void Dispose()
    {
        if (disposed) return;
        disposed = true;
        LoadingService.OnShow -= OnLoadingShown;
        LoadingService.OnHide -= OnLoadingHidden;
        Navigation.LocationChanged -= OnLocationChanged;
        systemBackRegistration?.Dispose();
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();
        if (scrollAttachment is not null)
        {
            try { await scrollAttachment.InvokeVoidAsync("dispose"); }
            catch (JSDisconnectedException) { }
            catch (JSException) { }
            try { await scrollAttachment.DisposeAsync(); }
            catch (JSDisconnectedException) { }
            scrollAttachment = null;
        }
        if (scrollModule is not null)
        {
            try { await scrollModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
            scrollModule = null;
        }
    }
}
