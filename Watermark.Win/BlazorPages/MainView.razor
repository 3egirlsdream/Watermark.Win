@using Watermark.Razor.BlazorPages
@using Watermark.Razor.Components.Layout
@using Watermark.Razor.Workspace
@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable
@inject IWMHostNavigationBridge HostNavigation
@inject NavigationManager Navigation

<Router AppAssembly="@typeof(MainView).Assembly" AdditionalAssemblies="new[] { typeof(WMRootRedirect).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound><WMNotFoundPage /></NotFound>
</Router>

@code {
    protected override void OnInitialized() => HostNavigation.NavigationRequested += OnNavigationRequested;

    private void OnNavigationRequested(string route) => _ = InvokeAsync(() => Navigation.NavigateTo(route));

    public void Dispose() => HostNavigation.NavigationRequested -= OnNavigationRequested;
}
