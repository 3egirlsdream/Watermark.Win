@using Watermark.Razor.BlazorPages
@using Watermark.Razor.Components.Layout
<WMPrivacyStartupGate>
    <Router AppAssembly="@typeof(MauiProgram).Assembly" AdditionalAssemblies="@([typeof(WMRootRedirect).Assembly])">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(WMAppShellLayout)"/>
            <FocusOnNavigate RouteData="@routeData" Selector="h1"/>
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(WMAppShellLayout)"><WMNotFoundPage /></LayoutView>
        </NotFound>
    </Router>
</WMPrivacyStartupGate>
